---
interface Props {
  title?: string;
  projectId?: string;
}

const { title = 'Dashboard', projectId } = Astro.props;
const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/sign-in');
}

const currentPath = new URL(Astro.request.url).pathname;
const inProject = !!projectId;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Grappes</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href="/assets/grappes/logo.png" />
    
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/assets/grappes/design-tokens.css" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; }
      body {
        background: #0a0a0a;
        color: #fff;
        font-family: var(--font-sans);
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        min-height: 100vh;
      }
      a { color: inherit; text-decoration: none; }
      button { font-family: inherit; cursor: pointer; }
      ul { list-style: none; margin: 0; padding: 0; }
      h1, h2, h3 { font-family: var(--font-sans); font-weight: var(--h-weight); letter-spacing: var(--h-tracking); color: #fff; }

      .status-live { color: var(--c-status-live); }
      .status-generating { color: var(--c-status-work); }
      .status-deploying { color: var(--c-status-deploy); }
      .status-failed { color: var(--c-status-failed); }
      /* Mobile nav toggle */
      .mobile-menu-btn { display: none; background: none; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: #fff; padding: 6px 10px; font-size: 18px; }

      @media (max-width: 768px) {
        main { padding: 80px 16px 80px !important; }
        header > div { padding: 0 16px !important; }
        .mobile-menu-btn { display: block; }
        .dash-nav { display: none !important; position: fixed; top: 60px; left: 0; right: 0; background: rgba(10,10,10,0.97); backdrop-filter: blur(40px); flex-direction: column !important; padding: 16px; gap: 4px !important; border-bottom: 1px solid rgba(255,255,255,0.08); z-index: 99; }
        .dash-nav.open { display: flex !important; }
        .dash-nav a { width: 100%; text-align: center; }
        .dash-right { gap: 8px !important; }
        .dash-right .referral-link { display: none; }
      }

      @media (max-width: 480px) {
        main { padding: 70px 12px 60px !important; }
        header > div { padding: 0 12px !important; }
      }
    </style>
  </head>
  <body>
    <!-- Fixed grape background (stays in place while scrolling) -->
    <div aria-hidden="true" style="position:fixed;inset:0;z-index:-3;background:url('/assets/grappes/dashboard-bg.webp') center/cover no-repeat, #0a0a0a;"></div>
    <div aria-hidden="true" style="position:fixed;inset:0;z-index:-2;background:linear-gradient(to bottom, rgba(10,10,10,0.4), rgba(10,10,10,0.6));"></div>
    <div aria-hidden="true" style="position:fixed;inset:0;z-index:-1;background:radial-gradient(ellipse at center, rgba(255,255,255,0.09) 0%, rgba(255,255,255,0) 70%);"></div>

    <!-- Header -->
    <header style="position:sticky;top:0;z-index:100;padding:18px 0;background:rgba(10,10,10,0.85);backdrop-filter:blur(40px);-webkit-backdrop-filter:blur(40px);border-bottom:1px solid rgba(255,255,255,0.06);">
      <div style="max-width:1650px;margin:0 auto;padding:0 40px;display:flex;align-items:center;justify-content:space-between;">
        <a href="/dashboard" style="display:block;">
          <img src="/logo.png" alt="Grappes" style="height:38px;display:block;" />
        </a>
        <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Toggle menu">☰</button>
        <nav class="dash-nav" id="dash-nav" style="display:flex;align-items:center;gap:8px;">
          {inProject && (
            <a href={`/dashboard/${projectId}`}
              style={`font-size:15px;font-weight:500;padding:8px 20px;border-radius:30px;transition:all 0.3s;${currentPath === `/dashboard/${projectId}` ? 'color:#0a0a0a;background:#06bfdd;font-weight:700;' : 'color:rgba(255,255,255,0.6);'}`}>
              <span>Overview</span>
            </a>
          )}
          {inProject && (
            <a href={`/dashboard/${projectId}/deploy`}
              style={`font-size:15px;font-weight:500;padding:8px 20px;border-radius:30px;transition:all 0.3s;${currentPath.endsWith('/deploy') ? 'color:#0a0a0a;background:#06bfdd;font-weight:700;' : 'color:rgba(255,255,255,0.6);'}`}>
              <span>Deploy</span>
            </a>
          )}
          {inProject && (
            <a href={`/dashboard/${projectId}/inbox`}
              style={`font-size:15px;font-weight:500;padding:8px 20px;border-radius:30px;transition:all 0.3s;${currentPath.endsWith('/inbox') ? 'color:#0a0a0a;background:#06bfdd;font-weight:700;' : 'color:rgba(255,255,255,0.6);'}`}>
              <span>Inbox</span>
            </a>
          )}
        </nav>
        <div class="dash-right" style="display:flex;align-items:center;gap:14px;">
          {!inProject && (
            <a href="/dashboard/referrals" class="referral-link"
              style={`font-size:14px;font-weight:600;padding:7px 16px;border-radius:30px;transition:all 0.3s;${currentPath === '/dashboard/referrals' ? 'color:#0a0a0a;background:#06bfdd;' : 'color:rgba(255,255,255,0.55);border:1px solid rgba(255,255,255,0.15);'}`}>
              <span>Referrals</span>
            </a>
          )}
          <form method="POST" action="/api/auth/signout" style="margin:0;">
            <button type="submit" style="background:none;border:1px solid rgba(255,255,255,0.25);border-radius:30px;color:rgba(255,255,255,0.7);font-size:13px;font-weight:600;padding:7px 18px;"><span>Sign out</span></button>
          </form>
          <a href="/dashboard/account" style="width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#06bfdd,#6c6bf3);display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;color:#0a0a0a;text-transform:uppercase;text-decoration:none;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
            {user.email?.[0] ?? '?'}
          </a>
        </div>
      </div>
    </header>

    <script>
      document.getElementById('mobile-menu-btn')?.addEventListener('click', function() {
        var nav = document.getElementById('dash-nav');
        if (nav) nav.classList.toggle('open');
      });
    </script>

    <!-- Page content -->
    <main style="max-width:1200px;margin:0 auto;padding:100px 40px 120px;">
      <slot />
    </main>

    <!-- ── Support chat widget ───────────────────────────────────────── -->
    <button id="sup-btn" type="button" aria-label="Open support chat" title="Chat with Grappes support">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" stroke="#0a0a0a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span id="sup-badge" hidden>1</span>
    </button>

    <div id="sup-panel" role="dialog" aria-label="Support chat" hidden>
      <header class="sup-head">
        <div>
          <p class="sup-title">Grappes Support</p>
          <p class="sup-sub" id="sup-sub">We usually reply within a few hours</p>
        </div>
        <button id="sup-close" type="button" aria-label="Close" class="sup-icon-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M6 18L18 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
      </header>
      <div id="sup-list" class="sup-list" aria-live="polite"></div>
      <form id="sup-form" class="sup-form" autocomplete="off">
        <textarea id="sup-input" rows="1" placeholder="Type a message…" maxlength="4000" required></textarea>
        <button type="submit" id="sup-send" aria-label="Send">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <line x1="22" y1="2" x2="11" y2="13" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round" fill="currentColor"/>
          </svg>
        </button>
      </form>
    </div>

    <style>
      #sup-btn {
        position: fixed; bottom: 22px; right: 22px; z-index: 950;
        width: 56px; height: 56px; border-radius: 50%;
        background: linear-gradient(135deg, #06bfdd, #6c6bf3);
        border: none; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 10px 30px rgba(6,191,221,0.35), 0 4px 12px rgba(0,0,0,0.35);
        transition: transform 0.2s, box-shadow 0.2s;
      }
      #sup-btn:hover { transform: translateY(-2px) scale(1.03); box-shadow: 0 14px 36px rgba(6,191,221,0.5); }
      #sup-btn #sup-badge {
        position: absolute; top: -4px; right: -4px;
        min-width: 20px; height: 20px; padding: 0 6px;
        border-radius: 999px; background: #ff3334; color: #fff;
        font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 700;
        display: inline-flex; align-items: center; justify-content: center;
        box-shadow: 0 2px 6px rgba(255,51,52,0.4);
      }
      #sup-btn #sup-badge[hidden] { display: none; }

      #sup-panel {
        position: fixed; bottom: 92px; right: 22px; z-index: 960;
        width: 360px; max-width: calc(100vw - 44px);
        height: 480px; max-height: calc(100vh - 140px);
        background: rgba(20, 20, 26, 0.92);
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 18px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.55);
        display: flex; flex-direction: column; overflow: hidden;
        font-family: 'DM Sans', sans-serif;
      }
      #sup-panel[hidden] { display: none; }
      @media (max-width: 480px) {
        #sup-panel { right: 12px; left: 12px; width: auto; bottom: 82px; }
        #sup-btn { right: 16px; bottom: 16px; }
      }

      .sup-head {
        display: flex; justify-content: space-between; align-items: flex-start;
        padding: 16px 18px 12px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
      }
      .sup-title { font-size: 14px; font-weight: 600; color: #fff; margin: 0; letter-spacing: -0.01em; }
      .sup-sub { font-size: 12px; color: rgba(255,255,255,0.45); margin: 2px 0 0; }
      .sup-icon-btn {
        background: none; border: none; cursor: pointer;
        color: rgba(255,255,255,0.5); padding: 4px;
        border-radius: 6px; transition: color 0.15s, background 0.15s;
      }
      .sup-icon-btn:hover { color: #fff; background: rgba(255,255,255,0.05); }

      .sup-list {
        flex: 1 1 0; min-height: 0; overflow-y: auto;
        padding: 14px 14px 8px;
        display: flex; flex-direction: column; gap: 8px;
        scrollbar-width: thin;
        scrollbar-color: rgba(6,191,221,0.3) transparent;
      }
      .sup-list::-webkit-scrollbar { width: 6px; }
      .sup-list::-webkit-scrollbar-thumb { background: rgba(6,191,221,0.3); border-radius: 3px; }

      .sup-msg {
        max-width: 85%; padding: 9px 12px;
        border-radius: 14px; font-size: 13px; line-height: 1.5;
        white-space: pre-wrap; word-wrap: break-word;
        animation: supIn 0.25s ease-out;
      }
      @keyframes supIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
      .sup-msg.user  { align-self: flex-end; background: linear-gradient(135deg, #06bfdd, #6c6bf3); color: #0a0a0a; font-weight: 500; border-bottom-right-radius: 4px; }
      .sup-msg.admin { align-self: flex-start; background: rgba(255,255,255,0.07); color: #fff; border: 1px solid rgba(255,255,255,0.08); border-bottom-left-radius: 4px; }
      .sup-msg.system { align-self: center; font-size: 12px; color: rgba(255,255,255,0.45); background: transparent; padding: 6px 0; }

      .sup-form {
        display: flex; gap: 6px; align-items: flex-end;
        padding: 10px 12px 12px;
        border-top: 1px solid rgba(255,255,255,0.06);
      }
      .sup-form textarea {
        flex: 1; background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        color: #fff; font-family: inherit; font-size: 13px; line-height: 1.5;
        padding: 9px 12px; resize: none; outline: none;
        max-height: 90px; min-height: 36px;
      }
      .sup-form textarea:focus { border-color: #06bfdd; box-shadow: 0 0 0 3px rgba(6,191,221,0.18); }
      .sup-form textarea::placeholder { color: rgba(255,255,255,0.35); }
      #sup-send {
        flex-shrink: 0; width: 38px; height: 38px;
        border-radius: 50%; border: none;
        background: #06bfdd; color: #0a0a0a;
        cursor: pointer; display: flex; align-items: center; justify-content: center;
        transition: background 0.15s, transform 0.1s;
      }
      #sup-send:hover:not(:disabled) { background: #37cce2; }
      #sup-send:disabled { opacity: 0.4; cursor: not-allowed; }
    </style>

    <script is:inline>
      (function () {
        var btn     = document.getElementById('sup-btn');
        var panel   = document.getElementById('sup-panel');
        var closeBtn = document.getElementById('sup-close');
        var listEl  = document.getElementById('sup-list');
        var form    = document.getElementById('sup-form');
        var input   = document.getElementById('sup-input');
        var sendBtn = document.getElementById('sup-send');
        var badge   = document.getElementById('sup-badge');
        var subEl   = document.getElementById('sup-sub');

        if (!btn || !panel || !listEl || !form || !input) return;

        var GREETING_KEY = 'grappes_sup_greeted';
        var lastMsgId = null;
        var pollTimer = null;

        function esc(s) { return (s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }

        function render(messages) {
          // Show system greeting on first-ever open if thread has no messages
          if (messages.length === 0 && !localStorage.getItem(GREETING_KEY)) {
            var g = document.createElement('div');
            g.className = 'sup-msg admin';
            g.textContent = "Hi! Tell us what's going on — a bug, a question, a feature wish. We read every message.";
            listEl.innerHTML = '';
            listEl.appendChild(g);
            return;
          }
          listEl.innerHTML = '';
          messages.forEach(function (m) {
            var div = document.createElement('div');
            div.className = 'sup-msg ' + m.sender;
            div.textContent = m.content;
            listEl.appendChild(div);
          });
          listEl.scrollTop = listEl.scrollHeight;
        }

        async function poll() {
          try {
            var res = await fetch('/api/support/messages', { credentials: 'same-origin' });
            if (!res.ok) return;
            var data = await res.json();
            var messages = data.messages || [];
            var latestId = messages.length ? messages[messages.length - 1].id : null;
            if (latestId !== lastMsgId) {
              render(messages);
              lastMsgId = latestId;
              // Show unread badge if panel is hidden and the last message is from admin
              if (panel.hidden && messages.length && messages[messages.length - 1].sender === 'admin') {
                badge.hidden = false;
              }
            }
          } catch (e) { /* silently */ }
        }

        function openPanel() {
          panel.hidden = false;
          badge.hidden = true;
          input.focus();
          if (!localStorage.getItem(GREETING_KEY)) {
            localStorage.setItem(GREETING_KEY, '1');
          }
          poll();
        }
        function closePanel() { panel.hidden = true; }

        btn.addEventListener('click', function () {
          if (panel.hidden) openPanel(); else closePanel();
        });
        closeBtn && closeBtn.addEventListener('click', closePanel);

        // auto-open if landing from an email link with ?support=1
        if (new URLSearchParams(window.location.search).get('support') === '1') {
          setTimeout(openPanel, 200);
          window.history.replaceState({}, '', window.location.pathname);
        }

        input.addEventListener('input', function () {
          input.style.height = 'auto';
          input.style.height = Math.min(input.scrollHeight, 90) + 'px';
        });
        input.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); form.dispatchEvent(new Event('submit', { cancelable: true, bubbles: true })); }
        });

        form.addEventListener('submit', async function (e) {
          e.preventDefault();
          var text = input.value.trim();
          if (!text) return;
          sendBtn.disabled = true;
          input.disabled = true;
          try {
            var res = await fetch('/api/support/messages', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ content: text }),
            });
            if (res.ok) {
              input.value = '';
              input.style.height = '36px';
              await poll();
            } else {
              var err = await res.json().catch(function () { return {}; });
              alert(err.error || 'Could not send message. Please try again.');
            }
          } catch {
            alert('Network error.');
          } finally {
            sendBtn.disabled = false;
            input.disabled = false;
            input.focus();
          }
        });

        // Initial fetch for badge + periodic poll
        poll();
        pollTimer = setInterval(poll, 8000);
      })();
    </script>
  </body>
</html>
