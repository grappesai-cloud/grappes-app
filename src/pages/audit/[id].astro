---
import Dashboard from '../../layouts/Dashboard.astro';
import { createAdminClient } from '../../lib/supabase';
import type { AuditReport, PerfReport, ContentReport, AttentionReport } from '../../lib/audit';
import type { AuditCheck } from '../../lib/audit-html-checks';

const { id } = Astro.params;
const authUser = Astro.locals.user!;

const client = createAdminClient();
const { data: row, error } = await client
  .from('seo_audits')
  .select('*')
  .eq('id', id!)
  .eq('user_id', authUser.id)
  .maybeSingle();

if (error || !row) return Astro.redirect('/audit');

const report = row.report as AuditReport | null;
const status = row.status as 'running' | 'complete' | 'failed';

function scoreColor(s: number | null | undefined): string {
  if (s === null || s === undefined) return 'rgba(255,255,255,0.4)';
  if (s >= 80) return '#6ee7a3';
  if (s >= 50) return '#f6c547';
  return '#ff8a8a';
}
function scoreLabel(s: number | null | undefined): string {
  if (s === null || s === undefined) return '—';
  if (s >= 80) return 'Good';
  if (s >= 50) return 'Needs work';
  return 'Poor';
}

const overall = row.overall_score ?? null;
const perfScore = row.perf_score ?? null;
const onpageScore = row.onpage_score ?? null;
const technicalScore = row.technical_score ?? null;
const contentScore = row.content_score ?? null;

const perf = report?.perf as PerfReport | undefined;
const content = report?.content as ContentReport | undefined;
const attention = report?.attention as AttentionReport | undefined;
const onpageChecks = (report?.onpage ?? []) as AuditCheck[];
const technicalChecks = (report?.technical ?? []) as AuditCheck[];

function statusBg(s: AuditCheck['status']) {
  if (s === 'ok')   return { color: '#6ee7a3', bg: 'rgba(110,231,163,0.06)', border: 'rgba(110,231,163,0.2)' };
  if (s === 'warn') return { color: '#f6c547', bg: 'rgba(246,197,71,0.06)', border: 'rgba(246,197,71,0.22)' };
  return                 { color: '#ff8a8a', bg: 'rgba(239,68,68,0.06)',  border: 'rgba(239,68,68,0.22)' };
}
function statusIcon(s: AuditCheck['status']) {
  if (s === 'ok')   return '✓';
  if (s === 'warn') return '!';
  return '✕';
}

function metricFormat(value: number, unit: string): string {
  if (unit === 'ms' || unit === 'millisecond') {
    return value >= 1000 ? `${(value / 1000).toFixed(1)} s` : `${Math.round(value)} ms`;
  }
  if (unit === 'unitless') return value.toFixed(3);
  return `${Math.round(value)} ${unit}`;
}
---

<Dashboard title={`Audit — ${row.url}`}>
  <style is:global>
    main { padding-top: 56px !important; padding-bottom: 80px !important; }
  </style>

  <div style="max-width:920px;margin:0 auto;">
    <div style="margin-bottom:24px;">
      <a href="/audit" style="display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:500;color:rgba(255,255,255,0.45);text-decoration:none;letter-spacing:0.04em;text-transform:uppercase;transition:color 0.2s;">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 19"/></svg>
        <span>Audit Lab</span>
      </a>
    </div>

    <header style="margin-bottom:32px;">
      <div style="font-size:11px;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.4);margin-bottom:6px;">Audit report</div>
      <h1 style="font-family:'Inter',sans-serif;font-size:32px;font-weight:400;line-height:1.15;letter-spacing:-0.035em;color:#fff;margin:0 0 6px;word-break:break-all;">{row.url}</h1>
      <p style="font-size:12.5px;color:rgba(255,255,255,0.45);margin:0;">
        Status: <span style={`color:${status === 'complete' ? '#6ee7a3' : status === 'failed' ? '#ff8a8a' : '#f6c547'};font-weight:600;`}>{status}</span>
        &nbsp;·&nbsp; {new Date(row.created_at).toLocaleString()}
      </p>
    </header>

    {status === 'running' && (
      <div style="background:rgba(246,197,71,0.06);border:1px solid rgba(246,197,71,0.22);border-radius:14px;padding:18px;text-align:center;color:rgba(255,255,255,0.75);font-size:14px;">
        Audit is still running. Refresh this page in a few seconds.
      </div>
    )}

    {status === 'failed' && (
      <div style="background:rgba(239,68,68,0.06);border:1px solid rgba(239,68,68,0.22);border-radius:14px;padding:18px;color:#ff8a8a;font-size:14px;">
        <div style="font-weight:600;margin-bottom:4px;">Audit failed</div>
        <div style="font-size:13px;color:rgba(255,255,255,0.5);">{row.error || 'Unknown error.'} Your credit was refunded.</div>
      </div>
    )}

    {status === 'complete' && report && (
      <div>
        {/* Score row */}
        <div style="display:grid;grid-template-columns:auto repeat(4, 1fr);gap:14px;align-items:stretch;margin-bottom:30px;">
          <div style="grid-column: 1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:20px 22px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:18px;">
            <div style={`width:84px;height:84px;border-radius:50%;border:4px solid ${scoreColor(overall)};display:flex;align-items:center;justify-content:center;font-size:30px;font-weight:700;color:${scoreColor(overall)};`}>
              {overall ?? '—'}
            </div>
            <div style="margin-top:10px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:rgba(255,255,255,0.5);">Overall</div>
          </div>

          {[
            { label: 'Performance', score: perfScore },
            { label: 'On-page SEO', score: onpageScore },
            { label: 'Technical',   score: technicalScore },
            { label: 'Content',     score: contentScore },
          ].map(cat => (
            <div style="display:flex;flex-direction:column;justify-content:space-between;padding:18px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:14px;">
              <div style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:rgba(255,255,255,0.5);">{cat.label}</div>
              <div style="display:flex;align-items:baseline;gap:8px;margin-top:8px;">
                <span style={`font-family:'Inter',sans-serif;font-size:34px;font-weight:300;color:${scoreColor(cat.score)};line-height:1;`}>{cat.score ?? '—'}</span>
                <span style="font-size:11px;color:rgba(255,255,255,0.4);">/ 100</span>
              </div>
              <div style={`font-size:11.5px;color:${scoreColor(cat.score)};margin-top:6px;font-weight:600;`}>{scoreLabel(cat.score)}</div>
            </div>
          ))}
        </div>

        {/* Attention / first impression — per page */}
        {attention && (() => {
          const pages = attention.pages && attention.pages.length > 0
            ? attention.pages
            : [{ url: row.url, score: attention.score, verdict: attention.verdict, checks: attention.checks, screenshot: perf?.screenshot }];
          const siteScore = attention.siteScore ?? attention.score;
          return (
            <section style="margin-bottom:28px;">
              <div style="display:flex;align-items:baseline;justify-content:space-between;gap:12px;">
                <h2 class="section-h" style="margin-bottom:0;">First impression — attention</h2>
                <span style="font-size:12px;color:rgba(255,255,255,0.5);">
                  Site avg <strong style={`color:${scoreColor(siteScore)};`}>{siteScore}</strong> · {pages.length} page{pages.length > 1 ? 's' : ''}
                </span>
              </div>
              <div style="display:flex;flex-direction:column;gap:14px;margin-top:12px;">
                {pages.map(pg => {
                  let pagePath = pg.url;
                  try { pagePath = new URL(pg.url).pathname || '/'; } catch {}
                  return (
                    <div style="background:rgba(167,139,250,0.05);border:1px solid rgba(167,139,250,0.18);border-radius:16px;padding:16px;">
                      <div style="display:grid;grid-template-columns:140px 1fr;gap:16px;align-items:start;">
                        {pg.screenshot && (
                          <img src={pg.screenshot} alt={`Screenshot of ${pagePath}`} style="width:140px;border-radius:10px;border:1px solid rgba(255,255,255,0.1);display:block;" />
                        )}
                        <div>
                          <div style="display:flex;align-items:baseline;gap:8px;flex-wrap:wrap;">
                            <span style={`font-family:'Inter',sans-serif;font-size:32px;font-weight:300;line-height:1;color:${scoreColor(pg.score)};`}>{pg.score}</span>
                            <code style="font-size:12px;color:rgba(255,255,255,0.55);">{pagePath}</code>
                          </div>
                          <p style="font-size:13.5px;color:rgba(255,255,255,0.8);margin:8px 0 0;line-height:1.45;">{pg.verdict}</p>
                          {pg.checks.length > 0 && (
                            <ul class="check-list" style="margin-top:12px;">
                              {pg.checks.map(c => {
                                const s = statusBg(c.status);
                                return (
                                  <li class="check-item" style={`background:${s.bg};border-color:${s.border};`}>
                                    <span class="check-pill" style={`background:${s.color};color:#0a0a0a;`}>{statusIcon(c.status)}</span>
                                    <div class="check-body">
                                      <div class="check-label">{c.label}</div>
                                      {c.detail && <div class="check-detail">{c.detail}</div>}
                                      {c.status !== 'ok' && c.fix && <div class="check-detail" style="color:rgba(167,139,250,0.85);margin-top:3px;">Fix: {c.fix}</div>}
                                    </div>
                                  </li>
                                );
                              })}
                            </ul>
                          )}
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </section>
          );
        })()}

        {/* Performance */}
        {perf && (
          <section style="margin-bottom:28px;">
            <h2 class="section-h">Performance — Core Web Vitals</h2>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px;margin-bottom:14px;">
              {([
                ['LCP', 'Largest Contentful Paint'],
                ['CLS', 'Cumulative Layout Shift'],
                ['INP', 'Interaction to Next Paint'],
                ['FCP', 'First Contentful Paint'],
                ['TBT', 'Total Blocking Time'],
                ['SI',  'Speed Index'],
              ] as const).map(([k, full]) => {
                const m = (perf.metrics as any)[k];
                if (!m) return null;
                return (
                  <div style="padding:12px 14px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:11px;" title={full}>
                    <div style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:rgba(255,255,255,0.4);font-weight:600;">{k}</div>
                    <div style="font-size:18px;font-weight:600;color:#fff;margin-top:4px;">{metricFormat(m.value, m.unit)}</div>
                    <div style={`font-size:11px;color:${scoreColor(m.score)};margin-top:2px;font-weight:600;`}>{m.score} / 100</div>
                  </div>
                );
              })}
            </div>

            {perf.opportunities.length > 0 && (
              <div>
                <h3 style="font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:rgba(255,255,255,0.45);margin:18px 0 10px;">Top opportunities</h3>
                <ul class="check-list">
                  {perf.opportunities.map(o => {
                    const s = statusBg('warn');
                    return (
                      <li class="check-item" style={`background:${s.bg};border-color:${s.border};`}>
                        <span class="check-pill" style={`background:${s.color};color:#0a0a0a;`}>!</span>
                        <div class="check-body">
                          <div class="check-label">{o.title}{o.savingsMs ? <span style="font-weight:500;color:rgba(255,255,255,0.55);margin-left:8px;">~{(o.savingsMs / 1000).toFixed(1)}s savings</span> : null}</div>
                          <div class="check-detail">{o.description}</div>
                        </div>
                      </li>
                    );
                  })}
                </ul>
              </div>
            )}

            <div style="display:flex;gap:14px;flex-wrap:wrap;margin-top:14px;font-size:12px;color:rgba(255,255,255,0.55);">
              <span>Accessibility <strong style={`color:${scoreColor(perf.accessibilityScore)};`}>{perf.accessibilityScore}</strong></span>
              <span>Best practices <strong style={`color:${scoreColor(perf.bestPracticesScore)};`}>{perf.bestPracticesScore}</strong></span>
              <span>Lighthouse SEO <strong style={`color:${scoreColor(perf.lhSeoScore)};`}>{perf.lhSeoScore}</strong></span>
            </div>
          </section>
        )}

        {/* On-page */}
        <section style="margin-bottom:28px;">
          <h2 class="section-h">On-page SEO</h2>
          <ul class="check-list">
            {onpageChecks.map(c => {
              const s = statusBg(c.status);
              return (
                <li class="check-item" style={`background:${s.bg};border-color:${s.border};`}>
                  <span class="check-pill" style={`background:${s.color};color:#0a0a0a;`}>{statusIcon(c.status)}</span>
                  <div class="check-body">
                    <div class="check-label">{c.label}</div>
                    {c.detail && <div class="check-detail">{c.detail}</div>}
                    {c.fix && c.status !== 'ok' && <div class="check-fix"><strong>Fix:</strong> {c.fix}</div>}
                  </div>
                </li>
              );
            })}
          </ul>
        </section>

        {/* Technical */}
        <section style="margin-bottom:28px;">
          <h2 class="section-h">Technical SEO</h2>
          <ul class="check-list">
            {technicalChecks.map(c => {
              const s = statusBg(c.status);
              return (
                <li class="check-item" style={`background:${s.bg};border-color:${s.border};`}>
                  <span class="check-pill" style={`background:${s.color};color:#0a0a0a;`}>{statusIcon(c.status)}</span>
                  <div class="check-body">
                    <div class="check-label">{c.label}</div>
                    {c.detail && <div class="check-detail">{c.detail}</div>}
                    {c.fix && c.status !== 'ok' && <div class="check-fix"><strong>Fix:</strong> {c.fix}</div>}
                  </div>
                </li>
              );
            })}
          </ul>
        </section>

        {/* Content */}
        {content && (
          <section style="margin-bottom:28px;">
            <h2 class="section-h">Content & keywords</h2>
            <div style="padding:16px 18px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:12px;margin-bottom:12px;">
              <div style="font-size:12px;text-transform:uppercase;letter-spacing:0.06em;color:rgba(255,255,255,0.45);margin-bottom:6px;font-weight:600;">Primary topic</div>
              <div style="font-size:15px;color:#fff;margin-bottom:14px;">{content.primaryTopic}</div>
              {content.primaryKeywords.length > 0 && (
                <div>
                  <div style="font-size:12px;text-transform:uppercase;letter-spacing:0.06em;color:rgba(255,255,255,0.45);margin-bottom:6px;font-weight:600;">Detected keywords</div>
                  <div style="display:flex;flex-wrap:wrap;gap:6px;">
                    {content.primaryKeywords.map(k => (
                      <span style="font-size:12px;padding:4px 10px;background:rgba(34,211,238,0.1);color:#9af5ff;border-radius:999px;border:1px solid rgba(34,211,238,0.25);">{k}</span>
                    ))}
                  </div>
                </div>
              )}
              {content.summary && (
                <p style="font-size:13px;color:rgba(255,255,255,0.65);margin:14px 0 0;line-height:1.5;">{content.summary}</p>
              )}
            </div>

            {content.nicheCoherence && (() => {
              const nc = content.nicheCoherence;
              const tone = nc.ambiguity === 'low'
                ? { c: '#7af5a7', bg: 'rgba(34,197,94,0.08)', br: 'rgba(34,197,94,0.30)' }
                : nc.ambiguity === 'medium'
                  ? { c: '#fcd34d', bg: 'rgba(234,179,8,0.08)', br: 'rgba(234,179,8,0.30)' }
                  : { c: '#fda4af', bg: 'rgba(244,63,94,0.08)', br: 'rgba(244,63,94,0.30)' };
              const ambLabel = nc.ambiguity === 'low' ? 'Clear positioning' : nc.ambiguity === 'medium' ? 'Mixed positioning' : 'Identity-confused';
              return (
                <div style={`padding:16px 18px;background:${tone.bg};border:1px solid ${tone.br};border-radius:12px;margin-bottom:12px;`}>
                  <div style="display:flex;align-items:baseline;justify-content:space-between;gap:12px;margin-bottom:10px;flex-wrap:wrap;">
                    <div>
                      <div style="font-size:11px;text-transform:uppercase;letter-spacing:0.08em;color:rgba(255,255,255,0.5);font-weight:600;margin-bottom:4px;">Niche coherence · SimClusters-style</div>
                      <div style={`font-size:14px;color:${tone.c};font-weight:600;`}>{ambLabel}</div>
                    </div>
                    <div style="text-align:right;">
                      <div style={`font-size:28px;font-weight:700;color:${tone.c};line-height:1;font-variant-numeric:tabular-nums;`}>{nc.coherenceScore}<span style="font-size:14px;color:rgba(255,255,255,0.4);font-weight:500;">/100</span></div>
                    </div>
                  </div>

                  <div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;margin-bottom:12px;">
                    <span style={`font-size:12px;padding:5px 12px;background:${tone.c};color:#0a0a0a;border-radius:999px;font-weight:600;`}>{nc.primary.label} · {nc.primary.confidence}%</span>
                    {nc.secondary.map(s => (
                      <span style="font-size:12px;padding:4px 10px;background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.7);border-radius:999px;border:1px solid rgba(255,255,255,0.10);">{s.label} · {s.confidence}%</span>
                    ))}
                  </div>

                  <p style="font-size:13px;color:rgba(255,255,255,0.78);margin:0 0 10px;line-height:1.55;">{nc.positioning}</p>
                  <p style="font-size:12px;color:rgba(255,255,255,0.55);margin:0;line-height:1.55;"><strong style={`color:${tone.c};`}>Fix:</strong> {nc.recommendation}</p>
                </div>
              );
            })()}

            {content.issues.length > 0 && (
              <ul class="check-list">
                {content.issues.map(c => {
                  const s = statusBg(c.status);
                  return (
                    <li class="check-item" style={`background:${s.bg};border-color:${s.border};`}>
                      <span class="check-pill" style={`background:${s.color};color:#0a0a0a;`}>{statusIcon(c.status)}</span>
                      <div class="check-body">
                        <div class="check-label">{c.label}</div>
                        {c.detail && <div class="check-detail">{c.detail}</div>}
                        {c.fix && c.status !== 'ok' && <div class="check-fix"><strong>Fix:</strong> {c.fix}</div>}
                      </div>
                    </li>
                  );
                })}
              </ul>
            )}

            {content.suggestions.length > 0 && (
              <div style="margin-top:14px;padding:16px 18px;background:rgba(34,211,238,0.05);border:1px solid rgba(34,211,238,0.18);border-radius:12px;">
                <div style="font-size:12px;text-transform:uppercase;letter-spacing:0.06em;color:#9af5ff;margin-bottom:8px;font-weight:600;">Suggestions</div>
                <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:6px;">
                  {content.suggestions.map(s => (
                    <li style="font-size:13px;color:rgba(255,255,255,0.75);line-height:1.5;">→ {s}</li>
                  ))}
                </ul>
              </div>
            )}
          </section>
        )}

        {report.errors && Object.keys(report.errors).length > 0 && (
          <details style="margin-top:18px;padding:14px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:10px;">
            <summary style="cursor:pointer;font-size:12px;color:rgba(255,255,255,0.45);">Partial errors (some checks could not complete)</summary>
            <pre style="margin:10px 0 0;font-size:11px;color:rgba(255,255,255,0.5);white-space:pre-wrap;">{JSON.stringify(report.errors, null, 2)}</pre>
          </details>
        )}
      </div>
    )}
  </div>

  <style>
    .section-h {
      font-family: 'Inter', sans-serif;
      font-size: 19px; font-weight: 600;
      letter-spacing: -0.02em; color: #fff;
      margin: 0 0 14px;
    }
    .check-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
    .check-item {
      display: flex; gap: 12px;
      padding: 12px 14px;
      border: 1px solid;
      border-radius: 12px;
    }
    .check-pill {
      flex-shrink: 0;
      width: 22px; height: 22px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 800;
      margin-top: 1px;
    }
    .check-body { flex: 1; min-width: 0; }
    .check-label { font-size: 13.5px; font-weight: 600; color: #fff; }
    .check-detail { font-size: 12.5px; color: rgba(255,255,255,0.6); margin-top: 3px; line-height: 1.45; }
    .check-fix { font-size: 12.5px; color: rgba(255,255,255,0.7); margin-top: 6px; line-height: 1.5; }
    .check-fix strong { color: rgba(255,255,255,0.95); font-weight: 700; }
  </style>
</Dashboard>
