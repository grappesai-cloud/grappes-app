---
import Dashboard from '../../layouts/Dashboard.astro';
import { db } from '../../lib/db';
import { createAdminClient } from '../../lib/supabase';

const authUser = Astro.locals.user!;
const dbUser = await db.users.findById(authUser.id);
const auditCredits = dbUser?.audit_credits ?? 0;

// Last 8 audits for this user
const client = createAdminClient();
const { data: recentRaw } = await client
  .from('seo_audits')
  .select('id, url, status, overall_score, created_at')
  .eq('user_id', authUser.id)
  .order('created_at', { ascending: false })
  .limit(8);
const recent = recentRaw ?? [];

function scoreColor(score: number | null): string {
  if (score === null || score === undefined) return 'rgba(255,255,255,0.4)';
  if (score >= 80) return '#6ee7a3';
  if (score >= 50) return '#f6c547';
  return '#ff8a8a';
}

function timeAgo(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const m = Math.floor(diff / 60000);
  const h = Math.floor(diff / 3600000);
  const d = Math.floor(diff / 86400000);
  if (m < 1) return 'just now';
  if (h < 1) return `${m}m ago`;
  if (d < 1) return `${h}h ago`;
  return `${d}d ago`;
}
---

<Dashboard title="SEO Audit">
  <style is:global>
    main { padding-top: 56px !important; padding-bottom: 80px !important; }
    @media (max-width: 768px) {
      main { padding-top: 40px !important; padding-bottom: 60px !important; }
    }
  </style>

  <div style="text-align:center;margin-bottom:32px;">
    <a href="/dashboard" style="display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:500;color:rgba(255,255,255,0.45);text-decoration:none;letter-spacing:0.04em;text-transform:uppercase;margin-bottom:12px;">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 19"/></svg>
      <span>Studio</span>
    </a>
    <span style="display:inline-block;font-size:13px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#22d3ee;margin-bottom:10px;">Audit Lab</span>
    <h2 style="font-family:'Inter',sans-serif;font-size:44px;font-weight:400;line-height:1.05;letter-spacing:-0.045em;color:#fff;margin-bottom:10px;">SEO & performance audit</h2>
    <p style="font-size:14px;color:rgba(255,255,255,0.55);margin-bottom:22px;max-width:560px;margin-left:auto;margin-right:auto;line-height:1.5;">
      Paste any public URL. We crawl every page, dismiss the cookie banner, and screenshot each one at desktop and mobile. You get performance, SEO, content, and a first-impression score per page, tuned to whether the site is built to sell or to present.
    </p>
    <p style="font-size:12px;color:rgba(255,255,255,0.4);letter-spacing:0.02em;">
      {auditCredits} audit credit{auditCredits === 1 ? '' : 's'} remaining
    </p>
  </div>

  <form id="audit-form" style="max-width:620px;margin:0 auto 40px;">
    <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px;">
      <input
        type="url"
        id="audit-url-input"
        name="url"
        required
        placeholder="https://yoursite.com"
        style="flex:1;min-width:240px;height:50px;padding:0 18px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.15);border-radius:12px;color:#fff;font-family:inherit;font-size:15px;outline:none;transition:border-color 0.2s;"
      />
      <button
        type="submit"
        id="audit-submit"
        style="height:50px;padding:0 28px;background:#22d3ee;color:#0a0a0a;border:none;border-radius:12px;font-family:inherit;font-size:14px;font-weight:700;letter-spacing:0.02em;cursor:pointer;transition:all 0.2s;display:inline-flex;align-items:center;gap:8px;"
      >
        <span id="audit-submit-label">Run audit</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </button>
    </div>

    <div style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.4);margin-bottom:10px;text-align:center;">What is this site for?</div>
    <input type="hidden" id="audit-goal" name="goal" value="sales" />
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
      <button type="button" class="goal-card" data-goal="sales" aria-pressed="true">
        <span class="goal-emoji">🎯</span>
        <span class="goal-title">Sales / conversion</span>
        <span class="goal-desc">Judge each page on the CTA, the offer's clarity, and the friction between visitor and action.</span>
      </button>
      <button type="button" class="goal-card" data-goal="presentation" aria-pressed="false">
        <span class="goal-emoji">✨</span>
        <span class="goal-title">Presentation / brand</span>
        <span class="goal-desc">Judge each page on first impression, aesthetic, and how coherently it tells the brand story.</span>
      </button>
    </div>
  </form>

  <div id="audit-progress" style="display:none;max-width:620px;margin:0 auto 40px;text-align:center;color:rgba(255,255,255,0.7);">
    <div style="display:inline-flex;align-items:center;gap:10px;font-size:14px;">
      <span class="spinner" style="display:inline-block;width:16px;height:16px;border:2px solid rgba(34,211,238,0.2);border-top-color:#22d3ee;border-radius:50%;animation:spin 0.8s linear infinite;"></span>
      <span id="audit-progress-msg">Crawling every page at desktop + mobile. This can take a minute or two…</span>
    </div>
  </div>

  <p id="audit-error" style="display:none;max-width:620px;margin:0 auto 18px;background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.28);border-radius:12px;padding:12px 16px;color:#ff8a8a;font-size:13.5px;text-align:center;"></p>

  <div style="max-width:760px;margin:0 auto;">
    {auditCredits === 0 && (
      <div style="background:rgba(34,211,238,0.06);border:1px solid rgba(34,211,238,0.22);border-radius:14px;padding:22px;text-align:center;margin-bottom:24px;">
        <p style="font-size:14px;color:rgba(255,255,255,0.7);margin:0;line-height:1.5;">
          You're out of audit credits. Contact your administrator to top up your balance.
        </p>
      </div>
    )}

    {recent.length > 0 && (
      <section>
        <h3 style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.4);margin:0 0 14px;">Recent audits</h3>
        <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:6px;">
          {recent.map(r => (
            <li>
              <a href={`/audit/${r.id}`} style="display:flex;align-items:center;justify-content:space-between;gap:14px;padding:12px 14px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:12px;text-decoration:none;transition:background 0.18s;" onmouseover="this.style.background='rgba(255,255,255,0.06)'" onmouseout="this.style.background='rgba(255,255,255,0.03)'">
                <div style="min-width:0;flex:1;">
                  <div style="font-size:13.5px;font-weight:600;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{r.url}</div>
                  <div style="font-size:11.5px;color:rgba(255,255,255,0.4);margin-top:2px;">{timeAgo(r.created_at)} · {r.status}</div>
                </div>
                {r.status === 'complete' ? (
                  <div style={`flex-shrink:0;display:flex;align-items:center;justify-content:center;width:42px;height:42px;border-radius:50%;background:rgba(255,255,255,0.04);border:2px solid ${scoreColor(r.overall_score)};font-size:13px;font-weight:700;color:${scoreColor(r.overall_score)};`}>
                    {r.overall_score ?? '—'}
                  </div>
                ) : (
                  <span style="flex-shrink:0;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:rgba(255,255,255,0.45);">{r.status}</span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>

  <style>
    @keyframes spin { to { transform: rotate(360deg); } }
    #audit-url-input:focus { border-color: #22d3ee; box-shadow: 0 0 0 3px rgba(34,211,238,0.18); }
    #audit-submit:hover:not(:disabled) { box-shadow: 0 6px 20px -6px rgba(34,211,238,0.5); transform: translateY(-1px); }
    #audit-submit:disabled { opacity: 0.55; cursor: wait; }
    .goal-card {
      display: flex; flex-direction: column; align-items: flex-start; gap: 6px;
      text-align: left; padding: 16px 16px 15px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 14px; cursor: pointer;
      font-family: inherit; transition: all 0.18s;
    }
    .goal-card:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.2); }
    .goal-card[aria-pressed="true"] {
      background: rgba(34,211,238,0.08);
      border-color: rgba(34,211,238,0.55);
      box-shadow: 0 0 0 1px rgba(34,211,238,0.3);
    }
    .goal-emoji { font-size: 20px; line-height: 1; }
    .goal-title { font-size: 14px; font-weight: 700; color: #fff; letter-spacing: -0.01em; }
    .goal-desc { font-size: 12px; color: rgba(255,255,255,0.55); line-height: 1.4; }
    @media (max-width: 520px) {
      #audit-form > div:last-child { grid-template-columns: 1fr; }
    }
  </style>

  <script is:inline define:vars={{ hasCredits: auditCredits > 0 }}>
    const form = document.getElementById('audit-form');
    const input = document.getElementById('audit-url-input');
    const submitBtn = document.getElementById('audit-submit');
    const progress = document.getElementById('audit-progress');
    const errorEl = document.getElementById('audit-error');
    const goalInput = document.getElementById('audit-goal');
    const goalCards = document.querySelectorAll('.goal-card');

    goalCards.forEach(function(card) {
      card.addEventListener('click', function() {
        goalCards.forEach(function(c) { c.setAttribute('aria-pressed', 'false'); });
        card.setAttribute('aria-pressed', 'true');
        if (goalInput) goalInput.value = card.getAttribute('data-goal') || 'sales';
      });
    });

    form?.addEventListener('submit', async function(ev) {
      ev.preventDefault();
      if (!hasCredits) {
        errorEl.textContent = 'You have no audit credits. Ask your admin to add credits.';
        errorEl.style.display = 'block';
        return;
      }
      errorEl.style.display = 'none';
      progress.style.display = 'block';
      submitBtn.disabled = true;
      try {
        const r = await fetch('/api/audit/run', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ url: input.value, goal: goalInput ? goalInput.value : 'sales' }),
        });
        const data = await r.json();
        if (r.status === 402) {
          window.location.reload();
          return;
        }
        if (!r.ok) {
          errorEl.textContent = data.error || 'Audit failed.';
          errorEl.style.display = 'block';
          progress.style.display = 'none';
          submitBtn.disabled = false;
          return;
        }
        window.location.href = '/audit/' + data.id;
      } catch (e) {
        errorEl.textContent = 'Network error. Please try again.';
        errorEl.style.display = 'block';
        progress.style.display = 'none';
        submitBtn.disabled = false;
      }
    });
  </script>
</Dashboard>
