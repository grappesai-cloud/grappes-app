---
// Savoy Admin — the marketing team's home: stats, the Content Studio tool,
// reel library and the post scheduler. Same design language as the LP
// (Fraunces + Inter + mono, gold on night), auth-guarded by Better-Auth.
import { listReels } from '../../lib/studio/db';
import { getPg } from '../../lib/supabase';

const authUser = Astro.locals.user;
if (!authUser) return Astro.redirect('/sign-in?next=/savoy/admin');

const reels = await listReels(authUser.id);
const complete = reels.filter(r => r.status === 'complete');
const inFlight = reels.filter(r => !['complete', 'image_failed', 'video_failed'].includes(r.status));

let posts: any[] = [];
try {
  const sql = getPg();
  posts = await sql`
    SELECT p.*, r.title AS reel_title, r.video_url
    FROM savoy_posts p JOIN studio_reels r ON r.id = p.reel_id
    WHERE p.user_id = ${authUser.id}
    ORDER BY p.scheduled_at ASC LIMIT 50
  ` as any[];
} catch { /* table may not exist yet in this env */ }
const queued = posts.filter(p => p.status === 'queued');

const fmtDate = (d: string) => new Date(d).toLocaleString('ro-RO', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });
---
<!doctype html>
<html lang="ro">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Savoy Admin · Content Studio</title>
  <meta name="robots" content="noindex" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <aside class="ad-side">
    <a href="/savoy" class="ad-logo">SAVOY<span>·</span>ADMIN</a>
    <nav class="ad-nav">
      <a href="#overview" class="active">Privire generală</a>
      <a href="/studio">Content Studio →</a>
      <a href="#reels">Reels</a>
      <a href="#posts">Calendar postări</a>
      <a href="/savoy" target="_blank">Vezi site-ul ↗</a>
    </nav>
    <div class="ad-side-foot">
      <span class="ad-user">{authUser.email}</span>
    </div>
  </aside>

  <main class="ad-main">
    <header class="ad-head reveal" id="overview">
      <p class="ad-kicker">Bun venit înapoi</p>
      <h1>Ce postăm <em>azi?</em></h1>
    </header>

    <!-- Stats -->
    <section class="ad-stats">
      <div class="ad-stat reveal"><strong data-count={complete.length}>0</strong><span>reels gata de postat</span></div>
      <div class="ad-stat reveal" data-delay="1"><strong data-count={inFlight.length}>0</strong><span>în producție acum</span></div>
      <div class="ad-stat reveal" data-delay="2"><strong data-count={queued.length}>0</strong><span>postări programate</span></div>
      <a class="ad-stat ad-stat-cta reveal" data-delay="3" href="/studio">
        <strong>+</strong><span>Reel nou cu Domnul Girafă</span>
      </a>
    </section>

    <!-- Reels library -->
    <section id="reels">
      <div class="ad-section-head reveal">
        <h2>Biblioteca de reels</h2>
        <a class="ad-btn" href="/studio">Deschide Studio</a>
      </div>
      {reels.length === 0 ? (
        <p class="ad-empty reveal">Niciun reel încă. Scrie prima idee în Studio și Domnul Girafă se ocupă de rest.</p>
      ) : (
        <div class="ad-reel-grid">
          {reels.slice(0, 8).map((r, i) => (
            <article class="ad-reel reveal" data-delay={String(i % 4)}>
              {r.video_url
                ? <video src={r.video_url} muted loop playsinline preload="metadata" />
                : <div class="ad-reel-ph">{r.mode === 'giraffe' ? '🦒' : '🏖️'}</div>}
              <div class="ad-reel-meta">
                <span class="ad-reel-name">{r.title}</span>
                <span class={`ad-pill ad-pill--${r.status}`}>{r.status === 'complete' ? 'Gata' : r.status.includes('failed') ? 'Eroare' : 'În lucru'}</span>
              </div>
              {r.status === 'complete' && (
                <button class="ad-btn ad-btn-sm js-schedule" data-reel={r.id} data-title={r.title} type="button">Programează</button>
              )}
            </article>
          ))}
        </div>
      )}
    </section>

    <!-- Scheduler -->
    <section id="posts">
      <div class="ad-section-head reveal">
        <h2>Calendar postări</h2>
      </div>

      <div class="ad-sched-card reveal" id="sched-card" hidden>
        <p class="ad-sched-title">Programează: <strong id="sched-reel-title"></strong></p>
        <label class="ad-label" for="caption">Caption</label>
        <textarea id="caption" class="ad-input" rows="3" maxlength="400" placeholder="ex: Domnul Girafă vă așteaptă la piscină 🦒☀️ #SavoyMamaia"></textarea>
        <label class="ad-label">Platforme</label>
        <div class="ad-platforms">
          <button type="button" class="ad-chip js-plat" data-p="instagram">Instagram</button>
          <button type="button" class="ad-chip js-plat" data-p="tiktok">TikTok</button>
          <button type="button" class="ad-chip js-plat" data-p="facebook">Facebook</button>
        </div>
        <label class="ad-label" for="when">Data și ora</label>
        <input id="when" class="ad-input" type="datetime-local" />
        <div class="ad-row">
          <button class="ad-btn ad-btn-gold" id="btn-queue" type="button">Adaugă în calendar</button>
          <button class="ad-btn" id="btn-cancel-sched" type="button">Renunță</button>
        </div>
        <p class="ad-error" id="sched-error" hidden></p>
      </div>

      {posts.length === 0 ? (
        <p class="ad-empty reveal">Calendarul e gol. Programează primul reel din bibliotecă.</p>
      ) : (
        <ul class="ad-post-list">
          {posts.map(p => (
            <li class={`ad-post reveal ad-post--${p.status}`} data-id={p.id}>
              <div class="ad-post-when">
                <strong>{fmtDate(p.scheduled_at)}</strong>
                <span>{(p.platforms ?? []).join(' · ')}</span>
              </div>
              <div class="ad-post-body">
                <span class="ad-post-reel">{p.reel_title}</span>
                <p>{p.caption}</p>
              </div>
              <div class="ad-post-actions">
                <span class={`ad-pill ad-pill--${p.status}`}>{p.status === 'queued' ? 'Programat' : p.status === 'posted' ? 'Postat' : 'Anulat'}</span>
                {p.status === 'queued' && <button class="ad-btn ad-btn-sm js-mark" data-id={p.id} type="button">Marchează postat</button>}
              </div>
            </li>
          ))}
        </ul>
      )}
    </section>
  </main>

  <style>
    :root {
      --night: #0D1B2A; --panel: #13243A; --cream: #FAF4E8;
      --gold: #FFB300; --orange: #E85D04;
      --serif: 'Fraunces', serif; --sans: 'Inter', sans-serif; --mono: 'JetBrains Mono', monospace;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--sans); background: var(--night); color: var(--cream); display: flex; min-height: 100vh; }

    /* Sidebar */
    .ad-side { width: 240px; flex-shrink: 0; display: flex; flex-direction: column; padding: 28px 22px; border-right: 1px solid rgba(250,244,232,0.1); position: sticky; top: 0; height: 100vh; }
    .ad-logo { font-family: var(--mono); font-size: 13px; letter-spacing: 0.22em; color: var(--cream); text-decoration: none; margin-bottom: 44px; }
    .ad-logo span { color: var(--gold); margin: 0 2px; }
    .ad-nav { display: flex; flex-direction: column; gap: 4px; }
    .ad-nav a { font-size: 13.5px; font-weight: 500; color: rgba(250,244,232,0.6); text-decoration: none; padding: 10px 12px; border-radius: 10px; transition: background 0.2s, color 0.2s; }
    .ad-nav a:hover, .ad-nav a.active { background: rgba(255,179,0,0.1); color: var(--gold); }
    .ad-side-foot { margin-top: auto; }
    .ad-user { font-family: var(--mono); font-size: 11px; opacity: 0.45; word-break: break-all; }
    @media (max-width: 860px) { .ad-side { display: none; } }

    /* Main */
    .ad-main { flex: 1; padding: clamp(24px, 4vw, 56px); max-width: 1100px; }
    .ad-kicker { font-family: var(--mono); font-size: 11.5px; letter-spacing: 0.26em; text-transform: uppercase; color: var(--gold); margin-bottom: 14px; }
    .ad-head h1 { font-family: var(--serif); font-weight: 300; font-size: clamp(34px, 5vw, 58px); }
    .ad-head h1 em { font-style: italic; color: var(--gold); }

    .ad-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin: 40px 0 64px; }
    @media (max-width: 760px) { .ad-stats { grid-template-columns: repeat(2, 1fr); } }
    .ad-stat { background: var(--panel); border: 1px solid rgba(250,244,232,0.08); border-radius: 18px; padding: 22px; text-decoration: none; color: inherit; transition: transform 0.3s cubic-bezier(0.2,0.8,0.2,1), border-color 0.2s; }
    .ad-stat:hover { transform: translateY(-4px); }
    .ad-stat strong { display: block; font-family: var(--serif); font-weight: 300; font-size: 44px; line-height: 1; }
    .ad-stat span { display: block; font-size: 12.5px; opacity: 0.6; margin-top: 8px; }
    .ad-stat-cta { border-color: rgba(255,179,0,0.4); }
    .ad-stat-cta strong { color: var(--gold); }

    section { margin-bottom: 72px; }
    .ad-section-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 26px; }
    .ad-section-head h2 { font-family: var(--serif); font-weight: 300; font-size: 30px; }

    .ad-btn { display: inline-flex; align-items: center; font-size: 13px; font-weight: 600; padding: 10px 18px; border-radius: 999px; border: 1px solid rgba(250,244,232,0.25); background: none; color: var(--cream); text-decoration: none; cursor: pointer; transition: transform 0.25s, background 0.2s, color 0.2s; }
    .ad-btn:hover { transform: translateY(-2px); background: rgba(250,244,232,0.08); }
    .ad-btn-gold { background: var(--gold); border-color: var(--gold); color: var(--night); }
    .ad-btn-sm { font-size: 12px; padding: 7px 14px; }

    /* Reels grid */
    .ad-reel-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
    @media (max-width: 1000px) { .ad-reel-grid { grid-template-columns: repeat(2, 1fr); } }
    .ad-reel { background: var(--panel); border: 1px solid rgba(250,244,232,0.08); border-radius: 18px; overflow: hidden; display: flex; flex-direction: column; }
    .ad-reel video, .ad-reel-ph { width: 100%; aspect-ratio: 9/16; object-fit: cover; background: #0a1420; display: flex; align-items: center; justify-content: center; font-size: 40px; max-height: 240px; }
    .ad-reel-meta { display: flex; align-items: center; justify-content: space-between; gap: 8px; padding: 12px 14px 6px; }
    .ad-reel-name { font-size: 13px; font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .ad-reel .ad-btn-sm { margin: 8px 14px 14px; align-self: flex-start; }

    .ad-pill { font-size: 10.5px; font-weight: 600; padding: 4px 10px; border-radius: 999px; background: rgba(250,244,232,0.1); white-space: nowrap; }
    .ad-pill--complete, .ad-pill--posted { background: rgba(110,231,160,0.15); color: #6ee7a0; }
    .ad-pill--queued { background: rgba(255,179,0,0.16); color: var(--gold); }
    .ad-pill--image_failed, .ad-pill--video_failed, .ad-pill--canceled { background: rgba(255,138,138,0.14); color: #ff8a8a; }

    /* Scheduler */
    .ad-sched-card { background: var(--panel); border: 1px solid rgba(255,179,0,0.35); border-radius: 18px; padding: 24px; margin-bottom: 26px; }
    .ad-sched-title { font-size: 14px; margin-bottom: 6px; }
    .ad-sched-title strong { color: var(--gold); }
    .ad-label { display: block; font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; opacity: 0.55; margin: 16px 0 7px; }
    .ad-input { width: 100%; background: rgba(250,244,232,0.05); border: 1px solid rgba(250,244,232,0.15); border-radius: 12px; padding: 11px 13px; font-size: 14px; color: var(--cream); font-family: inherit; resize: vertical; }
    .ad-input:focus { outline: none; border-color: var(--gold); }
    .ad-platforms { display: flex; gap: 8px; }
    .ad-chip { font-size: 12.5px; font-weight: 600; padding: 8px 16px; border-radius: 999px; background: none; border: 1px solid rgba(250,244,232,0.2); color: rgba(250,244,232,0.7); cursor: pointer; transition: all 0.2s; }
    .ad-chip.on { background: rgba(255,179,0,0.14); border-color: var(--gold); color: var(--gold); }
    .ad-row { display: flex; gap: 10px; margin-top: 20px; }
    .ad-error { font-size: 13px; color: #ff8a8a; margin-top: 12px; }
    .ad-empty { font-size: 14px; opacity: 0.55; }

    /* Post list */
    .ad-post-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .ad-post { display: grid; grid-template-columns: 150px 1fr auto; gap: 18px; align-items: center; background: var(--panel); border: 1px solid rgba(250,244,232,0.08); border-radius: 16px; padding: 16px 18px; }
    @media (max-width: 760px) { .ad-post { grid-template-columns: 1fr; gap: 8px; } }
    .ad-post--posted { opacity: 0.55; }
    .ad-post-when strong { display: block; font-size: 14px; }
    .ad-post-when span { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.06em; opacity: 0.5; text-transform: capitalize; }
    .ad-post-reel { font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; color: var(--gold); }
    .ad-post-body p { font-size: 13.5px; opacity: 0.8; margin-top: 3px; }
    .ad-post-actions { display: flex; align-items: center; gap: 10px; }

    /* Reveal */
    .reveal { opacity: 0; transform: translateY(22px); transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1); }
    .reveal[data-delay="1"] { transition-delay: 0.07s; } .reveal[data-delay="2"] { transition-delay: 0.14s; } .reveal[data-delay="3"] { transition-delay: 0.21s; }
    .reveal.in { opacity: 1; transform: none; }
    @media (prefers-reduced-motion: reduce) { .reveal { transition: none; opacity: 1; transform: none; } }
  </style>

  <script>
    const $ = (id: string) => document.getElementById(id)!;

    // Reveal + counters
    const io = new IntersectionObserver(es => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }), { threshold: 0.12 });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    document.querySelectorAll<HTMLElement>('[data-count]').forEach(el => {
      const target = Number(el.dataset.count ?? 0);
      const t0 = performance.now();
      const tick = (t: number) => {
        const p = Math.min((t - t0) / 1100, 1);
        el.textContent = String(Math.round(target * (1 - Math.pow(1 - p, 3))));
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    });

    // Hover-play reel previews
    document.querySelectorAll<HTMLVideoElement>('.ad-reel video').forEach(v => {
      v.addEventListener('mouseenter', () => v.play().catch(() => {}));
      v.addEventListener('mouseleave', () => { v.pause(); v.currentTime = 0; });
    });

    // Scheduler
    let schedReel: string | null = null;
    const plats = new Set<string>();
    document.querySelectorAll<HTMLButtonElement>('.js-schedule').forEach(b => b.addEventListener('click', () => {
      schedReel = b.dataset.reel!;
      $('sched-reel-title').textContent = b.dataset.title ?? '';
      $('sched-card').hidden = false;
      $('sched-card').scrollIntoView({ behavior: 'smooth', block: 'center' });
    }));
    document.querySelectorAll<HTMLButtonElement>('.js-plat').forEach(b => b.addEventListener('click', () => {
      const p = b.dataset.p!;
      plats.has(p) ? plats.delete(p) : plats.add(p);
      b.classList.toggle('on', plats.has(p));
    }));
    $('btn-cancel-sched').addEventListener('click', () => { $('sched-card').hidden = true; schedReel = null; });
    $('btn-queue').addEventListener('click', async () => {
      const err = $('sched-error'); err.hidden = true;
      try {
        const res = await fetch('/api/studio/posts', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            reelId: schedReel,
            caption: ($('caption') as HTMLTextAreaElement).value,
            platforms: [...plats],
            scheduledAt: ($('when') as HTMLInputElement).value,
          }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error ?? 'Eroare.');
        window.location.reload();
      } catch (e: any) { err.textContent = e.message; err.hidden = false; }
    });
    document.querySelectorAll<HTMLButtonElement>('.js-mark').forEach(b => b.addEventListener('click', async () => {
      await fetch(`/api/studio/posts/${b.dataset.id}`, {
        method: 'PATCH', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'posted' }),
      });
      window.location.reload();
    }));
  </script>
</body>
</html>
