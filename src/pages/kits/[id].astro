          { label: 'Years Active', value: '6' },
        ],
        booking: {
          agents: [
            { name: 'Andrei Popescu', email: 'andrei@booking.ro', phone: 'Worldwide' },
            { name: 'Maria Ionescu',  email: 'maria@mgmt.ro',   phone: 'Romania · Management' },
          ],
          instagram: '@deny.music',
          press_link: 'https://drive.google.com/press-kit-deny',
        },
        contact_email: 'booking@deny.music',
      };
      Object.assign(STATE, sample);
      try {
        await fetch(`/api/kits/${kitId}`, { method: 'PATCH', headers: { 'content-type': 'application/json' }, body: JSON.stringify(sample) });
        renderReview(); reloadPreview();
      } catch { alert('Could not load sample.'); }
      if (btn) { btn.disabled = false; btn.textContent = 'Use sample content (DENY-like)'; }
    }

    async function publishFlow() {
      const btn = document.getElementById('publish-btn');
      btn.disabled = true; btn.textContent = 'Opening checkout…';
      await flushSave();
      try {
        const r = await fetch(`/api/kits/${kitId}/publish`, { method: 'POST' });
        const data = await r.json();
        if (data.url) { window.location.href = data.url; return; }
        alert(data.error || 'Payment error.');
      } catch { alert('Network error.'); }
      btn.disabled = false; btn.textContent = 'Publish for €15 →';
    }

    // ── Palette presets ────────────────────────────────────
    const PALETTE_PRESETS = [
      { name:'Mono',     primary:'#0a0a0a', secondary:'#262626', accent:'#f97316', text:'#0a0a0a', bg:'#fafafa' },
      { name:'Editorial',primary:'#1d1d1f', secondary:'#5a5a5e', accent:'#c97064', text:'#1d1d1f', bg:'#f5efe5' },
      { name:'Studio',   primary:'#0b1f3a', secondary:'#1e3a8a', accent:'#e25822', text:'#0b1f3a', bg:'#f7f4ed' },
      { name:'Forest',   primary:'#0f5132', secondary:'#5a6b2f', accent:'#e25822', text:'#0f5132', bg:'#f4f1e8' },
      { name:'Night',    primary:'#f5efe0', secondary:'#a3a3a3', accent:'#e25822', text:'#f5efe0', bg:'#0b0b0d' },
      { name:'Aurora',   primary:'#1d2bd1', secondary:'#3b3bc7', accent:'#c97064', text:'#0a0a0a', bg:'#f0eef8' },
    ];

    // ── Utils ──────────────────────────────────────────────
    function escapeHtml(s) { return String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
    function escapeAttr(s) { return escapeHtml(s); }

    // ── Boot ───────────────────────────────────────────────
    function initialStepFromHash() {
      const m = (window.location.hash || '').match(/step=([\w-]+)/);
      if (!m) return 0;
      const idx = STEPS.findIndex(s => s.key === m[1]);
      return idx >= 0 ? idx : 0;
    }

    // If user already has a logo on load, skip needsLogoGen.
    if (STATE.assets?.logo) needsLogoGen = false;
    STEPS = buildSteps();
    stepIdx = initialStepFromHash();
    renderProgress();
    if (STEPS[stepIdx].key === 'review') {
      const wiz = document.getElementById('wiz-stage');
      const rev = document.getElementById('review-stage');
      wiz.hidden = true; wiz.style.display = 'none';
      rev.hidden = false; rev.style.display = 'grid';
      renderReview(); reloadPreview();
    } else {
      renderStep();
    }
    window.addEventListener('beforeunload', () => { flushSave(); });
    window.addEventListener('hashchange', () => {
      const idx = initialStepFromHash();
      if (idx !== stepIdx) goTo(idx, { skipSave: true });
    });
  </script>
  </Fragment>
  )}
