        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">Inline stats.</h2>
        <p style="${STYLE_HELPER}">Small label-value pairs printed underneath the Overview intro. e.g. "Social Media Followers — 97.7K", "Total Streams — 3.42M".</p>
        <div id="f-stats" style="display:flex;flex-direction:column;gap:10px;"></div>
        <button type="button" id="add-stat" class="pkw-add" style="${STYLE_ADD};margin-top:12px;">+ Add stat</button>
