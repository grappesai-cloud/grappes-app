          <input type="text" placeholder="${escapeAttr(isMusician ? 'Track title' : 'Project title')}" data-k="title" value="${escapeAttr(s.title ?? s.name ?? '')}" style="height:42px;padding:0 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13.5px;outline:none;" />
          <input type="text" placeholder="${escapeAttr(isMusician ? 'Original / Remix' : 'Your role')}" data-k="role" value="${escapeAttr(s.role ?? '')}" style="height:42px;padding:0 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13.5px;outline:none;" />
          <button type="button" class="pkw-rm" data-rm>×</button>
        `,
        STATE.press, 'add-port', () => ({ year: '', title: '', role: '' })
      );
      wireFooter(card);
    }

    // ── Step: big statistics (label + value) ───────────────
    function renderStatistics(card) {
      const initial = STATE.big_stats || [];
      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">Headline statistics.</h2>
        <p style="${STYLE_HELPER}">The big numbers — printed two-up on the Statistics page. e.g. "Monthly Listeners — 412K", "Total Streams — 3.42M".</p>
        <div id="f-big" style="display:flex;flex-direction:column;gap:10px;"></div>
        <button type="button" id="add-big" class="pkw-add" style="${STYLE_ADD};margin-top:12px;">+ Add headline stat</button>
        ${footerHTML({ skipText: 'Skip' })}
      `;
      bindRows(card, 'f-big', 'big_stats', 'grid-template-columns:1.4fr 1fr 40px;',
        (s) => `
          <input type="text" placeholder="Monthly Listeners" data-k="label" value="${escapeAttr(s.label ?? '')}" style="height:42px;padding:0 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13.5px;outline:none;" />
          <input type="text" placeholder="412K" data-k="value" value="${escapeAttr(s.value ?? '')}" style="height:42px;padding:0 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13.5px;outline:none;" />
          <button type="button" class="pkw-rm" data-rm>×</button>
        `,
        initial, 'add-big', () => ({ label: '', value: '' })
      );
      wireFooter(card);
    }

    // ── Step: contact & booking ────────────────────────────
    function renderContactBooking(card) {
      const b = STATE.booking || {};
      const agents = b.agents || [];
      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">Booking & contact.</h2>
        <p style="${STYLE_HELPER}">Who handles what, where to find you, and where journalists can grab high-res assets.</p>

        <div style="display:flex;flex-direction:column;gap:18px;">
          <div>
            <label style="${STYLE_LABEL}">Primary booking email</label>
            <input id="f-email" type="email" class="pkw-input" value="${escapeAttr(STATE.contact_email ?? '')}" placeholder="booking@you.com" style="${STYLE_INPUT}" />
          </div>
          <div>
            <label style="${STYLE_LABEL}">Booking agents &amp; management</label>
            <div id="f-agents" style="display:flex;flex-direction:column;gap:10px;"></div>
            <button type="button" id="add-agent" class="pkw-add" style="${STYLE_ADD};margin-top:10px;">+ Add agent</button>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div>
              <label style="${STYLE_LABEL}">Instagram</label>
              <input id="f-ig" type="text" class="pkw-input" value="${escapeAttr(b.instagram ?? '')}" placeholder="@handle or full URL" style="${STYLE_INPUT}" />
            </div>
            <div>
              <label style="${STYLE_LABEL}">Press materials link</label>
              <input id="f-press" type="url" class="pkw-input" value="${escapeAttr(b.press_link ?? '')}" placeholder="https://drive.google.com/…" style="${STYLE_INPUT}" />
            </div>
          </div>
        </div>

        ${footerHTML({ nextText: 'Review →' })}
      `;
      card.querySelector('#f-email').addEventListener('input', e => queueSave({ contact_email: e.target.value }));
      const persistBooking = () => {
        STATE.booking = {
          ...(STATE.booking || {}),
          instagram: card.querySelector('#f-ig').value,
          press_link: card.querySelector('#f-press').value,
        };
        queueSave({ booking: STATE.booking });
      };
      card.querySelector('#f-ig').addEventListener('input', persistBooking);
      card.querySelector('#f-press').addEventListener('input', persistBooking);

      bindRows(card, 'f-agents', '__agents_rows', 'grid-template-columns:1.2fr 1.5fr 1fr 40px;',
        (s) => `
          <input type="text" placeholder="Name" data-k="name" value="${escapeAttr(s.name ?? '')}" style="height:42px;padding:0 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13.5px;outline:none;" />
          <input type="email" placeholder="email" data-k="email" value="${escapeAttr(s.email ?? '')}" style="height:42px;padding:0 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13.5px;outline:none;" />
          <input type="text" placeholder="Phone / role" data-k="phone" value="${escapeAttr(s.phone ?? '')}" style="height:42px;padding:0 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13.5px;outline:none;" />
          <button type="button" class="pkw-rm" data-rm>×</button>
