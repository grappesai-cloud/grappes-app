        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">${title}</h2>
        <p style="${STYLE_HELPER}">${helper}</p>
        <div id="f-port" style="display:flex;flex-direction:column;gap:10px;"></div>
        <button type="button" id="add-port" class="pkw-add" style="${STYLE_ADD};margin-top:12px;">+ Add entry</button>
        ${footerHTML({ skipText: 'Skip' })}
      `;
      bindRows(card, 'f-port', 'press', 'grid-template-columns:80px 1.6fr 1fr 40px;',
