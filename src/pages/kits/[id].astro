      `;
      bindRows(card, 'f-stats', 'stats', 'grid-template-columns:1.4fr 1fr 40px;',
        (s) => `
          <input type="text" placeholder="Social Media Followers" data-k="label" value="${escapeAttr(s.label ?? '')}" style="height:42px;padding:0 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13.5px;outline:none;" />
          <input type="text" placeholder="97.7K" data-k="value" value="${escapeAttr(s.value ?? '')}" style="height:42px;padding:0 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13.5px;outline:none;" />
          <button type="button" class="pkw-rm" data-rm>×</button>
        `,
        STATE.stats, 'add-stat', () => ({ label: '', value: '' })
      );
      wireFooter(card);
    }

    // ── Step: key highlights (bullet list) ─────────────────
    function renderKeyHighlights(card) {
      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">Key highlights.</h2>
        <p style="${STYLE_HELPER}">5-8 punchy bullets. Optionally prefix with a lead like "#1 — Charted track in Portugal" — we'll style the part before the dash as an accent label.</p>
        <div id="f-hi" style="display:flex;flex-direction:column;gap:10px;"></div>
        <button type="button" id="add-hi" class="pkw-add" style="${STYLE_ADD};margin-top:12px;">+ Add highlight</button>
        ${footerHTML({ skipText: 'Skip highlights' })}
      `;
      // Wrap as objects for the repeater
      const initial = (STATE.key_highlights || []).map(t => ({ text: t }));
      bindRows(card, 'f-hi', '__hi_rows', 'grid-template-columns:1fr 40px;',
        (s) => `
          <input type="text" placeholder="#1 — Charted track in Portugal" data-k="text" value="${escapeAttr(s.text ?? '')}" style="height:42px;padding:0 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13.5px;outline:none;" />
          <button type="button" class="pkw-rm" data-rm>×</button>
        `,
        initial, 'add-hi', () => ({ text: '' })
      );
      // Mirror into the proper field on every save flush
      const origQueue = queueSave;
      const observer = setInterval(() => {
        if (Array.isArray(STATE.__hi_rows)) {
          const list = STATE.__hi_rows.map(r => (r.text || '').trim()).filter(Boolean);
          if (JSON.stringify(list) !== JSON.stringify(STATE.key_highlights)) {
            STATE.key_highlights = list;
            origQueue({ key_highlights: list });
          }
        }
      }, 700);
      // Clean up when the user navigates away
      card.addEventListener('DOMNodeRemoved', () => clearInterval(observer));
      wireFooter(card, { onNext: async () => {
        const list = (STATE.__hi_rows || []).map(r => (r.text || '').trim()).filter(Boolean);
        STATE.key_highlights = list;
        await fetch(`/api/kits/${kitId}`, { method: 'PATCH', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ key_highlights: list }) });
        clearInterval(observer);
        return true;
      }});
    }

    // ── Step: biography (long bio) ─────────────────────────
    function renderBiography(card) {
      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">The longer biography.</h2>
        <p style="${STYLE_HELPER}">Two or three paragraphs of the full story — context, sound, what makes you you. Up to 3000 characters.</p>
        <textarea id="f-bio" class="pkw-textarea" maxlength="3000" placeholder="The full story." style="${STYLE_TEXTAREA};min-height:240px;">${escapeHtml(STATE.bio_long ?? '')}</textarea>
        ${footerHTML({ skipText: 'Skip biography' })}
