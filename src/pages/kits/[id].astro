      if (btn) { btn.disabled = true; btn.textContent = 'Filling…'; }
      const sample = {
        name: STATE.name || 'DENY',
        tagline: 'Bucharest-based DJ & producer shaping the Romanian electronic scene.',
        role: 'dj',
        overview_intro: 'DENY is a Bucharest-based DJ and producer shaping the modern Romanian electronic scene — melodic, hypnotic, and uncompromisingly editorial.',
        bio_long: 'Across the last five years DENY has built a sound that hovers between hypnotic minimal and warm melodic house — at home in dark Bucharest basements and on the main stage at UNTOLD.\n\nResidencies at Form Space and Guesthouse Club bookended a 2024 European tour spanning Berlin, Lisbon, and Athens, while collaborations with Cap Records and Sunrise have pushed his records onto Beatport, Spotify editorial and Romania\'s national radio.',
