---
import Dashboard from '../../layouts/Dashboard.astro';
import { createAdminClient } from '../../lib/supabase';
import { googleFontsUrl, type PressKit } from '../../lib/press-kit';
import { GOOGLE_FONTS } from '../../lib/google-fonts';

const { id } = Astro.params;
const authUser = Astro.locals.user!;

const client = createAdminClient();
const { data: kit, error } = await client
  .from('press_kits')
  .select('*')
  .eq('id', id!)
  .eq('user_id', authUser.id)
  .maybeSingle();

if (!kit || error) return Astro.redirect('/kits');

const k = kit as unknown as PressKit;
const justPublished = Astro.url.searchParams.get('published') === '1';
const fontsCss = googleFontsUrl(k.fonts);

// Preload a healthy batch of preview fonts so the picker shows each family
// rendered in its own face without 150 stylesheet requests.
const _families = ['Inter', ...GOOGLE_FONTS.slice(0, 64).map(f => f.family)];
const _uniq = Array.from(new Set(_families));
const previewFontsCss = `https://fonts.googleapis.com/css2?${_uniq.map(f => `family=${f.replace(/\s+/g, '+')}:wght@400;500;700`).join('&')}&display=swap`;
---

<Dashboard title={`Edit — ${k.name}`}>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href={fontsCss} />
  <link rel="stylesheet" href={previewFontsCss} />

  <style is:global>
    main { padding-top: 28px !important; padding-bottom: 80px !important; max-width: 1180px !important; }
  </style>

  {/* ─── Top bar ────────────────────────────────────────── */}
  <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:18px;flex-wrap:wrap;">
    <a href="/kits" style="display:inline-flex;align-items:center;gap:6px;font-size:11.5px;font-weight:500;color:rgba(255,255,255,0.5);text-decoration:none;letter-spacing:0.06em;text-transform:uppercase;">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      <span>Press kits</span>
    </a>
    <div style="display:flex;gap:12px;align-items:center;">
      <span id="save-state" style="font-size:11.5px;color:rgba(255,255,255,0.5);transition:opacity .2s;"></span>
      {k.status === 'published' && k.slug ? (
        <a href={`/kit/${k.slug}`} target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:6px;background:rgba(110,231,163,0.1);color:#6ee7a3;border:1px solid rgba(110,231,163,0.3);border-radius:999px;padding:7px 14px;font-size:12px;font-weight:600;text-decoration:none;">View live →</a>
      ) : null}
    </div>
  </div>

  {justPublished && (
    <div style="background:rgba(110,231,163,0.08);border:1px solid rgba(110,231,163,0.28);border-radius:14px;padding:14px 18px;color:#6ee7a3;font-size:13.5px;margin-bottom:22px;text-align:center;">
      Published — your shareable link is grappes.dev/kit/{k.slug ?? '…'}
    </div>
  )}

  {/* ─── Slim progress bar + caption ────────────────────── */}
  <div id="wizard-progress" style="max-width:680px;margin:0 auto 28px;"></div>

  {/* ─── Bootstrap state for client ─────────────────────── */}
  <script id="kit-bootstrap" type="application/json" set:html={JSON.stringify({
    id: k.id, name: k.name, tagline: k.tagline, kit_type: k.kit_type,
    bio_short: k.bio_short, bio_long: k.bio_long,
    contact_email: k.contact_email, contact_phone: k.contact_phone, contact_other: k.contact_other,
    palette: k.palette, fonts: k.fonts,
    assets: k.assets ?? {}, stats: k.stats ?? [], links: k.links ?? [],
    press: k.press ?? [], awards: k.awards ?? [],
    status: k.status, slug: k.slug,
  })} />
  <script id="font-bootstrap" type="application/json" set:html={JSON.stringify(GOOGLE_FONTS)} />

  {/* ─── Wizard stage (single-question screens) ─────────── */}
  <div id="wiz-stage"></div>

  {/* ─── Review stage (only screen with live preview) ──── */}
  <div id="review-stage" hidden style="grid-template-columns:minmax(0,440px) minmax(0,1fr);gap:18px;align-items:start;margin-top:6px;">
    <aside id="review-recap" style="background:linear-gradient(180deg,rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%),rgba(18,18,22,0.92);backdrop-filter:blur(24px) saturate(1.3);border:1px solid rgba(255,255,255,0.09);border-radius:20px;padding:24px;max-height:calc(100vh - 140px);overflow-y:auto;position:sticky;top:90px;"></aside>
    <div style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.07);border-radius:20px;overflow:hidden;">
      <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:1px solid rgba(255,255,255,0.06);font-size:11px;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.55);font-weight:700;">
        <span>Live preview</span>
        {k.status === 'published' && k.slug ? (
          <a href={`/kit/${k.slug}?print=1`} target="_blank" style="color:#f97316;text-decoration:none;font-size:11px;font-weight:700;letter-spacing:0.08em;">Print / PDF →</a>
        ) : (
          <span style="font-size:10.5px;color:rgba(255,255,255,0.4);letter-spacing:0.06em;">PDF after publish</span>
        )}
      </div>
      <iframe id="kit-preview" src={`/kit/preview/${k.id}`} title="Press kit preview" style="width:100%;height:calc(100vh - 200px);min-height:640px;border:0;background:#fafafa;display:block;"></iframe>
    </div>
  </div>

  {/* Focus + hover micro-states (the only place we need a stylesheet beyond inline) */}
  <style>
    .pkw-input:focus, .pkw-textarea:focus { border-color:#f97316 !important; box-shadow:0 0 0 3px rgba(249,115,22,0.18) !important; }
    .pkw-chip:hover { border-color:rgba(255,255,255,0.28); color:#fff; }
    .pkw-chip.is-active { background:rgba(249,115,22,0.14) !important; border-color:#f97316 !important; color:#fff !important; box-shadow:0 0 0 3px rgba(249,115,22,0.14); }
    .pkw-tile:hover { border-color:rgba(255,255,255,0.28); transform:translateY(-1px); }
    .pkw-tile.is-active { background:rgba(249,115,22,0.1) !important; border-color:#f97316 !important; box-shadow:0 0 0 3px rgba(249,115,22,0.14); }
    .pkw-fadein { animation: pkwFade .28s ease both; }
    @keyframes pkwFade { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:translateY(0); } }
    .pkw-rm { width:36px;height:36px;border-radius:10px;border:0;background:rgba(239,68,68,0.1);color:#ff8a8a;cursor:pointer;font-size:16px;font-family:inherit; }
    .pkw-rm:hover { background:rgba(239,68,68,0.18); }
    .pkw-add:hover { background:rgba(255,255,255,0.07); color:#fff; }
    .pkw-font-opt:hover, .pkw-font-opt.is-active { background:rgba(249,115,22,0.12); color:#fff; }
    .pkw-secondary:hover { background:rgba(255,255,255,0.05); color:#fff; }
    .pkw-primary:hover:not(:disabled) { background:#fb923c; }
    .pkw-primary:disabled { opacity:.6;cursor:wait; }
    .pkw-recap-edit:hover { color:#fb923c; }
  </style>

  {/* ─── Client logic ─────────────────────────────────── */}
  <script is:inline define:vars={{ kitId: k.id }}>
    const STATE = JSON.parse(document.getElementById('kit-bootstrap').textContent);
    const FONTS = JSON.parse(document.getElementById('font-bootstrap').textContent);

    // ── Step manifest ──────────────────────────────────────
    // kit_type was chosen on /kits/new — we never re-ask it.
    // logo-gen step is dynamically included only if needsLogoGen flag is set.
    let needsLogoGen = false;

    function buildSteps() {
      const logoGenSteps = needsLogoGen ? [
        { key: 'logo-type',  chapter: 'Brand', title: 'What kind of logo do you want?' },
        { key: 'logo-vibe',  chapter: 'Brand', title: 'What should it feel like?' },
        { key: 'logo-desc',  chapter: 'Brand', title: 'What should appear in it?' },
        { key: 'logo-refs',  chapter: 'Brand', title: 'Any visual references?' },
        { key: 'logo-color', chapter: 'Brand', title: 'A specific color in mind?' },
        { key: 'logo-go',    chapter: 'Brand', title: 'Ready — let’s generate it.' },
      ] : [];
      const base = [
        { key: 'logo-gate',     chapter: 'Brand',    title: 'Do you already have a logo?' },
        { key: 'identity',      chapter: 'Identity', title: 'What’s the name + tagline?' },
        ...logoGenSteps,
        { key: 'bio-short',     chapter: 'Story',    title: 'The one-line story.' },
        { key: 'bio-long',      chapter: 'Story',    title: 'The longer version.' },
        { key: 'numbers',       chapter: 'Numbers',  title: 'What numbers matter?' },
        { key: 'press',         chapter: 'Press',    title: 'Where have you been featured?' },
        { key: 'awards',        chapter: 'Awards',   title: 'Any awards or recognition?' },
        { key: 'links',         chapter: 'Links',    title: 'Contact + social links.' },
        { key: 'brand',         chapter: 'Brand',    title: 'Palette & fonts.' },
        { key: 'review',        chapter: 'Review',   title: 'Review & publish' },
      ];
      return base;
    }
    let STEPS = buildSteps();
    let stepIdx = 0;

    // ── Save plumbing ──────────────────────────────────────
    let saveTimer = null;
    let pendingUpdate = {};
    const saveState = document.getElementById('save-state');
    function markDirty() { saveState.textContent = 'Saving…'; saveState.style.opacity = '1'; }
    function markSaved() { saveState.textContent = 'Saved'; setTimeout(() => { if (saveState.textContent === 'Saved') saveState.style.opacity = '0'; }, 1400); }

    async function flushSave() {
      if (Object.keys(pendingUpdate).length === 0) return;
      const body = pendingUpdate; pendingUpdate = {};
      try {
        const r = await fetch(`/api/kits/${kitId}`, { method: 'PATCH', headers: { 'content-type': 'application/json' }, body: JSON.stringify(body) });
        if (r.ok) markSaved(); else { saveState.textContent = 'Save failed'; saveState.style.opacity = '1'; }
      } catch { saveState.textContent = 'Save failed'; saveState.style.opacity = '1'; }
    }
    function queueSave(patch) {
      Object.assign(pendingUpdate, patch);
      Object.assign(STATE, patch);
      markDirty();
      clearTimeout(saveTimer);
      saveTimer = setTimeout(flushSave, 500);
    }

    // ── Progress bar ───────────────────────────────────────
    function renderProgress() {
      const wrap = document.getElementById('wizard-progress');
      const total = STEPS.length;
      const pct = Math.round(((stepIdx + 1) / total) * 100);
      const step = STEPS[stepIdx];
      wrap.innerHTML = `
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
          <span style="display:inline-flex;align-items:center;gap:8px;font-size:11px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:rgba(255,255,255,0.55);font-variant-numeric:tabular-nums;">
            <span style="color:#f97316;">${String(stepIdx + 1).padStart(2,'0')}</span>
            <span style="opacity:.5;">/ ${String(total).padStart(2,'0')}</span>
            <span style="width:3px;height:3px;border-radius:50%;background:rgba(255,255,255,0.3);margin:0 2px;"></span>
            <span>${step.chapter}</span>
          </span>
          <span style="font-size:11px;font-weight:600;color:rgba(255,255,255,0.4);letter-spacing:0.06em;font-variant-numeric:tabular-nums;">${pct}%</span>
        </div>
        <div style="height:3px;width:100%;background:rgba(255,255,255,0.08);border-radius:999px;overflow:hidden;">
          <div style="height:100%;width:${pct}%;background:linear-gradient(90deg,#f97316,#fb923c);border-radius:999px;transition:width .35s cubic-bezier(.4,0,.2,1);"></div>
        </div>
      `;
    }

    // ── Navigation ─────────────────────────────────────────
    function goTo(i, { skipSave = false } = {}) {
      if (i < 0 || i >= STEPS.length) return;
      if (!skipSave) flushSave();
      stepIdx = i;
      window.location.hash = `step=${STEPS[i].key}`;
      renderProgress();
      const review = STEPS[i].key === 'review';
      const wiz = document.getElementById('wiz-stage');
      const rev = document.getElementById('review-stage');
      wiz.hidden = review;
      wiz.style.display = review ? 'none' : '';
      rev.hidden = !review;
      rev.style.display = review ? 'grid' : 'none';
      if (review) { renderReview(); reloadPreview(); }
      else { renderStep(); }
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    function next() { goTo(stepIdx + 1); }
    function back() { goTo(stepIdx - 1); }

    function reloadPreview() {
      const iframe = document.getElementById('kit-preview');
      if (iframe) iframe.contentWindow.location.reload();
    }

    function rebuildSteps(preserveKey) {
      STEPS = buildSteps();
      if (preserveKey) {
        const idx = STEPS.findIndex(s => s.key === preserveKey);
        if (idx >= 0) stepIdx = idx;
      }
    }

    // ── Shared style fragments (inline strings) ────────────
    const STYLE_CARD = 'background:linear-gradient(180deg,rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%),rgba(18,18,22,0.92);backdrop-filter:blur(24px) saturate(1.3);-webkit-backdrop-filter:blur(24px) saturate(1.3);border:1px solid rgba(255,255,255,0.09);border-radius:20px;padding:36px 40px 28px;max-width:680px;margin:0 auto;box-shadow:0 1px 0 rgba(255,255,255,0.05) inset, 0 18px 40px -22px rgba(0,0,0,0.55);';
    const STYLE_EYEBROW = 'display:inline-flex;align-items:center;gap:8px;font-size:11px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#f97316;padding:5px 12px;border-radius:999px;background:rgba(249,115,22,0.1);border:1px solid rgba(249,115,22,0.28);';
    const STYLE_EYEBROW_DOT = 'width:6px;height:6px;border-radius:50%;background:#f97316;box-shadow:0 0 8px rgba(249,115,22,0.6);';
    const STYLE_TITLE = "font-family:'Inter',sans-serif;font-size:clamp(26px,3.4vw,34px);font-weight:300;letter-spacing:-0.028em;line-height:1.1;color:#fff;margin:18px 0 10px;";
    const STYLE_HELPER = 'font-size:13.5px;color:rgba(255,255,255,0.55);margin:0 0 26px;line-height:1.55;max-width:580px;';
    const STYLE_LABEL = "font-size:11px;font-weight:700;color:rgba(255,255,255,0.65);text-transform:uppercase;letter-spacing:0.1em;display:block;margin-bottom:8px;";
    const STYLE_INPUT = 'width:100%;height:48px;padding:0 16px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.14);border-radius:12px;color:#fff;font-family:inherit;font-size:15px;outline:none;transition:border-color .15s, box-shadow .15s;';
    const STYLE_TEXTAREA = 'width:100%;padding:14px 16px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.14);border-radius:12px;color:#fff;font-family:inherit;font-size:15px;line-height:1.6;outline:none;resize:vertical;min-height:130px;transition:border-color .15s, box-shadow .15s;';
    const STYLE_BTN_PRIMARY = 'height:48px;padding:0 26px;background:#f97316;color:#0a0a0a;border:none;border-radius:999px;font-family:inherit;font-size:13.5px;font-weight:700;letter-spacing:0.04em;cursor:pointer;transition:background .15s;';
    const STYLE_BTN_GHOST = 'height:44px;padding:0 18px;background:transparent;color:rgba(255,255,255,0.6);border:1px solid rgba(255,255,255,0.14);border-radius:999px;font-family:inherit;font-size:12.5px;font-weight:600;cursor:pointer;letter-spacing:0.02em;transition:all .15s;';
    const STYLE_BTN_LINK  = 'height:44px;padding:0 14px;background:transparent;color:rgba(255,255,255,0.5);border:0;font-family:inherit;font-size:12.5px;font-weight:600;cursor:pointer;letter-spacing:0.02em;';
    const STYLE_ADD = 'width:100%;padding:13px;background:rgba(255,255,255,0.03);border:1px dashed rgba(255,255,255,0.2);border-radius:12px;color:rgba(255,255,255,0.7);font-family:inherit;font-size:13px;font-weight:600;cursor:pointer;transition:all .15s;';
    const STYLE_CHIP = 'padding:9px 14px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:999px;color:rgba(255,255,255,0.78);font-family:inherit;font-size:12.5px;font-weight:600;cursor:pointer;transition:all .15s;';

    function eyebrowHTML() {
      const step = STEPS[stepIdx];
      return `<span style="${STYLE_EYEBROW}"><span style="${STYLE_EYEBROW_DOT}"></span>Step ${stepIdx + 1} of ${STEPS.length} · ${step.chapter}</span>`;
    }

    function footerHTML({ skipText = 'Skip', nextText = 'Continue →', hideNext = false, hideSkip = false } = {}) {
      return `
        <div style="display:flex;justify-content:space-between;align-items:center;margin-top:32px;padding-top:22px;border-top:1px solid rgba(255,255,255,0.06);gap:10px;flex-wrap:wrap;">
          <button type="button" data-act="back" class="pkw-secondary" style="${STYLE_BTN_LINK}" ${stepIdx === 0 ? 'disabled style="visibility:hidden"' : ''}>← Back</button>
          <div style="display:flex;gap:8px;align-items:center;margin-left:auto;">
            ${hideSkip ? '' : `<button type="button" data-act="skip" class="pkw-secondary" style="${STYLE_BTN_GHOST}">${skipText}</button>`}
            ${hideNext ? '' : `<button type="button" data-act="next" class="pkw-primary" style="${STYLE_BTN_PRIMARY}">${nextText}</button>`}
          </div>
        </div>
      `;
    }

    function wireFooter(card, { onNext } = {}) {
      card.querySelector('[data-act=back]')?.addEventListener('click', back);
      card.querySelector('[data-act=skip]')?.addEventListener('click', next);
      card.querySelector('[data-act=next]')?.addEventListener('click', async () => {
        if (onNext) { const ok = await onNext(); if (ok === false) return; }
        await flushSave(); next();
      });
    }

    // ── Render current step ────────────────────────────────
    function renderStep() {
      const step = STEPS[stepIdx];
      const stage = document.getElementById('wiz-stage');
      stage.innerHTML = '';
      const card = document.createElement('section');
      card.className = 'pkw-fadein';
      card.setAttribute('style', STYLE_CARD);
      stage.appendChild(card);

      if (step.key === 'logo-gate')      renderLogoGate(card);
      else if (step.key === 'identity')  renderIdentity(card);
      else if (step.key === 'logo-type') renderLogoType(card);
      else if (step.key === 'logo-vibe') renderLogoVibe(card);
      else if (step.key === 'logo-desc') renderLogoDesc(card);
      else if (step.key === 'logo-refs') renderLogoRefs(card);
      else if (step.key === 'logo-color') renderLogoColor(card);
      else if (step.key === 'logo-go')   renderLogoGo(card);
      else if (step.key === 'bio-short') renderBioShort(card);
      else if (step.key === 'bio-long')  renderBioLong(card);
      else if (step.key === 'numbers')   renderNumbers(card);
      else if (step.key === 'press')     renderPress(card);
      else if (step.key === 'awards')    renderAwards(card);
      else if (step.key === 'links')     renderLinks(card);
      else if (step.key === 'brand')     renderBrand(card);
    }

    // ── Step: logo gate ────────────────────────────────────
    function renderLogoGate(card) {
      const hasLogo = !!STATE.assets?.logo;
      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">Do you already have a logo?</h2>
        <p style="${STYLE_HELPER}">Either upload yours or we’ll generate one with AI based on your name + style. You can change it later.</p>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:10px;" id="lg-tiles">
          <button type="button" class="pkw-tile ${hasLogo ? 'is-active' : ''}" data-choice="yes" style="text-align:left;padding:24px 24px 22px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.12);border-radius:16px;color:#fff;font-family:inherit;cursor:pointer;transition:all .15s;">
            <div style="font-size:10.5px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:rgba(255,255,255,0.45);margin-bottom:14px;">A · Upload</div>
            <div style="font-size:16px;font-weight:600;letter-spacing:-0.015em;">Yes, I have one</div>
            <div style="font-size:12.5px;color:rgba(255,255,255,0.55);margin-top:6px;line-height:1.5;">Upload PNG / SVG / JPG. We’ll extract your palette automatically.</div>
          </button>
          <button type="button" class="pkw-tile" data-choice="no" style="text-align:left;padding:24px 24px 22px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.12);border-radius:16px;color:#fff;font-family:inherit;cursor:pointer;transition:all .15s;">
            <div style="font-size:10.5px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#a78bfa;margin-bottom:14px;">B · Generate with AI</div>
            <div style="font-size:16px;font-weight:600;letter-spacing:-0.015em;">No, generate one</div>
            <div style="font-size:12.5px;color:rgba(255,255,255,0.55);margin-top:6px;line-height:1.5;">We’ll create a clean vector mark from your name + tagline.</div>
          </button>
        </div>

        <div id="lg-upload-wrap" style="margin-top:18px;${hasLogo ? '' : 'display:none;'}"></div>

        ${footerHTML({ hideSkip: true, nextText: hasLogo ? 'Continue →' : 'Pick one to continue' })}
      `;

      function showUpload() {
        const wrap = card.querySelector('#lg-upload-wrap');
        wrap.style.display = 'block';
        renderUploadBox(wrap);
      }
      function hideUpload() {
        const wrap = card.querySelector('#lg-upload-wrap');
        wrap.style.display = 'none';
      }

      card.querySelectorAll('#lg-tiles .pkw-tile').forEach(b => {
        b.addEventListener('click', () => {
          card.querySelectorAll('#lg-tiles .pkw-tile').forEach(x => x.classList.remove('is-active'));
          b.classList.add('is-active');
          const next = card.querySelector('[data-act=next]');
          next.textContent = 'Continue →';
          if (b.dataset.choice === 'yes') {
            needsLogoGen = false;
            showUpload();
          } else {
            needsLogoGen = true;
            hideUpload();
          }
        });
      });

      if (hasLogo) showUpload();

      wireFooter(card, { onNext: async () => {
        const choice = card.querySelector('#lg-tiles .pkw-tile.is-active')?.dataset.choice;
        if (!choice) return false;
        rebuildSteps('logo-gate');
        return true;
      }});
    }

    function renderUploadBox(box) {
      const logo = STATE.assets?.logo;
      const svg = STATE.assets?.logo_svg;
      if (logo) {
        const filename = (logo.split('/').pop() || 'logo').slice(0, 32);
        box.innerHTML = `
          <div style="display:flex;align-items:center;gap:14px;padding:14px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:14px;">
            <img src="${logo}" alt="" style="width:64px;height:64px;object-fit:contain;background:#fafafa;border-radius:10px;padding:6px;" />
            <div style="flex:1;display:flex;flex-direction:column;gap:2px;">
              <strong style="font-size:13.5px;color:#fff;font-weight:600;">${escapeHtml(filename)}</strong>
              <span style="font-size:11.5px;color:rgba(255,255,255,0.45);">${svg ? 'SVG vector ready' : 'PNG · vectorizing…'}</span>
            </div>
            <button type="button" id="lg-replace" style="height:36px;padding:0 14px;border-radius:999px;background:rgba(255,255,255,0.06);color:#fff;border:1px solid rgba(255,255,255,0.12);font-family:inherit;font-size:12px;font-weight:600;cursor:pointer;">Replace</button>
          </div>
        `;
        box.querySelector('#lg-replace').addEventListener('click', () => openUploadDialog(box));
        if (!svg && !logo.toLowerCase().endsWith('.svg')) {
          fetch(`/api/kits/${kitId}/vectorize-logo`, { method: 'POST' })
            .then(r => r.json()).then(d => {
              if (d.svgUrl) { STATE.assets.logo_svg = d.svgUrl; renderUploadBox(box); }
            }).catch(() => {});
        }
      } else {
        box.innerHTML = `
          <div id="lg-drop" style="position:relative;padding:36px 24px;text-align:center;background:rgba(255,255,255,0.025);border:1px dashed rgba(255,255,255,0.2);border-radius:14px;cursor:pointer;transition:all .15s;">
            <input type="file" accept="image/*" id="lg-input" style="position:absolute;inset:0;opacity:0;cursor:pointer;" />
            <div style="font-size:24px;margin-bottom:6px;">↑</div>
            <div style="font-size:14px;font-weight:600;color:#fff;margin-bottom:4px;">Drag a logo or click to upload</div>
            <div style="font-size:12px;color:rgba(255,255,255,0.5);">PNG, SVG, or JPG. We’ll extract your palette automatically.</div>
          </div>
        `;
        box.querySelector('#lg-input').addEventListener('change', e => handleLogoUpload(e.target.files[0], box));
      }
    }
    function openUploadDialog(box) {
      const f = document.createElement('input');
      f.type = 'file'; f.accept = 'image/*';
      f.onchange = () => handleLogoUpload(f.files[0], box);
      f.click();
    }
    async function handleLogoUpload(file, box) {
      if (!file) return;
      markDirty();
      try {
        const { upload } = await import('https://esm.sh/@vercel/blob@2.3.3/client');
        const blob = await upload(file.name, file, { access: 'public', handleUploadUrl: `/api/kits/${kitId}/sign-upload` });
        STATE.assets = { ...(STATE.assets || {}), logo: blob.url, logo_svg: undefined };
        await fetch(`/api/kits/${kitId}`, { method: 'PATCH', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ assets: STATE.assets }) });
        renderUploadBox(box);
        markSaved();
      } catch (e) {
        console.error(e); saveState.textContent = 'Upload failed';
      }
    }

    // ── Step: identity (name + tagline) ────────────────────
    function renderIdentity(card) {
      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">What’s the name + tagline?</h2>
        <p style="${STYLE_HELPER}">The name sits at the top of every page. The tagline is the first thing journalists read — keep it short, sharp, quotable.</p>

        <div style="display:flex;flex-direction:column;gap:18px;">
          <div>
            <label style="${STYLE_LABEL}">Name on the kit</label>
            <input id="f-name" type="text" maxlength="80" class="pkw-input" value="${escapeAttr(STATE.name)}" placeholder="e.g. Mattman Music" style="${STYLE_INPUT}" />
          </div>
          <div>
            <label style="${STYLE_LABEL}">Tagline (one line)</label>
            <input id="f-tagline" type="text" maxlength="120" class="pkw-input" value="${escapeAttr(STATE.tagline ?? '')}" placeholder="e.g. House music from Cluj" style="${STYLE_INPUT}" />
          </div>
        </div>

        ${footerHTML()}
      `;
      card.querySelector('#f-name').addEventListener('input', e => queueSave({ name: e.target.value }));
      card.querySelector('#f-tagline').addEventListener('input', e => queueSave({ tagline: e.target.value }));
      wireFooter(card);
    }

    // ── Logo-gen sub-step state ────────────────────────────
    // One conversational question per screen. All answers live on a session
    // object so the user can flow back/forward without losing them.
    window.__LG__ = window.__LG__ || { type: 'icon', mood: '', desc: '', style: '', primaryColor: null, returnTo: null };
    const LG = window.__LG__;

    function selectableTile({ value, title, sub, selected }) {
      const border = selected ? '2px solid #f97316' : '1px solid rgba(255,255,255,0.12)';
      const bg = selected ? 'rgba(249,115,22,0.12)' : 'rgba(255,255,255,0.03)';
      const ring = selected ? 'box-shadow:0 0 0 4px rgba(249,115,22,0.16);' : '';
      const dot = selected
        ? `<span style="position:absolute;top:14px;right:14px;width:18px;height:18px;border-radius:50%;background:#f97316;display:inline-flex;align-items:center;justify-content:center;color:#0a0a0a;font-size:11px;font-weight:900;">&#10003;</span>`
        : '';
      return `
        <button type="button" data-tile="${value}" style="position:relative;text-align:left;padding:22px 22px 20px;background:${bg};border:${border};border-radius:16px;color:#fff;font-family:inherit;cursor:pointer;transition:all .15s;${ring}">
          ${dot}
          <div style="font-size:16px;font-weight:600;letter-spacing:-0.01em;margin-bottom:4px;color:#fff;">${title}</div>
          <div style="font-size:12.5px;color:rgba(255,255,255,0.6);line-height:1.5;">${sub}</div>
        </button>
      `;
    }

    function selectablePill({ value, label, selected }) {
      const border = selected ? '2px solid #f97316' : '1px solid rgba(255,255,255,0.14)';
      const bg = selected ? 'rgba(249,115,22,0.16)' : 'rgba(255,255,255,0.04)';
      const color = selected ? '#fff' : 'rgba(255,255,255,0.78)';
      const weight = selected ? '700' : '500';
      const ring = selected ? 'box-shadow:0 0 0 3px rgba(249,115,22,0.18);' : '';
      return `
        <button type="button" data-pill="${value}" style="padding:11px 18px;background:${bg};border:${border};border-radius:999px;color:${color};font-family:inherit;font-size:13px;font-weight:${weight};cursor:pointer;transition:all .15s;${ring}">
          ${label}
        </button>
      `;
    }

    // ── Step: logo type ────────────────────────────────────
    function renderLogoType(card) {
      const opts = [
        { value: 'icon',        title: 'Just an icon', sub: 'A symbol or mark on its own. Cleanest at small sizes — favicons, app icons.' },
        { value: 'wordmark',    title: 'A wordmark',   sub: `Your brand name ("${STATE.name || 'your brand'}") as the whole logo, in a strong custom letterform.` },
        { value: 'combination', title: 'Icon + text',  sub: `An icon next to "${STATE.name || 'your brand'}", working together as one mark.` },
      ];
      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">What kind of logo do you want?</h2>
        <p style="${STYLE_HELPER}">Pick the shape. We'll figure out the details together over the next few questions.</p>
        <div id="lg-type-grid" style="display:grid;grid-template-columns:1fr;gap:10px;margin-bottom:8px;">
          ${opts.map(o => selectableTile({ ...o, selected: LG.type === o.value })).join('')}
        </div>
        ${footerHTML({ hideSkip: true, nextText: 'Continue →' })}
      `;
      card.querySelector('#lg-type-grid').addEventListener('click', (e) => {
        const b = e.target.closest('[data-tile]'); if (!b) return;
        LG.type = b.dataset.tile;
        renderLogoType(card);
      });
      wireFooter(card);
    }

    // ── Step: logo vibe ────────────────────────────────────
    function renderLogoVibe(card) {
      const moods = [
        ['minimal','Minimal · clean'], ['bold','Bold · loud'], ['editorial','Editorial · refined'],
        ['geometric','Geometric'], ['organic','Organic · flowing'], ['playful','Playful'],
        ['hand-drawn','Hand-drawn'], ['brutalist','Brutalist'], ['modernist','Modernist · swiss'],
        ['retro','Retro · vintage'], ['futuristic','Futuristic'], ['luxury','Luxury'],
      ];
      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">What should it feel like?</h2>
        <p style="${STYLE_HELPER}">Pick one vibe. This becomes the mood the AI aims for.</p>
        <div id="lg-vibe-grid" style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:6px;">
          ${moods.map(([v,l]) => selectablePill({ value: v, label: l, selected: LG.mood === v })).join('')}
        </div>
        ${footerHTML({ skipText: 'Skip vibe', nextText: 'Continue →' })}
      `;
      card.querySelector('#lg-vibe-grid').addEventListener('click', (e) => {
        const b = e.target.closest('[data-pill]'); if (!b) return;
        LG.mood = LG.mood === b.dataset.pill ? '' : b.dataset.pill;
        renderLogoVibe(card);
      });
      wireFooter(card);
    }

    // ── Step: logo desc ────────────────────────────────────
    function renderLogoDesc(card) {
      const subTitle = LG.type === 'wordmark'
        ? `Anything you want us to know about the wordmark? (e.g. "all-caps, geometric sans, single weight")`
        : LG.type === 'combination'
          ? `Describe the icon that should sit next to "${STATE.name}". Name the motif, shape, or concept.`
          : `Describe the icon. Name the motif, shape, or concept — be specific so the AI uses it.`;
      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">What should appear in it?</h2>
        <p style="${STYLE_HELPER}">${subTitle}</p>
        <textarea id="lg-desc" maxlength="500" class="pkw-textarea" placeholder="${LG.type === 'wordmark' ? 'e.g. all-caps geometric sans, tight tracking, single weight, sharp terminals' : 'e.g. an abstract snowflake fused with the letter A — single line, sharp, geometric'}" style="${STYLE_TEXTAREA};min-height:130px;">${escapeAttr(LG.desc || '')}</textarea>
        <p style="font-size:11.5px;color:rgba(255,255,255,0.4);margin:6px 0 14px;line-height:1.5;">The AI takes this <b style="color:rgba(255,255,255,0.7);font-weight:600;">literally</b>. Whatever you name here will land in the logo.</p>
        <label style="${STYLE_LABEL};margin-top:6px;">Extra style keywords (optional)</label>
        <input id="lg-style" type="text" maxlength="120" class="pkw-input" value="${escapeAttr(LG.style || '')}" placeholder="e.g. monogram, single line, swiss, art deco" style="${STYLE_INPUT}" />
        ${footerHTML({ skipText: 'Skip details', nextText: 'Continue →' })}
      `;
      const ta = card.querySelector('#lg-desc');
      ta.addEventListener('input', () => { LG.desc = ta.value; });
      card.querySelector('#lg-style').addEventListener('input', (e) => { LG.style = e.target.value; });
      wireFooter(card);
    }

    // ── Step: logo refs ────────────────────────────────────
    function renderLogoRefs(card) {
      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">Any visual references?</h2>
        <p style="${STYLE_HELPER}">Up to 3 photos of logos / styles you'd like ours to <em>feel like</em> (not copy). Optional.</p>
        <div id="lg-refs" style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:10px;"></div>
        <button type="button" id="lg-add-ref" class="pkw-add" style="${STYLE_ADD}">+ Add reference photo</button>
        <input type="file" accept="image/*" id="lg-ref-input" style="display:none;" />
        ${footerHTML({ skipText: 'Skip references', nextText: 'Continue →' })}
      `;
      function renderRefs() {
        const wrap = card.querySelector('#lg-refs');
        const list = STATE.assets?.logo_refs || [];
        if (list.length === 0) { wrap.innerHTML = ''; return; }
        wrap.innerHTML = list.map((u, i) => `
          <div style="position:relative;aspect-ratio:1;border-radius:12px;overflow:hidden;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);">
            <img src="${u}" alt="" style="width:100%;height:100%;object-fit:cover;" />
            <button type="button" data-rm-ref="${i}" style="position:absolute;top:6px;right:6px;width:24px;height:24px;border-radius:50%;border:0;background:rgba(0,0,0,0.75);color:#fff;cursor:pointer;font-size:13px;font-family:inherit;">×</button>
          </div>
        `).join('');
        wrap.querySelectorAll('[data-rm-ref]').forEach(b => b.addEventListener('click', () => {
          const idx = +b.dataset.rmRef;
          STATE.assets.logo_refs = (STATE.assets.logo_refs || []).filter((_, j) => j !== idx);
          queueSave({ assets: { ...STATE.assets } });
          renderRefs();
        }));
      }
      renderRefs();
      card.querySelector('#lg-add-ref').addEventListener('click', () => {
        if ((STATE.assets?.logo_refs || []).length >= 3) return;
        card.querySelector('#lg-ref-input').click();
      });
      card.querySelector('#lg-ref-input').addEventListener('change', async (e) => {
        const file = e.target.files?.[0]; if (!file) return;
        markDirty();
        try {
          const { upload } = await import('https://esm.sh/@vercel/blob@2.3.3/client');
          const blob = await upload(file.name, file, { access: 'public', handleUploadUrl: `/api/kits/${kitId}/sign-upload` });
          STATE.assets = { ...(STATE.assets || {}), logo_refs: [...(STATE.assets?.logo_refs || []), blob.url] };
          queueSave({ assets: STATE.assets });
          renderRefs();
        } catch (err) { console.error(err); saveState.textContent = 'Upload failed'; }
      });
      wireFooter(card);
    }

    // ── Step: logo color ───────────────────────────────────
    function renderLogoColor(card) {
      const presets = ['#0f5132','#6b1d1d','#1d2bd1','#e25822','#1e3a8a','#b65238','#5a6b2f','#0b1f3a','#c97064','#7a8b6f','#0a0a0a','#fafafa'];
      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">A specific color in mind?</h2>
        <p style="${STYLE_HELPER}">Skip and we'll use your kit palette if you have one, or pick a bold accent automatically.</p>
        <div id="lg-color-grid" style="display:grid;grid-template-columns:repeat(6,1fr);gap:8px;margin-bottom:14px;">
          ${presets.map(h => `
            <button type="button" data-color="${h}" title="${h}" style="aspect-ratio:1;border-radius:12px;background:${h};border:${LG.primaryColor === h ? '3px solid #fff' : '1px solid rgba(255,255,255,0.12)'};cursor:pointer;position:relative;${LG.primaryColor === h ? 'box-shadow:0 0 0 3px rgba(249,115,22,0.4);' : ''}"></button>
          `).join('')}
        </div>
        <div style="display:flex;align-items:center;gap:12px;padding:14px 16px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:12px;">
          <input id="lg-custom-color" type="color" value="${LG.primaryColor || '#f97316'}" style="width:48px;height:36px;padding:0;border-radius:8px;border:1px solid rgba(255,255,255,0.14);background:none;cursor:pointer;" />
          <span style="font-size:13px;color:rgba(255,255,255,0.78);font-weight:500;">Or pick any custom color</span>
          ${LG.primaryColor ? `<button type="button" id="lg-clear-color" style="margin-left:auto;height:32px;padding:0 14px;background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.75);border:1px solid rgba(255,255,255,0.14);border-radius:999px;font-family:inherit;font-size:11.5px;font-weight:600;cursor:pointer;">Clear</button>` : ''}
        </div>
        ${footerHTML({ skipText: 'Skip color', nextText: 'Continue →' })}
      `;
      card.querySelector('#lg-color-grid').addEventListener('click', (e) => {
        const b = e.target.closest('[data-color]'); if (!b) return;
        LG.primaryColor = LG.primaryColor === b.dataset.color ? null : b.dataset.color;
        renderLogoColor(card);
      });
      card.querySelector('#lg-custom-color').addEventListener('input', (e) => {
        LG.primaryColor = e.target.value;
        renderLogoColor(card);
      });
      card.querySelector('#lg-clear-color')?.addEventListener('click', () => {
        LG.primaryColor = null;
        renderLogoColor(card);
      });
      wireFooter(card);
    }

    // ── Step: logo go (generate + review) ──────────────────
    function renderLogoGo(card) {
      const logo = STATE.assets?.logo;
      const refsCount = (STATE.assets?.logo_refs || []).length;
      const typeLabel = ({ icon: 'Icon only', wordmark: 'Wordmark', combination: 'Icon + text' })[LG.type] || LG.type;
      const summaryRow = (k, v) => `<div style="display:flex;justify-content:space-between;gap:12px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.05);font-size:12.5px;"><span style="color:rgba(255,255,255,0.45);text-transform:uppercase;letter-spacing:0.08em;font-weight:600;">${k}</span><span style="color:#fff;text-align:right;max-width:60%;">${v}</span></div>`;
      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">${logo ? 'Here it is.' : 'Ready — let&rsquo;s generate it.'}</h2>
        <p style="${STYLE_HELPER}">${logo ? 'Happy with it? Continue. Want a different direction? Go back and adjust, then regenerate here.' : 'Quick recap of your answers, then we&rsquo;ll create your logo.'}</p>

        <div id="lg-result" style="${logo ? '' : 'display:none;'}margin-bottom:18px;"></div>

        <div style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:14px;padding:14px 18px;margin-bottom:18px;">
          ${summaryRow('Type', typeLabel)}
          ${summaryRow('Vibe', LG.mood || '—')}
          ${summaryRow('Description', LG.desc ? (LG.desc.length > 64 ? LG.desc.slice(0, 64) + '…' : LG.desc) : '—')}
          ${summaryRow('Style keywords', LG.style || '—')}
          ${summaryRow('References', refsCount > 0 ? refsCount + ' photo' + (refsCount === 1 ? '' : 's') : '—')}
          ${summaryRow('Color', LG.primaryColor ? `<span style="display:inline-flex;align-items:center;gap:6px;"><span style="width:12px;height:12px;border-radius:3px;background:${LG.primaryColor};border:1px solid rgba(255,255,255,0.2);"></span>${LG.primaryColor}</span>` : 'Auto')}
        </div>

        <button type="button" id="lg-go" style="${STYLE_BTN_PRIMARY};height:54px;width:100%;font-size:14.5px;background:linear-gradient(135deg,#f97316 0%, #a78bfa 140%);">
          ${logo ? 'Generate another version' : 'Generate my logo'}
        </button>

        <div id="lg-progress" style="display:none;font-size:12.5px;color:rgba(255,255,255,0.65);margin-top:12px;">
          <div data-pstep="1" style="padding:6px 0;color:#f97316;">1. Generating with AI…</div>
          <div data-pstep="2" style="padding:6px 0;color:rgba(255,255,255,0.35);">2. Removing background…</div>
          <div data-pstep="3" style="padding:6px 0;color:rgba(255,255,255,0.35);">3. Vectorizing to SVG…</div>
        </div>
        <p id="lg-error" style="display:none;font-size:12.5px;color:#ff8a8a;margin-top:8px;"></p>

        ${footerHTML({ hideSkip: true, nextText: logo ? 'Looks good — continue →' : 'Continue →' })}
      `;

      function renderResult() {
        const wrap = card.querySelector('#lg-result');
        const url = STATE.assets?.logo;
        if (!url) { wrap.style.display = 'none'; return; }
        wrap.style.display = 'block';
        wrap.innerHTML = `
          <div style="background:#fafafa;border-radius:18px;padding:34px;display:flex;align-items:center;justify-content:center;min-height:220px;border:1px solid rgba(255,255,255,0.08);">
            <img src="${url}" alt="" style="max-width:260px;max-height:180px;object-fit:contain;" />
          </div>
          <div style="display:flex;gap:8px;margin-top:12px;align-items:center;flex-wrap:wrap;font-size:11.5px;color:rgba(255,255,255,0.55);font-weight:600;letter-spacing:0.04em;">
            ${STATE.assets?.logo_svg ? '<span style="color:#6ee7a3;">SVG ready</span>' : '<span>Vectorizing…</span>'}
          </div>
        `;
      }
      renderResult();

      function setPStep(n, status) {
        card.querySelectorAll('#lg-progress [data-pstep]').forEach(el => {
          const s = +el.dataset.pstep;
          if (s < n) { el.style.color = '#6ee7a3'; }
          else if (s === n) { el.style.color = status === 'done' ? '#6ee7a3' : '#f97316'; }
          else { el.style.color = 'rgba(255,255,255,0.35)'; }
        });
      }

      card.querySelector('#lg-go').addEventListener('click', async () => {
        const goBtn = card.querySelector('#lg-go');
        const err = card.querySelector('#lg-error');
        const prog = card.querySelector('#lg-progress');
        const referenceImages = (STATE.assets?.logo_refs || []).slice(0, 3);
        const baseDesc = (LG.desc && LG.desc.length >= 4) ? LG.desc : `Logo for ${STATE.name}${STATE.tagline ? ' — ' + STATE.tagline : ''}`;

        err.style.display = 'none';
        prog.style.display = 'block';
        const oldLabel = goBtn.textContent;
        goBtn.disabled = true; goBtn.textContent = 'Generating…';

        setPStep(1, 'active');
        const t2 = setTimeout(() => setPStep(2, 'active'), 8000);
        const t3 = setTimeout(() => setPStep(3, 'active'), 18000);

        try {
          const r = await fetch(`/api/kits/${kitId}/generate-logo`, {
            method: 'POST', headers: { 'content-type': 'application/json' },
            body: JSON.stringify({
              description: baseDesc,
              style: LG.style || undefined,
              primaryColor: LG.primaryColor || undefined,
              referenceImages,
              logoType: LG.type,
              mood: LG.mood || undefined,
            }),
          });
          const data = await r.json();
          clearTimeout(t2); clearTimeout(t3);
          if (!r.ok) {
            err.textContent = data.error || 'Generation failed.';
            err.style.display = 'block'; prog.style.display = 'none';
            goBtn.disabled = false; goBtn.textContent = oldLabel;
            return;
          }
          setPStep(3, 'done');
          STATE.assets = { ...(STATE.assets || {}), logo: data.pngUrl || data.logo, logo_svg: data.svgUrl || data.logo_svg };
          renderLogoGo(card); // re-render with the result
          setTimeout(() => { prog.style.display = 'none'; }, 800);
        } catch (e) {
          clearTimeout(t2); clearTimeout(t3);
          err.textContent = 'Network error.';
          err.style.display = 'block'; prog.style.display = 'none';
          goBtn.disabled = false; goBtn.textContent = oldLabel;
        }
      });

      wireFooter(card, { onNext: async () => {
        if (!STATE.assets?.logo) { alert('Generate your logo first (or go back to skip).'); return false; }
        // If user came from the Brand step via "Generate with AI", route back there.
        if (LG.returnTo) {
          const target = LG.returnTo; LG.returnTo = null;
          needsLogoGen = false;
          rebuildSteps(target);
          renderProgress();
          renderStep();
          window.scrollTo({ top: 0, behavior: 'smooth' });
          return false; // we handled navigation
        }
        return true;
      } });
    }

    // ── (deprecated, retained for safety if cached) ────────
    function renderLogoGen(card) {
      const logo = STATE.assets?.logo;
      const svg = STATE.assets?.logo_svg;
      const refs = STATE.assets?.logo_refs || [];

      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">Let’s generate your logo.</h2>
        <p style="${STYLE_HELPER}">We’ll use your name + tagline. Add a description and (optionally) up to 3 reference photos for style guidance.</p>

        <div id="lg-result" style="${logo ? '' : 'display:none;'}margin-bottom:18px;"></div>

        <div id="lg-controls" style="display:flex;flex-direction:column;gap:16px;">
          <div>
            <label style="${STYLE_LABEL}">Logo type</label>
            <div id="lg-type" style="display:flex;flex-wrap:wrap;gap:6px;margin-top:6px;">
              <button type="button" class="pkw-chip is-active" data-type="icon" style="${STYLE_CHIP}">Icon only</button>
              <button type="button" class="pkw-chip" data-type="wordmark" style="${STYLE_CHIP}">Wordmark (text)</button>
              <button type="button" class="pkw-chip" data-type="combination" style="${STYLE_CHIP}">Icon + text</button>
            </div>
            <p style="font-size:11.5px;color:rgba(255,255,255,0.4);margin:8px 0 0;line-height:1.5;">Wordmark / Icon + text will render your brand name (<b style="color:rgba(255,255,255,0.7);font-weight:600;">${STATE.name || 'your brand'}</b>) as actual readable text.</p>
          </div>
          <div>
            <label style="${STYLE_LABEL}">Vibe</label>
            <div id="lg-mood" style="display:flex;flex-wrap:wrap;gap:6px;margin-top:6px;">
              ${['Minimal','Bold','Editorial','Geometric','Organic','Playful','Hand-drawn','Brutalist'].map(m => `<button type="button" class="pkw-chip" data-mood="${m.toLowerCase()}" style="${STYLE_CHIP}">${m}</button>`).join('')}
            </div>
          </div>
          <div>
            <label style="${STYLE_LABEL}">Describe what should appear in the logo</label>
            <textarea id="lg-desc" maxlength="500" class="pkw-textarea" placeholder="e.g. an abstract snowflake fused with the letter A; sharp, geometric, single weight." style="${STYLE_TEXTAREA};min-height:96px;"></textarea>
            <p style="font-size:11.5px;color:rgba(255,255,255,0.4);margin:6px 0 0;line-height:1.5;">Be specific. The AI takes this literally — name the elements, motifs, or concepts you want included.</p>
          </div>
          <div>
            <label style="${STYLE_LABEL}">Extra style keywords (optional)</label>
            <input id="lg-style" type="text" maxlength="120" class="pkw-input" placeholder="e.g. monogram, single line, swiss, art deco" style="${STYLE_INPUT}" />
          </div>
          <div>
            <label style="${STYLE_LABEL}">Reference photos (0–3, optional)</label>
            <div id="lg-refs" style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:8px;"></div>
            <button type="button" id="lg-add-ref" class="pkw-add" style="${STYLE_ADD}">+ Add reference photo</button>
            <input type="file" accept="image/*" id="lg-ref-input" style="display:none;" />
          </div>
          <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:12px;padding:12px 14px;">
            <label style="display:flex;align-items:center;gap:10px;cursor:pointer;font-size:13px;color:rgba(255,255,255,0.78);font-weight:500;">
              <input id="lg-force-color" type="checkbox" style="width:16px;height:16px;accent-color:#f97316;cursor:pointer;" />
              <span>Force a specific color for the mark</span>
            </label>
            <div id="lg-color-row" style="display:none;align-items:center;gap:10px;margin-top:10px;padding-top:10px;border-top:1px solid rgba(255,255,255,0.05);">
              <input id="lg-color" type="color" value="${STATE.palette?.primary || '#f97316'}" style="width:44px;height:34px;padding:0;border-radius:8px;border:1px solid rgba(255,255,255,0.14);background:none;cursor:pointer;" />
              <span style="font-size:11.5px;color:rgba(255,255,255,0.5);line-height:1.45;">Otherwise we'll use your kit palette if you have one, or pick a bold accent automatically.</span>
            </div>
          </div>

          <button type="button" id="lg-go" class="pkw-primary" style="${STYLE_BTN_PRIMARY};height:52px;width:100%;margin-top:4px;background:linear-gradient(135deg,#f97316 0%, #a78bfa 140%);">
            Generate logo
          </button>

          <div id="lg-progress" style="display:none;font-size:12.5px;color:rgba(255,255,255,0.65);">
            <div data-pstep="1" style="padding:6px 0;color:#f97316;">1. Generating logo with AI…</div>
            <div data-pstep="2" style="padding:6px 0;color:rgba(255,255,255,0.35);">2. Removing background…</div>
            <div data-pstep="3" style="padding:6px 0;color:rgba(255,255,255,0.35);">3. Vectorizing to SVG…</div>
          </div>
          <p id="lg-error" style="display:none;font-size:12.5px;color:#ff8a8a;margin:0;"></p>
        </div>

        ${footerHTML({ hideSkip: false, skipText: 'Skip for now', nextText: 'Continue →' })}
      `;

      function renderRefs() {
        const wrap = card.querySelector('#lg-refs');
        const list = STATE.assets?.logo_refs || [];
        if (list.length === 0) { wrap.innerHTML = ''; return; }
        wrap.innerHTML = list.map((u, i) => `
          <div style="position:relative;aspect-ratio:1;border-radius:10px;overflow:hidden;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);">
            <img src="${u}" alt="" style="width:100%;height:100%;object-fit:cover;" />
            <button type="button" data-rm-ref="${i}" style="position:absolute;top:4px;right:4px;width:22px;height:22px;border-radius:50%;border:0;background:rgba(0,0,0,0.7);color:#fff;cursor:pointer;font-size:13px;font-family:inherit;">×</button>
          </div>
        `).join('');
        wrap.querySelectorAll('[data-rm-ref]').forEach(b => b.addEventListener('click', () => {
          const idx = +b.dataset.rmRef;
          STATE.assets.logo_refs = (STATE.assets.logo_refs || []).filter((_, j) => j !== idx);
          queueSave({ assets: { ...STATE.assets } });
          renderRefs();
        }));
      }

      function renderResult() {
        const wrap = card.querySelector('#lg-result');
        const url = STATE.assets?.logo;
        if (!url) { wrap.style.display = 'none'; return; }
        wrap.style.display = 'block';
        wrap.innerHTML = `
          <div style="background:#fafafa;border-radius:16px;padding:28px;display:flex;align-items:center;justify-content:center;min-height:200px;border:1px solid rgba(255,255,255,0.08);">
            <img src="${url}" alt="" style="max-width:240px;max-height:160px;object-fit:contain;" />
          </div>
          <div style="display:flex;gap:8px;margin-top:12px;align-items:center;flex-wrap:wrap;">
            <span style="font-size:11.5px;color:rgba(255,255,255,0.55);font-weight:600;letter-spacing:0.04em;">${STATE.assets?.logo_svg ? 'SVG ready ·' : 'Vectorizing… ·'}</span>
            <button type="button" id="lg-try-again" style="height:36px;padding:0 16px;border-radius:999px;background:rgba(255,255,255,0.06);color:#fff;border:1px solid rgba(255,255,255,0.14);font-family:inherit;font-size:12px;font-weight:600;cursor:pointer;">Try again with more guidance</button>
          </div>
        `;
        wrap.querySelector('#lg-try-again').addEventListener('click', () => {
          card.querySelector('#lg-controls').scrollIntoView({ behavior:'smooth', block:'start' });
          card.querySelector('#lg-desc').focus();
        });
      }

      renderRefs();
      renderResult();

      card.querySelector('#lg-add-ref').addEventListener('click', () => {
        const list = STATE.assets?.logo_refs || [];
        if (list.length >= 3) return;
        card.querySelector('#lg-ref-input').click();
      });
      card.querySelector('#lg-ref-input').addEventListener('change', async (e) => {
        const file = e.target.files?.[0]; if (!file) return;
        markDirty();
        try {
          const { upload } = await import('https://esm.sh/@vercel/blob@2.3.3/client');
          const blob = await upload(file.name, file, { access: 'public', handleUploadUrl: `/api/kits/${kitId}/sign-upload` });
          STATE.assets = { ...(STATE.assets || {}), logo_refs: [...(STATE.assets?.logo_refs || []), blob.url] };
          queueSave({ assets: STATE.assets });
          renderRefs();
        } catch (err) { console.error(err); saveState.textContent = 'Upload failed'; }
      });

      function setPStep(n, status) {
        card.querySelectorAll('#lg-progress [data-pstep]').forEach(el => {
          const s = +el.dataset.pstep;
          if (s < n) { el.style.color = '#6ee7a3'; }
          else if (s === n) { el.style.color = status === 'done' ? '#6ee7a3' : '#f97316'; }
          else { el.style.color = 'rgba(255,255,255,0.35)'; }
        });
      }

      // Wire the force-color toggle: show the picker only when checked.
      const forceColorCb = card.querySelector('#lg-force-color');
      const colorRow = card.querySelector('#lg-color-row');
      forceColorCb.addEventListener('change', () => {
        colorRow.style.display = forceColorCb.checked ? 'flex' : 'none';
      });

      // Wire type + mood chips (single-select for type, single-select for mood).
      const typeGroup = card.querySelector('#lg-type');
      typeGroup.addEventListener('click', (e) => {
        const b = e.target.closest('[data-type]'); if (!b) return;
        typeGroup.querySelectorAll('[data-type]').forEach(x => x.classList.remove('is-active'));
        b.classList.add('is-active');
      });
      const moodGroup = card.querySelector('#lg-mood');
      moodGroup.addEventListener('click', (e) => {
        const b = e.target.closest('[data-mood]'); if (!b) return;
        const wasActive = b.classList.contains('is-active');
        moodGroup.querySelectorAll('[data-mood]').forEach(x => x.classList.remove('is-active'));
        if (!wasActive) b.classList.add('is-active');
      });

      card.querySelector('#lg-go').addEventListener('click', async () => {
        const desc = card.querySelector('#lg-desc').value.trim();
        const style = card.querySelector('#lg-style').value.trim();
        const colorEl = card.querySelector('#lg-color');
        const primaryColor = forceColorCb.checked ? colorEl.value : undefined;
        const referenceImages = (STATE.assets?.logo_refs || []).slice(0, 3);
        const logoType = typeGroup.querySelector('.is-active')?.dataset.type || 'icon';
        const mood = moodGroup.querySelector('.is-active')?.dataset.mood;
        const goBtn = card.querySelector('#lg-go');
        const err = card.querySelector('#lg-error');
        const prog = card.querySelector('#lg-progress');

        // Build description: prepend name + tagline if user left it blank/short.
        const baseDesc = desc.length >= 4
          ? desc
          : `Logo for ${STATE.name}${STATE.tagline ? ' — ' + STATE.tagline : ''}`;

        err.style.display = 'none';
        prog.style.display = 'block';
        goBtn.disabled = true;
        const oldLabel = goBtn.textContent;
        goBtn.textContent = 'Generating…';

        setPStep(1, 'active');
        const t2 = setTimeout(() => setPStep(2, 'active'), 8000);
        const t3 = setTimeout(() => setPStep(3, 'active'), 18000);

        try {
          const r = await fetch(`/api/kits/${kitId}/generate-logo`, {
            method: 'POST', headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ description: baseDesc, style: style || undefined, primaryColor, referenceImages, logoType, mood }),
          });
          const data = await r.json();
          clearTimeout(t2); clearTimeout(t3);
          if (!r.ok) {
            err.textContent = data.error || 'Generation failed.';
            err.style.display = 'block'; prog.style.display = 'none';
            goBtn.disabled = false; goBtn.textContent = oldLabel;
            return;
          }
          setPStep(3, 'done');
          // Pull fresh state for assets
          STATE.assets = { ...(STATE.assets || {}), logo: data.pngUrl || data.logo, logo_svg: data.svgUrl || data.logo_svg };
          renderResult();
          goBtn.disabled = false; goBtn.textContent = 'Generate another';
          setTimeout(() => { prog.style.display = 'none'; }, 800);
        } catch (e) {
          clearTimeout(t2); clearTimeout(t3);
          err.textContent = 'Network error.';
          err.style.display = 'block'; prog.style.display = 'none';
          goBtn.disabled = false; goBtn.textContent = oldLabel;
        }
      });

      wireFooter(card);
    }

    // ── Step: bio short ────────────────────────────────────
    function renderBioShort(card) {
      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">The one-line story.</h2>
        <p style="${STYLE_HELPER}">Two sentences that journalists will literally copy-paste. 280 characters max — think headline, not paragraph.</p>

        <textarea id="f-bio-short" class="pkw-textarea" maxlength="280" placeholder="A line that captures the whole thing." style="${STYLE_TEXTAREA};min-height:120px;">${escapeHtml(STATE.bio_short ?? '')}</textarea>
        <div style="display:flex;justify-content:flex-end;font-size:11.5px;color:rgba(255,255,255,0.4);margin-top:6px;font-variant-numeric:tabular-nums;" id="f-bio-count">${(STATE.bio_short ?? '').length} / 280</div>

        ${footerHTML()}
      `;
      const ta = card.querySelector('#f-bio-short');
      const ct = card.querySelector('#f-bio-count');
      ta.addEventListener('input', e => { queueSave({ bio_short: e.target.value }); ct.textContent = `${e.target.value.length} / 280`; });
      wireFooter(card);
    }

    // ── Step: bio long ─────────────────────────────────────
    function renderBioLong(card) {
      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">The longer version.</h2>
        <p style="${STYLE_HELPER}">The full story: what you do, who you’ve worked with, why it matters. Optional — skip if you don’t want one.</p>

        <textarea id="f-bio-long" class="pkw-textarea" maxlength="3000" placeholder="The full story." style="${STYLE_TEXTAREA};min-height:200px;">${escapeHtml(STATE.bio_long ?? '')}</textarea>

        ${footerHTML()}
      `;
      card.querySelector('#f-bio-long').addEventListener('input', e => queueSave({ bio_long: e.target.value }));
      wireFooter(card);
    }

    // ── Step: numbers (stats) ──────────────────────────────
    function renderNumbers(card) {
      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">What numbers matter?</h2>
        <p style="${STYLE_HELPER}">Stats sit on the inside spread in big tabular numbers. Three or four is usually plenty.</p>

        <div id="f-stats" style="display:flex;flex-direction:column;gap:10px;"></div>
        <button type="button" id="add-stat" class="pkw-add" style="${STYLE_ADD};margin-top:12px;">+ Add stat</button>

        ${footerHTML({ skipText: 'No stats' })}
      `;
      bindRows(card, 'f-stats', 'stats', 'grid-template-columns:1fr 1.4fr 40px;',
        (s) => `
          <input type="text" placeholder="1.2M" data-k="value" value="${escapeAttr(s.value ?? '')}" class="pkw-input" style="height:42px;padding:0 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13.5px;outline:none;" />
          <input type="text" placeholder="monthly listeners" data-k="label" value="${escapeAttr(s.label ?? '')}" class="pkw-input" style="height:42px;padding:0 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13.5px;outline:none;" />
          <button type="button" class="pkw-rm" data-rm>×</button>
        `,
        STATE.stats, 'add-stat', () => ({ value: '', label: '' })
      );
      wireFooter(card);
    }

    // ── Step: press mentions ───────────────────────────────
    function renderPress(card) {
      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">Where have you been featured?</h2>
        <p style="${STYLE_HELPER}">Outlet name and year (and optionally a quote). Recent or prestigious first — we’ll lay them out as a clean list.</p>

        <div id="f-press" style="display:flex;flex-direction:column;gap:10px;"></div>
        <button type="button" id="add-press" class="pkw-add" style="${STYLE_ADD};margin-top:12px;">+ Add press mention</button>

        ${footerHTML({ skipText: 'No press yet' })}
      `;
      bindRows(card, 'f-press', 'press', 'grid-template-columns:1.5fr 80px 40px;',
        (p) => `
          <input type="text" placeholder="Outlet (Mixmag)" data-k="name" value="${escapeAttr(p.name ?? '')}" style="height:42px;padding:0 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13.5px;outline:none;" />
          <input type="text" placeholder="Year" data-k="year" value="${escapeAttr(p.year ?? '')}" style="height:42px;padding:0 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13.5px;outline:none;" />
          <button type="button" class="pkw-rm" data-rm>×</button>
        `,
        STATE.press, 'add-press', () => ({ name: '', year: '' })
      );
      wireFooter(card);
    }

    // ── Step: awards ───────────────────────────────────────
    function renderAwards(card) {
      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">Any awards or recognition?</h2>
        <p style="${STYLE_HELPER}">Name + year + (optional) issuer. Keep it short — only the ones that move the needle.</p>

        <div id="f-awards" style="display:flex;flex-direction:column;gap:10px;"></div>
        <button type="button" id="add-award" class="pkw-add" style="${STYLE_ADD};margin-top:12px;">+ Add award</button>

        ${footerHTML({ skipText: 'No awards' })}
      `;
      bindRows(card, 'f-awards', 'awards', 'grid-template-columns:1.4fr 80px 1fr 40px;',
        (a) => `
          <input type="text" placeholder="Award name" data-k="name" value="${escapeAttr(a.name ?? '')}" style="height:42px;padding:0 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13.5px;outline:none;" />
          <input type="text" placeholder="Year" data-k="year" value="${escapeAttr(a.year ?? '')}" style="height:42px;padding:0 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13.5px;outline:none;" />
          <input type="text" placeholder="Issuer (opt)" data-k="issuer" value="${escapeAttr(a.issuer ?? '')}" style="height:42px;padding:0 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13.5px;outline:none;" />
          <button type="button" class="pkw-rm" data-rm>×</button>
        `,
        STATE.awards, 'add-award', () => ({ name: '', year: '', issuer: '' })
      );
      wireFooter(card);
    }

    // ── Step: links (contact + social) ─────────────────────
    function renderLinks(card) {
      const PLATFORMS = ['spotify','soundcloud','youtube','apple_music','bandcamp','instagram','tiktok','website','booking','other'];
      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">Contact + social links.</h2>
        <p style="${STYLE_HELPER}">Where journalists send emails, what they listen to first, where they find you. This becomes the back cover.</p>

        <div style="display:flex;flex-direction:column;gap:18px;">
          <div>
            <label style="${STYLE_LABEL}">Booking email</label>
            <input id="f-email" type="email" class="pkw-input" value="${escapeAttr(STATE.contact_email ?? '')}" placeholder="booking@you.com" style="${STYLE_INPUT}" />
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div>
              <label style="${STYLE_LABEL}">Phone</label>
              <input id="f-phone" type="tel" class="pkw-input" value="${escapeAttr(STATE.contact_phone ?? '')}" placeholder="(optional)" style="${STYLE_INPUT}" />
            </div>
            <div>
              <label style="${STYLE_LABEL}">Other (telegram, etc.)</label>
              <input id="f-other" type="text" class="pkw-input" value="${escapeAttr(STATE.contact_other ?? '')}" placeholder="(optional)" style="${STYLE_INPUT}" />
            </div>
          </div>
          <div>
            <label style="${STYLE_LABEL}">Social + streaming links</label>
            <div id="f-links" style="display:flex;flex-direction:column;gap:10px;"></div>
            <button type="button" id="add-link" class="pkw-add" style="${STYLE_ADD};margin-top:10px;">+ Add link</button>
          </div>
        </div>

        ${footerHTML()}
      `;
      card.querySelector('#f-email').addEventListener('input', e => queueSave({ contact_email: e.target.value }));
      card.querySelector('#f-phone').addEventListener('input', e => queueSave({ contact_phone: e.target.value }));
      card.querySelector('#f-other').addEventListener('input', e => queueSave({ contact_other: e.target.value }));
      const SELECT_STYLE = 'height:42px;padding:0 10px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13px;outline:none;appearance:none;-webkit-appearance:none;background-image:url("data:image/svg+xml,%3Csvg width=\'10\' height=\'6\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cpath d=\'M1 1l4 4 4-4\' stroke=\'%23ffffff80\' fill=\'none\' stroke-width=\'1.5\'/%3E%3C/svg%3E");background-repeat:no-repeat;background-position:right 12px center;padding-right:28px;';
      bindRows(card, 'f-links', 'links', 'grid-template-columns:150px 1fr 40px;',
        (l) => `
          <select data-k="platform" style="${SELECT_STYLE}">${PLATFORMS.map(p => `<option ${l.platform === p ? 'selected' : ''} value="${p}">${p}</option>`).join('')}</select>
          <input type="url" placeholder="https://…" data-k="url" value="${escapeAttr(l.url ?? '')}" style="height:42px;padding:0 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13.5px;outline:none;" />
          <button type="button" class="pkw-rm" data-rm>×</button>
        `,
        STATE.links, 'add-link', () => ({ platform: 'spotify', url: '' })
      );
      wireFooter(card);
    }

    // ── Step: brand (palette + fonts) ──────────────────────
    function renderBrand(card) {
      const logoUrl = STATE.assets?.logo;
      const logoSvgUrl = STATE.assets?.logo_svg;
      card.innerHTML = `
        ${eyebrowHTML()}
        <h2 style="${STYLE_TITLE}">Logo, palette & fonts.</h2>
        <p style="${STYLE_HELPER}">We pulled the palette from your logo (where possible). Tweak any swatch. Fonts search across all Google Fonts. You can also regenerate the logo with AI any time.</p>

        <div style="display:flex;flex-direction:column;gap:22px;">
          <div>
            <label style="${STYLE_LABEL}">Logo</label>
            <div style="display:flex;align-items:center;gap:14px;padding:14px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:14px;">
              ${logoUrl
                ? `<img src="${logoUrl}" alt="" style="width:72px;height:72px;object-fit:contain;background:#fafafa;border-radius:10px;padding:6px;" />`
                : `<div style="width:72px;height:72px;background:rgba(255,255,255,0.03);border:1px dashed rgba(255,255,255,0.18);border-radius:10px;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.4);font-size:11px;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;">None</div>`}
              <div style="flex:1;display:flex;flex-direction:column;gap:2px;min-width:0;">
                <strong style="font-size:13.5px;color:#fff;font-weight:600;">${logoUrl ? 'Current logo' : 'No logo yet'}</strong>
                <span style="font-size:11.5px;color:rgba(255,255,255,0.45);">${logoSvgUrl ? 'SVG vector ready' : (logoUrl ? 'PNG only' : 'Upload or generate one with AI')}</span>
              </div>
            </div>
            <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:10px;">
              ${logoUrl ? `<a href="${logoUrl}" download style="height:36px;padding:0 14px;display:inline-flex;align-items:center;border-radius:999px;background:rgba(255,255,255,0.06);color:#fff;border:1px solid rgba(255,255,255,0.12);font-family:inherit;font-size:12px;font-weight:600;text-decoration:none;cursor:pointer;">Download PNG</a>` : ''}
              ${logoSvgUrl ? `<a href="${logoSvgUrl}" download style="height:36px;padding:0 14px;display:inline-flex;align-items:center;border-radius:999px;background:rgba(255,255,255,0.06);color:#fff;border:1px solid rgba(255,255,255,0.12);font-family:inherit;font-size:12px;font-weight:600;text-decoration:none;cursor:pointer;">Download SVG</a>` : ''}
              <button type="button" id="brand-logo-replace" style="height:36px;padding:0 14px;border-radius:999px;background:rgba(255,255,255,0.06);color:#fff;border:1px solid rgba(255,255,255,0.12);font-family:inherit;font-size:12px;font-weight:600;cursor:pointer;">${logoUrl ? 'Replace with new upload' : 'Upload a logo'}</button>
              <button type="button" id="brand-logo-ai" style="height:36px;padding:0 14px;border-radius:999px;background:linear-gradient(135deg,rgba(167,139,250,0.18) 0%, rgba(249,115,22,0.18) 140%);color:#fff;border:1px solid rgba(167,139,250,0.4);font-family:inherit;font-size:12px;font-weight:700;letter-spacing:0.02em;cursor:pointer;">${logoUrl ? 'Regenerate with AI' : 'Generate with AI'}</button>
            </div>
            <input type="file" accept="image/*" id="brand-logo-input" style="display:none;" />
          </div>

          <div>
            <label style="${STYLE_LABEL}">Palette</label>
            <div id="f-palette" style="display:grid;grid-template-columns:repeat(5,1fr);gap:10px;">
              ${['primary','secondary','accent','text','bg'].map(k => `
                <div style="display:flex;flex-direction:column;align-items:center;gap:6px;">
                  <input type="color" data-pal="${k}" value="${STATE.palette?.[k] || '#000000'}" style="width:100%;height:54px;border-radius:12px;border:1px solid rgba(255,255,255,0.14);background:none;cursor:pointer;padding:0;" />
                  <label style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.55);">${k}</label>
                </div>
              `).join('')}
            </div>
            <div id="f-presets" style="display:flex;gap:8px;flex-wrap:wrap;margin-top:14px;"></div>
          </div>

          <div>
            <label style="${STYLE_LABEL}">Fonts</label>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
              <div style="display:flex;flex-direction:column;gap:6px;">
                <span style="font-size:11px;color:rgba(255,255,255,0.5);font-weight:600;text-transform:uppercase;letter-spacing:0.08em;">Heading</span>
                ${fontCombo('heading', STATE.fonts.heading)}
              </div>
              <div style="display:flex;flex-direction:column;gap:6px;">
                <span style="font-size:11px;color:rgba(255,255,255,0.5);font-weight:600;text-transform:uppercase;letter-spacing:0.08em;">Body</span>
                ${fontCombo('body', STATE.fonts.body)}
              </div>
            </div>
            <p style="font-size:11.5px;color:rgba(255,255,255,0.4);margin-top:10px;">Search across all Google Fonts. Each option previews in its own family.</p>
          </div>
        </div>

        ${footerHTML({ nextText: 'Review →' })}
      `;

      // palette
      card.querySelectorAll('#f-palette input[type=color]').forEach(el => {
        el.addEventListener('input', () => {
          const next = { ...STATE.palette };
          next[el.dataset.pal] = el.value;
          next.extracted_from_logo = false;
          queueSave({ palette: next });
        });
      });

      // presets
      const presetsWrap = card.querySelector('#f-presets');
      presetsWrap.innerHTML = PALETTE_PRESETS.map((p, i) => `
        <button type="button" data-preset="${i}" title="${p.name}" style="display:inline-flex;gap:2px;align-items:center;padding:6px;border-radius:10px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);cursor:pointer;">
          ${['primary','accent','bg'].map(k => `<span style="width:22px;height:22px;border-radius:5px;background:${p[k]};"></span>`).join('')}
        </button>
      `).join('');
      presetsWrap.querySelectorAll('[data-preset]').forEach(btn => {
        btn.addEventListener('click', () => {
          const p = PALETTE_PRESETS[+btn.dataset.preset];
          const next = { primary: p.primary, secondary: p.secondary, accent: p.accent, text: p.text, bg: p.bg };
          card.querySelectorAll('#f-palette input[type=color]').forEach(el => { el.value = next[el.dataset.pal]; });
          queueSave({ palette: next });
        });
      });

      // ── Logo affordances (Brand step) ──────────────────
      const fileInput = card.querySelector('#brand-logo-input');
      card.querySelector('#brand-logo-replace')?.addEventListener('click', () => fileInput.click());
      fileInput?.addEventListener('change', async (e) => {
        const file = e.target.files?.[0]; if (!file) return;
        markDirty();
        try {
          const { upload } = await import('https://esm.sh/@vercel/blob@2.3.3/client');
          const blob = await upload(file.name, file, { access: 'public', handleUploadUrl: `/api/kits/${kitId}/sign-upload` });
          STATE.assets = { ...(STATE.assets || {}), logo: blob.url, logo_svg: undefined };
          await fetch(`/api/kits/${kitId}`, { method: 'PATCH', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ assets: STATE.assets }) });
          markSaved();
          renderBrand(card);
        } catch (err) { console.error(err); saveState.textContent = 'Upload failed'; }
      });
      card.querySelector('#brand-logo-ai')?.addEventListener('click', () => {
        LG.returnTo = 'brand';
        needsLogoGen = true;
        rebuildSteps('logo-type');
        renderProgress();
        renderStep();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      wireFontCombos(card);
      wireFooter(card);
    }

    // ── Font combobox ──────────────────────────────────────
    function fontCombo(target, current) {
      return `
        <div class="pkw-font-combo" data-font="${target}" style="position:relative;">
          <input type="text" class="pkw-input pkw-font-input" value="${escapeAttr(current)}" style="${STYLE_INPUT};font-family:'${current}',sans-serif;" placeholder="Search Google Fonts…" />
          <div class="pkw-font-list" style="position:absolute;top:calc(100% + 4px);left:0;right:0;max-height:280px;overflow-y:auto;background:#15151a;border:1px solid rgba(255,255,255,0.14);border-radius:12px;z-index:60;display:none;box-shadow:0 18px 48px rgba(0,0,0,0.45);"></div>
        </div>
      `;
    }
    function wireFontCombos(card) {
      card.querySelectorAll('.pkw-font-combo').forEach(box => {
        const inp = box.querySelector('input');
        const list = box.querySelector('.pkw-font-list');
        const target = box.dataset.font;
        let active = -1;

        function render(filter) {
          const q = (filter || '').toLowerCase().trim();
          const matches = FONTS.filter(f => !q || f.family.toLowerCase().includes(q)).slice(0, 60);
          active = -1;
          list.innerHTML = matches.map((f, i) => `
            <div class="pkw-font-opt" data-fam="${escapeAttr(f.family)}" data-idx="${i}" style="padding:10px 14px;font-size:15px;color:rgba(255,255,255,0.85);cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:8px;font-family:'${f.family}',sans-serif;">
              <span>${escapeHtml(f.family)}</span>
              <span style="font-size:10px;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.4);font-family:'Inter',sans-serif;">${f.category}</span>
            </div>
          `).join('') || '<div style="padding:14px;color:rgba(255,255,255,0.4);font-size:12px;">No match.</div>';
          list.querySelectorAll('.pkw-font-opt').forEach(o => o.addEventListener('click', () => pick(o.dataset.fam)));
        }
        function pick(fam) {
          inp.value = fam;
          inp.style.fontFamily = `'${fam}', sans-serif`;
          list.style.display = 'none';
          loadGoogleFont(fam);
          const next = { ...STATE.fonts, [target]: fam, auto: false };
          queueSave({ fonts: next });
        }

        inp.addEventListener('focus', () => { render(inp.value); list.style.display = 'block'; });
        inp.addEventListener('input', () => { render(inp.value); list.style.display = 'block'; });
        inp.addEventListener('keydown', (e) => {
          const opts = list.querySelectorAll('.pkw-font-opt');
          if (e.key === 'ArrowDown') { active = Math.min(active + 1, opts.length - 1); opts.forEach((o,i)=>o.classList.toggle('is-active', i===active)); opts[active]?.scrollIntoView({block:'nearest'}); e.preventDefault(); }
          else if (e.key === 'ArrowUp') { active = Math.max(active - 1, 0); opts.forEach((o,i)=>o.classList.toggle('is-active', i===active)); opts[active]?.scrollIntoView({block:'nearest'}); e.preventDefault(); }
          else if (e.key === 'Enter' && active >= 0) { pick(opts[active].dataset.fam); e.preventDefault(); }
          else if (e.key === 'Escape') { list.style.display = 'none'; }
        });
        document.addEventListener('click', (e) => { if (!box.contains(e.target)) list.style.display = 'none'; });
      });
    }
    function loadGoogleFont(family) {
      const id = 'gf-' + family.replace(/\s+/g, '-');
      if (document.getElementById(id)) return;
      const link = document.createElement('link');
      link.id = id; link.rel = 'stylesheet';
      link.href = `https://fonts.googleapis.com/css2?family=${family.replace(/\s+/g, '+')}:wght@300;400;500;600;700;800&display=swap`;
      document.head.appendChild(link);
    }

    // ── Repeater helper ────────────────────────────────────
    function bindRows(card, listId, stateKey, gridCols, tmpl, initialList, addBtnId, blank) {
      const wrap = card.querySelector('#' + listId);
      function refresh() {
        const out = [];
        wrap.querySelectorAll('[data-row]').forEach(row => {
          const obj = {};
          row.querySelectorAll('[data-k]').forEach(el => { obj[el.dataset.k] = el.value; });
          if (Object.values(obj).some(v => v)) out.push(obj);
        });
        STATE[stateKey] = out;
        queueSave({ [stateKey]: out });
      }
      function add(data) {
        const row = document.createElement('div');
        row.setAttribute('data-row', '');
        row.style.cssText = `display:grid;gap:8px;align-items:center;${gridCols}`;
        row.innerHTML = tmpl(data);
        wrap.appendChild(row);
        row.querySelectorAll('input, select').forEach(el => { el.addEventListener('input', refresh); el.addEventListener('change', refresh); });
        row.querySelector('[data-rm]')?.addEventListener('click', () => { row.remove(); refresh(); });
      }
      (initialList || []).forEach(add);
      card.querySelector('#' + addBtnId).addEventListener('click', () => add(blank()));
    }

    // ── Review screen ──────────────────────────────────────
    function renderReview() {
      const recap = document.getElementById('review-recap');
      const heading = STATE.fonts?.heading ?? 'Inter';
      const body = STATE.fonts?.body ?? 'Inter';
      const published = STATE.status === 'published';

      const idxOf = (key) => STEPS.findIndex(s => s.key === key);
      const SECTIONS = [
        { title: 'Identity', step: idxOf('identity'), rows: [
          ['Name', STATE.name || '—'],
          ['Tagline', STATE.tagline || '—'],
        ]},
        { title: 'Brand', step: idxOf('brand'), rows: [
          ['Logo', `${STATE.assets?.logo ? 'Yes' : '—'}${STATE.assets?.logo_svg ? ' · SVG ready' : ''}`],
          ['Palette', `<span style="display:inline-flex;gap:4px;justify-content:flex-end;">${['primary','accent','bg'].map(k => `<span style="width:14px;height:14px;border-radius:3px;background:${STATE.palette?.[k] ?? '#000'};border:1px solid rgba(255,255,255,0.12);"></span>`).join('')}</span>`],
          ['Fonts', `<span style="font-family:'${heading}', sans-serif;">${escapeHtml(heading)} <span style="opacity:.55;font-family:'${body}',sans-serif;">/ ${escapeHtml(body)}</span></span>`],
        ]},
        { title: 'Story', step: idxOf('bio-short'), rows: [
          ['Short bio', STATE.bio_short ? escapeHtml(STATE.bio_short.slice(0, 70)) + (STATE.bio_short.length > 70 ? '…' : '') : '—'],
          ['Long bio', STATE.bio_long ? `${STATE.bio_long.split(/\s+/).length} words` : '—'],
        ]},
        { title: 'Numbers', step: idxOf('numbers'), rows: [
          ['Stats', String((STATE.stats || []).length)],
        ]},
        { title: 'Press', step: idxOf('press'), rows: [
          ['Mentions', String((STATE.press || []).length)],
        ]},
        { title: 'Awards', step: idxOf('awards'), rows: [
          ['Awards', String((STATE.awards || []).length)],
        ]},
        { title: 'Links', step: idxOf('links'), rows: [
          ['Email', escapeHtml(STATE.contact_email ?? '—')],
          ['Links', String((STATE.links || []).length)],
        ]},
      ];

      recap.innerHTML = SECTIONS.map(sec => `
        <div style="margin-top:18px;padding-top:18px;border-top:1px solid rgba(255,255,255,0.08);">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
            <h3 style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:rgba(255,255,255,0.55);margin:0;">${sec.title}</h3>
            <button type="button" class="pkw-recap-edit" data-go="${sec.step}" style="display:inline-flex;align-items:center;gap:4px;font-size:11px;color:#f97316;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;cursor:pointer;background:none;border:0;font-family:inherit;padding:0;">Edit →</button>
          </div>
          ${sec.rows.map(([l, v]) => `
            <div style="display:flex;justify-content:space-between;gap:12px;padding:7px 0;border-bottom:1px solid rgba(255,255,255,0.05);font-size:13px;">
              <span style="color:rgba(255,255,255,0.55);font-weight:500;">${l}</span>
              <span style="color:#fff;text-align:right;max-width:60%;word-break:break-word;">${v}</span>
            </div>
          `).join('')}
        </div>
      `).join('') + `
        <div style="margin-top:22px;display:flex;flex-direction:column;gap:10px;">
          ${published
            ? `<a href="/kit/${STATE.slug}" target="_blank" style="height:48px;display:inline-flex;align-items:center;justify-content:center;padding:0 22px;background:rgba(255,255,255,0.06);color:#fff;border:1px solid rgba(255,255,255,0.14);border-radius:999px;font-family:inherit;font-size:13px;font-weight:600;text-decoration:none;letter-spacing:0.02em;">View live kit ↗</a>
               <a href="/kit/${STATE.slug}?print=1" target="_blank" style="height:52px;display:inline-flex;align-items:center;justify-content:center;padding:0 22px;background:#f97316;color:#0a0a0a;border-radius:999px;font-family:inherit;font-size:14px;font-weight:700;text-decoration:none;letter-spacing:0.04em;">Download PDF ↓</a>`
            : `<button type="button" id="publish-btn" class="pkw-primary" style="height:54px;background:#f97316;color:#0a0a0a;border:none;border-radius:999px;font-family:inherit;font-size:15px;font-weight:700;letter-spacing:0.04em;cursor:pointer;">Publish for €15 →</button>
               <p style="font-size:11.5px;color:rgba(255,255,255,0.4);text-align:center;margin:0;line-height:1.5;">You’ll be charged once. Shareable link + PDF unlock immediately after.</p>`
          }
        </div>
      `;

      // Header for the recap
      const head = document.createElement('div');
      head.style.cssText = 'display:flex;align-items:center;justify-content:space-between;gap:8px;';
      head.innerHTML = `
        <div>
          <span style="${STYLE_EYEBROW}"><span style="${STYLE_EYEBROW_DOT}"></span>Review</span>
          <h2 style="font-family:'Inter',sans-serif;font-size:24px;font-weight:300;letter-spacing:-0.025em;color:#fff;margin:14px 0 4px;">What you’ve answered</h2>
          <p style="font-size:13px;color:rgba(255,255,255,0.55);margin:0;line-height:1.5;">Tap any section to edit. The preview on the right updates live.</p>
        </div>
      `;
      recap.prepend(head);

      recap.querySelectorAll('[data-go]').forEach(b => b.addEventListener('click', () => goTo(+b.dataset.go)));
      const pubBtn = recap.querySelector('#publish-btn');
      if (pubBtn) pubBtn.addEventListener('click', publishFlow);
    }

    async function publishFlow() {
      const btn = document.getElementById('publish-btn');
      btn.disabled = true; btn.textContent = 'Opening checkout…';
      await flushSave();
      try {
        const r = await fetch(`/api/kits/${kitId}/publish`, { method: 'POST' });
        const data = await r.json();
        if (data.url) { window.location.href = data.url; return; }
        alert(data.error || 'Payment error.');
      } catch { alert('Network error.'); }
      btn.disabled = false; btn.textContent = 'Publish for €15 →';
    }

    // ── Palette presets ────────────────────────────────────
    const PALETTE_PRESETS = [
      { name:'Mono',     primary:'#0a0a0a', secondary:'#262626', accent:'#f97316', text:'#0a0a0a', bg:'#fafafa' },
      { name:'Editorial',primary:'#1d1d1f', secondary:'#5a5a5e', accent:'#c97064', text:'#1d1d1f', bg:'#f5efe5' },
      { name:'Studio',   primary:'#0b1f3a', secondary:'#1e3a8a', accent:'#e25822', text:'#0b1f3a', bg:'#f7f4ed' },
      { name:'Forest',   primary:'#0f5132', secondary:'#5a6b2f', accent:'#e25822', text:'#0f5132', bg:'#f4f1e8' },
      { name:'Night',    primary:'#f5efe0', secondary:'#a3a3a3', accent:'#e25822', text:'#f5efe0', bg:'#0b0b0d' },
      { name:'Aurora',   primary:'#1d2bd1', secondary:'#3b3bc7', accent:'#c97064', text:'#0a0a0a', bg:'#f0eef8' },
    ];

    // ── Utils ──────────────────────────────────────────────
    function escapeHtml(s) { return String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
    function escapeAttr(s) { return escapeHtml(s); }

    // ── Boot ───────────────────────────────────────────────
    function initialStepFromHash() {
      const m = (window.location.hash || '').match(/step=([\w-]+)/);
      if (!m) return 0;
      const idx = STEPS.findIndex(s => s.key === m[1]);
      return idx >= 0 ? idx : 0;
    }

    // If user already has a logo on load, skip needsLogoGen.
    if (STATE.assets?.logo) needsLogoGen = false;
    STEPS = buildSteps();
    stepIdx = initialStepFromHash();
    renderProgress();
    if (STEPS[stepIdx].key === 'review') {
      const wiz = document.getElementById('wiz-stage');
      const rev = document.getElementById('review-stage');
      wiz.hidden = true; wiz.style.display = 'none';
      rev.hidden = false; rev.style.display = 'grid';
      renderReview(); reloadPreview();
    } else {
      renderStep();
    }
    window.addEventListener('beforeunload', () => { flushSave(); });
    window.addEventListener('hashchange', () => {
      const idx = initialStepFromHash();
      if (idx !== stepIdx) goTo(idx, { skipSave: true });
    });
  </script>
</Dashboard>
