        <h2 style="${STYLE_TITLE}">Shared the stage with…</h2>
        <p style="${STYLE_HELPER}">Comma-separated names. We print them at the bottom of the Biography page in italic.</p>
        <input id="f-shared" type="text" maxlength="600" class="pkw-input" value="${escapeAttr(STATE.shared_stage ?? '')}" placeholder="e.g. Solomun, Tale Of Us, Adriatique" style="${STYLE_INPUT};height:60px;" />
