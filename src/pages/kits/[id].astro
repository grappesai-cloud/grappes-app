      bindRows(card, 'f-list', '__career_rows', 'grid-template-columns:1fr 40px;',
        (s) => `
          <input type="text" placeholder="${escapeAttr(placeholder)}" data-k="text" value="${escapeAttr(s.text ?? '')}" style="height:42px;padding:0 12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:inherit;font-size:13.5px;outline:none;" />
          <button type="button" class="pkw-rm" data-rm>×</button>
        `,
        initial, 'add-row', () => ({ text: '' })
      );
