        const list = (STATE.__career_rows || []).map(r => (r.text || '').trim()).filter(Boolean);
        STATE.career = { ...(STATE.career || {}), [careerKey]: list };
        await fetch(`/api/kits/${kitId}`, { method: 'PATCH', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ career: STATE.career }) });
        return true;
      }});
    }
    function renderCareerFestivals(card)     { renderCareerList(card, 'festivals', 'Festivals played.', 'One per row. e.g. UNTOLD 2024, Electric Castle 2023, Neversea 2022.', 'UNTOLD 2024'); }
    function renderCareerInternational(card) { renderCareerList(card, 'international', 'International reach.', 'Cities or countries you have performed / shipped to. One per row.', 'Berlin, Germany — Watergate 2024'); }
    function renderCareerCharts(card)        { renderCareerList(card, 'charts', 'Charts & radio.', 'Notable chart positions, radio plays, playlist features. One per row.', '#1 charted in Portugal — Antena 3'); }

    // ── Step: portfolio / discography (year + title + role) ──
    function renderPortfolio(card) {
      const isMusician = ['dj','producer','musician'].includes(STATE.role) || STATE.kit_type === 'musician';
      const title = isMusician ? 'Releases.' : 'Portfolio.';
      const helper = isMusician
        ? 'Year, title, and "Original" / "Remix" / "EP". We group by year on the page.'
        : 'Year, project title, and your role. We group by year on the page.';
