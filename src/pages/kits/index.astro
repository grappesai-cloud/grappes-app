---
import Dashboard from '../../layouts/Dashboard.astro';
import { createAdminClient } from '../../lib/supabase';

const authUser = Astro.locals.user!;
const client = createAdminClient();
const { data: kitsRaw } = await client
  .from('press_kits')
  .select('id, name, status, slug, kit_type, assets, palette, created_at, updated_at')
  .eq('user_id', authUser.id)
  .order('updated_at', { ascending: false });
const kits = kitsRaw ?? [];

function timeAgo(d: string) {
  const diff = Date.now() - new Date(d).getTime();
  const m = Math.floor(diff / 60000), h = Math.floor(diff / 3600000), day = Math.floor(diff / 86400000);
  if (m < 1) return 'just now';
  if (h < 1) return `${m}m ago`;
  if (day < 1) return `${h}h ago`;
  return `${day}d ago`;
}
---
<Dashboard title="Press Kits">
  <style is:global>
    main { padding-top: 56px !important; padding-bottom: 80px !important; }
  </style>

  <div style="text-align:center;margin-bottom:36px;">
    <a href="/dashboard" style="display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:500;color:rgba(255,255,255,0.45);text-decoration:none;letter-spacing:0.04em;text-transform:uppercase;margin-bottom:12px;">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      <span>Studio</span>
    </a>
    <span style="display:inline-block;font-size:13px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#f97316;margin-bottom:10px;">Press Kit Lab</span>
    <h2 style="font-family:'Inter',sans-serif;font-size:44px;font-weight:400;line-height:1.05;letter-spacing:-0.045em;color:#fff;margin-bottom:10px;">Your press kits</h2>
    <p style="font-size:14px;color:rgba(255,255,255,0.55);margin-bottom:22px;max-width:540px;margin-left:auto;margin-right:auto;line-height:1.5;">
      Build a polished digital press kit in minutes. Upload your logo, photos, videos and bio. We compose them into a premium one-pager with a shareable link and downloadable PDF. Drafts are free, publishing costs €15.
    </p>
    <a href="/kits/new" style="display:inline-flex;align-items:center;gap:8px;background:#f97316;color:#0a0a0a;border:none;border-radius:999px;padding:12px 24px;font-size:13.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;text-decoration:none;">
      <span>+ New press kit</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </a>
  </div>

  {kits.length === 0 ? (
    <div style="max-width:560px;margin:0 auto;text-align:center;padding:60px 20px;color:rgba(255,255,255,0.5);">
      <p style="font-size:15px;margin-bottom:6px;">No press kits yet.</p>
      <p style="font-size:13px;color:rgba(255,255,255,0.4);">Start your first one above. You won't be charged until you publish.</p>
    </div>
  ) : (
    <div style="max-width:880px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:18px;">
      {kits.map((k) => {
        const accent = (k.palette as any)?.primary ?? '#f97316';
        const logo = (k.assets as any)?.logo;
        return (
          <a href={`/kits/${k.id}`} style="display:block;text-decoration:none;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:14px;padding:18px;color:#fff;transition:all 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.07)';this.style.borderColor='rgba(255,255,255,0.18)'" onmouseout="this.style.background='rgba(255,255,255,0.04)';this.style.borderColor='rgba(255,255,255,0.08)'">
            <div style={`display:flex;align-items:center;gap:12px;margin-bottom:14px;`}>
              {logo ? (
                <img src={logo} alt="" style="width:42px;height:42px;border-radius:10px;object-fit:contain;background:rgba(255,255,255,0.05);padding:4px;" />
              ) : (
                <div style={`width:42px;height:42px;border-radius:10px;background:${accent};display:flex;align-items:center;justify-content:center;color:#0a0a0a;font-size:18px;font-weight:700;`}>{k.name[0]?.toUpperCase() ?? '?'}</div>
              )}
              <span style={`font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;padding:3px 8px;border-radius:999px;background:${k.status === 'published' ? 'rgba(110,231,163,0.15)' : 'rgba(255,255,255,0.08)'};color:${k.status === 'published' ? '#6ee7a3' : 'rgba(255,255,255,0.55)'};margin-left:auto;`}>{k.status}</span>
            </div>
            <h3 style="font-family:'DM Sans',sans-serif;font-size:16px;font-weight:700;letter-spacing:-0.025em;margin:0 0 4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{k.name}</h3>
            <p style="font-size:12px;color:rgba(255,255,255,0.45);margin:0;">
              {k.kit_type} · updated {timeAgo(k.updated_at)}
            </p>
            {k.status === 'published' && k.slug && (
              <p style="font-size:11px;color:rgba(255,255,255,0.35);margin:6px 0 0;font-family:'JetBrains Mono',monospace;">grappes.dev/kit/{k.slug}</p>
            )}
          </a>
        );
      })}
    </div>
  )}
</Dashboard>
