---
import Dashboard from '../../layouts/Dashboard.astro';
---
<Dashboard title="Press Kits">
  <main style="min-height: 60vh; display: grid; place-items: center; padding: 64px 24px;">
    <div style="text-align: center; max-width: 520px;">
      <div style="font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.5; margin-bottom: 18px;">Press Kit · Brand Book</div>
      <h1 style="font-family: 'Fraunces', Georgia, serif; font-size: 72px; line-height: 0.95; letter-spacing: -2px; margin: 0;">Soon.</h1>
      <p style="margin: 22px auto 0; max-width: 380px; font-size: 15px; line-height: 1.5; opacity: 0.7;">Both tools are off the menu while we rebuild them. Use Audit or Reels in the meantime.</p>
      <div style="margin-top: 32px; display: inline-flex; gap: 8px;">
        <a href="/audit" style="padding: 10px 16px; border: 1px solid currentColor; border-radius: 999px; font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; text-decoration: none; color: inherit;">↗ Audit</a>
        <a href="/reels" style="padding: 10px 16px; border: 1px solid currentColor; border-radius: 999px; font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; text-decoration: none; color: inherit;">↗ Reels</a>
      </div>
    </div>
  </main>
</Dashboard>
