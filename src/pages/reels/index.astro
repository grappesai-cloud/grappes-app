---
import Dashboard from '../../layouts/Dashboard.astro';
import { listAnalysesByUser } from '../../lib/reels/db';

const authUser = Astro.locals.user;
if (!authUser) return Astro.redirect('/sign-in?next=/reels');

const recent = await listAnalysesByUser(authUser.id, 8);

function timeAgo(d: Date | string): string {
  const t = new Date(d).getTime();
  const diff = Date.now() - t;
  const m = Math.floor(diff / 60000), h = Math.floor(diff / 3600000), day = Math.floor(diff / 86400000);
  if (m < 1) return 'just now';
  if (h < 1) return `${m}m ago`;
  if (day < 1) return `${h}h ago`;
  return `${day}d ago`;
}
---
<Dashboard title="Reels Lab">
  <style is:global>
    main { padding-top: 56px !important; padding-bottom: 80px !important; }
  </style>

  <div class="reels-wrap">
    <header class="reels-head">
      <a href="/dashboard" class="reels-back">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        <span>Studio</span>
      </a>
      <span class="reels-eyebrow">Reels Lab</span>
      <h1 class="reels-title">Upload a reel. Get a <strong>brutal breakdown.</strong></h1>
      <p class="reels-sub">Drop an MP4 or MOV up to 200MB. We analyze hook, pacing, audio sync, visual quality, CTA and estimated retention. Output is actionable — three concrete edits for the next cut.</p>
    </header>

    <section class="reels-upload-card">
      <div id="upload-dropzone" class="reels-drop">
        <input type="file" id="reel-file" accept="video/mp4,video/quicktime,video/webm" hidden />
        <div class="reels-drop-inner" id="drop-idle">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          <p class="reels-drop-title">Drop a reel or click to upload</p>
          <p class="reels-drop-hint">MP4 / MOV / WebM · up to 200MB</p>
        </div>
        <div class="reels-drop-busy" id="drop-busy" hidden>
          <div class="reels-spinner"></div>
          <p id="busy-msg">Preparing upload…</p>
          <div class="reels-progress" id="progress-bar" hidden><span id="progress-fill"></span></div>
        </div>
      </div>
      <p id="upload-error" class="reels-error" hidden></p>
    </section>

    {recent.length > 0 && (
      <section class="reels-history">
        <span class="reels-section-label">Recent analyses</span>
        <ul class="reels-list">
          {recent.map(r => (
            <li>
              <a href={`/reels/analysis/${r.id}`}>
                <div class="reels-list-main">
                  <span class="reels-list-name">{r.file_name}</span>
                  <span class="reels-list-meta">{timeAgo(r.created_at)} · {(r.file_size_bytes / 1024 / 1024).toFixed(1)}MB</span>
                </div>
                <span class={`reels-pill reels-pill--${r.status}`}>{r.status}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>

  <style>
    .reels-wrap { max-width: 720px; margin: 0 auto; }
    .reels-head { text-align: center; margin-bottom: 28px; }
    .reels-back { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; color: rgba(255,255,255,0.45); text-decoration: none; margin-bottom: 14px; transition: color 0.2s; }
    .reels-back:hover { color: rgba(255,255,255,0.85); }
    .reels-eyebrow { display: inline-flex; align-items: center; font-size: 12.5px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #a78bfa; margin-bottom: 14px; padding: 6px 14px; border-radius: 999px; background: rgba(167,139,250,0.1); border: 1px solid rgba(167,139,250,0.28); }
    .reels-title { font-family: 'Inter', sans-serif; font-size: clamp(28px, 4.5vw, 44px); font-weight: 300; line-height: 1.05; letter-spacing: -0.045em; color: #fff; margin: 0 0 14px; }
    .reels-title strong { font-weight: 700; background: linear-gradient(135deg, #a78bfa 0%, #f97316 50%, #06bfdd 100%); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .reels-sub { font-size: 14px; color: rgba(255,255,255,0.55); margin: 0 auto; max-width: 560px; line-height: 1.55; }

    .reels-upload-card { margin-bottom: 28px; }
    .reels-drop {
      background: linear-gradient(180deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%), rgba(18,18,22,0.92);
      backdrop-filter: blur(24px) saturate(1.3);
      border: 1px dashed rgba(167,139,250,0.3); border-radius: 20px;
      padding: 56px 24px; text-align: center; cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
    }
    .reels-drop:hover, .reels-drop.dragover { border-color: #a78bfa; background: linear-gradient(180deg, rgba(167,139,250,0.08) 0%, rgba(18,18,22,0.92) 100%); }
    .reels-drop svg { color: #a78bfa; opacity: 0.85; margin-bottom: 14px; }
    .reels-drop-title { font-size: 16px; font-weight: 600; color: #fff; margin: 0 0 4px; }
    .reels-drop-hint { font-size: 12.5px; color: rgba(255,255,255,0.45); margin: 0; letter-spacing: 0.01em; }

    .reels-drop-busy { display: flex; flex-direction: column; align-items: center; gap: 10px; }
    .reels-spinner { width: 28px; height: 28px; border: 3px solid rgba(167,139,250,0.2); border-top-color: #a78bfa; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .reels-progress { width: 240px; height: 6px; background: rgba(255,255,255,0.08); border-radius: 999px; overflow: hidden; }
    .reels-progress span { display: block; height: 100%; background: #a78bfa; width: 0%; transition: width 0.2s; }

    .reels-error { background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.25); border-radius: 12px; padding: 10px 14px; color: #ff8a8a; font-size: 13px; margin-top: 12px; }

    .reels-history { background: linear-gradient(180deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%), rgba(18,18,22,0.92); backdrop-filter: blur(24px) saturate(1.3); border: 1px solid rgba(255,255,255,0.09); border-radius: 18px; padding: 22px 24px; }
    .reels-section-label { display: inline-block; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: rgba(255,255,255,0.45); padding: 4px 10px; border-radius: 999px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); margin-bottom: 16px; }
    .reels-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 4px; }
    .reels-list a { display: flex; justify-content: space-between; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 11px; text-decoration: none; color: #fff; transition: background 0.18s; }
    .reels-list a:hover { background: rgba(255,255,255,0.05); }
    .reels-list-main { display: flex; flex-direction: column; gap: 2px; min-width: 0; flex: 1; }
    .reels-list-name { font-size: 13.5px; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .reels-list-meta { font-size: 11.5px; color: rgba(255,255,255,0.45); }
    .reels-pill { font-size: 10.5px; font-weight: 700; padding: 3px 10px; border-radius: 999px; letter-spacing: 0.06em; text-transform: uppercase; flex-shrink: 0; }
    .reels-pill--pending { background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.5); }
    .reels-pill--processing { background: rgba(246,197,71,0.12); color: #f6c547; }
    .reels-pill--done { background: rgba(110,231,163,0.12); color: #6ee7a3; }
    .reels-pill--failed { background: rgba(239,68,68,0.12); color: #ff8a8a; }
  </style>

  <script is:inline>
    const dropzone = document.getElementById('upload-dropzone');
    const fileInput = document.getElementById('reel-file');
    const idleEl = document.getElementById('drop-idle');
    const busyEl = document.getElementById('drop-busy');
    const busyMsg = document.getElementById('busy-msg');
    const progressBar = document.getElementById('progress-bar');
    const progressFill = document.getElementById('progress-fill');
    const errorEl = document.getElementById('upload-error');

    function showError(msg) {
      errorEl.textContent = msg;
      errorEl.hidden = false;
      idleEl.hidden = false; busyEl.hidden = true;
    }

    function setBusy(msg) {
      idleEl.hidden = true; busyEl.hidden = false; errorEl.hidden = true;
      busyMsg.textContent = msg;
    }

    async function startUpload(file) {
      if (!file) return;
      if (file.size > 200 * 1024 * 1024) { showError('File too large. Max 200MB.'); return; }
      setBusy('Uploading…');
      progressBar.hidden = false;

      try {
        const mod = await import('https://esm.sh/@vercel/blob@2.3.3/client');
        const blob = await mod.upload(file.name, file, {
          access: 'public',
          handleUploadUrl: '/api/reels/upload',
          onUploadProgress: ({ percentage }) => { progressFill.style.width = Math.round(percentage) + '%'; },
        });
        setBusy('Queueing analysis…');
        progressBar.hidden = true;
        const r = await fetch('/api/reels/analyze', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            blobUrl: blob.url, blobPathname: blob.pathname,
            fileName: file.name, fileSizeBytes: file.size,
          }),
        });
        const data = await r.json();
        if (!r.ok) { showError(data.error || 'Could not start analysis.'); return; }
        window.location.href = '/reels/analysis/' + data.id;
      } catch (e) {
        showError('Upload failed: ' + (e && e.message ? e.message : 'unknown error'));
      }
    }

    dropzone.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', () => startUpload(fileInput.files?.[0]));
    dropzone.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add('dragover'); });
    dropzone.addEventListener('dragleave', () => dropzone.classList.remove('dragover'));
    dropzone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropzone.classList.remove('dragover');
      startUpload(e.dataTransfer.files?.[0]);
    });
  </script>
</Dashboard>
