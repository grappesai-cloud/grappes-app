---
import Dashboard from '../../../layouts/Dashboard.astro';
import AnalysisView from '../../../components/reels/AnalysisView';
import { findAnalysis } from '../../../lib/reels/db';

const { id } = Astro.params;
const authUser = Astro.locals.user;
if (!authUser) return Astro.redirect(`/sign-in?next=/reels/analysis/${id}`);
if (!id) return Astro.redirect('/reels');

const row = await findAnalysis(id);
if (!row || row.userId !== authUser.id) return Astro.redirect('/reels');
---
<Dashboard title="Analysis">
  <style is:global>
    main { padding-top: 56px !important; padding-bottom: 80px !important; max-width: none !important; }
  </style>
  <div style="max-width:1100px;margin:0 auto;padding:0 8px;">
    <a href="/reels" style="display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:500;color:rgba(255,255,255,0.5);text-decoration:none;letter-spacing:0.04em;text-transform:uppercase;margin-bottom:16px;">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      <span>Reels Lab</span>
    </a>
    <AnalysisView id={id} initial={row} client:load />
  </div>
</Dashboard>
