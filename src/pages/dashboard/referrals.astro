---
import Dashboard from '../../layouts/Dashboard.astro';
import { getReferralStats } from '../../lib/referral';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/sign-in');

const stats = await getReferralStats(user.id);
const baseUrl = import.meta.env.PUBLIC_SITE_URL ?? new URL(Astro.request.url).origin;
const refLink = `${baseUrl}/?ref=${stats.code}`;

const planLabel = (p: string | null) =>
  p === 'agency' ? 'Lifetime' : p === 'pro' ? 'Annual' : p === 'starter' ? 'Monthly' : '—';
---

<Dashboard title="Referrals">
  <div style="max-width:800px;">

    <!-- Header -->
    <div style="margin-bottom:2.5rem;">
      <h1 style="font-size:clamp(1.75rem,3vw,2.25rem);font-weight:700;letter-spacing:-0.04em;margin:0 0 8px;">
        <span>Referral program</span>
      </h1>
      <p style="color:rgba(255,255,255,0.5);font-size:15px;margin:0;">Earn cash for every person you bring to Grappes.</p>
    </div>

    <!-- Stats row -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:16px;margin-bottom:2rem;">
      {[
        { label: 'Available balance', value: `${stats.balance.toFixed(2)}€`, highlight: stats.balance >= 50 },
        { label: 'Total earned', value: `${stats.totalEarned.toFixed(2)}€`, highlight: false },
        { label: 'Confirmed referrals', value: String(stats.confirmedCount), highlight: false },
        { label: 'Pending referrals', value: String(stats.pendingCount), highlight: false },
      ].map(s => (
        <div style={`background:rgba(255,255,255,0.04);border:1px solid ${s.highlight ? 'rgba(6,191,221,0.3)' : 'rgba(255,255,255,0.07)'};border-radius:16px;padding:20px;`}>
          <p style="font-size:12px;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:0.08em;margin:0 0 8px;">{s.label}</p>
          <p style={`font-size:1.75rem;font-weight:700;font-family:'Inter',sans-serif;margin:0;color:${s.highlight ? '#06bfdd' : '#fff'};`}>{s.value}</p>
        </div>
      ))}
    </div>

    <!-- Link & Code card -->
    <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:20px;padding:28px;margin-bottom:1.5rem;">
      <h2 style="font-size:16px;font-weight:700;margin:0 0 20px;">Your referral link & code</h2>

      <!-- Link -->
      <div style="margin-bottom:16px;">
        <label style="font-size:12px;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;">Link (for social media, bio, articles)</label>
        <div style="display:flex;gap:10px;align-items:center;">
          <input id="ref-link" type="text" value={refLink} readonly
            style="flex:1;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:12px 16px;color:#fff;font-size:14px;font-family:monospace;outline:none;" />
          <button id="copy-link" onclick="navigator.clipboard.writeText(document.getElementById('ref-link').value);this.textContent='✓';setTimeout(()=>this.textContent='Copy',1500);"
            style="background:#06bfdd;color:#0a0a0a;border:none;border-radius:10px;padding:12px 18px;font-weight:700;font-size:13px;cursor:pointer;white-space:nowrap;">
            Copy
          </button>
        </div>
      </div>

      <!-- Code -->
      <div>
        <label style="font-size:12px;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:6px;">Code (mention verbally — podcast, video)</label>

        <!-- Display mode -->
        <div id="code-display" style="display:flex;gap:10px;align-items:center;">
          <div id="code-value" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:12px 20px;font-size:18px;font-weight:700;font-family:monospace;letter-spacing:0.15em;color:#06bfdd;">
            {stats.code.toUpperCase()}
          </div>
          <button id="copy-code"
            style="background:rgba(255,255,255,0.08);color:#fff;border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:12px 18px;font-weight:700;font-size:13px;cursor:pointer;">
            Copy
          </button>
          <button id="edit-code-btn"
            style="background:rgba(255,255,255,0.04);color:rgba(255,255,255,0.5);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:12px 18px;font-size:13px;cursor:pointer;">
            ✎ Edit
          </button>
        </div>

        <!-- Edit mode (hidden initially) -->
        <div id="code-edit" style="display:none;flex-direction:column;gap:10px;">
          <div style="display:flex;gap:10px;align-items:center;">
            <input id="code-input" type="text" value={stats.code.toUpperCase()} maxlength="20"
              style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:12px 16px;font-size:18px;font-weight:700;font-family:monospace;letter-spacing:0.15em;color:#fff;outline:none;width:180px;text-transform:uppercase;transition:border-color 0.2s;" />
            <span id="code-status" style="font-size:13px;font-weight:600;min-width:80px;"></span>
          </div>
          <div style="display:flex;gap:8px;">
            <button id="save-code-btn"
              style="background:#06bfdd;color:#0a0a0a;border:none;border-radius:10px;padding:10px 20px;font-weight:700;font-size:13px;cursor:pointer;opacity:0.5;" disabled>
              Save
            </button>
            <button id="cancel-code-btn"
              style="background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.6);border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:10px 18px;font-size:13px;cursor:pointer;">
              Cancel
            </button>
          </div>
          <p id="code-error" style="font-size:12px;color:#f87171;margin:0;display:none;"></p>
        </div>
      </div>
    </div>

    <!-- Rewards table -->
    <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:20px;padding:28px;margin-bottom:1.5rem;">
      <h2 style="font-size:16px;font-weight:700;margin:0 0 16px;">How rewards work</h2>
      <table style="width:100%;border-collapse:collapse;font-size:14px;">
        <thead>
          <tr>
            <th style="text-align:left;padding:10px 0;color:rgba(255,255,255,0.4);font-weight:500;border-bottom:1px solid rgba(255,255,255,0.06);">Plan</th>
            <th style="text-align:left;padding:10px 0;color:rgba(255,255,255,0.4);font-weight:500;border-bottom:1px solid rgba(255,255,255,0.06);">Your reward</th>
            <th style="text-align:left;padding:10px 0;color:rgba(255,255,255,0.4);font-weight:500;border-bottom:1px solid rgba(255,255,255,0.06);">When</th>
          </tr>
        </thead>
        <tbody>
          {[
            { plan: 'Annual (€99/yr)', reward: '€10', when: 'Per conversion' },
            { plan: 'Lifetime (€399)', reward: '€40', when: 'Per conversion' },
          ].map(row => (
            <tr>
              <td style="padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.04);color:rgba(255,255,255,0.8);">{row.plan}</td>
              <td style="padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.04);color:#06bfdd;font-weight:700;">{row.reward}</td>
              <td style="padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.04);color:rgba(255,255,255,0.5);">{row.when}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <p style="margin:16px 0 0;font-size:13px;color:rgba(255,255,255,0.35);">Payout in cash via bank transfer when balance reaches €50.</p>
    </div>

    <!-- Payout request -->
    {stats.balance >= 50 && !stats.hasPendingPayout && (
      <div id="payout-card" style="background:rgba(6,191,221,0.06);border:1px solid rgba(6,191,221,0.2);border-radius:20px;padding:24px;margin-bottom:1.5rem;">
        <p style="font-weight:700;color:#06bfdd;margin:0 0 4px;">You can request a payout!</p>
        <p style="font-size:14px;color:rgba(255,255,255,0.6);margin:0 0 16px;">You have €{stats.balance.toFixed(2)} available. Enter your bank details to receive the payout within 1–3 business days.</p>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
          <input id="payout-iban" type="text" placeholder="IBAN (e.g. RO49AAAA1B31007593840000)" maxlength="34"
            style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:10px 14px;color:#fff;font-size:14px;outline:none;text-transform:uppercase;" />
          <input id="payout-holder" type="text" placeholder="Account holder name" maxlength="120"
            style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:10px 14px;color:#fff;font-size:14px;outline:none;" />
        </div>
        <p id="payout-error" style="color:#f87171;font-size:13px;margin:0 0 10px;display:none;"></p>
        <button id="payout-btn"
          style="background:#06bfdd;color:#0a0a0a;border:none;border-radius:12px;padding:12px 24px;font-weight:700;font-size:14px;cursor:pointer;white-space:nowrap;">Request payout</button>
      </div>
    )}

    {stats.hasPendingPayout && (
      <div style="background:rgba(246,197,71,0.06);border:1px solid rgba(246,197,71,0.2);border-radius:20px;padding:20px;margin-bottom:1.5rem;">
        <p style="color:#f6c547;font-weight:600;margin:0;">Payout in progress — we'll process the transfer to your provided IBAN within 1–3 business days.</p>
      </div>
    )}

    <!-- Referrals history -->
    {stats.referrals.length > 0 && (
      <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:20px;padding:28px;margin-bottom:1.5rem;">
        <h2 style="font-size:16px;font-weight:700;margin:0 0 16px;">Referral history</h2>
        <table style="width:100%;border-collapse:collapse;font-size:14px;">
          <thead>
            <tr>
              <th style="text-align:left;padding:10px 0;color:rgba(255,255,255,0.4);font-weight:500;border-bottom:1px solid rgba(255,255,255,0.06);">Date</th>
              <th style="text-align:left;padding:10px 0;color:rgba(255,255,255,0.4);font-weight:500;border-bottom:1px solid rgba(255,255,255,0.06);">Plan</th>
              <th style="text-align:left;padding:10px 0;color:rgba(255,255,255,0.4);font-weight:500;border-bottom:1px solid rgba(255,255,255,0.06);">Status</th>
              <th style="text-align:right;padding:10px 0;color:rgba(255,255,255,0.4);font-weight:500;border-bottom:1px solid rgba(255,255,255,0.06);">Earned</th>
            </tr>
          </thead>
          <tbody>
            {stats.referrals.map(r => (
              <tr>
                <td style="padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.04);color:rgba(255,255,255,0.6);">
                  {new Date(r.confirmed_at || r.created_at).toLocaleDateString('en-US')}
                </td>
                <td style="padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.04);color:rgba(255,255,255,0.8);">
                  {planLabel(r.plan_type)}
                </td>
                <td style="padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.04);">
                  <span style={`font-size:12px;font-weight:600;padding:3px 10px;border-radius:20px;${r.status === 'confirmed' ? 'background:rgba(6,191,221,0.12);color:#06bfdd;' : 'background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.4);'}`}>
                    {r.status === 'confirmed' ? 'Confirmed' : 'Pending'}
                  </span>
                </td>
                <td style="padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.04);text-align:right;color:#06bfdd;font-weight:700;">
                  {r.amount_earned > 0 ? `+${r.amount_earned}€` : '—'}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    <!-- Payout history -->
    {stats.payouts.length > 0 && (
      <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:20px;padding:28px;">
        <h2 style="font-size:16px;font-weight:700;margin:0 0 16px;">Payout history</h2>
        <table style="width:100%;border-collapse:collapse;font-size:14px;">
          <thead>
            <tr>
              <th style="text-align:left;padding:10px 0;color:rgba(255,255,255,0.4);font-weight:500;border-bottom:1px solid rgba(255,255,255,0.06);">Date</th>
              <th style="text-align:left;padding:10px 0;color:rgba(255,255,255,0.4);font-weight:500;border-bottom:1px solid rgba(255,255,255,0.06);">Amount</th>
              <th style="text-align:left;padding:10px 0;color:rgba(255,255,255,0.4);font-weight:500;border-bottom:1px solid rgba(255,255,255,0.06);">Status</th>
            </tr>
          </thead>
          <tbody>
            {stats.payouts.map(p => (
              <tr>
                <td style="padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.04);color:rgba(255,255,255,0.6);">
                  {new Date(p.paid_at || p.created_at).toLocaleDateString('en-US')}
                </td>
                <td style="padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.04);color:#fff;font-weight:700;">{p.amount.toFixed(2)}€</td>
                <td style="padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.04);">
                  <span style={`font-size:12px;font-weight:600;padding:3px 10px;border-radius:20px;${p.status === 'paid' ? 'background:rgba(6,191,221,0.12);color:#06bfdd;' : 'background:rgba(246,197,71,0.12);color:#f6c547;'}`}>
                    {p.status === 'paid' ? 'Paid' : 'Processing'}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

  </div>
</Dashboard>

<script>
  // ── Payout request ────────────────────────────────────────────────────────
  const payoutBtn = document.getElementById('payout-btn') as HTMLButtonElement | null;
  if (payoutBtn) {
    const ibanInput   = document.getElementById('payout-iban')   as HTMLInputElement;
    const holderInput = document.getElementById('payout-holder') as HTMLInputElement;
    const errEl       = document.getElementById('payout-error')!;

    payoutBtn.addEventListener('click', async () => {
      const iban   = (ibanInput?.value ?? '').trim().replace(/\s+/g, '').toUpperCase();
      const holder = (holderInput?.value ?? '').trim();
      errEl.style.display = 'none';

      if (!/^[A-Z]{2}\d{2}[A-Z0-9]{11,30}$/.test(iban)) {
        errEl.textContent = 'Please enter a valid IBAN.';
        errEl.style.display = 'block';
        return;
      }
      if (holder.length < 2) {
        errEl.textContent = 'Please enter the account holder name.';
        errEl.style.display = 'block';
        return;
      }

      payoutBtn.disabled = true;
      payoutBtn.textContent = 'Sending...';
      try {
        const res = await fetch('/api/referral/request-payout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ iban, holder }),
        });
        if (res.ok) {
          document.getElementById('payout-card')!.innerHTML =
            `<p style="color:#06bfdd;font-weight:600;margin:0;">✓ Request sent. We'll transfer the amount to your IBAN within 1–3 business days.</p>`;
        } else {
          const d = await res.json();
          errEl.textContent = d.error || 'Request failed.';
          errEl.style.display = 'block';
          payoutBtn.disabled = false;
          payoutBtn.textContent = 'Request payout';
        }
      } catch {
        errEl.textContent = 'Network error.';
        errEl.style.display = 'block';
        payoutBtn.disabled = false;
        payoutBtn.textContent = 'Request payout';
      }
    });
  }

  // ── Copy code button ──────────────────────────────────────────────────────
  document.getElementById('copy-code')?.addEventListener('click', () => {
    const code = document.getElementById('code-value')!.textContent!.trim();
    navigator.clipboard.writeText(code);
    const btn = document.getElementById('copy-code')!;
    btn.textContent = '✓';
    setTimeout(() => btn.textContent = 'Copy', 1500);
  });

  // ── Edit code ─────────────────────────────────────────────────────────────
  const codeDisplay = document.getElementById('code-display')!;
  const codeEdit    = document.getElementById('code-edit')!;
  const codeInput   = document.getElementById('code-input') as HTMLInputElement;
  const codeStatus  = document.getElementById('code-status')!;
  const saveBtn     = document.getElementById('save-code-btn') as HTMLButtonElement;
  const cancelBtn   = document.getElementById('cancel-code-btn')!;
  const codeError   = document.getElementById('code-error')!;

  let checkTimeout: ReturnType<typeof setTimeout>;
  let currentCode   = codeInput.value; // original code
  let isAvailable   = false;

  document.getElementById('edit-code-btn')?.addEventListener('click', () => {
    codeDisplay.style.display = 'none';
    codeEdit.style.display = 'flex';
    codeInput.focus();
    codeInput.select();
  });

  cancelBtn.addEventListener('click', () => {
    codeInput.value = currentCode;
    codeStatus.textContent = '';
    codeError.style.display = 'none';
    saveBtn.disabled = true;
    saveBtn.style.opacity = '0.5';
    codeEdit.style.display = 'none';
    codeDisplay.style.display = 'flex';
  });

  codeInput.addEventListener('input', () => {
    const val = codeInput.value.trim().toUpperCase();
    codeInput.value = val;                // force uppercase while typing
    codeStatus.textContent = '';
    codeError.style.display = 'none';
    saveBtn.disabled = true;
    saveBtn.style.opacity = '0.5';
    isAvailable = false;

    if (!val || val === currentCode) return;
    if (!/^[A-Z0-9]{3,20}$/.test(val)) {
      codeStatus.textContent = '✗ 3-20 letters/digits';
      codeStatus.style.color = '#f87171';
      return;
    }

    codeStatus.textContent = '…';
    codeStatus.style.color = 'rgba(255,255,255,0.4)';

    clearTimeout(checkTimeout);
    checkTimeout = setTimeout(async () => {
      try {
        const res = await fetch(`/api/referral/check-code?code=${encodeURIComponent(val.toLowerCase())}`);
        const d = await res.json();
        if (d.available) {
          codeStatus.textContent = '✓ Available';
          codeStatus.style.color = '#06bfdd';
          isAvailable = true;
          saveBtn.disabled = false;
          saveBtn.style.opacity = '1';
        } else {
          codeStatus.textContent = d.error ?? '✗ Unavailable';
          codeStatus.style.color = '#f87171';
          isAvailable = false;
        }
      } catch {
        codeStatus.textContent = '? Check failed';
        codeStatus.style.color = '#f87171';
      }
    }, 400);
  });

  saveBtn.addEventListener('click', async () => {
    if (!isAvailable) return;
    const val = codeInput.value.trim().toLowerCase();
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving…';

    try {
      const res = await fetch('/api/referral/update-code', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code: val }),
      });
      const d = await res.json();
      if (d.ok) {
        const newCode = d.code.toUpperCase();
        currentCode = newCode;
        // Update display + link
        document.getElementById('code-value')!.textContent = newCode;
        const newLink = window.location.origin + '/?ref=' + d.code;
        const linkInput = document.getElementById('ref-link') as HTMLInputElement;
        if (linkInput) linkInput.value = newLink;
        // copy-link reads from the input, no need to update onclick
        // Back to display mode
        cancelBtn.click();
        codeStatus.textContent = '';
      } else {
        codeError.textContent = d.error || 'Save failed.';
        codeError.style.display = 'block';
        saveBtn.disabled = false;
        saveBtn.style.opacity = '1';
        saveBtn.textContent = 'Save';
      }
    } catch {
      codeError.textContent = 'Network error.';
      codeError.style.display = 'block';
      saveBtn.disabled = false;
      saveBtn.style.opacity = '1';
      saveBtn.textContent = 'Save';
    }
  });
</script>
