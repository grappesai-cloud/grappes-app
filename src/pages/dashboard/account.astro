---
import Dashboard from '../../layouts/Dashboard.astro';
import { db } from '../../lib/db';
import { getEditQuota } from '../../lib/edit-quota';
import { createAdminClient } from '../../lib/supabase';

const authUser = Astro.locals.user!;
const [dbUser, quota] = await Promise.all([
  db.users.findById(authUser.id),
  getEditQuota(authUser.id),
]);
const totalCount = dbUser ? await db.projects.countByUser(dbUser.id) : 0;
const totalEditsAvailable = quota.limit + quota.extra;
const totalEditsUsed = quota.used;
const totalRemaining = Math.max(0, totalEditsAvailable - totalEditsUsed);
const quotaDisplay = quota.limit > 0
  ? `${quota.used} / ${quota.limit}${quota.extra > 0 ? ` + ${quota.extra} extra` : ''}`
  : `${totalRemaining} ${quota.extra > 0 ? 'extra' : ''} available`.trim();

const reelCredits  = dbUser?.reel_credits  ?? 0;
const auditCredits = dbUser?.audit_credits ?? 0;

// Press Kit Lab is shelved — counts zeroed for the account usage strip.
const kitsTotal = 0;
const kitsPublished = 0;

const firstName = (authUser.user_metadata?.full_name ?? authUser.user_metadata?.name ?? authUser.email?.split('@')[0] ?? '').split(' ')[0];
---

<Dashboard title="Account">
  <style is:global>
    main { padding-top: 56px !important; padding-bottom: 80px !important; }
  </style>

  <div class="acc-wrap">
    <header class="acc-head">
      <a href="/dashboard" class="acc-back">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        <span>Studio</span>
      </a>
      <span class="acc-eyebrow">Account</span>
      <h1 class="acc-title">{firstName ? <>Settings for <strong>{firstName}</strong>.</> : 'Account settings.'}</h1>
      <p class="acc-sub">Plan, credits, security, language, and danger zone.</p>
    </header>

    <div class="acc-sections">

      <!-- Profile -->
      <section class="acc-card">
        <div class="acc-card-head">
          <span class="acc-label">Profile</span>
        </div>
        <div class="acc-row">
          <span class="acc-row-label">Email</span>
          <span class="acc-row-value" data-user-email={authUser.email}>{authUser.email}</span>
        </div>
        <p class="acc-help">To change your password, we send a reset link to your email.</p>
        <button id="reset-btn" class="acc-btn acc-btn--ghost">Send reset email</button>
        <div id="reset-msg" class="acc-msg" hidden></div>
      </section>

      <!-- Usage across all Studio products -->
      <section class="acc-card">
        <div class="acc-card-head">
          <span class="acc-label">Usage</span>
        </div>
        <div class="acc-usage-grid">
          <div class="acc-usage-item" style="--u-accent:#06bfdd;">
            <span class="acc-usage-name">Sites</span>
            <span class="acc-usage-value">{totalCount} <span class="acc-usage-unit">project{totalCount === 1 ? '' : 's'}</span></span>
          </div>
          <div class="acc-usage-item" style="--u-accent:#06bfdd;">
            <span class="acc-usage-name">AI edits</span>
            <span class="acc-usage-value">{quotaDisplay}</span>
          </div>
          <div class="acc-usage-item" style="--u-accent:#a78bfa;">
            <span class="acc-usage-name">Reels Lab</span>
            <span class="acc-usage-value">{reelCredits} <span class="acc-usage-unit">credit{reelCredits === 1 ? '' : 's'}</span></span>
          </div>
          <div class="acc-usage-item" style="--u-accent:#22d3ee;">
            <span class="acc-usage-name">Audit Lab</span>
            <span class="acc-usage-value">{auditCredits} <span class="acc-usage-unit">audit{auditCredits === 1 ? '' : 's'}</span></span>
          </div>
          <div class="acc-usage-item" style="--u-accent:#f97316;">
            <span class="acc-usage-name">Press Kits</span>
            <span class="acc-usage-value">— <span class="acc-usage-unit">soon</span></span>
          </div>
        </div>
        <div class="acc-help acc-help--top">Credits are provisioned by your administrator. Contact them to top up your balance.</div>
      </section>

      <!-- Language -->
      <section class="acc-card">
        <div class="acc-card-head">
          <span class="acc-label">Language</span>
        </div>
        <div class="acc-lang">
          <button class="acc-lang-btn" id="lang-ro" data-lang="ro">🇷🇴 Română</button>
          <button class="acc-lang-btn" id="lang-en" data-lang="en">🇬🇧 English</button>
        </div>
      </section>

      <!-- Support -->
      <section class="acc-card">
        <div class="acc-card-head">
          <span class="acc-label">Support</span>
        </div>
        <p class="acc-help">Need help? Chat with us on WhatsApp.</p>
        <a href="https://wa.me/40770279935" target="_blank" rel="noopener" class="acc-btn acc-btn--whatsapp">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <span>Chat on WhatsApp</span>
        </a>
      </section>

      <!-- Danger zone -->
      <section class="acc-card acc-card--danger">
        <div class="acc-card-head">
          <span class="acc-label acc-label--danger">Danger zone</span>
        </div>
        <p class="acc-help">Permanently delete your account and all associated data. This action cannot be undone.</p>
        <button id="delete-account-btn" class="acc-btn acc-btn--danger">Delete my account</button>
        <p id="delete-msg" class="acc-msg" hidden></p>
      </section>

    </div>
  </div>

  <style>
    .acc-wrap { max-width: 680px; margin: 0 auto; }

    .acc-head { text-align: center; margin-bottom: 38px; }
    .acc-back {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 12px; font-weight: 500; letter-spacing: 0.04em;
      text-transform: uppercase; color: rgba(255,255,255,0.45);
      text-decoration: none; margin-bottom: 14px;
      transition: color 0.2s;
    }
    .acc-back:hover { color: rgba(255,255,255,0.85); }
    .acc-eyebrow {
      display: inline-flex; align-items: center;
      font-size: 12.5px; font-weight: 700;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: #06bfdd; margin-bottom: 14px;
      padding: 6px 14px; border-radius: 999px;
      background: rgba(6,191,221,0.08);
      border: 1px solid rgba(6,191,221,0.22);
    }
    .acc-title {
      font-family: 'Inter', sans-serif;
      font-size: clamp(28px, 4.5vw, 44px);
      font-weight: 300; line-height: 1.05;
      letter-spacing: -0.045em; color: #fff; margin: 0 0 12px;
    }
    .acc-title strong {
      font-weight: 700;
      background: linear-gradient(135deg, #06bfdd 0%, #a78bfa 50%, #f97316 100%);
      -webkit-background-clip: text; background-clip: text; color: transparent;
    }
    .acc-sub { font-size: 14px; color: rgba(255,255,255,0.55); margin: 0; }

    .acc-sections { display: flex; flex-direction: column; gap: 14px; }

    .acc-card {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%),
        rgba(18, 18, 22, 0.92);
      backdrop-filter: blur(24px) saturate(1.3);
      -webkit-backdrop-filter: blur(24px) saturate(1.3);
      border: 1px solid rgba(255,255,255,0.09);
      border-radius: 18px;
      padding: 22px 24px;
      box-shadow: 0 1px 0 rgba(255,255,255,0.05) inset, 0 12px 28px -16px rgba(0,0,0,0.5);
      display: flex; flex-direction: column; gap: 14px;
    }

    .acc-card-head { margin-bottom: 2px; }
    .acc-label {
      display: inline-block;
      font-size: 11px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.14em; color: rgba(255,255,255,0.45);
      padding: 4px 10px; border-radius: 999px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
    }
    .acc-label--danger { color: #ff8a8a; background: rgba(239,68,68,0.08); border-color: rgba(239,68,68,0.2); }

    .acc-row { display: flex; justify-content: space-between; align-items: center; gap: 12px; }
    .acc-row-label { font-size: 13px; color: rgba(255,255,255,0.55); }
    .acc-row-value { font-size: 13.5px; color: #fff; font-weight: 500; word-break: break-word; text-align: right; }

    .acc-help { font-size: 13px; color: rgba(255,255,255,0.5); margin: 0; line-height: 1.55; }
    .acc-help--top { margin-top: 8px; }

    .acc-btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 10px 18px; border-radius: 11px;
      font-family: inherit; font-size: 13px; font-weight: 600;
      cursor: pointer; align-self: flex-start;
      transition: all 0.2s; text-decoration: none;
      border: 1px solid transparent;
    }
    .acc-btn--ghost {
      background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.78);
      border-color: rgba(255,255,255,0.1);
    }
    .acc-btn--ghost:hover { background: rgba(255,255,255,0.08); color: #fff; border-color: rgba(255,255,255,0.18); }
    .acc-btn--ghost:disabled { opacity: 0.5; cursor: not-allowed; }
    .acc-btn--whatsapp { background: #25d366; color: #fff; }
    .acc-btn--whatsapp:hover { background: #20c05c; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(37,211,102,0.3); }
    .acc-btn--danger {
      background: rgba(239,68,68,0.12); color: #ff8a8a;
      border-color: rgba(239,68,68,0.3);
    }
    .acc-btn--danger:hover { background: rgba(239,68,68,0.2); border-color: rgba(239,68,68,0.5); }
    .acc-btn--danger:disabled { opacity: 0.5; cursor: not-allowed; }

    .acc-msg { font-size: 13px; padding: 10px 14px; border-radius: 10px; margin: 0; }
    .acc-msg.success { background: rgba(56,161,105,0.08); border: 1px solid rgba(56,161,105,0.2); color: #6ee7a3; }
    .acc-msg.error   { background: rgba(229,62,62,0.06); border: 1px solid rgba(229,62,62,0.2); color: #ff8a8a; }

    /* ── Usage grid ─────────────────────────────────────────────── */
    .acc-usage-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 10px;
    }
    .acc-usage-item {
      padding: 12px 14px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 12px;
      display: flex; flex-direction: column; gap: 4px;
      position: relative; overflow: hidden;
      transition: border-color 0.25s ease;
    }
    .acc-usage-item::before {
      content: '';
      position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
      background: var(--u-accent);
      opacity: 0.7;
    }
    .acc-usage-item:hover { border-color: color-mix(in srgb, var(--u-accent) 35%, rgba(255,255,255,0.07)); }
    .acc-usage-name {
      font-size: 10.5px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.1em; color: var(--u-accent);
    }
    .acc-usage-value {
      font-family: 'Inter', sans-serif;
      font-size: 18px; font-weight: 700; letter-spacing: -0.025em;
      color: #fff; line-height: 1.1;
    }
    .acc-usage-unit {
      font-size: 11.5px; font-weight: 500;
      color: rgba(255,255,255,0.5); letter-spacing: 0;
    }

    /* ── Language toggle ────────────────────────────────────────── */
    .acc-lang { display: flex; gap: 8px; }
    .acc-lang-btn {
      flex: 1; padding: 10px; border-radius: 11px;
      font-family: inherit; font-size: 13px; font-weight: 600;
      background: rgba(255,255,255,0.03); color: rgba(255,255,255,0.6);
      border: 1px solid rgba(255,255,255,0.08); cursor: pointer;
      transition: all 0.2s;
    }
    .acc-lang-btn:hover { background: rgba(255,255,255,0.07); color: #fff; }
    .acc-lang-btn.active {
      background: rgba(6,191,221,0.1); color: #06bfdd;
      border-color: rgba(6,191,221,0.35);
    }

    .acc-card--danger { border-color: rgba(239,68,68,0.18); }
  </style>
</Dashboard>

<script>
  document.getElementById('reset-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('reset-btn') as HTMLButtonElement;
    const msg = document.getElementById('reset-msg')!;
    btn.disabled = true;
    btn.textContent = 'Sending…';
    const email = document.querySelector<HTMLElement>('[data-user-email]')?.dataset.userEmail ?? '';
    try {
      const r = await fetch('/api/auth/forget-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, redirectTo: `${location.origin}/reset-password` }),
      });
      if (r.ok) {
        msg.hidden = false;
        msg.className = 'acc-msg success';
        msg.textContent = 'Check your email for the reset link.';
      } else {
        msg.hidden = false;
        msg.className = 'acc-msg error';
        const data = await r.json().catch(() => ({}));
        msg.textContent = data.error || 'Could not send the reset email.';
      }
    } catch {
      msg.hidden = false;
      msg.className = 'acc-msg error';
      msg.textContent = 'Network error.';
    }
    btn.disabled = false;
    btn.textContent = 'Send reset email';
  });

  // Language toggle (cosmetic — persists via localStorage for now)
  const savedLang = localStorage.getItem('grappes_lang') ?? 'en';
  const langButtons = document.querySelectorAll<HTMLButtonElement>('.acc-lang-btn');
  langButtons.forEach(b => {
    if (b.dataset.lang === savedLang) b.classList.add('active');
    b.addEventListener('click', () => {
      langButtons.forEach(x => x.classList.remove('active'));
      b.classList.add('active');
      localStorage.setItem('grappes_lang', b.dataset.lang!);
    });
  });

  document.getElementById('delete-account-btn')?.addEventListener('click', async () => {
    if (!confirm('Permanently delete your account, sites, kits, and credits? This cannot be undone.')) return;
    const btn = document.getElementById('delete-account-btn') as HTMLButtonElement;
    const msg = document.getElementById('delete-msg')!;
    btn.disabled = true;
    btn.textContent = 'Deleting…';
    try {
      const r = await fetch('/api/account/delete', { method: 'POST' });
      if (r.ok) { window.location.href = '/'; return; }
      const data = await r.json().catch(() => ({}));
      msg.hidden = false;
      msg.className = 'acc-msg error';
      msg.textContent = data.error || 'Could not delete account.';
      btn.disabled = false;
      btn.textContent = 'Delete my account';
    } catch {
      msg.hidden = false;
      msg.className = 'acc-msg error';
      msg.textContent = 'Network error.';
      btn.disabled = false;
      btn.textContent = 'Delete my account';
    }
  });
</script>
