---
import Dashboard from '../../../layouts/Dashboard.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import { db } from '../../../lib/db';
import { createAdminClient } from '../../../lib/supabase';

const authUser = Astro.locals.user!;
let dbUser = null;
let projects: import('../../../lib/db').Project[] = [];
let totalCount = 0;
try {
  dbUser = await db.users.findById(authUser.id);
  if (!dbUser) {
    const client = createAdminClient();
    await client.from('users').upsert({
      id: authUser.id,
      email: authUser.email ?? '',
      name: authUser.user_metadata?.full_name ?? authUser.user_metadata?.name ?? null,
    }, { onConflict: 'id' });
    dbUser = await db.users.findById(authUser.id);
  }
  if (dbUser) {
    projects = await db.projects.findByUser(dbUser.id);
    totalCount = projects.length;
  }
} catch (err) {
  console.error('[dashboard/sites] DB error:', err);
}

// IDs of projects still working — the page polls these and refreshes itself the
// moment one finishes, so a freshly generated site appears without a manual reload.
const pendingIds = projects
  .filter(p => p.status === 'generating' || p.status === 'deploying')
  .map(p => p.id);
---

<Dashboard title="Sites">
  <style is:global>
    main { padding-top: 56px !important; padding-bottom: 80px !important; }
    @media (max-width: 768px) {
      main { padding-top: 40px !important; padding-bottom: 60px !important; }
    }
  </style>

  <div style="text-align:center;margin-bottom:36px;">
    <a href="/dashboard" style="display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:500;color:rgba(255,255,255,0.45);text-decoration:none;letter-spacing:0.04em;text-transform:uppercase;margin-bottom:12px;transition:color 0.2s;" onmouseover="this.style.color='rgba(255,255,255,0.8)'" onmouseout="this.style.color='rgba(255,255,255,0.45)'">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      <span>Studio</span>
    </a>
    <h2 style="font-family:'Inter',sans-serif;font-size:44px;font-weight:400;line-height:1.05;letter-spacing:-0.045em;color:#fff;margin-bottom:10px;">Your Sites</h2>
    <p style="font-size:14px;color:rgba(255,255,255,0.5);margin-bottom:22px;">
      {totalCount} / {dbUser?.projects_limit ?? 1} <span>project(s) used</span>
    </p>
    <a href="/dashboard/new" style="display:inline-flex;align-items:center;gap:8px;background:#06bfdd;color:#0a0a0a;border:none;border-radius:999px;padding:12px 24px;font-size:13.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;text-decoration:none;transition:all 0.3s;line-height:1;">
      <span>+ New Project</span>
      <svg width="16" height="16" viewBox="0 0 28 28" fill="none"><rect x="5.066" y="19.978" width="20.571" height="2.612" transform="rotate(-40.28 5.066 19.978)" fill="currentColor"/><rect x="7.971" y="7.245" width="2.612" height="2.612" transform="rotate(-40.28 7.971 7.245)" fill="currentColor"/><rect x="11.652" y="7.548" width="2.612" height="2.612" transform="rotate(-40.28 11.652 7.548)" fill="currentColor"/><rect x="15.334" y="7.852" width="2.612" height="2.612" transform="rotate(-40.28 15.334 7.852)" fill="currentColor"/><rect x="18.712" y="11.837" width="2.612" height="2.612" transform="rotate(-40.28 18.712 11.837)" fill="currentColor"/><rect x="18.408" y="15.52" width="2.612" height="2.612" transform="rotate(-40.28 18.408 15.52)" fill="currentColor"/><rect x="18.104" y="19.201" width="2.612" height="2.612" transform="rotate(-40.28 18.104 19.201)" fill="currentColor"/></svg>
    </a>
  </div>

  {projects.length > 0 ? (
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,260px));gap:18px;justify-content:center;">
      {projects.map(p => <ProjectCard project={p} />)}
    </div>
  ) : (
    <div style="text-align:center;padding:60px 20px;color:rgba(255,255,255,0.5);">
      <p style="font-size:15px;margin-bottom:6px;">No sites yet.</p>
      <p style="font-size:13px;color:rgba(255,255,255,0.4);">Start your first AI-generated website with the button above.</p>
    </div>
  )}

  <script is:inline define:vars={{ pendingIds }}>
    (function () {
      if (!pendingIds || !pendingIds.length) return;
      var watching = pendingIds.slice();
      var poll = setInterval(async function () {
        try {
          for (var i = 0; i < watching.length; i++) {
            var res = await fetch('/api/projects/' + watching[i] + '/launch');
            if (!res.ok) continue;
            var data = await res.json();
            if (data.status === 'generated' || data.status === 'live' || data.status === 'failed') {
              clearInterval(poll);
              window.location.reload();
              return;
            }
          }
        } catch (e) {}
      }, 4000);
      // Safety stop well past the worst-case generation time.
      setTimeout(function () { clearInterval(poll); }, 30 * 60 * 1000);
    })();
  </script>
</Dashboard>
