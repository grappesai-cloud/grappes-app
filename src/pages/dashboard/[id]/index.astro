    .bdr-left { display: flex; flex-direction: column; gap: 4px; }
    .bdr-name { font-size: 15px; font-weight: 700; color: #fff; }
    .bdr-status-available { font-size: 12px; color: #4ade80; font-weight: 600; }
    .bdr-status-unavailable { font-size: 12px; color: #f87171; font-weight: 600; }
    .bdr-price { font-size: 13px; color: rgba(255,255,255,0.5); }
    .bdr-premium { font-size: 11px; color: #fbbf24; font-weight: 600; }
    .buy-confirm-btn {
      background: #9BD4D7; color: #0a0a0a; border: none; border-radius: 10px;
      padding: 10px 20px; font-size: 13px; font-weight: 700; cursor: pointer;
      transition: background 0.2s; white-space: nowrap; flex-shrink: 0;
    }
    .buy-confirm-btn:hover { background: #00e088; }
    .buy-confirm-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .buy-domain-error {
      font-size: 13px; color: #f87171;
      background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2);
      padding: 10px 14px; border-radius: 10px;
    }
    .buy-domain-success {
      font-size: 13px; color: #4ade80; line-height: 1.6;
      background: rgba(34,197,94,0.08); border: 1px solid rgba(34,197,94,0.2);
      padding: 14px 16px; border-radius: 10px;
    }
  </style>

  <script define:vars={{ projectId: id, isLaunching, isLive, isGenerated, hasPreview, previewUrl, justActivated, showActivate, serverSectionIds }}>
    // LANGUAGE
    const _lang = (localStorage.getItem('i18nextLng') || 'en').split('-')[0];
    document.querySelectorAll('.edit-suggestion[data-msg-ro]').forEach(btn => {
      const msg = _lang === 'en' ? btn.dataset.msgEn : btn.dataset.msgRo;
      if (msg) { btn.dataset.msg = msg; btn.textContent = _lang === 'en' ? btn.dataset.msgEn : btn.dataset.msgRo; }
    });

    // EDIT QUOTA — load on mount and update UI
    const quotaBar   = document.getElementById('edit-quota-bar');
    const quotaLabel = document.getElementById('quota-label');
    const buyBtn     = document.getElementById('buy-edits-btn');

    async function loadQuota() {
      try {
        const res  = await fetch('/api/billing/edit-quota');
        if (!res.ok) return;
        const q = await res.json();
        renderQuota(q);
      } catch {}
    }

    function renderQuota(q) {
      const isRo = _lang !== 'en';
      const remaining = q.remaining ?? 0;

      // Topbar pill
      const topbarQuota = document.getElementById('topbar-quota');
      const topbarLabel = document.getElementById('topbar-quota-label');
      if (topbarQuota && topbarLabel) {
        topbarQuota.className = 'topbar-quota' + (remaining <= 0 ? ' empty' : remaining <= 3 ? ' warn' : '');
        topbarLabel.textContent = remaining <= 0
          ? (isRo ? '0 credite' : '0 credits')
          : (isRo ? `${remaining} credite` : `${remaining} credits`);
      }

      // Inline bar (below suggestions)
      if (quotaBar && quotaLabel) {
        quotaBar.style.display = 'flex';
        if (remaining <= 0) {
          quotaLabel.textContent = isRo ? '0 editări rămase' : '0 edits left';
          quotaLabel.className = 'quota-label empty';
          if (buyBtn) buyBtn.style.display = 'inline';
        } else {
          quotaLabel.textContent = isRo
            ? `${remaining} editări rămase`
            : `${remaining} edits left`;
          quotaLabel.className = `quota-label${remaining <= 1 ? ' warn' : ''}`;
          if (buyBtn) buyBtn.style.display = remaining <= 2 ? 'inline' : 'none';
        }
      }
    }

    if (buyBtn) {
      buyBtn.addEventListener('click', async e => {
        e.preventDefault();
        buyBtn.textContent = '...';
        try {
          const res  = await fetch('/api/billing/buy-edits', { method: 'POST' });
          const data = await res.json();
          if (data.url) window.location.href = data.url;
          else alert(data.error || 'Stripe not configured yet.');
        } catch {
          alert('Error. Try again.');
        }
        buyBtn.textContent = '+ 10 editări / €5';
      });
    }

    if (hasPreview) loadQuota();

    // ACTIVATE MODAL
    const activateModal    = document.getElementById('activate-modal');
    const activateBackdrop = document.getElementById('activate-backdrop');
    const activateLoading  = document.getElementById('activate-loading');
    const activatedBanner  = document.getElementById('activated-banner');

    document.getElementById('activate-btn')?.addEventListener('click', () => {
      if (activateModal) { activateModal.style.display = 'flex'; activateModal.classList.add('open'); }
    });
    activateBackdrop?.addEventListener('click', () => {
      if (activateModal) { activateModal.style.display = 'none'; activateModal.classList.remove('open'); }
    });

    document.querySelectorAll('.activate-plan').forEach(plan => {
      plan.addEventListener('click', async () => {
        const billingType = plan.dataset.billing;
        if (!billingType) return;
        if (activateLoading) activateLoading.style.display = 'block';
        document.querySelectorAll('.activate-plan').forEach(p => p.style.pointerEvents = 'none');
        try {
          const res  = await fetch('/api/billing/activate-site', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ projectId, billingType }),
          });
          const data = await res.json();
          if (data.url) {
            window.location.href = data.url;
          } else {
            alert(data.error || 'Eroare la creare sesiune Stripe.');
            if (activateLoading) activateLoading.style.display = 'none';
            document.querySelectorAll('.activate-plan').forEach(p => p.style.pointerEvents = '');
          }
        } catch {
          alert('Eroare de rețea. Încearcă din nou.');
          if (activateLoading) activateLoading.style.display = 'none';
          document.querySelectorAll('.activate-plan').forEach(p => p.style.pointerEvents = '');
        }
      });
    });

    // Show success banner if redirected back after activation
    if (justActivated && activatedBanner) {
      activatedBanner.style.display = 'block';
      setTimeout(() => { activatedBanner.style.display = 'none'; }, 4000);
    }

    // Show banner after domain purchase redirect
    if (new URLSearchParams(window.location.search).get('domain_purchased') === '1') {
      const b = document.createElement('div');
      b.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:rgba(34,197,94,0.15);border:1px solid rgba(34,197,94,0.3);color:#4ade80;padding:10px 20px;border-radius:20px;font-size:13px;font-weight:600;z-index:200;backdrop-filter:blur(10px);';
      b.textContent = '✓ Domeniu cumpărat! Va fi activ în câteva minute.';
      document.body.appendChild(b);
      setTimeout(() => b.remove(), 5000);
      window.history.replaceState({}, '', `/dashboard/${projectId}`);
    }

    // VIEWPORT TOGGLES (panel sidebar)

    // ONBOARDING TOUR
    const TOUR_KEY = 'grappes_tour_done';
    const isEn = _lang === 'en';

    const TOUR_STEPS = isEn ? [
      { text: 'Select a section from the list on the left to start editing it.', anchor: '#section-list' },
      { text: 'Describe the change you want in Romanian or English.', anchor: '#edit-input' },
      { text: 'Publish your site with one click using the Publish button above.', anchor: '#publish-btn' },
    ] : [
      { text: 'Selectează o secțiune din lista din stânga pentru a o edita.', anchor: '#section-list' },
      { text: 'Descrie modificarea dorită în română sau engleză.', anchor: '#edit-input' },
      { text: 'Publică site-ul cu un click folosind butonul Publish de sus.', anchor: '#publish-btn' },
    ];

    if (hasPreview && !localStorage.getItem(TOUR_KEY)) {
      let tourStep = 0;
      const overlay = document.getElementById('tour-overlay');
      const tooltip = document.getElementById('tour-tooltip');
      const stepInd = document.getElementById('tour-step-indicator');
      const tourText = document.getElementById('tour-text');
      const nextBtn = document.getElementById('tour-next-btn');

      function positionTourTooltip(anchorSelector) {
        const anchor = document.querySelector(anchorSelector);
        if (!anchor || !tooltip) return;
        const rect = anchor.getBoundingClientRect();
        const tipW = 280, tipH = 140;
        let top = rect.bottom + 12;
        let left = rect.left;
        if (top + tipH > window.innerHeight) top = rect.top - tipH - 12;
        if (left + tipW > window.innerWidth) left = window.innerWidth - tipW - 16;
        if (left < 8) left = 8;
        tooltip.style.top = top + 'px';
        tooltip.style.left = left + 'px';
      }

      function showTourStep(step) {
        if (!overlay || !tourText || !stepInd || !nextBtn) return;
        overlay.style.display = 'block';
        const s = TOUR_STEPS[step];
        stepInd.textContent = `${step + 1} / ${TOUR_STEPS.length}`;
        tourText.textContent = s.text;
        nextBtn.textContent = step === TOUR_STEPS.length - 1
          ? (isEn ? 'Got it!' : 'Am înțeles!')
          : (isEn ? 'Next →' : 'Înainte →');
        positionTourTooltip(s.anchor);
      }

      nextBtn?.addEventListener('click', () => {
        tourStep++;
        if (tourStep >= TOUR_STEPS.length) {
          if (overlay) overlay.style.display = 'none';
          localStorage.setItem(TOUR_KEY, '1');
        } else {
          showTourStep(tourStep);
        }
      });

      // Show tour after sections load (small delay)
      setTimeout(() => showTourStep(0), 1500);
    }

    // VERSION HISTORY
    const historyToggleBtn = document.getElementById('history-toggle-btn');
    const historyPanel = document.getElementById('history-panel');
    const historyList = document.getElementById('history-list');
    let historyLoaded = false;

    historyToggleBtn?.addEventListener('click', async () => {
      const isOpen = historyPanel?.style.display !== 'none';
      if (isOpen) {
        if (historyPanel) historyPanel.style.display = 'none';
        historyToggleBtn.classList.remove('active');
      } else {
        if (historyPanel) historyPanel.style.display = 'block';
        historyToggleBtn.classList.add('active');
        if (!historyLoaded) {
          historyLoaded = true;
          await loadHistory();
        }
      }
    });

    async function loadHistory() {
      if (!historyList) return;
      try {
        const res = await fetch(`/api/projects/${projectId}/versions`);
        if (!res.ok) { historyList.innerHTML = '<div style="color:#888;font-size:12px;padding:8px 12px;">Eroare la încărcare.</div>'; return; }
        const { versions } = await res.json();
        if (!versions?.length) { historyList.innerHTML = '<div style="color:#888;font-size:12px;padding:8px 12px;">' + (isEn ? 'No versions yet.' : 'Nicio versiune încă.') + '</div>'; return; }

        historyList.innerHTML = '';
        versions.forEach(v => {
          const dt = new Date(v.created_at).toLocaleString(isEn ? 'en-GB' : 'ro-RO', { dateStyle: 'short', timeStyle: 'short' });
          const item = document.createElement('div');
          item.className = 'history-item';
          item.innerHTML = `
            <span class="history-item-meta">v${v.version} — ${dt}</span>
            <button class="history-restore-btn" data-version="${v.version}">${isEn ? 'Restore' : 'Restaurează'}</button>
          `;
          item.querySelector('.history-restore-btn')?.addEventListener('click', async (e) => {
            const btn = e.target;
            btn.textContent = '…';
            btn.disabled = true;
            await fetch(`/api/projects/${projectId}/versions/restore`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ version: v.version }),
            });
            window.location.reload();
          });
          historyList.appendChild(item);
        });
      } catch {
        historyList.innerHTML = '<div style="color:#888;font-size:12px;padding:8px 12px;">Eroare.</div>';
      }
    }

    // QA STATUS
    if (hasPreview) {
      fetch(`/api/projects/${projectId}/qa-status`)
        .then(r => r.ok ? r.json() : null)
        .then(data => {
          const bar = document.getElementById('qa-status-bar');
          if (!bar || !data) return;
          bar.style.display = 'block';
          const issues = data.issues ?? 0;
          if (issues === 0) {
            bar.innerHTML = '<span class="qa-badge ok">✓ QA OK</span>';
          } else {
            bar.innerHTML = `<span class="qa-badge warn">⚠ ${issues} ${isEn ? 'issue' + (issues === 1 ? '' : 's') : 'problem' + (issues === 1 ? 'ă' : 'e')}</span>`;
          }
        })
        .catch(() => {});
    }

    // CUSTOM DOMAIN
    const domainModal    = document.getElementById('domain-modal');
    const domainBackdrop = document.getElementById('domain-backdrop');
    const domainInput    = /** @type {HTMLInputElement|null} */ (document.getElementById('domain-input'));
    const domainSaveBtn  = /** @type {HTMLButtonElement|null} */ (document.getElementById('domain-modal-save'));
    const domainErrEl    = document.getElementById('domain-modal-error');
    const domainNsSection = document.getElementById('domain-ns-section');
    const domainCloseBtn = document.getElementById('domain-modal-close');

    document.getElementById('domain-add-btn')?.addEventListener('click', () => {
      if (domainModal) domainModal.classList.add('open');
      if (domainNsSection) domainNsSection.hidden = true;
      if (domainErrEl) { domainErrEl.hidden = true; }
      if (domainInput) domainInput.value = '';
      setTimeout(() => domainInput?.focus(), 100);
    });

    domainBackdrop?.addEventListener('click', () => domainModal?.classList.remove('open'));
    domainCloseBtn?.addEventListener('click', () => domainModal?.classList.remove('open'));

    domainSaveBtn?.addEventListener('click', async () => {
      const domain = domainInput?.value.trim();
      if (!domain) return;
      domainSaveBtn.disabled = true;
      domainSaveBtn.textContent = 'Se salvează...';
      if (domainErrEl) domainErrEl.hidden = true;

      try {
        const res  = await fetch(`/api/projects/${projectId}/domain`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ domain }),
        });
        const data = await res.json();
        if (!res.ok || !data.ok) {
          if (domainErrEl) { domainErrEl.textContent = data.error || 'Eroare. Încearcă din nou.'; domainErrEl.hidden = false; }
        } else {
          // Hide form, show nameservers
          domainSaveBtn.style.display = 'none';
          if (domainInput) domainInput.style.display = 'none';
          if (domainNsSection) domainNsSection.hidden = false;
        }
      } catch {
        if (domainErrEl) { domainErrEl.textContent = 'Eroare de rețea. Încearcă din nou.'; domainErrEl.hidden = false; }
      }
      domainSaveBtn.disabled = false;
      domainSaveBtn.textContent = 'Salvează domeniu';
    });

    // Copy nameserver buttons
    document.querySelectorAll('.domain-ns-copy').forEach(btn => {
      btn.addEventListener('click', () => {
        const val = btn.dataset.value ?? '';
        navigator.clipboard.writeText(val).then(() => {
          btn.textContent = 'Copiat ✓';
          setTimeout(() => { btn.textContent = 'Copiază'; }, 2000);
        });
      });
    });

    // Remove domain
    document.getElementById('domain-remove-btn')?.addEventListener('click', async () => {
      if (!confirm('Ești sigur că vrei să ștergi domeniul custom?')) return;
      await fetch(`/api/projects/${projectId}/domain`, { method: 'DELETE' });
      window.location.reload();
    });

    // BUY DOMAIN MODAL
    const buyDomainModal    = document.getElementById('buy-domain-modal');
    const buyDomainBackdrop = document.getElementById('buy-domain-backdrop');
    const buyDomainInput    = /** @type {HTMLInputElement|null} */ (document.getElementById('buy-domain-input'));
    const buyDomainCheckBtn = /** @type {HTMLButtonElement|null} */ (document.getElementById('buy-domain-check-btn'));
    const buyDomainResult   = document.getElementById('buy-domain-result');
    const buyDomainError    = document.getElementById('buy-domain-error');
    const buyDomainSuccess  = document.getElementById('buy-domain-success');

    document.getElementById('domain-buy-btn')?.addEventListener('click', () => {
      buyDomainModal?.classList.add('open');
      if (buyDomainResult) { buyDomainResult.hidden = true; buyDomainResult.innerHTML = ''; }
      if (buyDomainError)  { buyDomainError.hidden = true; }
      if (buyDomainSuccess){ buyDomainSuccess.hidden = true; }
      if (buyDomainInput)  buyDomainInput.value = '';
      setTimeout(() => buyDomainInput?.focus(), 100);
    });
    buyDomainBackdrop?.addEventListener('click', () => buyDomainModal?.classList.remove('open'));

    function showBuyError(msg) {
      if (buyDomainError) { buyDomainError.textContent = msg; buyDomainError.hidden = false; }
    }

    buyDomainCheckBtn?.addEventListener('click', checkDomain);
    buyDomainInput?.addEventListener('keydown', (e) => { if (e.key === 'Enter') checkDomain(); });

    async function checkDomain() {
      const name = buyDomainInput?.value.trim().toLowerCase().replace(/^https?:\/\//,'').replace(/\/.*/,'');
      if (!name) return;
      if (buyDomainError)  buyDomainError.hidden = true;
      if (buyDomainResult) { buyDomainResult.hidden = true; buyDomainResult.innerHTML = ''; }
      if (buyDomainCheckBtn) { buyDomainCheckBtn.disabled = true; buyDomainCheckBtn.textContent = 'Se verifică...'; }

      try {
        const res  = await fetch(`/api/domains/check?name=${encodeURIComponent(name)}`);
        const data = await res.json();

        if (!res.ok) { showBuyError(data.error || 'Eroare la verificare.'); return; }

        if (!buyDomainResult) return;
        buyDomainResult.hidden = false;

        if (data.available) {
          const vercelPriceUsd = data.price ?? 0;
          // Platform charge = Vercel price (≈EUR) + markup (shown from API)
          // We'll fetch the exact charge from the buy-domain endpoint, but estimate here
          const markupEur = 5; // default; actual value from DOMAIN_MARKUP_EUR env
          const chargeEur = Math.ceil(vercelPriceUsd) + markupEur;
          const priceText = vercelPriceUsd ? `${chargeEur}€ / an` : 'Preț indisponibil';
          const premiumNote = data.premium ? '<span class="bdr-premium">★ Domeniu premium</span>' : '';
          buyDomainResult.innerHTML = `
            <div class="buy-domain-result-card available">
              <div class="bdr-left">
                <span class="bdr-name">${name}</span>
                <span class="bdr-status-available">✓ Disponibil</span>
                <span class="bdr-price">${priceText}</span>
                ${premiumNote}
              </div>
              <button class="buy-confirm-btn" id="buy-confirm-btn" data-name="${name}" data-price="${vercelPriceUsd}">
                Cumpără
              </button>
            </div>
          `;
          document.getElementById('buy-confirm-btn')?.addEventListener('click', confirmPurchase);
        } else {
          buyDomainResult.innerHTML = `
            <div class="buy-domain-result-card unavailable">
              <div class="bdr-left">
                <span class="bdr-name">${name}</span>
                <span class="bdr-status-unavailable">✗ Indisponibil</span>
              </div>
            </div>
          `;
        }
      } catch {
        showBuyError('Eroare de rețea. Încearcă din nou.');
      } finally {
        if (buyDomainCheckBtn) { buyDomainCheckBtn.disabled = false; buyDomainCheckBtn.textContent = 'Verifică'; }
      }
    }

    async function confirmPurchase(e) {
      const btn = /** @type {HTMLButtonElement} */ (e.currentTarget);
      const name       = btn.dataset.name;
      const priceUsd   = Number(btn.dataset.price) || 0;

      btn.disabled = true; btn.textContent = 'Se pregătește plata...';
      if (buyDomainError) buyDomainError.hidden = true;

      try {
        const res  = await fetch('/api/billing/buy-domain', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ projectId, domainName: name, domainPriceUsd: priceUsd }),
        });
        const data = await res.json();

        if (!res.ok || !data.url) {
          showBuyError(data.error || 'Eroare la creare sesiune de plată. Încearcă din nou.');
          btn.disabled = false; btn.textContent = 'Cumpără';
          return;
        }

        // Redirect to Stripe Checkout
        window.location.href = data.url;
      } catch {
        showBuyError('Eroare de rețea. Încearcă din nou.');
        btn.disabled = false; btn.textContent = 'Cumpără';
      }
    }

    // LAUNCH — trigger generation and poll until done, then reload into editor
    document.getElementById('launch-btn')?.addEventListener('click', async function() {
      this.disabled = true;
      this.textContent = 'Generating…';
      try {
        const res = await fetch(`/api/projects/${projectId}/launch`, { method: 'POST' });
        if (res.ok) {
          window.location.reload();
        } else {
          const data = await res.json().catch(() => ({}));
          alert(data.error || 'Generation failed.');
          this.disabled = false;
          this.textContent = 'Generate ✦';
        }
      } catch {
        alert('Network error.');
        this.disabled = false;
        this.textContent = 'Generate ✦';
      }
    });

    // Poll while generating — reload page when site is ready (editor loads automatically)
    if (isLaunching) {
      setInterval(async () => {
        try {
          const res = await fetch(`/api/projects/${projectId}/launch`);
          if (!res.ok) return;
          const data = await res.json();
          if (data.status === 'generated' || data.status === 'live') {
            window.location.reload();
          } else if (data.status === 'failed') {
            window.location.reload();
          }
        } catch {}
      }, 3000);
    }

    // PUBLISH
    document.getElementById('publish-btn')?.addEventListener('click', async function() {
      this.disabled = true; this.textContent = 'Publishing…';
      const res = await fetch(`/api/projects/${projectId}/publish`, { method: 'POST' });
      if (res.ok) {
        this.textContent = 'Published ✓';
        // Poll for live status
        const poll = setInterval(async () => {
          const r = await fetch(`/api/projects/${projectId}/launch`);
          const d = await r.json();
          if (d.status === 'live') { clearInterval(poll); window.location.reload(); }
        }, 3000);
      } else {
        this.disabled = false; this.textContent = 'Publish ✦';
        alert('Publish failed. Try again.');
      }
    });

    // EDIT MODE (sections + chat)
    if (hasPreview) {
      let activeSectionId = null;
      let activeElement = null; // { selector, outerHTML, tag } — set when user clicks an element
      let chatHistory = [];
      var _isEn = (document.documentElement.lang || 'en') === 'en';

      // Load section list from preview iframe
      const iframe = document.getElementById('preview-iframe');
      const sectionList = document.getElementById('section-list');

      function populateSections(ids) {
        if (!sectionList) return;
        if (!ids || !ids.length) {
          sectionList.innerHTML = '<div style="color:rgba(255,255,255,0.4);font-size:12px;padding:8px 12px">No sections found.</div>';
          return;
        }
        sectionList.innerHTML = '';
        ids.forEach(id => {
          const div = document.createElement('div');
          div.className = 'section-item';
          div.textContent = id.charAt(0).toUpperCase() + id.slice(1);
          div.dataset.sectionId = id;
          div.addEventListener('click', () => selectSection(id));
          sectionList.appendChild(div);
        });
      }

      // Listen for messages from iframe
      let veDebounce = null;
      window.addEventListener('message', e => {
        if (e.data?.type === 'sections-ready') populateSections(e.data.sectionIds);
        if (e.data?.type === 'section-click') selectSection(e.data.sectionId);
        if (e.data?.type === 'element-click') selectElement(e.data);
        if (e.data?.type === 'element-deselect') { clearElement(); hideVeControls(); }

        // Visual editor: populate controls on element select
        if (e.data?.type === 'wn-select') {
          activeElement = { wnId: e.data.wnId, tag: e.data.tag, elType: e.data.elType };
          showVeControls(e.data);
        }
        if (e.data?.type === 'wn-deselect') hideVeControls();

        // Image edit: open upload dialog
        if (e.data?.type === 'wn-request-image') {
          iframe?.contentWindow?.postMessage({ type: 'wn-image-dialog-ack' }, '*');
          openImageDialog(e.data.wnId, e.data.currentSrc || '');
        }

        // Text edit: open prompt (no separate edit page needed)
        if (e.data?.type === 'wn-request-text') {
          iframe?.contentWindow?.postMessage({ type: 'wn-text-dialog-ack' }, '*');
          var newText = prompt(_isEn ? 'Edit text:' : 'Editează textul:', e.data.text || '');
          if (newText !== null && newText !== e.data.text) {
            iframe?.contentWindow?.postMessage({ type: 'wn-update-text', wnId: e.data.wnId, value: newText }, '*');
            fetch('/api/projects/' + projectId + '/edit-content', {
              method: 'POST', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ wnId: e.data.wnId, prop: 'innerHTML', value: newText }),
            }).catch(function(){});
          }
        }

        // Save edits from iframe (image prompt etc)
        if (e.data?.type === 'wn-edit') {
          fetch('/api/projects/' + projectId + '/edit-content', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ wnId: e.data.wnId, prop: e.data.prop, value: e.data.value }),
          }).catch(function(){});
        }
      });

      function showDeleteBtn(label) {
        var wrap = document.getElementById('ve-delete-wrap');
        if (wrap) {
          wrap.style.display = '';
          var span = wrap.querySelector('span');
          if (span) span.textContent = label || (_isEn ? 'Delete element' : 'Șterge element');
        }
      }
      function hideDeleteBtn() {
        // Delete btn is inside ve-controls; hidden when panel hides
      }

      function showVeControls(data) {
        var panel = document.getElementById('ve-controls');
        if (!panel) return;
        if (data.elType === 'image') {
          // Image: show only delete button
          panel.style.display = 'flex';
          panel.querySelectorAll('.ve-group, .ve-row').forEach(function(g) { g.style.display = 'none'; });
          showDeleteBtn(_isEn ? 'Delete image' : 'Șterge imaginea');
          document.getElementById('ve-hint').style.display = 'none';
          return;
        }
        if (data.elType !== 'text') {
          // container: only show bg color + delete
          panel.style.display = 'flex';
          panel.querySelectorAll('.ve-group').forEach(function(g) { g.style.display = 'none'; });
          var groups = panel.querySelectorAll('.ve-group');
          var bgGroup = groups[groups.length - 1];
          if (bgGroup) { bgGroup.style.display = 'flex'; bgGroup.parentElement.style.display = 'flex'; }
          document.getElementById('ve-bg-color').value = rgbToHex(data.bgColor);
          showDeleteBtn(_isEn ? 'Delete element' : 'Șterge element');
          document.getElementById('ve-hint').style.display = 'none';
          return;
        }

        panel.style.display = 'flex';
        panel.querySelectorAll('.ve-group, .ve-row').forEach(g => g.style.display = '');

        // Font family
        var fontSel = document.getElementById('ve-font-family');
        var currentFont = (data.fontFamily || '').split(',')[0].replace(/['"]/g, '').trim();
        var fonts = data.fonts || [];
        if (currentFont && fonts.indexOf(currentFont) === -1) fonts.unshift(currentFont);
        fonts = ['sans-serif', 'serif', 'monospace'].concat(fonts);
        fontSel.innerHTML = fonts.map(f =>
          '<option value="' + f + '"' + (f === currentFont ? ' selected' : '') + '>' + f + '</option>'
        ).join('');

        document.getElementById('ve-font-size').value = data.fontSize || 16;

        var isBold = parseInt(data.fontWeight) >= 600 || data.fontWeight === 'bold';
        document.getElementById('ve-bold').classList.toggle('ve-active', isBold);
        document.getElementById('ve-italic').classList.toggle('ve-active', data.fontStyle === 'italic');

        var align = (data.textAlign || 'left').replace('start', 'left').replace('end', 'right');
        ['left', 'center', 'right'].forEach(d => document.getElementById('ve-align-' + d).classList.toggle('ve-active', d === align));

        document.getElementById('ve-text-color').value = rgbToHex(data.color);
        document.getElementById('ve-bg-color').value = rgbToHex(data.bgColor);

        document.getElementById('ve-hint').style.display = 'none';
        showDeleteBtn(_isEn ? 'Delete element' : 'Șterge element');
      }

      function hideVeControls() {
        var panel = document.getElementById('ve-controls');
        if (panel) panel.style.display = 'none';
        var hint = document.getElementById('ve-hint');
        if (hint) hint.style.display = '';
        hideDeleteBtn();
      }

      function veApply(jsProp, cssProp, value) {
        if (!activeElement?.wnId) return;
        iframe?.contentWindow?.postMessage({ type: 'wn-update-style', wnId: activeElement.wnId, prop: jsProp, value: value }, '*');
        clearTimeout(veDebounce);
        veDebounce = setTimeout(function() {
          fetch('/api/projects/' + projectId + '/edit-content', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ wnId: activeElement.wnId, prop: cssProp, value: value }),
          }).catch(function(){});
        }, 500);
      }

      function rgbToHex(rgb) {
        if (!rgb || rgb === 'transparent' || rgb === 'rgba(0, 0, 0, 0)' || rgb === 'color(srgb 0 0 0 / 0)') return '#000000';
        if (rgb.startsWith('#')) return rgb.length === 4
          ? '#' + rgb[1]+rgb[1] + rgb[2]+rgb[2] + rgb[3]+rgb[3]
          : rgb.slice(0, 7);
        // Chrome 128+ returns color(srgb r g b) with values 0-1
        if (rgb.startsWith('color(srgb')) {
          var s = rgb.match(/[\d.]+/g);
          if (!s || s.length < 3) return '#000000';
          return '#' + [s[0],s[1],s[2]].map(x => {
            var n = Math.round(parseFloat(x) * 255);
            return Math.min(255, Math.max(0, n)).toString(16).padStart(2,'0');
          }).join('');
        }
        // Standard rgb(r, g, b) / rgba(r, g, b, a) with values 0-255
        var m = rgb.match(/[\d.]+/g);
        if (!m || m.length < 3) return '#000000';
        return '#' + [m[0],m[1],m[2]].map(x => {
          var n = Math.round(parseFloat(x));
          return Math.min(255, Math.max(0, n)).toString(16).padStart(2,'0');
        }).join('');
      }

      // Wire up VE controls
      document.getElementById('ve-font-family')?.addEventListener('change', function() { veApply('fontFamily', 'font-family', this.value); });
      document.getElementById('ve-font-size')?.addEventListener('change', function() { veApply('fontSize', 'font-size', this.value + 'px'); });
      document.getElementById('ve-text-color')?.addEventListener('input', function() { veApply('color', 'color', this.value); });
      document.getElementById('ve-bg-color')?.addEventListener('input', function() { veApply('backgroundColor', 'background-color', this.value); });
      document.getElementById('ve-bold')?.addEventListener('click', function() {
        this.classList.toggle('ve-active');
        veApply('fontWeight', 'font-weight', this.classList.contains('ve-active') ? '700' : '400');
      });
      document.getElementById('ve-italic')?.addEventListener('click', function() {
        this.classList.toggle('ve-active');
        veApply('fontStyle', 'font-style', this.classList.contains('ve-active') ? 'italic' : 'normal');
      });
      ['left', 'center', 'right'].forEach(function(dir) {
        document.getElementById('ve-align-' + dir)?.addEventListener('click', function() {
          ['left','center','right'].forEach(d => document.getElementById('ve-align-'+d)?.classList.remove('ve-active'));
          this.classList.add('ve-active');
          veApply('textAlign', 'text-align', dir);
        });
      });

      // ── Background edit mode ─────────────────────────────────────────
      var bgMode = false;
      var bgActiveSection = null;
      var bgDebounce = null;

      var bgImgMode = false;
      var bgImgActiveSection = null;
      var bgImgType = null;   // 'css' or 'img'
      var bgImgWnId = null;   // wn-id of img element acting as bg

      function deactivateBgModes() {
        bgMode = false; bgImgMode = false;
        bgActiveSection = null; bgImgActiveSection = null;
        document.getElementById('ve-bg-toggle-btn')?.classList.remove('active');
        document.getElementById('ve-bgimg-toggle-btn')?.classList.remove('active');
        document.getElementById('ve-bg-picker')?.classList.remove('active');
        document.getElementById('ve-bgimg-picker')?.classList.remove('active');
        iframe?.contentWindow?.postMessage({ type: 'wn-bg-mode', active: false }, '*');
      }

      document.getElementById('ve-bg-toggle-btn')?.addEventListener('click', function() {
        var wasActive = bgMode;
        deactivateBgModes();
        if (!wasActive) {
          bgMode = true;
          this.classList.add('active');
          iframe?.contentWindow?.postMessage({ type: 'wn-bg-mode', active: true }, '*');
          hideVeControls();
        }
      });

      document.getElementById('ve-bgimg-toggle-btn')?.addEventListener('click', function() {
        var wasActive = bgImgMode;
        deactivateBgModes();
        if (!wasActive) {
          bgImgMode = true;
          this.classList.add('active');
          iframe?.contentWindow?.postMessage({ type: 'wn-bg-mode', active: true }, '*');
          hideVeControls();
        }
      });

      // Listen for section selection in bg mode
      window.addEventListener('message', function(e) {
        if (e.data?.type === 'wn-select-section') {
          var name = e.data.sectionId.charAt(0).toUpperCase() + e.data.sectionId.slice(1);
          activeSectionId = e.data.sectionId;
          hideVeControls();
          showDeleteBtn(_isEn ? 'Delete section: ' + name : 'Șterge secțiunea: ' + name);

          if (bgMode) {
            bgActiveSection = e.data.sectionId;
            document.getElementById('ve-bg-picker')?.classList.add('active');
            document.getElementById('ve-bgimg-picker')?.classList.remove('active');
            document.getElementById('ve-bg-section-name').textContent = name;
            document.getElementById('ve-section-bg-color').value = rgbToHex(e.data.bgColor);
          }

          if (bgImgMode) {
            bgImgActiveSection = e.data.sectionId;
            bgImgType = e.data.bgImageType;  // 'css' or 'img'
            bgImgWnId = e.data.bgImageWnId;  // wn-id of the img element (if type=img)
            document.getElementById('ve-bgimg-picker')?.classList.add('active');
            document.getElementById('ve-bg-picker')?.classList.remove('active');
            document.getElementById('ve-bgimg-section-name').textContent = name;
            // Show current bg image
            var preview = document.getElementById('ve-bgimg-preview');
            var noneText = document.getElementById('ve-bgimg-none');
            var bgImg = e.data.bgImage || '';
            if (bgImg && bgImg !== 'none') {
              // Extract URL from css value like url("...") or use raw src
              var urlMatch = bgImg.match(/url\\(["']?([^"')]+)["']?\\)/);
              var imgUrl = urlMatch ? urlMatch[1] : bgImg;
              preview.style.backgroundImage = 'url(' + imgUrl + ')';
              noneText.style.display = 'none';
            } else {
              preview.style.backgroundImage = '';
              noneText.style.display = '';
            }
          }
        }
      });

      document.getElementById('ve-section-bg-color')?.addEventListener('input', function() {
        if (!bgActiveSection) return;
        var value = this.value;
        iframe?.contentWindow?.postMessage({ type: 'wn-update-style', sectionId: bgActiveSection, prop: 'backgroundColor', value: value }, '*');
        clearTimeout(bgDebounce);
        bgDebounce = setTimeout(function() {
          fetch('/api/projects/' + projectId + '/edit-content', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ sectionId: bgActiveSection, prop: 'background-color', value: value }),
          }).catch(function(){});
        }, 500);
      });

      // "Schimbă imaginea" for bg-image mode
      document.getElementById('ve-bgimg-change')?.addEventListener('click', function() {
        if (!bgImgActiveSection) return;
        if (bgImgType === 'img' && bgImgWnId) {
          // It's an <img> element acting as background — edit its src
          openImageDialog(bgImgWnId, '');
        } else if (bgImgType === 'css' && bgImgWnId) {
          // CSS background-image on a child element with wn-id
          openImageDialog('__bgcss__' + bgImgWnId, '');
        } else {
          // CSS background-image directly on section
          openImageDialog('__section__' + bgImgActiveSection, '');
        }
      });

      // ── Delete element / section ──────────────────────────────────────
      document.getElementById('ve-delete-btn')?.addEventListener('click', function() {
        var confirmMsg = _isEn ? 'Are you sure you want to delete this element?' : 'Sigur vrei să ștergi acest element?';
        if (!confirm(confirmMsg)) return;

        if (activeElement?.wnId) {
          // Delete element by wn-id
          iframe?.contentWindow?.postMessage({ type: 'wn-delete', wnId: activeElement.wnId }, '*');
          fetch('/api/projects/' + projectId + '/edit-content', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ wnId: activeElement.wnId, prop: 'delete' }),
          }).catch(function(){});
          activeElement = null;
          hideVeControls();
        } else if (activeSectionId) {
          // Delete entire section
          iframe?.contentWindow?.postMessage({ type: 'wn-delete-section', sectionId: activeSectionId }, '*');
          fetch('/api/projects/' + projectId + '/edit-content', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ sectionId: activeSectionId, prop: 'delete' }),
          }).catch(function(){});
          activeSectionId = null;
          deactivateBgModes();
          hideVeControls();
        }
      });

      // Section delete buttons (in bg-color and bg-image pickers)
      function deleteActiveSection() {
        var sid = activeSectionId || bgActiveSection || bgImgActiveSection;
        if (!sid) return;
        var confirmMsg = _isEn ? 'Are you sure you want to delete this section?' : 'Sigur vrei să ștergi această secțiune?';
        if (!confirm(confirmMsg)) return;
        iframe?.contentWindow?.postMessage({ type: 'wn-delete-section', sectionId: sid }, '*');
        fetch('/api/projects/' + projectId + '/edit-content', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ sectionId: sid, prop: 'delete' }),
        }).catch(function(){});
        activeSectionId = null;
        deactivateBgModes();
        hideVeControls();
      }
      document.getElementById('ve-section-delete-btn')?.addEventListener('click', deleteActiveSection);
      document.getElementById('ve-section-delete-btn2')?.addEventListener('click', deleteActiveSection);

      // ── Image upload dialog ──────────────────────────────────────────
      var imgDialogWnId = null;
      var imgDialogUrl = '';
      var imgOverlay = document.getElementById('img-dialog-overlay');
      var imgThumb = document.getElementById('img-dialog-thumb');
      var imgDropText = document.getElementById('img-drop-text');
      var imgFileInput = document.getElementById('img-dialog-file');
      var imgUrlInput = document.getElementById('img-dialog-url');
      var imgSaveBtn = document.getElementById('img-dialog-save');
      var imgUploadingEl = document.getElementById('img-dialog-uploading');
      var imgDropZone = document.getElementById('img-dialog-drop');

      function openImageDialog(wnId, currentSrc) {
        imgDialogWnId = wnId;
        imgDialogUrl = '';
        imgThumb.style.display = currentSrc ? 'block' : 'none';
        imgThumb.src = currentSrc || '';
        imgDropText.style.display = currentSrc ? 'none' : '';
        imgUrlInput.value = '';
        imgSaveBtn.disabled = true;
        imgUploadingEl.style.display = 'none';
        imgOverlay.classList.add('active');
      }

      function closeImageDialog() {
        imgOverlay.classList.remove('active');
        imgDialogWnId = null;
        imgFileInput.value = '';
      }

      function setImagePreview(url) {
        imgDialogUrl = url;
        imgThumb.src = url;
        imgThumb.style.display = 'block';
        imgDropText.style.display = 'none';
        imgSaveBtn.disabled = false;
      }

      async function uploadImageFile(file) {
        imgUploadingEl.style.display = '';
        imgSaveBtn.disabled = true;
        try {
          // Step 1: Get signed upload URL from server
          var signRes = await fetch('/api/assets/' + projectId + '/sign-upload', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ filename: file.name, contentType: file.type }),
          });
          var signData = await signRes.json();
          if (!signData.signedUrl) { alert(signData.error || 'Upload failed'); imgUploadingEl.style.display = 'none'; return; }

          // Step 2: Upload directly to Supabase Storage from browser
          var upRes = await fetch(signData.signedUrl, {
            method: 'PUT',
            headers: { 'Content-Type': file.type },
            body: file,
          });
          if (!upRes.ok) { alert('Upload failed: ' + upRes.statusText); imgUploadingEl.style.display = 'none'; return; }

          setImagePreview(signData.publicUrl);
        } catch (e) {
          alert('Upload failed');
        }
        imgUploadingEl.style.display = 'none';
      }

      // Click drop zone → open file picker
      imgDropZone?.addEventListener('click', function() { imgFileInput?.click(); });

      // File selected
      imgFileInput?.addEventListener('change', function() {
        if (this.files?.[0]) uploadImageFile(this.files[0]);
      });

      // Drag & drop
      imgDropZone?.addEventListener('dragover', function(e) { e.preventDefault(); this.classList.add('dragover'); });
      imgDropZone?.addEventListener('dragleave', function() { this.classList.remove('dragover'); });
      imgDropZone?.addEventListener('drop', function(e) {
        e.preventDefault(); this.classList.remove('dragover');
        var file = e.dataTransfer?.files?.[0];
        if (file && file.type.startsWith('image/')) uploadImageFile(file);
      });

      // URL input
      imgUrlInput?.addEventListener('input', function() {
        var val = this.value.trim();
        if (val && (val.startsWith('http://') || val.startsWith('https://'))) {
          setImagePreview(val);
        } else {
          imgSaveBtn.disabled = !imgDialogUrl;
        }
      });

      // Cancel
      document.getElementById('img-dialog-cancel')?.addEventListener('click', closeImageDialog);
      imgOverlay?.addEventListener('click', function(e) { if (e.target === this) closeImageDialog(); });

      // Save
      imgSaveBtn?.addEventListener('click', function() {
        if (!imgDialogWnId || !imgDialogUrl) return;

        // CSS background-image on a child element (identified by wn-id)
        if (imgDialogWnId.startsWith('__bgcss__')) {
          var wnId = imgDialogWnId.replace('__bgcss__', '');
          var bgValue = 'url(' + imgDialogUrl + ')';
          iframe?.contentWindow?.postMessage({ type: 'wn-update-style', wnId: wnId, prop: 'backgroundImage', value: bgValue }, '*');
          iframe?.contentWindow?.postMessage({ type: 'wn-update-style', wnId: wnId, prop: 'backgroundSize', value: 'cover' }, '*');
          iframe?.contentWindow?.postMessage({ type: 'wn-update-style', wnId: wnId, prop: 'backgroundPosition', value: 'center' }, '*');
          fetch('/api/projects/' + projectId + '/edit-content', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ wnId: wnId, prop: 'background-image', value: bgValue }),
          }).catch(function(){});
          fetch('/api/projects/' + projectId + '/edit-content', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ wnId: wnId, prop: 'background-size', value: 'cover' }),
          }).catch(function(){});
          fetch('/api/projects/' + projectId + '/edit-content', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ wnId: wnId, prop: 'background-position', value: 'center' }),
          }).catch(function(){});
          var preview = document.getElementById('ve-bgimg-preview');
          if (preview) { preview.style.backgroundImage = bgValue; document.getElementById('ve-bgimg-none').style.display = 'none'; }
          closeImageDialog();
          return;
        }

        // Section background-image mode (directly on section tag)
        if (imgDialogWnId.startsWith('__section__')) {
          var secId = imgDialogWnId.replace('__section__', '');
          var bgValue = 'url(' + imgDialogUrl + ')';
          // Update iframe live
          iframe?.contentWindow?.postMessage({ type: 'wn-update-style', sectionId: secId, prop: 'backgroundImage', value: bgValue }, '*');
          // Also ensure cover + center
          iframe?.contentWindow?.postMessage({ type: 'wn-update-style', sectionId: secId, prop: 'backgroundSize', value: 'cover' }, '*');
          iframe?.contentWindow?.postMessage({ type: 'wn-update-style', sectionId: secId, prop: 'backgroundPosition', value: 'center' }, '*');
          // Save to DB
          fetch('/api/projects/' + projectId + '/edit-content', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ sectionId: secId, prop: 'background-image', value: bgValue }),
          }).catch(function(){});
          fetch('/api/projects/' + projectId + '/edit-content', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ sectionId: secId, prop: 'background-size', value: 'cover' }),
          }).catch(function(){});
          fetch('/api/projects/' + projectId + '/edit-content', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ sectionId: secId, prop: 'background-position', value: 'center' }),
          }).catch(function(){});
          // Update preview in sidebar
          var preview = document.getElementById('ve-bgimg-preview');
          if (preview) { preview.style.backgroundImage = bgValue; document.getElementById('ve-bgimg-none').style.display = 'none'; }
          closeImageDialog();
          return;
        }

        // Normal image element
        iframe?.contentWindow?.postMessage({ type: 'wn-update-image', wnId: imgDialogWnId, value: imgDialogUrl }, '*');
        fetch('/api/projects/' + projectId + '/edit-content', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ wnId: imgDialogWnId, prop: 'src', value: imgDialogUrl }),
        }).catch(function(){});
        closeImageDialog();
      });

      // If server already extracted section IDs, populate immediately (no iframe polling needed)
      let _sectionsPollDone = false;
      if (hasPreview && serverSectionIds && serverSectionIds.length > 0) {
        _sectionsPollDone = true;
        populateSections(serverSectionIds);
      }

      // Poll contentDocument directly — reliable regardless of load event timing
      const _sectionsPoll = setInterval(() => {
        if (_sectionsPollDone) return;
        try {
          const doc = iframe?.contentDocument;
          if (!doc || doc.readyState !== 'complete') return;
          const nodes = doc.querySelectorAll('[data-section]');
          if (!nodes.length) return;
          const ids = [];
          nodes.forEach(n => { if (n.dataset.section && n.dataset.section !== 'full') ids.push(n.dataset.section); });
          if (!ids.length) return;
          _sectionsPollDone = true;
          clearInterval(_sectionsPoll);
          populateSections(ids);
          // Also send request-sections so iframe registers listener for future refreshes
          iframe?.contentWindow?.postMessage({ type: 'request-sections' }, '*');
        } catch {}
      }, 300);
      // Give up after 30s — clear spinner and show fallback message
      setTimeout(() => {
        if (_sectionsPollDone) return;
        _sectionsPollDone = true;
        clearInterval(_sectionsPoll);
        const sl = document.getElementById('section-list');
        if (sl && sl.querySelector('.sections-loading')) {
          sl.innerHTML = '<div style="color:rgba(255,255,255,0.3);font-size:12px;padding:8px 12px">No sections found.<br>Try re-generating.</div>';
        }
      }, 30000);

      function selectSection(sectionId) {
        activeSectionId = sectionId;
        activeElement = null;
        chatHistory = [];

        // Update sidebar
        document.querySelectorAll('.section-item').forEach(el => {
          el.classList.toggle('active', el.dataset.sectionId === sectionId);
        });

        // Enable input
        const input = document.getElementById('edit-input');
        const send = document.getElementById('edit-send');
        if (input) { input.disabled = false; input.placeholder = `Edit ${sectionId}...`; input.focus(); }
        if (send) send.disabled = false;

        // Clear messages
        const msgs = document.getElementById('edit-messages');
        // Section context is shown via active highlight in section list — no message needed

        // Tell iframe to highlight
        iframe?.contentWindow?.postMessage({ type: 'set-active', sectionId }, '*');
      }

      function selectElement(data) {
        // Legacy handler — only update section context, don't overwrite activeElement
        // (wn-select handler sets activeElement with wnId which veApply needs)
        activeSectionId = data.sectionId;
      }

      function clearElement() {
        activeElement = null;
        // Don't clear activeSectionId — keep section context
      }

      // Tip popup toggle
      (function() {
        var btn = document.getElementById('edit-tip-toggle');
        var popup = document.getElementById('edit-tip-popup');
        if (btn && popup) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var open = popup.classList.toggle('show');
            btn.classList.toggle('active', open);
          });
          document.addEventListener('click', function() {
            popup.classList.remove('show');
            btn.classList.remove('active');
          });
        }
      })();

      // Send edit message
      document.getElementById('edit-form')?.addEventListener('submit', async e => {
        e.preventDefault();
        const input = document.getElementById('edit-input');
        const msg = input?.value?.trim();
        if (!msg) return;

        input.value = '';
        addEditMessage('user', msg);

        // Disable while processing
        input.disabled = true;
        document.getElementById('edit-send').disabled = true;
        addEditMessage('system', 'Thinking...');

        try {
          let res, data;

          const removePlaceholder = () => {
            const msgs = document.getElementById('edit-messages');
            const last = msgs?.lastElementChild;
            if (last?.classList?.contains('system') && last.textContent === 'Thinking...') last.remove();
          };

          // Helper: show quota-exceeded message
          const showLimitError = (d) => {
            const isRo = _lang !== 'en';
            const msg = isRo
              ? `Ai atins limita de editări a planului tău (${d.used}/${d.limit + (d.extra||0)}). Cumpără un pachet extra sau fă upgrade.`
              : `Edit limit reached (${d.used}/${d.limit + (d.extra||0)}). Buy an extra pack or upgrade your plan.`;
            addEditMessage('system', msg);
            if (buyBtn) buyBtn.style.display = 'inline';
            if (quotaLabel) { quotaLabel.textContent = isRo ? '0 editări rămase' : '0 edits left'; quotaLabel.className = 'quota-label empty'; }
          };

          // Helper: full-page iterate (used as primary or fallback)
          const runIterate = async (message) => {
            res = await fetch(`/api/projects/${projectId}/iterate`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ message }),
            });
            data = await res.json();
            removePlaceholder();
            if (data.error === 'edit_limit_reached') { showLimitError(data); return; }
            if (data.reply) addEditMessage('assistant', data.reply);
            if (data.newHtml) iframe.src = `${previewUrl}?edit&t=${Date.now()}`;
            await loadQuota();
          };

          if (activeElement) {
            // Element-level edit
            res = await fetch(`/api/projects/${projectId}/edit-element`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                sectionId: activeSectionId,
                selector: activeElement.selector,
                outerHTML: activeElement.outerHTML,
                instruction: msg,
              }),
            });
            data = await res.json();
            removePlaceholder();

            if (data.error === 'edit_limit_reached') {
              showLimitError(data);
            } else if (!res.ok && activeSectionId) {
              // Fallback: route to section edit instead of full-site iterate
              res = await fetch(`/api/projects/${projectId}/edit-section`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ sectionId: activeSectionId, instruction: msg }),
              });
              data = await res.json();
              removePlaceholder();
              if (!res.ok) {
                addEditMessage('system', data.error || 'Edit failed. Try rephrasing.');
              } else {
                addEditMessage('assistant', 'Done.');
                if (data.sectionHtml) iframe?.contentWindow?.postMessage({ type: 'update-section', sectionId: data.sectionId || activeSectionId, html: data.sectionHtml }, '*');
                if (data.css) iframe?.contentWindow?.postMessage({ type: 'update-style', css: data.css }, '*');
                activeElement = null;
                await loadQuota();
              }
            } else if (!res.ok) {
              removePlaceholder();
              addEditMessage('system', data.error || 'Edit failed. Select a section and try again.');
            } else {
              addEditMessage('assistant', 'Done.');
              if (data.sectionHtml) {
                iframe?.contentWindow?.postMessage({
                  type: 'update-section', sectionId: data.sectionId, html: data.sectionHtml
                }, '*');
              }
              if (data.css) {
                iframe?.contentWindow?.postMessage({ type: 'update-style', css: data.css }, '*');
              }
              activeElement = null;
              await loadQuota();
            }
          } else if (activeSectionId) {
            // Section-level edit
            res = await fetch(`/api/projects/${projectId}/edit-section`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ sectionId: activeSectionId, instruction: msg }),
            });
            data = await res.json();
            removePlaceholder();
            if (data.error === 'edit_limit_reached') {
              showLimitError(data);
            } else if (!res.ok) {
              addEditMessage('system', data.error || 'Edit failed. Try rephrasing.');
            } else {
              addEditMessage('assistant', 'Done.');
              if (data.sectionHtml) {
                iframe?.contentWindow?.postMessage({ type: 'update-section', sectionId: data.sectionId || activeSectionId, html: data.sectionHtml }, '*');
              }
              if (data.css) {
                iframe?.contentWindow?.postMessage({ type: 'update-style', css: data.css }, '*');
              }
              await loadQuota();
            }
          } else {
            // No section selected — tell user to select one
            removePlaceholder();
            addEditMessage('system', _lang !== 'en' ? 'Selectează o secțiune din stânga sau apasă ✦ pentru a edita tot site-ul.' : 'Select a section from the left or press ✦ to edit the whole site.');
          }
        } catch {
          addEditMessage('system', 'Error. Try again.');
        }

        input.disabled = false;
        document.getElementById('edit-send').disabled = false;
        input.focus();
      });

      // ✦ Global edit button (4 credits)
      document.getElementById('edit-global')?.addEventListener('click', async () => {
        const input = document.getElementById('edit-input');
        const msg = input?.value?.trim();
        if (!msg) { addEditMessage('system', _lang !== 'en' ? 'Scrie o instrucțiune mai întâi.' : 'Write an instruction first.'); return; }

        const isRo = _lang !== 'en';
        if (!confirm(isRo ? 'Editarea întregului site consumă 4 credite. Continui?' : 'Editing the entire site costs 4 credits. Continue?')) return;

        input.value = '';
        addEditMessage('user', '✦ ' + msg);
        input.disabled = true;
        document.getElementById('edit-send').disabled = true;
        document.getElementById('edit-global').disabled = true;
        addEditMessage('system', isRo ? 'Se editează tot site-ul…' : 'Editing entire site…');

        try {
          await runIterate(msg);
        } catch {
          addEditMessage('system', 'Error. Try again.');
        }

        input.disabled = false;
        document.getElementById('edit-send').disabled = false;
        document.getElementById('edit-global').disabled = false;
        input.focus();
      });

      // Suggestion buttons
      document.querySelectorAll('.edit-suggestion').forEach(btn => {
        btn.addEventListener('click', () => {
          const input = document.getElementById('edit-input');
          const form = document.getElementById('edit-form');
          if (input && !input.disabled && form) {
            input.value = btn.dataset.msg;
            form.requestSubmit();
          }
        });
      });

      function addEditMessage(role, text) {
        const msgs = document.getElementById('edit-messages');
        if (!msgs) return;
        const div = document.createElement('div');
        div.className = `edit-msg ${role}`;
        div.textContent = text;
        msgs.appendChild(div);
        msgs.scrollTop = msgs.scrollHeight;
      }
    }
  </script>
</body>
</html>
