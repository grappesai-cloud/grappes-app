---
import OnboardingChat from '../../../components/islands/OnboardingChat.astro';
import StatusBadge from '../../../components/StatusBadge.astro';
import { db } from '../../../lib/db';
import { getSitePrice } from '../../../lib/site-billing';
import { generateShareToken } from '../../preview/[projectId]';

const { id } = Astro.params;
const authUser = Astro.locals.user!;

const project = await db.projects.findById(id!);
if (!project || project.user_id !== authUser.id) return Astro.redirect('/dashboard');

const justActivated = new URL(Astro.request.url).searchParams.get('activated') === '1';

const [brief, conversation, deployments] = await Promise.all([
  db.briefs.findByProjectId(id!),
  db.conversations.findByProjectId(id!),
  db.deployments.findByProject(id!),
]);

const isOnboarding = ['onboarding'].includes(project.status);
const isBriefReady = project.status === 'brief_ready';
const isLaunching  = ['generating'].includes(project.status);
const isDeploying  = project.status === 'deploying';
const isGenerated  = project.status === 'generated';
const isLive       = project.status === 'live';
const isFailed     = project.status === 'failed';
const hasPreview   = isGenerated || isLive || isDeploying;
const briefCompleteness = brief?.completeness ?? 0;
const hasConversation = conversation && conversation.messages && conversation.messages.length >= 2;
const canForceGenerate = isOnboarding && (briefCompleteness >= 0.3 || hasConversation);
const canLaunch = ['brief_ready', 'generated', 'failed'].includes(project.status) || canForceGenerate;
const shareToken = generateShareToken(id!);
const siteUrl = import.meta.env.SITE ?? import.meta.env.PUBLIC_SITE_URL ?? 'https://grappes.dev';
const sharePreviewUrl = `${siteUrl}/preview/${id}?token=${shareToken}`;

// ── Billing status ──────────────────────────────────────────────────────────
const billingStatus = project.billing_status ?? 'free';
const isBillingActive = billingStatus === 'active';
const isFreeSite      = billingStatus === 'free';
const isExpiredSite   = billingStatus === 'expired';
const showActivate    = (isFreeSite || isExpiredSite) && hasPreview;

const expiresAt = project.expires_at ? new Date(project.expires_at) : null;
const daysRemaining = expiresAt
  ? Math.max(0, Math.ceil((expiresAt.getTime() - Date.now()) / 86_400_000))
  : null;

// Prices for activation modal
const activatePrices = {
  monthly:  getSitePrice('monthly'),
  annual:   getSitePrice('annual'),
  lifetime: getSitePrice('lifetime'),
};

const previewUrl = `/preview/${project.id}`;

// ── Extract section IDs server-side so the sidebar populates instantly ────────
// Parse <section> / <nav> / <footer> tags from stored HTML and derive IDs,
// mirroring the logic in addDataSectionAttributes (html-compat.ts).
const serverSectionIds: string[] = [];
if (hasPreview) {
  const gen = await db.generatedFiles.findLatest(id!);
  const rawHtml = gen?.files?.['__html__full'] ?? '';
  if (rawHtml) {
    let sIdx = 0;
    const tagRe = /<(section|nav|footer)\b([^>]*?)>/gi;
    let m: RegExpExecArray | null;
    while ((m = tagRe.exec(rawHtml)) !== null) {
      const tag = m[1].toLowerCase();
      const attrs = m[2];
      // Check existing data-section
      const dsMatch = attrs.match(/\bdata-section\s*=\s*["']([^"']*)["']/i);
      if (dsMatch && dsMatch[1] && dsMatch[1] !== 'full') {
        serverSectionIds.push(dsMatch[1]);
        continue;
      }
      if (tag === 'nav')    { serverSectionIds.push('nav');    continue; }
      if (tag === 'footer') { serverSectionIds.push('footer'); continue; }
      // Derive from id or class
      const idM  = attrs.match(/\bid\s*=\s*["']([^"']+)["']/i);
      const clsM = attrs.match(/\bclass\s*=\s*["']([^"']+)["']/i);
      if (idM) {
        serverSectionIds.push(idM[1].trim().toLowerCase().replace(/[^a-z0-9-]/g, '-'));
      } else if (clsM) {
        const cls = clsM[1].trim().split(/\s+/).find((c: string) => c.length > 2 && !/^\d/.test(c)) ?? clsM[1].trim().split(/\s+/)[0];
        serverSectionIds.push(cls.toLowerCase().replace(/[^a-z0-9-]/g, '-'));
      } else {
        serverSectionIds.push(`section-${++sIdx}`);
      }
    }
  }
}

---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{project.name} — Grappes</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <style>
    /* RESET */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; overflow: hidden; }
    body {
      font-family: 'Inter', 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      background: #0a0a0a;
      color: #eef2ff; font-size: 14px; line-height: 1.5;
    }
    a { color: inherit; text-decoration: none; }
    button { font: inherit; cursor: pointer; }
    input, textarea { font: inherit; }

    /* LAYOUT */
    .app { display: flex; flex-direction: column; height: 100vh; padding: 12px; gap: 12px; }

    /* Top bar */
    .topbar {
      height: 56px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 28px;
      background: rgba(14, 20, 55, 0.85);
      backdrop-filter: blur(60px) saturate(1.4);
      -webkit-backdrop-filter: blur(60px) saturate(1.4);
      border: 1px solid rgba(255,255,255,0.09);
      border-radius: 999px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.45);
      position: relative;
      z-index: 950;
    }
    .topbar-left { display: flex; align-items: center; gap: 12px; }
    .topbar-logo {
      font-family: 'Inter', 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      font-weight: 800; font-size: 15px; letter-spacing: -0.02em; color: #fff;
    }
    .topbar-logo-accent {
      background: linear-gradient(135deg, #9BD4D7, #00a4af);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    .topbar-link {
      color: rgba(255,255,255,0.5); font-size: 0.875rem; font-weight: 500;
      padding: 6px 14px; border-radius: 8px;
      transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .topbar-link:hover { color: #fff; background: rgba(255,255,255,0.08); }
    .topbar-sep { width: 1px; height: 20px; background: rgba(255,255,255,0.1); }
    .topbar-signout {
      background: none; border: 1px solid rgba(255,255,255,0.15); border-radius: 8px;
      color: rgba(255,255,255,0.5); font-size: 0.75rem; padding: 5px 12px; cursor: pointer;
      transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .topbar-signout:hover { color: #fff; border-color: rgba(255,255,255,0.3); }
    .topbar-avatar {
      width: 32px; height: 32px; border-radius: 50%;
      background: linear-gradient(135deg, #9BD4D7, #00a4af);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.75rem; font-weight: 600; color: #0a0a0a;
      text-transform: uppercase; flex-shrink: 0;
    }
    .topbar-project { color: rgba(255,255,255,0.5); font-size: 13px; font-weight: 500; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .topbar-status { margin-left: 4px; }

    .topbar-center { display: flex; align-items: center; gap: 8px; }
    .topbar-right { display: flex; align-items: center; gap: 8px; }
    .topbar-quota {
      display: flex; align-items: center; gap: 5px;
      padding: 5px 12px; border-radius: 20px;
      border: 1px solid rgba(155,212,215,0.2);
      background: rgba(155,212,215,0.06);
      color: rgba(255,255,255,0.65); font-size: 12px; font-weight: 500;
    }
    .topbar-quota svg { color: #9BD4D7; flex-shrink: 0; }
    .topbar-quota.warn { border-color: rgba(245,158,11,0.3); background: rgba(245,158,11,0.06); }
    .topbar-quota.warn svg { color: #f59e0b; }
    .topbar-quota.empty { border-color: rgba(239,68,68,0.3); background: rgba(239,68,68,0.06); }
    .topbar-quota.empty svg { color: #ef4444; }
    .topbar-btn {
      padding: 6px 16px; border-radius: 12px; font-size: 12px; font-weight: 500;
      border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.6);
      transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .topbar-btn:hover { background: rgba(255,255,255,0.13); color: #fff; }
    .topbar-btn--primary { background: #9BD4D7; color: #0a0a0a; border-color: transparent; font-weight: 600; }
    .topbar-btn--primary:hover { background: #00e088; box-shadow: 0 4px 16px -4px rgba(155,212,215,0.4); }
    .topbar-btn--primary:disabled { opacity: 0.5; cursor: not-allowed; }
    .topbar-btn--upsell { background: rgba(251,191,36,0.12); color: #f6ad55; border-color: rgba(251,191,36,0.25); font-weight: 600; text-decoration: none; }
    .topbar-btn--upsell:hover { background: rgba(251,191,36,0.2); border-color: rgba(251,191,36,0.4); }
    .topbar-btn--share { cursor: pointer; text-decoration: none; }
    .topbar-back { color: rgba(255,255,255,0.4); font-size: 13px; transition: color 0.2s; }
    .topbar-back:hover { color: #fff; }

    /* Main split */
    .main { flex: 1; display: flex; overflow: hidden; gap: 12px; border-radius: 24px; }

    /* Left panel */
    .panel {
      width: 380px; flex-shrink: 0;
      display: flex; flex-direction: column;
      background: rgba(255,255,255,0.04);
      backdrop-filter: blur(80px) saturate(1.2);
      -webkit-backdrop-filter: blur(80px) saturate(1.2);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 4px 32px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.05);
    }

    /* Right preview */
    .preview {
      flex: 1; display: flex; flex-direction: column;
      background: rgba(255,255,255,0.03);
      backdrop-filter: blur(60px);
      -webkit-backdrop-filter: blur(60px);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 4px 32px rgba(0,0,0,0.4);
      position: relative;
    }
    .preview-iframe {
      flex: 1; border: none; width: 100%; height: 100%;
      background: #fff; border-radius: 16px;
      transition: max-width 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .preview-wrapper {
      flex: 1; display: flex; justify-content: center; align-items: stretch;
      overflow: hidden; padding: 12px;
    }
    /* Empty state */
    .preview-empty {
      flex: 1; display: flex; align-items: center; justify-content: center;
      flex-direction: column; gap: 16px;
    }
    .preview-empty-icon { font-size: 48px; opacity: 0.15; color: #fff; }
    .preview-empty-text { font-size: 14px; color: rgba(255,255,255,0.4); max-width: 280px; text-align: center; line-height: 1.7; font-weight: 500; }

    /* Phase: onboarding chat */
    .phase-onboarding { flex: 1; display: flex; flex-direction: column; min-height: 0; }
    .phase-onboarding :global(.chat-container) {
      flex: 1; display: flex; flex-direction: column; min-height: 0;
      background: transparent; backdrop-filter: none; -webkit-backdrop-filter: none;
      border: none; border-radius: 0; box-shadow: none;
      height: auto; max-height: none;
    }
    .phase-onboarding :global(.messages) { flex: 1; overflow-y: auto; background: transparent; min-height: 0; }

    /* Phase: generating spinner */
    .phase-generating {
      flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px; padding: 24px;
    }
    .gen-spinner {
      width: 40px; height: 40px; border: 3px solid rgba(155,212,215,0.2); border-top-color: #9BD4D7;
      border-radius: 50%; animation: genSpin 0.8s linear infinite;
    }
    @keyframes genSpin { to { transform: rotate(360deg); } }
    .gen-title { font-size: 15px; font-weight: 600; color: #fff; }
    .gen-sub { font-size: 13px; color: rgba(255,255,255,0.4); }

    /* Section list header */
    .section-list-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 8px 12px 4px; flex-shrink: 0;
    }
    .section-list-title { font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.06em; }
    .history-toggle-btn {
      display: flex; align-items: center; gap: 4px; padding: 4px 8px;
      border-radius: 8px; font-size: 11px; font-weight: 500; color: rgba(255,255,255,0.45);
      background: none; border: 1px solid transparent;
      transition: all 0.2s cubic-bezier(0.16,1,0.3,1);
    }
    .history-toggle-btn:hover, .history-toggle-btn.active {
      color: #fff; border-color: rgba(255,255,255,0.12); background: rgba(255,255,255,0.07);
    }

    /* History panel */
    .history-panel {
      background: rgba(255,255,255,0.03); border-bottom: 1px solid rgba(255,255,255,0.06);
      flex-shrink: 0; max-height: 200px; overflow-y: auto;
    }
    .history-list { display: flex; flex-direction: column; gap: 2px; padding: 8px; }
    .history-item {
      display: flex; align-items: center; justify-content: space-between;
      padding: 7px 10px; border-radius: 8px; font-size: 12px;
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);
    }
    .history-item-meta { color: rgba(255,255,255,0.5); }
    .history-restore-btn {
      font-size: 11px; font-weight: 600; color: #00a4af; padding: 2px 8px;
      border: 1px solid rgba(0,164,175,0.3); border-radius: 12px; background: none;
      cursor: pointer; transition: all 0.15s;
    }
    .history-restore-btn:hover { background: rgba(0,164,175,0.1); }

    /* QA status — hidden from user */
    .qa-status-bar { display: none !important; }

    /* Phase: edit (generated/live) */
    .phase-edit { flex: 1; display: flex; flex-direction: column; overflow-y: auto; overflow-x: hidden; }
    .section-list { padding: 10px; display: flex; flex-direction: column; gap: 4px; border-bottom: 1px solid rgba(255,255,255,0.06); flex-shrink: 0; max-height: 180px; overflow-y: auto; }
    .section-item {
      padding: 9px 14px; border-radius: 10px; font-size: 13px; cursor: pointer;
      color: rgba(255,255,255,0.5); transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
      border: 1px solid rgba(255,255,255,0.06); background: rgba(255,255,255,0.02);
      font-weight: 500; letter-spacing: 0.01em;
    }
    .section-item:hover { background: rgba(255,255,255,0.06); color: #fff; border-color: rgba(255,255,255,0.12); }
    .section-item.active { background: rgba(155,212,215,0.08); color: #9BD4D7; border-color: rgba(155,212,215,0.25); }

    /* Visual editor controls */
    .ve-hint { padding: 12px; font-size: 12px; color: rgba(255,255,255,0.35); line-height: 1.5; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .ve-controls { padding: 12px; display: flex; flex-direction: column; gap: 12px; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .ve-group { display: flex; flex-direction: column; gap: 4px; }
    .ve-row { display: flex; gap: 10px; }
    .ve-grow { flex: 1; }
    .ve-label { font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.06em; }
    .ve-select {
      background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 6px;
      color: #fff; font-size: 12px; padding: 6px 8px; outline: none; width: 100%;
    }
    .ve-select:focus { border-color: #7c3aed; }
    .ve-input-num {
      background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 6px;
      color: #fff; font-size: 12px; padding: 6px 8px; width: 100%; outline: none; -moz-appearance: textfield;
    }
    .ve-input-num:focus { border-color: #7c3aed; }
    .ve-btn-row { display: flex; gap: 4px; }
    .ve-btn {
      width: 30px; height: 30px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.1);
      background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.5); font-size: 13px; font-weight: 700;
      cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.15s; padding: 0;
    }
    .ve-btn:hover { border-color: rgba(255,255,255,0.25); color: #fff; }
    .ve-btn.ve-active { background: #7c3aed; border-color: #7c3aed; color: #fff; }
    .ve-italic-btn { font-style: italic; font-family: serif; }
    .ve-color { width: 100%; height: 30px; border: 1px solid rgba(255,255,255,0.1); border-radius: 6px; background: transparent; cursor: pointer; padding: 2px; }
    .ve-color::-webkit-color-swatch-wrapper { padding: 1px; }
    .ve-color::-webkit-color-swatch { border-radius: 4px; border: none; }

    .ve-bg-toggle {
      display: flex; align-items: center; gap: 8px; padding: 10px 12px;
      border-bottom: 1px solid rgba(255,255,255,0.06); cursor: pointer; user-select: none;
    }
    .ve-bg-toggle-btn {
      position: relative; width: 36px; height: 20px; border-radius: 10px;
      background: rgba(255,255,255,0.12); border: none; cursor: pointer; transition: background 0.2s; padding: 0;
    }
    .ve-bg-toggle-btn::after {
      content: ''; position: absolute; top: 2px; left: 2px; width: 16px; height: 16px;
      border-radius: 50%; background: #fff; transition: transform 0.2s;
    }
    .ve-bg-toggle-btn.active { background: #7c3aed; }
    .ve-bg-toggle-btn.active::after { transform: translateX(16px); }
    .ve-bg-toggle-label { font-size: 12px; color: rgba(255,255,255,0.6); font-weight: 500; }
    .ve-bg-toggle-btn.active + .ve-bg-toggle-label { color: #c4b5fd; }

    .ve-bg-picker { display: none; padding: 10px 12px; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .ve-bg-picker.active { display: flex; flex-direction: column; gap: 6px; }
    .ve-bg-picker .ve-label { font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.06em; }
    .ve-bg-section-name { font-size: 11px; color: #c4b5fd; font-weight: 600; margin-bottom: 2px; }

    .ve-bgimg-picker { display: none; padding: 10px 12px; border-bottom: 1px solid rgba(255,255,255,0.06); flex-direction: column; gap: 8px; }
    .ve-bgimg-picker.active { display: flex; }
    .ve-bgimg-preview {
      width: 100%; height: 80px; border-radius: 6px; background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1); overflow: hidden;
      background-size: cover; background-position: center;
      display: flex; align-items: center; justify-content: center;
    }
    .ve-bgimg-none { font-size: 11px; color: rgba(255,255,255,0.3); }
    .ve-bgimg-change { width: 100%; padding: 8px; font-size: 12px; }

    .ve-delete-wrap { padding: 10px 12px; border-top: 1px solid rgba(255,255,255,0.06); }
    .ve-delete-btn {
      width: 100%; padding: 8px 12px; border-radius: 6px; border: 1px solid rgba(239,68,68,0.3);
      background: rgba(239,68,68,0.08); color: #f87171; font-size: 12px; font-weight: 500;
      cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 6px;
      transition: all 0.15s;
    }
    .ve-delete-btn:hover { background: rgba(239,68,68,0.18); border-color: rgba(239,68,68,0.5); color: #fca5a5; }

    /* Image dialog */
    .img-dialog-overlay {
      display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6);
      z-index: 1000; align-items: center; justify-content: center;
    }
    .img-dialog-overlay.active { display: flex; }
    .img-dialog {
      background: #0d1229; border: 1px solid rgba(255,255,255,0.12); border-radius: 16px;
      padding: 24px; width: 420px; max-width: 90vw; display: flex; flex-direction: column; gap: 16px;
    }
    .img-dialog-title { font-size: 15px; font-weight: 600; color: #fff; margin: 0; }
    .img-dialog-preview {
      width: 100%; height: 160px; border-radius: 8px; background: rgba(255,255,255,0.04);
      border: 1px dashed rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center;
      overflow: hidden; cursor: pointer; position: relative;
    }
    .img-dialog-preview img { max-width: 100%; max-height: 100%; object-fit: contain; }
    .img-dialog-preview .img-drop-text {
      color: rgba(255,255,255,0.35); font-size: 13px; text-align: center; pointer-events: none;
    }
    .img-dialog-preview.dragover { border-color: #7c3aed; background: rgba(124,58,237,0.08); }
    .img-dialog-url {
      background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 8px;
      color: #fff; font-size: 13px; padding: 10px 12px; outline: none; width: 100%;
    }
    .img-dialog-url:focus { border-color: #7c3aed; }
    .img-dialog-url::placeholder { color: rgba(255,255,255,0.3); }
    .img-dialog-or { text-align: center; font-size: 11px; color: rgba(255,255,255,0.3); text-transform: uppercase; letter-spacing: 0.1em; }
    .img-dialog-actions { display: flex; gap: 8px; justify-content: flex-end; }
    .img-dialog-btn {
      padding: 8px 20px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; border: none; transition: all 0.15s;
    }
    .img-dialog-cancel { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.6); }
    .img-dialog-cancel:hover { background: rgba(255,255,255,0.12); color: #fff; }
    .img-dialog-save { background: #7c3aed; color: #fff; }
    .img-dialog-save:hover { background: #6d28d9; }
    .img-dialog-save:disabled { opacity: 0.4; cursor: not-allowed; }
    .img-dialog-uploading { font-size: 12px; color: #c4b5fd; display: none; }

    .edit-quota-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px; }
    .quota-label { font-size: 11px; color: rgba(255,255,255,0.5); }
    .quota-label.warn { color: #f59e0b; }
    .quota-label.empty { color: #ef4444; font-weight: 600; }
    .quota-buy { font-size: 11px; font-weight: 600; color: #00a4af; text-decoration: none; padding: 2px 8px; border: 1px solid rgba(0,164,175,0.3); border-radius: 20px; transition: all 0.15s; }
    .quota-buy:hover { background: rgba(0,164,175,0.1); }

    .edit-input-area { padding: 12px; border-top: 1px solid rgba(255,255,255,0.06); flex-shrink: 0; }
    .edit-suggestions { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 8px; }
    .edit-suggestion {
      padding: 4px 12px; border-radius: 20px; font-size: 11px;
      border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.5); background: rgba(255,255,255,0.05);
      transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .edit-suggestion:hover { color: #fff; border-color: rgba(155,212,215,0.4); background: rgba(255,255,255,0.08); }
    .edit-tip { position: relative; display: flex; justify-content: flex-end; margin-bottom: 6px; }
    .edit-tip-icon {
      width: 18px; height: 18px; border-radius: 50%; font-size: 11px; font-weight: 700; font-style: italic;
      background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.35); border: 1px solid rgba(255,255,255,0.1);
      display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s;
      font-family: Georgia, serif; line-height: 1;
    }
    .edit-tip-icon:hover, .edit-tip-icon.active { color: #9BD4D7; border-color: rgba(155,212,215,0.4); background: rgba(155,212,215,0.08); }
    .edit-tip-popup {
      display: none; position: absolute; bottom: calc(100% + 8px); right: 0; width: 240px;
      background: #1a1a2e; border: 1px solid rgba(155,212,215,0.2); border-radius: 10px;
      padding: 10px 14px; font-size: 12px; line-height: 1.5; color: rgba(255,255,255,0.7);
      box-shadow: 0 8px 24px rgba(0,0,0,0.4); z-index: 10;
    }
    .edit-tip-popup.show { display: block; animation: tipFadeIn 0.2s ease; }
    .edit-tip-popup strong { color: #9BD4D7; }
    @keyframes tipFadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }
    .edit-form { display: flex; gap: 8px; }
    .edit-input {
      flex: 1; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
      color: #fff; padding: 8px 14px; border-radius: 10px; font-size: 13px; outline: none;
      transition: border-color 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .edit-input:focus { border-color: #9BD4D7; box-shadow: 0 0 0 3px rgba(155,212,215,0.15); }
    .edit-input::placeholder { color: rgba(255,255,255,0.25); }
    .edit-send {
      background: #9BD4D7; color: #0a0a0a; border: none; border-radius: 10px;
      padding: 8px 18px; font-size: 13px; font-weight: 600;
      transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .edit-send:hover { background: #00e088; box-shadow: 0 4px 12px -4px rgba(155,212,215,0.4); }
    .edit-send:disabled { opacity: 0.4; cursor: not-allowed; }
    .edit-global {
      background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.5); border: 1px solid rgba(255,255,255,0.1);
      border-radius: 10px; padding: 8px 12px; font-size: 13px; cursor: pointer;
      transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .edit-global:hover { color: #ff9800; border-color: rgba(255,152,0,0.4); background: rgba(255,152,0,0.08); }
    .edit-global:disabled { opacity: 0.4; cursor: not-allowed; }

    /* Live banner */
    .live-banner {
      padding: 8px 16px; background: rgba(34,197,94,0.08);
      border-bottom: 1px solid rgba(34,197,94,0.12);
      display: flex; align-items: center; gap: 8px; font-size: 12px; flex-shrink: 0;
      border-radius: 16px 16px 0 0;
    }
    .live-dot { width: 6px; height: 6px; border-radius: 50%; background: #22c55e; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{ opacity:1; } 50%{ opacity:0.4; } }
    .live-url { color: #4ade80; }

    /* Responsive */
    @media (max-width: 768px) {
      .main { flex-direction: column; }
      .panel { width: 100%; height: 50%; }
      .topbar-center { display: none; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</head>
<body>
  <div class="app">

    <!-- TOP BAR -->
    <nav class="topbar">
      <div class="topbar-left">
        <a href="/dashboard" class="topbar-logo"><img src="/assets/grappes/logo.png" alt="Grappes" style="height:28px;width:auto;" /></a>
      </div>

      <div class="topbar-center">
        <a href="/dashboard" class="topbar-link">Projects</a>
        <div class="topbar-sep"></div>
        <span class="topbar-project">{project.name}</span>
      </div>

      <div class="topbar-right">
        {hasPreview && project.preview_url && !project.preview_url.startsWith('/') && (
          <a href={project.preview_url} target="_blank" class="topbar-btn">View Live ↗</a>
        )}
        {hasPreview && (
          <button class="topbar-btn topbar-btn--share" onclick={`navigator.clipboard.writeText('${sharePreviewUrl}').then(()=>{this.textContent='Copied!';setTimeout(()=>{this.textContent='Share Preview'},1500)})`}>Share Preview</button>
        )}
        {/* Billing status badge */}
        {isBillingActive && (
          <span class="billing-badge billing-badge--active">✓ Activ</span>
        )}
        {isFreeSite && daysRemaining !== null && isLive && (
          <span class={`billing-badge ${daysRemaining <= 2 ? 'billing-badge--warn' : 'billing-badge--free'}`}>
            {daysRemaining > 0 ? `${daysRemaining}z gratis` : 'Expirat'}
          </span>
        )}
        {isExpiredSite && (
          <span class="billing-badge billing-badge--expired">Expirat</span>
        )}

        {hasPreview && isBillingActive && (
          <button class="topbar-btn topbar-btn--primary" id="publish-btn">
            {isLive ? 'Re-publish' : 'Publish ✦'}
          </button>
        )}
        {hasPreview && !isBillingActive && (
          <>
            <button class="topbar-btn topbar-btn--primary" id="publish-btn">
              {isLive ? 'Re-publish' : 'Publish ✦'}
            </button>
            <button class="topbar-btn topbar-btn--activate" id="activate-btn">Subscribe & Publish</button>
          </>
        )}
        {canLaunch && !isLaunching && !hasPreview && (
          <button class="topbar-btn topbar-btn--primary" id="launch-btn">
            {isFailed ? 'Retry →' : 'Generate ✦'}
          </button>
        )}
        <a href="/dashboard/account" class="topbar-avatar" title="Cont">{authUser.email?.[0]?.toUpperCase() ?? '?'}</a>
      </div>
    </nav>

    <!-- MAIN SPLIT -->
    <div class="main">

      <!-- LEFT PANEL -->
      <div class="panel">

        {/* Phase: Onboarding / Chat */}
        {(isOnboarding || isBriefReady) && (
          <div class="phase-onboarding">
            <OnboardingChat
              projectId={project.id}
              initialMessages={conversation?.messages ?? []}
              initialCompleteness={brief?.completeness ?? 0}
              initialPhase={conversation?.phase ?? 'discovery'}
            />
          </div>
        )}

        {/* Phase: Generating — simple spinner */}
        {isLaunching && (
          <div class="phase-generating">
            <div class="gen-spinner"></div>
            <p class="gen-title">Se generează website-ul...</p>
            <p class="gen-sub">Durează 60-120 secunde. Nu închide pagina.</p>
          </div>
        )}

        {/* Live banner */}
        {isLive && project.preview_url && !project.preview_url.startsWith('/') && (
          <div class="live-banner">
            <div class="live-dot"></div>
            <span>Live:</span>
            <a href={project.preview_url} target="_blank" class="live-url">{project.preview_url} ↗</a>
          </div>
        )}

        {/* Custom domain strip — only for active paid sites */}
        {isLive && isBillingActive && (
          <div class="domain-strip" id="domain-strip">
            {project.custom_domain ? (
              <div class="domain-set">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                <span class="domain-set-name">{project.custom_domain}</span>
                {project.domain_verified
                  ? <span class="domain-verified-badge">✓ Verificat</span>
                  : <span class="domain-pending-badge">⏳ Pendinte</span>
                }
                <button class="domain-remove-btn" id="domain-remove-btn" title="Șterge domeniu">×</button>
              </div>
            ) : (
              <div class="domain-actions">
                <button class="domain-add-btn" id="domain-add-btn">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                  Am deja domeniu
                </button>
                <span class="domain-or">sau</span>
                <button class="domain-buy-btn" id="domain-buy-btn">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                  Cumpără domeniu nou
                </button>
              </div>
            )}
          </div>
        )}

        {/* Phase: Edit (generated/live) — Visual editor sidebar */}
        {hasPreview && (
          <div class="phase-edit">
            <div class="ve-hint" id="ve-hint">Click an element to select it. Double-click to edit.</div>

            <!-- Background edit mode toggle -->
            <div class="ve-bg-toggle">
              <button id="ve-bg-toggle-btn" class="ve-bg-toggle-btn" title="Editare fundal secțiuni"></button>
              <span class="ve-bg-toggle-label">Edit section backgrounds</span>
            </div>
            <div class="ve-bg-picker" id="ve-bg-picker">
              <div class="ve-bg-section-name" id="ve-bg-section-name"></div>
              <label class="ve-label">Section background</label>
              <input type="color" id="ve-section-bg-color" class="ve-color" />
              <button id="ve-section-delete-btn2" class="ve-delete-btn" style="margin-top:8px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2m3 0v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6h14"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                <span>Delete section</span>
              </button>
            </div>

            <!-- Background image mode toggle -->
            <div class="ve-bg-toggle">
              <button id="ve-bgimg-toggle-btn" class="ve-bg-toggle-btn" title="Editare imagini fundal"></button>
              <span class="ve-bg-toggle-label">Edit background images</span>
            </div>
            <div class="ve-bgimg-picker" id="ve-bgimg-picker">
              <div class="ve-bg-section-name" id="ve-bgimg-section-name"></div>
              <div class="ve-bgimg-preview" id="ve-bgimg-preview">
                <span class="ve-bgimg-none" id="ve-bgimg-none">Fără imagine fundal</span>
              </div>
              <button class="img-dialog-btn img-dialog-save ve-bgimg-change" id="ve-bgimg-change">Schimbă imaginea</button>
              <button id="ve-section-delete-btn" class="ve-delete-btn" style="margin-top:8px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2m3 0v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6h14"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                <span>Delete section</span>
              </button>
            </div>

            <!-- Visual editor controls (shown on element select) -->
            <div class="ve-controls" id="ve-controls" style="display:none;">
              <div class="ve-group">
                <label class="ve-label">Font</label>
                <select id="ve-font-family" class="ve-select"></select>
              </div>
              <div class="ve-row">
                <div class="ve-group ve-grow">
                  <label class="ve-label">Size</label>
                  <input type="number" id="ve-font-size" class="ve-input-num" min="8" max="120" />
                </div>
                <div class="ve-group">
                  <label class="ve-label">&nbsp;</label>
                  <div class="ve-btn-row">
                    <button id="ve-bold" class="ve-btn" title="Bold">B</button>
                    <button id="ve-italic" class="ve-btn ve-italic-btn" title="Italic">I</button>
                  </div>
                </div>
              </div>
              <div class="ve-group">
                <label class="ve-label">Alignment</label>
                <div class="ve-btn-row">
                  <button id="ve-align-left" class="ve-btn ve-active" title="Left">☰</button>
                  <button id="ve-align-center" class="ve-btn" title="Center">☰</button>
                  <button id="ve-align-right" class="ve-btn" title="Right">☰</button>
                </div>
              </div>
              <div class="ve-row">
                <div class="ve-group">
                  <label class="ve-label">Text color</label>
                  <input type="color" id="ve-text-color" class="ve-color" />
                </div>
                <div class="ve-group">
                  <label class="ve-label">Background</label>
                  <input type="color" id="ve-bg-color" class="ve-color" />
                </div>
              </div>
              <div class="ve-delete-wrap" id="ve-delete-wrap">
                <button id="ve-delete-btn" class="ve-delete-btn">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2m3 0v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6h14"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                  <span>Delete element</span>
                </button>
              </div>
            </div>

          </div>
        )}

      </div>

      <!-- RIGHT PREVIEW -->
      <div class="preview">
        {hasPreview ? (
          <div class="preview-wrapper" id="preview-wrapper">
            <iframe class="preview-iframe" id="preview-iframe" src={`${previewUrl}?edit`} title={project.name}></iframe>
          </div>
        ) : (
          <div class="preview-empty" id="preview-empty">
            <div class="preview-empty-icon">◇</div>
            <p class="preview-empty-text">
              {isLaunching
                ? 'Website-ul se generează...'
                : isFailed
                ? 'Generarea a eșuat. Apasă "Retry" pentru a reîncerca.'
                : 'Preview-ul va apărea aici după generare.'
              }
            </p>
          </div>
        )}
      </div>

    </div>
  </div>

  <!-- Image upload dialog -->
  <div class="img-dialog-overlay" id="img-dialog-overlay">
    <div class="img-dialog">
      <p class="img-dialog-title">Schimbă imaginea</p>
      <div class="img-dialog-preview" id="img-dialog-drop">
        <img id="img-dialog-thumb" style="display:none" />
        <span class="img-drop-text" id="img-drop-text">Click sau trage o imagine aici</span>
      </div>
      <input type="file" id="img-dialog-file" accept="image/*" style="display:none" />
      <div class="img-dialog-or">sau</div>
      <input type="text" class="img-dialog-url" id="img-dialog-url" placeholder="Lipește URL imagine..." />
      <span class="img-dialog-uploading" id="img-dialog-uploading">Se încarcă...</span>
      <div class="img-dialog-actions">
        <button class="img-dialog-btn img-dialog-cancel" id="img-dialog-cancel">Anulează</button>
        <button class="img-dialog-btn img-dialog-save" id="img-dialog-save" disabled>Salvează</button>
      </div>
    </div>
  </div>

  <!-- Activate modal -->
  <div id="activate-modal">
    <div class="activate-backdrop" id="activate-backdrop"></div>
    <div class="activate-dialog">
      <p class="activate-title">Activează site-ul</p>
      <p class="activate-sub">Alege perioada — site-ul rămâne live și editabil.</p>
      <div class="activate-plans">
        <div class="activate-plan" data-billing="monthly">
          <div class="ap-left">
            <span class="ap-name">Lunar</span>
            <span class="ap-desc">Reînnoire automată lunară</span>
          </div>
          <div class="ap-right">
            <span class="ap-price">{activatePrices.monthly}€<span style="font-size:13px;font-weight:400;color:rgba(255,255,255,0.4)"> /lună</span></span>
          </div>
        </div>
        <div class="activate-plan highlight" data-billing="annual">
          <div class="ap-left">
            <span class="ap-name">Anual ★</span>
            <span class="ap-desc">Cel mai bun preț — un an întreg</span>
          </div>
          <div class="ap-right">
            <span class="ap-price">{activatePrices.annual}€<span style="font-size:13px;font-weight:400;color:rgba(255,255,255,0.4)"> /an</span></span>
          </div>
        </div>
        <div class="activate-plan" data-billing="lifetime">
          <div class="ap-left">
            <span class="ap-name">Lifetime</span>
            <span class="ap-desc">Plătești o singură dată, pentru totdeauna</span>
          </div>
          <div class="ap-right">
            <span class="ap-price">{activatePrices.lifetime}€</span>
          </div>
        </div>
      </div>
      <p class="activate-loading" id="activate-loading">Se redirecționează către Stripe...</p>
    </div>
  </div>

  <!-- Activated success banner -->
  <div id="activated-banner">✓ Site activat cu succes!</div>

  <!-- Domain modal -->
  <div id="domain-modal">
    <div class="domain-backdrop" id="domain-backdrop"></div>
    <div class="domain-dialog">
      <p class="domain-modal-title">Adaugă domeniu custom</p>
      <p class="domain-modal-sub">Introdu domeniul tău (ex: <code>domeniu.com</code> sau <code>www.domeniu.com</code>).</p>
      <input class="domain-input" id="domain-input" type="text" placeholder="domeniu.com" autocomplete="off" spellcheck="false" />
      <div id="domain-modal-error" class="domain-modal-error" hidden></div>
      <button class="domain-modal-btn" id="domain-modal-save">Salvează domeniu</button>

      <div id="domain-ns-section" hidden>
        <p class="domain-ns-title">Schimbă nameserverele domeniului tău la registrar:</p>
        <div class="domain-ns-list">
          <div class="domain-ns-item">
            <code>ns1.vercel-dns.com</code>
            <button class="domain-ns-copy" data-value="ns1.vercel-dns.com">Copiază</button>
          </div>
          <div class="domain-ns-item">
            <code>ns2.vercel-dns.com</code>
            <button class="domain-ns-copy" data-value="ns2.vercel-dns.com">Copiază</button>
          </div>
        </div>
        <p class="domain-ns-note">După ce schimbi nameserverele, propagarea DNS poate dura 24–48h. Site-ul tău va fi accesibil pe domeniul custom odată ce Vercel verifică domeniul.</p>
        <button class="domain-modal-close-btn" id="domain-modal-close">Am înțeles, închide</button>
      </div>
    </div>
  </div>

  <!-- Buy domain modal -->
  <div id="buy-domain-modal">
    <div class="buy-domain-backdrop" id="buy-domain-backdrop"></div>
    <div class="buy-domain-dialog">
      <p class="buy-domain-title">Cumpără domeniu nou</p>
      <p class="buy-domain-sub">Verifică disponibilitatea și cumpără direct prin platformă.</p>

      <div class="buy-domain-search">
        <input class="buy-domain-input" id="buy-domain-input" type="text" placeholder="exemplu.com" autocomplete="off" spellcheck="false" />
        <button class="buy-domain-check-btn" id="buy-domain-check-btn">Verifică</button>
      </div>

      <div id="buy-domain-result" hidden>
        <!-- filled by JS -->
      </div>

      <div id="buy-domain-error" class="buy-domain-error" hidden></div>
      <div id="buy-domain-success" class="buy-domain-success" hidden></div>
    </div>
  </div>

  <!-- Onboarding Tour Overlay -->
  {hasPreview && (
    <div id="tour-overlay" style="display:none;">
      <div class="tour-backdrop"></div>
      <div class="tour-tooltip" id="tour-tooltip">
        <div class="tour-step-indicator" id="tour-step-indicator">1 / 3</div>
        <p class="tour-text" id="tour-text"></p>
        <div class="tour-actions">
          <button class="tour-next-btn" id="tour-next-btn">Înainte →</button>
        </div>
      </div>
    </div>
  )}

  <style>
    /* Tour overlay */
    .tour-backdrop {
      position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 900;
      animation: fadeIn 0.3s ease;
    }
    @keyframes fadeIn { from { opacity:0; } to { opacity:1; } }
    .tour-tooltip {
      position: fixed; z-index: 901; max-width: 280px;
      background: rgba(255,255,255,0.95); color: #1a1a2e;
      border-radius: 16px; padding: 20px;
      box-shadow: 0 8px 40px rgba(0,0,0,0.2);
      animation: slideUp 0.3s cubic-bezier(0.16,1,0.3,1);
    }
    @keyframes slideUp { from { opacity:0; transform: translateY(10px); } to { opacity:1; transform: translateY(0); } }
    .tour-step-indicator { font-size: 11px; font-weight: 600; color: rgba(0,0,0,0.4); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.06em; }
    .tour-text { font-size: 14px; line-height: 1.6; color: #1a1a2e; margin: 0 0 16px; }
    .tour-next-btn {
      background: #9BD4D7; color: #1a1a2e; border: none; border-radius: 20px;
      padding: 8px 20px; font-size: 13px; font-weight: 700; cursor: pointer;
      transition: all 0.2s; width: 100%;
    }
    .tour-next-btn:hover { background: #00e088; }

    /* Billing badges */
