    .buy-domain-result-card.available {
      background: rgba(155,212,215,0.06); border: 1px solid rgba(155,212,215,0.2);
    }
    .buy-domain-result-card.unavailable {
      background: rgba(239,68,68,0.06); border: 1px solid rgba(239,68,68,0.2);
