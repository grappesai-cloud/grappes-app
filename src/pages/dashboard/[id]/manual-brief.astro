---
import Dashboard from '../../../layouts/Dashboard.astro';
import { db } from '../../../lib/db';

const { id } = Astro.params;
const authUser = Astro.locals.user!;

const project = await db.projects.findById(id!);
if (!project || project.user_id !== authUser.id) return Astro.redirect('/dashboard');

if (['brief_ready', 'generating', 'generated', 'deploying', 'live'].includes(project.status)) {
  return Astro.redirect(`/dashboard/${id}/brief`);
}
---

<Dashboard title={`Brief — ${project.name}`} projectId={project.id}>
  <div class="wizard-wrap">

    <div class="page-header">
      <a href="/dashboard" class="back-link" data-en="← Projects">← Proiecte</a>
      <h1 data-en="Create Brief">{project.name}</h1>
      <p class="subtitle" data-en="Fill in the details for your website.">Completează detaliile pentru site-ul tău.</p>
    </div>

    <!-- Step indicator -->
    <div class="steps-bar">
      <div class="step active" data-step="1"><span class="step-num">1</span><span class="step-label" data-en="Basics">Baze</span></div>
      <div class="step-line"></div>
      <div class="step" data-step="2"><span class="step-num">2</span><span class="step-label" data-en="Content">Conținut</span></div>
      <div class="step-line"></div>
      <div class="step" data-step="3"><span class="step-num">3</span><span class="step-label">Branding</span></div>
      <div class="step-line"></div>
      <div class="step" data-step="4"><span class="step-num">4</span><span class="step-label" data-en="Confirm">Confirmare</span></div>
    </div>

    <!-- STEP 1: Basics -->
    <div class="step-panel active" id="panel-1">
      <div class="form-card">

        <div class="field-group">
          <label data-en="Type of site">Tipul site-ului</label>
          <div class="choice-row">
            <button class="choice-btn active" data-field="page_type" data-value="landing">
              <span class="choice-icon">⬛</span>
              <span class="choice-title" data-en="Landing page">Landing page</span>
              <span class="choice-desc" data-en="Single page, high conversion">O pagină, conversie mare</span>
            </button>
            <button class="choice-btn" data-field="page_type" data-value="multi-page">
              <span class="choice-icon">⬛⬛⬛</span>
              <span class="choice-title" data-en="Multi-page">Multi-pagini</span>
              <span class="choice-desc" data-en="Home, About, Services, Contact...">Home, Despre, Servicii, Contact…</span>
            </button>
          </div>
        </div>

        <div class="field-group">
          <label data-en="Industry / domain">Industrie / domeniu</label>
          <div class="industry-chips">
            <button class="tag-btn" data-field="industry_chip" data-value="Restaurant / Cafenea">Restaurant / Cafenea</button>
            <button class="tag-btn" data-field="industry_chip" data-value="Salon / Spa">Salon / Spa</button>
            <button class="tag-btn" data-field="industry_chip" data-value="Freelancer / Portofoliu">Freelancer / Portofoliu</button>
            <button class="tag-btn" data-field="industry_chip" data-value="Agenție">Agenție</button>
            <button class="tag-btn" data-field="industry_chip" data-value="IT / SaaS">IT / SaaS</button>
            <button class="tag-btn" data-field="industry_chip" data-value="Construcții / Renovări">Construcții / Renovări</button>
            <button class="tag-btn" data-field="industry_chip" data-value="Medical / Clinic">Medical / Clinică</button>
            <button class="tag-btn" data-field="industry_chip" data-value="Educație">Educație</button>
            <button class="tag-btn" data-field="industry_chip" data-value="Fitness / Sport">Fitness / Sport</button>
          </div>
          <input type="text" id="industry-input" placeholder="sau scrie industria ta..." data-en-placeholder="or type your industry..." />
        </div>

        <div class="field-group">
          <label data-en="Website language">Limba site-ului</label>
          <div class="choice-row">
            <button class="choice-btn active" data-field="site_language" data-value="ro">
              <span class="choice-icon">🇷🇴</span>
              <span class="choice-title">Română</span>
            </button>
            <button class="choice-btn" data-field="site_language" data-value="en">
              <span class="choice-icon">🇬🇧</span>
              <span class="choice-title">English</span>
            </button>
            <button class="choice-btn" data-field="site_language" data-value="ro-en">
              <span class="choice-icon">🌐</span>
              <span class="choice-title" data-en="Both">Ambele</span>
            </button>
          </div>
        </div>

        <div class="field-group">
          <label data-en="Level of detail">Nivel de detaliu</label>
          <div class="choice-row">
            <button class="choice-btn" data-field="complexity" data-value="essential">
              <span class="choice-title">Essential</span>
              <span class="choice-desc" data-en="6–8 sections, clean">6–8 secțiuni, curat</span>
            </button>
            <button class="choice-btn active" data-field="complexity" data-value="complete">
              <span class="choice-title">Complete</span>
              <span class="choice-desc" data-en="10–14 sections, full">10–14 secțiuni, complet</span>
            </button>
            <button class="choice-btn" data-field="complexity" data-value="showcase">
              <span class="choice-title">Showcase</span>
              <span class="choice-desc" data-en="14+ sections, rich">14+ secțiuni, rich</span>
            </button>
          </div>
        </div>

      </div>
      <div class="step-actions">
        <button class="btn-next" onclick="goToStep(2)" data-en="Continue →">Continuă →</button>
      </div>
    </div>

    <!-- STEP 2: Content -->
    <div class="step-panel" id="panel-2">
      <div class="form-card">

        <div class="field-grid-2">
          <div class="field-group">
            <label data-en="Business name">Numele afacerii <span class="req">*</span></label>
            <input type="text" id="business-name" placeholder="ex: Bella Cucina, Acme SRL..." />
          </div>
          <div class="field-group">
            <label>Tagline <span class="opt" data-en="optional">opțional</span></label>
            <input type="text" id="business-tagline" placeholder="ex: Mâncare cu suflet din 1998" />
          </div>
        </div>

        <div class="field-group">
          <label data-en="Business description (2-3 sentences)">Descriere afacere (2-3 propoziții) <span class="req">*</span></label>
          <textarea id="business-description" rows="3" placeholder="Spune pe scurt ce faci, pentru cine și ce te diferențiază..."></textarea>
        </div>

        <div class="field-group">
          <label data-en="Main headline for the site">Titlu principal pe site <span class="req">*</span></label>
          <input type="text" id="content-headline" placeholder="ex: Construim case cu suflet în București" />
        </div>

        <div class="field-group">
          <label data-en="About section text">Text secțiunea Despre <span class="opt" data-en="optional">opțional</span></label>
          <textarea id="content-about" rows="3" placeholder="Povestea ta, misiunea, echipa..."></textarea>
        </div>

        <div class="field-group" id="pages-group" style="display:none">
          <label data-en="Pages">Pagini</label>
          <div class="tag-wrap" id="pages-wrap">
            <button class="tag-btn active" data-field="page" data-value="Home">Home</button>
            <button class="tag-btn active" data-field="page" data-value="Despre">Despre</button>
            <button class="tag-btn active" data-field="page" data-value="Servicii">Servicii</button>
            <button class="tag-btn active" data-field="page" data-value="Contact">Contact</button>
            <button class="tag-btn" data-field="page" data-value="Portofoliu">Portofoliu</button>
            <button class="tag-btn" data-field="page" data-value="Blog">Blog</button>
            <button class="tag-btn" data-field="page" data-value="Prețuri">Prețuri</button>
            <button class="tag-btn" data-field="page" data-value="FAQ">FAQ</button>
            <button class="tag-btn" data-field="page" data-value="Echipă">Echipă</button>
          </div>
        </div>

        <div class="field-group">
          <label data-en="Services / products (one per line)">Servicii / produse (unul pe linie) <span class="opt" data-en="optional">opțional</span></label>
          <textarea id="content-services" rows="3" placeholder="Design interior&#10;Renovare completă&#10;Consultanță"></textarea>
        </div>

        <div class="field-grid-3">
          <div class="field-group">
            <label>Email <span class="opt" data-en="optional">opțional</span></label>
            <input type="email" id="contact-email" placeholder="contact@firma.ro" />
          </div>
          <div class="field-group">
            <label data-en="Phone">Telefon <span class="opt" data-en="optional">opțional</span></label>
            <input type="text" id="contact-phone" placeholder="+40 700 000 000" />
          </div>
          <div class="field-group">
            <label data-en="Address">Adresă <span class="opt" data-en="optional">opțional</span></label>
            <input type="text" id="contact-address" placeholder="Str. Exemplu 1, București" />
          </div>
        </div>

        <div class="field-grid-3">
          <div class="field-group">
            <label>Facebook <span class="opt" data-en="optional">opțional</span></label>
            <input type="text" id="social-facebook" placeholder="facebook.com/pagina" />
          </div>
          <div class="field-group">
            <label>Instagram <span class="opt" data-en="optional">opțional</span></label>
            <input type="text" id="social-instagram" placeholder="@username" />
          </div>
          <div class="field-group">
            <label>LinkedIn <span class="opt" data-en="optional">opțional</span></label>
            <input type="text" id="social-linkedin" placeholder="linkedin.com/company/..." />
          </div>
        </div>

      </div>
      <div class="step-actions">
        <button class="btn-back" onclick="goToStep(1)" data-en="← Back">← Înapoi</button>
        <button class="btn-next" onclick="validateAndGoStep3()" data-en="Continue →">Continuă →</button>
      </div>
    </div>

    <!-- STEP 3: Branding -->
    <div class="step-panel" id="panel-3">
      <div class="form-card">

        <div class="field-group">
          <label data-en="Visual style">Stil vizual <span class="opt" data-en="optional">opțional</span></label>
          <div class="tag-wrap">
            <button class="tag-btn" data-field="style" data-value="Minimal">Minimal</button>
            <button class="tag-btn" data-field="style" data-value="Modern">Modern</button>
            <button class="tag-btn" data-field="style" data-value="Bold">Bold</button>
            <button class="tag-btn" data-field="style" data-value="Elegant">Elegant</button>
            <button class="tag-btn" data-field="style" data-value="Clasic">Clasic</button>
            <button class="tag-btn" data-field="style" data-value="Dark">Dark</button>
            <button class="tag-btn" data-field="style" data-value="Colorat">Colorat</button>
            <button class="tag-btn" data-field="style" data-value="Playful">Playful</button>
          </div>
        </div>

        <div class="field-group">
          <div class="colors-header">
            <label data-en="Colors">Culori</label>
            <button class="btn-ai-colors" id="ai-colors-toggle" type="button">✦ <span data-en="Suggest with AI">Sugerează cu AI</span></button>
          </div>

          <div class="ai-colors-panel" id="ai-panel" style="display:none">
            <div class="ai-colors-input-row">
              <input type="text" id="ai-color-prompt" placeholder="ex: cald, primitor, culori toamnă, logo portocaliu..." data-en-placeholder="e.g: warm, welcoming, autumn colors, orange logo..." />
              <button type="button" id="ai-colors-btn" class="btn-generate-colors" data-en="Generate">Generează</button>
            </div>
            <div id="ai-palettes" class="palettes-grid"></div>
          </div>

          <div class="colors-row">
            <div class="color-field">
              <span class="color-label" data-en="Primary">Primar</span>
              <div class="color-input-wrap">
                <input type="color" id="color-primary" value="#2563eb" />
                <input type="text" id="color-primary-hex" value="#2563eb" maxlength="7" class="hex-input" placeholder="#000000" />
              </div>
            </div>
            <div class="color-field">
              <span class="color-label" data-en="Secondary">Secundar</span>
              <div class="color-input-wrap">
                <input type="color" id="color-secondary" value="#f8fafc" />
                <input type="text" id="color-secondary-hex" value="#f8fafc" maxlength="7" class="hex-input" placeholder="#000000" />
              </div>
            </div>
            <div class="color-field">
              <span class="color-label">Accent</span>
              <div class="color-input-wrap">
                <input type="color" id="color-accent" value="#f59e0b" />
                <input type="text" id="color-accent-hex" value="#f59e0b" maxlength="7" class="hex-input" placeholder="#000000" />
              </div>
            </div>
          </div>
        </div>

        <div class="field-grid-2">
          <div class="field-group">
            <label data-en="Heading font (optional)">Font titluri <span class="opt" data-en="optional">opțional</span></label>
            <input type="text" id="font-heading" placeholder="ex: Playfair Display, Space Grotesk..." />
          </div>
          <div class="field-group">
            <label data-en="Body font (optional)">Font text <span class="opt" data-en="optional">opțional</span></label>
            <input type="text" id="font-body" placeholder="ex: Inter, DM Sans..." />
          </div>
        </div>

        <div class="field-group">
          <label data-en="Do you have a logo?">Ai un logo?</label>
          <div class="choice-row">
            <button class="choice-btn" data-field="has_logo" data-value="true">
              <span class="choice-icon">✓</span>
              <span class="choice-title" data-en="Yes">Da</span>
            </button>
            <button class="choice-btn active" data-field="has_logo" data-value="false">
              <span class="choice-icon">✗</span>
              <span class="choice-title" data-en="No">Nu</span>
            </button>
          </div>
        </div>

        <div class="field-group">
          <label data-en="Features">Funcționalități</label>
          <div class="tag-wrap">
            <button class="tag-btn active" data-field="feature" data-value="contact_form" data-en="Contact form">Formular contact</button>
            <button class="tag-btn" data-field="feature" data-value="gallery" data-en="Gallery">Galerie foto</button>
            <button class="tag-btn" data-field="feature" data-value="testimonials" data-en="Testimonials">Testimoniale</button>
            <button class="tag-btn" data-field="feature" data-value="blog" data-en="Blog">Blog</button>
            <button class="tag-btn" data-field="feature" data-value="newsletter" data-en="Newsletter">Newsletter</button>
            <button class="tag-btn" data-field="feature" data-value="booking" data-en="Booking">Rezervări</button>
          </div>
        </div>

        <div class="field-grid-2">
          <div class="field-group">
            <label data-en="Meta title (SEO)">Meta titlu (SEO) <span class="opt" data-en="optional">opțional</span></label>
            <input type="text" id="meta-title" placeholder="ex: Bella Cucina | Restaurant Italian București" />
          </div>
          <div class="field-group">
            <label data-en="Meta description (SEO)">Meta descriere (SEO) <span class="opt" data-en="optional">opțional</span></label>
            <input type="text" id="meta-description" placeholder="max 160 caractere..." maxlength="160" />
          </div>
        </div>

      </div>
      <div class="step-actions">
        <button class="btn-back" onclick="goToStep(2)" data-en="← Back">← Înapoi</button>
        <button class="btn-next" onclick="goToStep(4)" data-en="Review →">Revizuire →</button>
      </div>
    </div>

    <!-- STEP 4: Review & Confirm -->
    <div class="step-panel" id="panel-4">
      <div class="review-card" id="review-content">
        <!-- Populated by JS -->
      </div>
      <div id="submit-error" class="error-msg" hidden></div>
      <div class="step-actions">
        <button class="btn-back" onclick="goToStep(3)" data-en="← Edit">← Editează</button>
        <button class="btn-confirm" id="confirm-btn" data-en="Confirm & generate site →">Confirmă și generează site →</button>
      </div>
    </div>

  </div>
</Dashboard>

<script define:vars={{ projectId: id }}>

// ── State ────────────────────────────────────────────────────────────────────
const state = {
  page_type: 'landing',
  industry: '',
  site_language: 'ro',
  complexity: 'complete',
  style: '',
  has_logo: false,
  pages: ['Home', 'Despre', 'Servicii', 'Contact'],
  features: ['contact_form'],
};

// ── Step navigation ──────────────────────────────────────────────────────────
function goToStep(n) {
  document.querySelectorAll('.step-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.step').forEach(s => {
    const num = parseInt(s.dataset.step);
    s.classList.toggle('active', num === n);
    s.classList.toggle('done', num < n);
  });
  document.getElementById(`panel-${n}`).classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });

  // Roll the eyes on step change
  document.querySelectorAll('.peep-iris').forEach(iris => {
    iris.style.animationName = '';
    iris.style.transform = '';
    iris.classList.remove('rolling');
    void iris.offsetWidth; // force reflow
    iris.classList.add('rolling');
    // Remove rolling class after animation so mouse tracking resumes
    setTimeout(() => iris.classList.remove('rolling'), 820);
  });
  document.querySelectorAll('.peep-brow').forEach(brow => {
    brow.classList.add('raised');
    setTimeout(() => brow.classList.remove('raised'), 900);
  });

  if (n === 4) buildReview();
}

function validateAndGoStep3() {
  const name = document.getElementById('business-name').value.trim();
  const desc = document.getElementById('business-description').value.trim();
  const headline = document.getElementById('content-headline').value.trim();
  const _isEn = (localStorage.getItem('i18nextLng')||'ro').split('-')[0]==='en';

  if (!name) {
    alert(_isEn ? 'Please enter a business name.' : 'Te rugăm introdu numele afacerii.');
    document.getElementById('business-name').focus();
    return;
  }
  if (!desc) {
    alert(_isEn ? 'Please add a business description.' : 'Te rugăm adaugă o descriere a afacerii.');
    document.getElementById('business-description').focus();
    return;
  }
  if (!headline) {
    alert(_isEn ? 'Please add a main headline.' : 'Te rugăm adaugă un titlu principal.');
    document.getElementById('content-headline').focus();
    return;
  }
  goToStep(3);
}

// ── Choice buttons ───────────────────────────────────────────────────────────
document.querySelectorAll('.choice-btn[data-field]').forEach(btn => {
  btn.addEventListener('click', () => {
    const field = btn.dataset.field;
    // Deselect siblings
    document.querySelectorAll(`.choice-btn[data-field="${field}"]`).forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const val = btn.dataset.value;

    if (field === 'page_type') {
      state.page_type = val;
      document.getElementById('pages-group').style.display = val === 'multi-page' ? 'block' : 'none';
    } else if (field === 'site_language') {
      state.site_language = val;
    } else if (field === 'complexity') {
      state.complexity = val;
    } else if (field === 'has_logo') {
      state.has_logo = val === 'true';
    }
  });
});

// ── Industry chips ───────────────────────────────────────────────────────────
document.querySelectorAll('.tag-btn[data-field="industry_chip"]').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tag-btn[data-field="industry_chip"]').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('industry-input').value = btn.dataset.value;
    state.industry = btn.dataset.value;
  });
});

document.getElementById('industry-input').addEventListener('input', e => {
  state.industry = e.target.value;
  document.querySelectorAll('.tag-btn[data-field="industry_chip"]').forEach(b => b.classList.remove('active'));
});

// ── Style chips ──────────────────────────────────────────────────────────────
document.querySelectorAll('.tag-btn[data-field="style"]').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tag-btn[data-field="style"]').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    state.style = btn.dataset.value;
  });
});

// ── Pages chips ──────────────────────────────────────────────────────────────
document.querySelectorAll('.tag-btn[data-field="page"]').forEach(btn => {
  btn.addEventListener('click', () => {
    btn.classList.toggle('active');
    const val = btn.dataset.value;
    if (btn.classList.contains('active')) {
      if (!state.pages.includes(val)) state.pages.push(val);
    } else {
      state.pages = state.pages.filter(p => p !== val);
    }
  });
});

// ── Features chips ───────────────────────────────────────────────────────────
document.querySelectorAll('.tag-btn[data-field="feature"]').forEach(btn => {
  btn.addEventListener('click', () => {
    btn.classList.toggle('active');
    const val = btn.dataset.value;
    if (btn.classList.contains('active')) {
      if (!state.features.includes(val)) state.features.push(val);
    } else {
      state.features = state.features.filter(f => f !== val);
    }
  });
});

// ── Color pickers ────────────────────────────────────────────────────────────
['primary', 'secondary', 'accent'].forEach(key => {
  const picker = document.getElementById(`color-${key}`);
  const hex = document.getElementById(`color-${key}-hex`);
  picker.addEventListener('input', () => { hex.value = picker.value; });
  hex.addEventListener('input', () => {
    const v = hex.value.trim();
    if (/^#[0-9a-fA-F]{6}$/.test(v)) picker.value = v;
  });
});

// ── AI Color suggestion ──────────────────────────────────────────────────────
document.getElementById('ai-colors-toggle').addEventListener('click', () => {
  const panel = document.getElementById('ai-panel');
  panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
});

document.getElementById('ai-colors-btn').addEventListener('click', async () => {
  const prompt = document.getElementById('ai-color-prompt').value.trim();
  if (!prompt) return;
  const btn = document.getElementById('ai-colors-btn');
  const _isEn = (localStorage.getItem('i18nextLng')||'ro').split('-')[0]==='en';
  btn.textContent = _isEn ? 'Generating…' : 'Se generează…';
  btn.disabled = true;

  try {
    const res = await fetch(`/api/onboarding/${projectId}/suggest-colors`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        prompt,
        industry: state.industry,
        style: state.style,
      }),
    });
    const data = await res.json();
    if (data.palettes?.length) {
      renderPalettes(data.palettes);
    }
  } catch {}

  btn.textContent = _isEn ? 'Generate' : 'Generează';
  btn.disabled = false;
});

function _esc(s) { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }
function _safeHex(s) { return /^#[0-9a-fA-F]{3,8}$/.test(s) ? s : '#ccc'; }

function renderPalettes(palettes) {
  const wrap = document.getElementById('ai-palettes');
  wrap.innerHTML = palettes.map((p, i) => `
    <div class="palette-card" data-idx="${i}">
      <div class="palette-swatches">
        <span class="swatch" style="background:${_safeHex(p.primary)}" title="${_esc(p.primary)}"></span>
        <span class="swatch" style="background:${_safeHex(p.secondary)}" title="${_esc(p.secondary)}"></span>
        <span class="swatch" style="background:${_safeHex(p.accent)}" title="${_esc(p.accent)}"></span>
      </div>
      <div class="palette-info">
        <strong>${_esc(p.name)}</strong>
        <span>${_esc(p.description)}</span>
      </div>
      <button class="btn-apply-palette" onclick="applyPalette(${i})">Aplică</button>
    </div>
  `).join('');
  wrap.__palettes = palettes;
}

function applyPalette(idx) {
  const palettes = document.getElementById('ai-palettes').__palettes;
  const p = palettes[idx];
  ['primary','secondary','accent'].forEach(key => {
    document.getElementById(`color-${key}`).value = p[key];
    document.getElementById(`color-${key}-hex`).value = p[key];
  });
  // Highlight selected
  document.querySelectorAll('.palette-card').forEach((c, i) => {
    c.classList.toggle('selected', i === idx);
  });
}

// ── Build review ─────────────────────────────────────────────────────────────
function buildReview() {
  const _isEn = (localStorage.getItem('i18nextLng')||'ro').split('-')[0]==='en';
  const d = collectBriefData();

  const rows = [
    [_isEn ? 'Site type' : 'Tip site', d.preferences.websiteType === 'landing' ? 'Landing page' : 'Multi-pagini'],
    [_isEn ? 'Industry' : 'Industrie', d.business.industry || '—'],
    [_isEn ? 'Complexity' : 'Complexitate', d.preferences.complexity],
    ['', ''],
    [_isEn ? 'Business name' : 'Nume afacere', d.business.name || '—'],
    ['Tagline', d.business.tagline || '—'],
    [_isEn ? 'Headline' : 'Titlu principal', d.content.headline || '—'],
    [_isEn ? 'Description' : 'Descriere', d.business.description ? d.business.description.substring(0, 80) + '…' : '—'],
    [_isEn ? 'Services' : 'Servicii', (d.content.services || []).join(', ') || '—'],
    d.preferences.websiteType === 'multi-page' ? [_isEn ? 'Pages' : 'Pagini', (d.content.pages || []).join(', ')] : null,
    ['', ''],
    [_isEn ? 'Style' : 'Stil', d.branding.style || '—'],
    [_isEn ? 'Primary color' : 'Culoare primară', `<span class="r-swatch" style="background:${_safeHex(d.branding.colors.primary)}"></span> ${_esc(d.branding.colors.primary)}`],
    [_isEn ? 'Secondary color' : 'Culoare secundară', `<span class="r-swatch" style="background:${_safeHex(d.branding.colors.secondary)}"></span> ${_esc(d.branding.colors.secondary)}`],
    [_isEn ? 'Accent color' : 'Culoare accent', `<span class="r-swatch" style="background:${_safeHex(d.branding.colors.accent)}"></span> ${_esc(d.branding.colors.accent)}`],
    ['', ''],
    [_isEn ? 'Features' : 'Funcții', Object.entries(d.features).filter(([,v])=>v).map(([k])=>k.replace(/_/g,' ')).join(', ') || '—'],
    [_isEn ? 'Email' : 'Email', d.contact.email || '—'],
    [_isEn ? 'Phone' : 'Telefon', d.contact.phone || '—'],
  ].filter(Boolean);

  document.getElementById('review-content').innerHTML = `
    <h2 class="review-title" data-en="Review before generating">Revizuire înainte de generare</h2>
    <table class="review-table">
      ${rows.map(([k, v]) => k ? `<tr><td class="rk">${k}</td><td class="rv">${v}</td></tr>` : '<tr class="divider-row"><td colspan="2"></td></tr>').join('')}
    </table>
  `;
}

// ── Collect data ─────────────────────────────────────────────────────────────
function collectBriefData() {
  const services = (document.getElementById('content-services').value || '')
    .split('\n').map(s => s.trim()).filter(Boolean);

  return {
    preferences: {
      websiteType: state.page_type,
      complexity: state.complexity,
      language: state.site_language,
    },
    business: {
      name: document.getElementById('business-name').value.trim(),
      industry: state.industry || document.getElementById('industry-input').value.trim(),
      tagline: document.getElementById('business-tagline').value.trim(),
      description: document.getElementById('business-description').value.trim(),
    },
    content: {
      headline: document.getElementById('content-headline').value.trim(),
      about: document.getElementById('content-about').value.trim(),
      services,
      pages: state.page_type === 'multi-page' ? state.pages : ['Home'],
    },
    branding: {
      style: state.style,
      colors: {
        primary: document.getElementById('color-primary-hex').value.trim() || '#2563eb',
        secondary: document.getElementById('color-secondary-hex').value.trim() || '#f8fafc',
        accent: document.getElementById('color-accent-hex').value.trim() || '#f59e0b',
      },
      fonts: {
        heading: document.getElementById('font-heading').value.trim(),
        body: document.getElementById('font-body').value.trim(),
      },
    },
    contact: {
      email: document.getElementById('contact-email').value.trim(),
      phone: document.getElementById('contact-phone').value.trim(),
      address: document.getElementById('contact-address').value.trim(),
    },
    social: {
      facebook: document.getElementById('social-facebook').value.trim(),
      instagram: document.getElementById('social-instagram').value.trim(),
      linkedin: document.getElementById('social-linkedin').value.trim(),
    },
    features: Object.fromEntries(
      ['contact_form','gallery','testimonials','blog','newsletter','booking']
        .map(f => [f, state.features.includes(f)])
    ),
    media: {
      has_logo: state.has_logo,
      hero_style: 'image',
    },
    meta: {
      title: document.getElementById('meta-title').value.trim(),
      description: document.getElementById('meta-description').value.trim(),
    },
  };
}

// ── Confirm & submit ─────────────────────────────────────────────────────────
document.getElementById('confirm-btn').addEventListener('click', async () => {
  const btn = document.getElementById('confirm-btn');
  const errEl = document.getElementById('submit-error');
  const _isEn = (localStorage.getItem('i18nextLng')||'ro').split('-')[0]==='en';

  btn.disabled = true;
  btn.textContent = _isEn ? 'Saving…' : 'Se salvează…';
  errEl.hidden = true;

  try {
    const res = await fetch(`/api/onboarding/${projectId}/manual-confirm`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ data: collectBriefData() }),
    });
    const data = await res.json();

    if (res.ok) {
      window.location.href = `/dashboard/${projectId}/brief`;
    } else {
      errEl.textContent = data.error || (_isEn ? 'Something went wrong.' : 'Ceva n-a mers. Încearcă din nou.');
      errEl.hidden = false;
      btn.disabled = false;
      btn.textContent = _isEn ? 'Confirm & generate site →' : 'Confirmă și generează site →';
    }
  } catch {
    errEl.textContent = _isEn ? 'Network error. Try again.' : 'Eroare de rețea. Încearcă din nou.';
    errEl.hidden = false;
    btn.disabled = false;
    btn.textContent = _isEn ? 'Confirm & generate site →' : 'Confirmă și generează site →';
  }
});

// Expose globally for inline onclick
window.goToStep = goToStep;
window.validateAndGoStep3 = validateAndGoStep3;
