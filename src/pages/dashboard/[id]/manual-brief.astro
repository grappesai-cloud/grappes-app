// ── Inject peeping eyes into every card ─────────────────────────────────────
(function() {
  var EYE = '<div class="peep-unit"><div class="peep-brow"></div><div class="peep-eye"><div class="peep-iris"><div class="peep-pupil"></div></div></div></div>';

  document.querySelectorAll('.form-card, .review-card').forEach(function(card) {
    var eyes = document.createElement('div');
    eyes.className = 'peeping-eyes';
    eyes.setAttribute('aria-hidden', 'true');
    eyes.innerHTML = EYE + EYE;
    card.insertBefore(eyes, card.firstChild);
  });

  // ── Mouse-tracking: iris follows cursor ────────────────────────────────────
  var _eyeIdleTimer;
  document.addEventListener('mousemove', function(e) {
    clearTimeout(_eyeIdleTimer);
    document.querySelectorAll('.peep-iris').forEach(function(iris) {
      if (iris.classList.contains('rolling')) return;
      var eye = iris.closest('.peep-eye');
      if (!eye) return;
      var r = eye.getBoundingClientRect();
      var cx = r.left + r.width / 2;
      var cy = r.top + r.height / 2;
      var dx = e.clientX - cx;
      var dy = e.clientY - cy;
      var ang = Math.atan2(dy, dx);
      var ratio = Math.min(Math.hypot(dx, dy) / 260, 1);
      var ix = (Math.cos(ang) * 7 * ratio).toFixed(2);
      var iy = (Math.sin(ang) * 7 * ratio).toFixed(2);
      iris.style.animationName = 'none';
      iris.style.transform = 'translate(calc(-50% + ' + ix + 'px), calc(-30% + ' + iy + 'px))';
    });
    _eyeIdleTimer = setTimeout(function() {
      document.querySelectorAll('.peep-iris').forEach(function(iris) {
        if (iris.classList.contains('rolling')) return;
        iris.style.animationName = '';
        iris.style.transform = '';
      });
    }, 2500);
  });
})();
</script>

