---
import Dashboard from '../../../layouts/Dashboard.astro';
import OnboardingChat from '../../../components/islands/OnboardingChat.astro';
import { db } from '../../../lib/db';

const { id } = Astro.params;
const authUser = Astro.locals.user!;

const project = await db.projects.findById(id!);
if (!project || project.user_id !== authUser.id) return Astro.redirect('/dashboard');

// If brief is already confirmed, skip to brief review
if (project.status === 'brief_ready') return Astro.redirect(`/dashboard/${id}/brief`);

const conv = await db.conversations.findByProjectId(id!);
const brief = await db.briefs.findByProjectId(id!);

const initialMessages = conv?.messages ?? [];
const initialCompleteness = brief?.completeness ?? 0;
const initialPhase = (conv?.phase ?? 'discovery') as string;
---

<Dashboard title={`Onboarding — ${project.name}`} projectId={project.id}>
  <div class="page-header">
    <a href={`/dashboard/${project.id}`} class="back-link">← Back to project</a>
  </div>

  <OnboardingChat
    projectId={id!}
    initialMessages={initialMessages}
    initialCompleteness={initialCompleteness}
    initialPhase={initialPhase}
  />
</Dashboard>

<style>
  :global(body) { overflow: hidden; }
  :global(main) { padding-top: 24px !important; padding-bottom: 0 !important; }
  .page-header { margin-bottom: 1.25rem; }
  .back-link {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    font-size: 0.875rem;
    display: inline-block;
    margin-bottom: 1rem;
    transition: color 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .back-link:hover { color: #ffffff; }
  h1 {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #ffffff;
  }
  .subtitle { color: rgba(255, 255, 255, 0.5); margin-top: 0.25rem; font-size: 1rem; }
</style>
