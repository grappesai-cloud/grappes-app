---
import Dashboard from '../../../layouts/Dashboard.astro';
import { db } from '../../../lib/db';

const { id } = Astro.params;
const authUser = Astro.locals.user!;

let project;
try {
  project = await db.projects.findById(id!);
} catch (e) {
  console.error('[settings] DB error:', e);
  return Astro.redirect('/dashboard');
}
if (!project || project.user_id !== authUser.id) return Astro.redirect('/dashboard');
---

<Dashboard title={`Settings — ${project.name}`} projectId={project.id}>
  <div class="page-header">
    <a href={`/dashboard/${project.id}`} class="back-link">← Back to project</a>
    <h1>Settings</h1>
    <p class="subtitle">{project.name}</p>
  </div>

  <div class="settings-sections">
    <!-- Rename project -->
    <section class="settings-card">
      <h2>Project Name</h2>
      <form id="rename-form" class="form-row">
        <input type="text" name="name" value={project.name} class="input" />
        <button type="submit" class="btn-primary">Save</button>
      </form>
    </section>

    <!-- Custom domain -->
    <section class="settings-card">
      <h2>Custom Domain</h2>
      <p class="help">Point your domain to this project after it's deployed.</p>
      <form id="domain-form" class="form-row">
        <input
          type="text"
          name="custom_domain"
          value={project.custom_domain || ''}
          placeholder="yourdomain.com"
          class="input"
          id="domain-input"
        />
        <button type="submit" class="btn-primary">Save</button>
      </form>

      {project.custom_domain && (
        <div class="dns-info">
          <p class="dns-title">Required DNS record:</p>
          <div class="dns-record">
            <span class="dns-type">CNAME</span>
            <span class="dns-host">@</span>
            <span class="dns-value">cname.vercel-dns.com</span>
          </div>
          <p class="dns-help">Add this CNAME record in your domain provider's DNS settings. Changes can take up to 48 hours to propagate.</p>
          <div class="dns-verify-row">
            <button id="verify-dns-btn" class="btn-secondary dns-verify-btn">Verify DNS</button>
            <span id="dns-status" class="dns-status-badge" style="display:none;"></span>
          </div>
        </div>
      )}
    </section>

    <!-- Danger zone -->
    <section class="settings-card danger">
      <h2>Danger Zone</h2>
      <p class="help">Archive this project. This cannot be undone.</p>
      <button id="archive-btn" class="btn-danger">Archive Project</button>
    </section>
  </div>
</Dashboard>

<script define:vars={{ projectId: project.id }}>
  function flashSaveSuccess(btn) {
    const orig = btn.textContent;
    btn.classList.add('save-success');
    btn.textContent = '\u2713 Saved';
    setTimeout(() => {
      btn.classList.remove('save-success');
      btn.textContent = orig;
    }, 1200);
  }

  // Rename
  document.getElementById('rename-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = new FormData(e.target).get('name');
    const btn = e.target.querySelector('.btn-primary');
    try {
      const res = await fetch(`/api/projects/${projectId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name }),
      });
      if (res.ok) {
        flashSaveSuccess(btn);
        setTimeout(() => window.location.reload(), 1400);
      } else {
        const data = await res.json().catch(() => ({}));
        btn.textContent = '⚠ ' + (data.error || 'Failed');
        btn.style.color = '#f87171';
        setTimeout(() => { btn.textContent = 'Save'; btn.style.color = ''; }, 2000);
      }
    } catch {
      btn.textContent = '⚠ Network error';
      setTimeout(() => { btn.textContent = 'Save'; btn.style.color = ''; }, 2000);
    }
  });

  // Custom domain
  document.getElementById('domain-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const domain = new FormData(e.target).get('custom_domain');
    const btn = e.target.querySelector('.btn-primary');
    btn.disabled = true;
    btn.textContent = 'Saving…';
    try {
      const res = await fetch(`/api/projects/${projectId}/domain`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ domain }),
      });
      const data = await res.json();
      if (!res.ok) {
        alert(data.error || 'Failed to save domain.');
        btn.disabled = false;
        btn.textContent = 'Save';
        return;
      }
      if (data.vercelError) {
        console.warn('[domain] Vercel warning:', data.vercelError);
      }
      flashSaveSuccess(btn);
      setTimeout(() => window.location.reload(), 1400);
    } catch {
      alert('Network error.');
      btn.disabled = false;
      btn.textContent = 'Save';
    }
  });

  // Verify DNS
  document.getElementById('verify-dns-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('verify-dns-btn');
    const status = document.getElementById('dns-status');
    btn.disabled = true;
    btn.textContent = 'Checking…';
    status.style.display = 'none';
    try {
      const res = await fetch(`/api/projects/${projectId}/verify-domain`);
      const data = await res.json();
      status.style.display = 'inline-flex';
      if (data.verified) {
        status.className = 'dns-status-badge status-ok';
        status.textContent = '✓ Verified';
      } else {
        status.className = 'dns-status-badge status-pending';
        status.textContent = data.status === 'failed'
          ? '✗ Not pointing to Vercel'
          : '⏳ Pending — try again later';
      }
    } catch {
      status.style.display = 'inline-flex';
      status.className = 'dns-status-badge status-pending';
      status.textContent = 'Error checking';
    }
    btn.disabled = false;
    btn.textContent = 'Verify DNS';
  });

  // Archive
  document.getElementById('archive-btn')?.addEventListener('click', async () => {
    const msg = 'Archive this project? It will be removed from your dashboard.';
    if (!confirm(msg)) return;
    try {
      const res = await fetch(`/api/projects/${projectId}/delete`, { method: 'POST' });
      if (res.ok) {
        window.location.href = '/dashboard';
      } else {
        const data = await res.json().catch(() => ({}));
        alert(data.error || 'Failed to archive project.');
      }
    } catch {
      alert('Network error.');
    }
  });
</script>

<style>
  .page-header { margin-bottom: 2.5rem; }
  .back-link {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    font-size: 0.875rem;
    display: inline-block;
    margin-bottom: 1rem;
    transition: color 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .back-link:hover { color: #ffffff; }
  h1 {
    font-family: 'DM Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #ffffff;
  }
  .subtitle { color: rgba(255, 255, 255, 0.5); margin-top: 0.25rem; font-size: 1rem; }

  @keyframes settingsCardFadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .settings-sections { display: flex; flex-direction: column; gap: 1.5rem; max-width: 560px; }
  .settings-card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 24px;
    padding: 1.75rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.8);
    animation: settingsCardFadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .settings-card:nth-child(1) { animation-delay: 0s; }
  .settings-card:nth-child(2) { animation-delay: 0.08s; }
  .settings-card:nth-child(3) { animation-delay: 0.16s; }
  .settings-card h2 {
    font-family: 'DM Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: #ffffff;
  }
  .help { color: rgba(255, 255, 255, 0.5); font-size: 0.875rem; margin-bottom: 1rem; }
  .form-row { display: flex; gap: 0.75rem; }
  .input {
    flex: 1;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 12px 16px;
    color: #ffffff;
    font-size: 0.875rem;
    transition: border-color 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .input:focus {
    border-color: #06bfdd;
    box-shadow: 0 0 0 3px rgba(6,191,221,0.15);
    outline: none;
  }
  .btn-primary {
    background: #06bfdd;
    color: #0a0a0a;
    border: none;
    border-radius: 16px;
    padding: 12px 20px;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 600;
    white-space: nowrap;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .btn-primary:hover {
    background: #00e088;
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(6,191,221,0.25);
  }

  .btn-primary.save-success {
    background: #38a169;
    color: #fff;
    pointer-events: none;
    transition: background 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .btn-danger {
    background: rgba(229,62,62,0.08);
    color: #e53e3e;
    border: 1px solid rgba(229,62,62,0.2);
    border-radius: 16px;
    padding: 12px 20px;
    cursor: pointer;
    font-size: 0.875rem;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .danger h2 { color: #e53e3e; }

  .settings-card.danger {
    background: rgba(229,62,62,0.06);
    border-color: rgba(229,62,62,0.15);
    transition: border-color 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .settings-card.danger:hover {
    border-color: rgba(229,62,62,0.3);
    box-shadow: 0 0 0 1px rgba(229,62,62,0.1), 0 8px 32px rgba(229,62,62,0.06);
    animation: dangerPulse 2s ease-in-out infinite;
  }
  @keyframes dangerPulse {
    0%, 100% { border-color: rgba(229,62,62,0.3); }
    50% { border-color: rgba(229,62,62,0.15); }
  }

  /* DNS info block */
  .dns-info {
    background: rgba(0,164,175,0.04); border: 1px solid rgba(0,164,175,0.12);
    border-radius: 14px; padding: 1rem; display: flex; flex-direction: column; gap: 0.6rem;
    margin-top: 0.25rem;
  }
  .dns-title { font-size: 0.8125rem; font-weight: 600; color: rgba(255,255,255,0.6); }
  .dns-record {
    display: flex; gap: 8px; align-items: center; flex-wrap: wrap;
    background: rgba(0,0,0,0.2); border-radius: 8px; padding: 8px 12px;
    font-family: 'Courier New', monospace; font-size: 13px;
  }
  .dns-type { color: #06bfdd; font-weight: 700; }
  .dns-host { color: rgba(255,255,255,0.6); }
  .dns-value { color: rgba(255,255,255,0.9); }
  .dns-help { font-size: 0.8rem; color: rgba(255,255,255,0.4); line-height: 1.5; }
  .dns-verify-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .dns-verify-btn {
    background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.8);
    border: 1px solid rgba(255,255,255,0.1); border-radius: 14px;
    padding: 8px 16px; font-size: 0.8125rem; font-weight: 500; cursor: pointer;
    transition: all 0.2s;
  }
  .dns-verify-btn:hover { background: rgba(255,255,255,0.1); color: #fff; }
  .dns-verify-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .dns-status-badge {
    display: inline-flex; align-items: center; padding: 4px 12px; border-radius: 20px;
    font-size: 0.8125rem; font-weight: 600;
  }
  .status-ok { background: rgba(56,161,105,0.1); border: 1px solid rgba(56,161,105,0.2); color: #38a169; }
  .status-pending { background: rgba(251,191,36,0.08); border: 1px solid rgba(251,191,36,0.2); color: #d97706; }

  @media (prefers-reduced-motion: reduce) {
    .settings-card { animation: none; opacity: 1; transform: none; }
    .settings-card.danger:hover { animation: none; }
    .btn-primary:hover { transform: none; }
  }
</style>
