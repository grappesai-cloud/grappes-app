---
import Dashboard from '../../layouts/Dashboard.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { db } from '../../lib/db';
import { createAdminClient } from '../../lib/supabase';

const authUser = Astro.locals.user!;
let dbUser = null;
let projects: import('../../lib/db').Project[] = [];
let totalCount = 0;
try {
  dbUser = await db.users.findById(authUser.id);
  // Auto-create profile if trigger missed
  if (!dbUser) {
    const client = createAdminClient();
    await client.from('users').upsert({
      id: authUser.id,
      email: authUser.email ?? '',
      name: authUser.user_metadata?.full_name ?? authUser.user_metadata?.name ?? null,
    }, { onConflict: 'id' });
    dbUser = await db.users.findById(authUser.id);
  }
  if (dbUser) {
    projects = await db.projects.findByUser(dbUser.id);
    totalCount = projects.length;
  }
} catch (err) {
  console.error('[dashboard] DB error:', err);
}
---

<Dashboard title="Projects">
  <div style="text-align:center;margin-bottom:60px;">
    <span style="display:inline-block;font-size:16px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#9BD4D7;margin-bottom:14px;">Dashboard</span>
    <h2 style="font-family:'Inter',sans-serif;font-size:72px;font-weight:400;line-height:1.1;letter-spacing:-0.08em;color:#fff;margin-bottom:14px;">Your Projects</h2>
    <p style="font-size:20px;color:rgba(255,255,255,0.5);margin-bottom:32px;">
      {totalCount} / {dbUser?.projects_limit ?? 1} <span>project(s) used</span>
    </p>
    <a href="/dashboard/new" style="display:inline-flex;align-items:center;gap:10px;background:#9BD4D7;color:#0a0a0a;border:none;border-radius:30px;padding:16px 32px;font-size:16px;font-weight:700;text-transform:uppercase;text-decoration:none;transition:all 0.3s;line-height:1;">
      <span>+ New Project</span>
      <svg width="20" height="20" viewBox="0 0 28 28" fill="none"><rect x="5.066" y="19.978" width="20.571" height="2.612" transform="rotate(-40.28 5.066 19.978)" fill="currentColor"/><rect x="7.971" y="7.245" width="2.612" height="2.612" transform="rotate(-40.28 7.971 7.245)" fill="currentColor"/><rect x="11.652" y="7.548" width="2.612" height="2.612" transform="rotate(-40.28 11.652 7.548)" fill="currentColor"/><rect x="15.334" y="7.852" width="2.612" height="2.612" transform="rotate(-40.28 15.334 7.852)" fill="currentColor"/><rect x="18.712" y="11.837" width="2.612" height="2.612" transform="rotate(-40.28 18.712 11.837)" fill="currentColor"/><rect x="18.408" y="15.52" width="2.612" height="2.612" transform="rotate(-40.28 18.408 15.52)" fill="currentColor"/><rect x="18.104" y="19.201" width="2.612" height="2.612" transform="rotate(-40.28 18.104 19.201)" fill="currentColor"/></svg>
    </a>
  </div>

  {projects.length > 0 && (
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:28px;">
      {projects.map(p => <ProjectCard project={p} />)}
    </div>
  )}
</Dashboard>

