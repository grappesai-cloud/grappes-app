---
import Dashboard from '../../layouts/Dashboard.astro';
import ProductTile from '../../components/ProductTile.astro';
import { db } from '../../lib/db';
import { createAdminClient } from '../../lib/supabase';
import { toolAllowed } from '../../lib/tools';
import type { CreditKind } from '../../lib/credits';

const authUser = Astro.locals.user!;

let dbUser = null;
let projects: import('../../lib/db').Project[] = [];

try {
  dbUser = await db.users.findById(authUser.id);
  if (!dbUser) {
    const client = createAdminClient();
    await client.from('users').upsert({
      id: authUser.id,
      email: authUser.email ?? '',
      name: authUser.user_metadata?.full_name ?? authUser.user_metadata?.name ?? null,
    }, { onConflict: 'id' });
    dbUser = await db.users.findById(authUser.id);
  }
  if (dbUser) {
    projects = await db.projects.findByUser(dbUser.id);
  }
} catch (err) {
  console.error('[dashboard/studio] DB error:', err);
}

const totalSites = projects.length;
const sitesLimit = dbUser?.projects_limit ?? 1;

const reelCredits = dbUser?.reel_credits ?? 0;
const auditCredits = dbUser?.audit_credits ?? 0;
const soc2Credits = dbUser?.soc2_credits ?? 0;

// Brand Book Lab — count for the tile meter.
let bookCount = 0;
try {
  const { count } = await createAdminClient()
    .from('press_kits')
    .select('id', { count: 'exact', head: true })
    .eq('user_id', authUser.id)
    .eq('mode', 'brand_book');
  bookCount = count ?? 0;
} catch { /* table/columns not migrated yet — tile still renders */ }

const firstName = (authUser.user_metadata?.full_name ?? authUser.user_metadata?.name ?? authUser.email?.split('@')[0] ?? '').split(' ')[0];

// Per-user tool access. NULL allowed_tools = full access (legacy + unrestricted).
const allowedTools = ((dbUser as any)?.allowed_tools ?? null) as string[] | null;
const can = (key: CreditKind) => toolAllowed(allowedTools, key);
const anyTool = (['site','reel','social','audit','soc2','brandbook','logo','offer'] as CreditKind[]).some(can);

const sitesIcon  = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 9h18"/><path d="M8 4v5"/></svg>`;
const reelsIcon  = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>`;
const auditIcon  = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 5-7"/></svg>`;
const soc2Icon   = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`;
const kitIcon    = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="3" width="16" height="18" rx="2"/><path d="M8 7h8"/><path d="M8 11h8"/><path d="M8 15h5"/></svg>`;
const logoIcon   = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 3v18"/><path d="M3 12h18"/></svg>`;
const offerIcon  = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="13" y2="17"/></svg>`;
const socialIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.6" y1="13.5" x2="15.4" y2="17.5"/><line x1="15.4" y1="6.5" x2="8.6" y2="10.5"/></svg>`;

// Social Lab — autopost queue depth for the tile meter.
let socialQueued = 0;
let socialConnected = 0;
try {
  const adminClient = createAdminClient();
  const { count: qc } = await adminClient
    .from('social_queue_items')
    .select('id', { count: 'exact', head: true })
    .eq('user_id', authUser.id)
    .eq('status', 'queued');
  socialQueued = qc ?? 0;
  const { count: cc } = await adminClient
    .from('social_connections')
    .select('id', { count: 'exact', head: true })
    .eq('user_id', authUser.id)
    .is('disconnected_at', null);
  socialConnected = cc ?? 0;
} catch (e) {
  // social_* tables may not exist on environments where the migration hasn't
  // been applied — fail silently rather than break the dashboard.
}
const socialMeter = socialConnected === 0
  ? 'Connect your accounts'
  : `${socialQueued} post${socialQueued === 1 ? '' : 's'} in queue`;

// Logo Lab — count standalone logos owned by this user.
let logoCount = 0;
try {
  const adminClient = createAdminClient();
  const { count } = await adminClient
    .from('user_logos')
    .select('id', { count: 'exact', head: true })
    .eq('user_id', authUser.id);
  logoCount = count ?? 0;
} catch (e) {
  // user_logos table may not exist yet on environments where the migration
  // hasn't been applied — fail silently rather than break the dashboard.
}
---

<Dashboard title="Studio">
  <style is:global>
    main { padding-top: 56px !important; padding-bottom: 80px !important; }
    @media (max-width: 768px) {
      main { padding-top: 40px !important; padding-bottom: 60px !important; }
    }
  </style>

  <div class="studio-head">
    <span class="studio-eyebrow">Studio</span>
    <h2 class="studio-title">
      Welcome back{firstName ? ', ' : '.'}{firstName && <strong>{firstName}.</strong>}
    </h2>
    <p class="studio-sub">Your AI creative tools, all in one place.</p>
  </div>

  <div class="studio-grid">
    <section class="studio-tools">
      <div class="section-head">
        <span class="section-label">Your tools</span>
      </div>
      <div class="tile-grid">
        {can('site') && (
        <ProductTile
          name="Sites"
          tagline="AI-generated websites with custom design. From a brief to a live URL in about 15 minutes."
          href="/dashboard/sites"
          icon={sitesIcon}
          meter={`${totalSites} / ${sitesLimit} project${sitesLimit === 1 ? '' : 's'} used`}
          cta="Open Sites"
          accent="#06bfdd"
        />
        )}
        {can('reel') && (
        <ProductTile
          name="Reels Lab"
          tagline="Upload an Instagram reel, get a frame-by-frame AI breakdown with hook scores, pacing, and retention insights."
          href={reelCredits > 0 ? '/reels' : '/dashboard/reels'}
          icon={reelsIcon}
          meter={`${reelCredits} credit${reelCredits === 1 ? '' : 's'} remaining`}
          cta={reelCredits > 0 ? 'Open Reels' : 'Get credits'}
          accent="#a78bfa"        />
        )}
        {can('social') && (
        <ProductTile
          name="Social Lab"
          tagline="Drop photos and videos into a folder. AI writes captions in your voice and posts them to Instagram, TikTok and Facebook on schedule."
          href="/social"
          icon={socialIcon}
          meter={socialMeter}
          cta="Open Social"
          accent="#f472b6"        />
        )}
        {can('audit') && (
        <ProductTile
          name="Audit Lab"
          tagline="Paste a URL, get a 30-second AI audit. Performance, on-page SEO, technical SEO, and content scored 0-100 with concrete fixes."
          href="/audit"
          icon={auditIcon}
          meter={`${auditCredits} audit${auditCredits === 1 ? '' : 's'} remaining`}
          cta={auditCredits > 0 ? 'Run audit' : 'Get credits'}
          accent="#22d3ee"        />
        )}
        {can('soc2') && (
        <ProductTile
          name="SOC 2 Lab"
          tagline="Find your SOC 2 gaps before the auditor does. Code audit or an authorized live pentest, mapped to the Trust Service Criteria."
          href="/soc2"
          icon={soc2Icon}
          meter={`${soc2Credits} credit${soc2Credits === 1 ? '' : 's'} remaining`}
          cta="Open SOC 2"
          accent="#34d399"        />
        )}
        {can('brandbook') && (
        <ProductTile
          name="Brand Book Lab"
          tagline="Brand books, AI-built. Visual identity guidelines and editorial documents for your team."
          href="/brandbook"
          icon={kitIcon}
          meter={bookCount === 0 ? 'No brand books yet' : `${bookCount} brand book${bookCount === 1 ? '' : 's'}`}
          cta={bookCount > 0 ? 'Open Brand Book Lab' : 'New brand book'}
          accent="#f97316"        />
        )}
        {can('logo') && (
        <ProductTile
          name="Logo Lab"
          tagline="AI vector logo, instant SVG + PNG. A conversational flow that produces a clean mark in seconds."
          href="/logo"
          icon={logoIcon}
          meter={logoCount === 0 ? 'No logos yet' : `${logoCount} logo${logoCount === 1 ? '' : 's'}`}
          cta={logoCount > 0 ? 'Open Logo Lab' : 'New logo'}
          accent="#a78bfa"        />
        )}
        {can('offer') && (
        <ProductTile
          name="Offer Lab"
          tagline="Build a client offer or proposal and export it as a clean Grappes-branded PDF. Services, pricing, and a payment plan in minutes."
          href="/dashboard/offers"
          icon={offerIcon}
          meter="Draft saved locally"
          cta="New offer"
          accent="#06bfdd"        />
        )}
        {!anyTool && (
          <p style="grid-column:1/-1;color:rgba(255,255,255,0.5);font-size:14px;padding:24px 0;">No tools are enabled on your account yet. Contact your administrator.</p>
        )}
      </div>
    </section>
  </div>

  <style>
    .studio-head { text-align: center; margin-bottom: 48px; position: relative; }
    .studio-eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 12.5px; font-weight: 700;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: #06bfdd; margin-bottom: 14px;
      padding: 6px 14px; border-radius: 999px;
      background: rgba(6,191,221,0.08);
      border: 1px solid rgba(6,191,221,0.22);
    }
    .studio-eyebrow::before {
      content: ''; width: 6px; height: 6px; border-radius: 50%;
      background: #06bfdd;
      animation: studio-pulse 1.8s ease-in-out infinite;
    }
    @keyframes studio-pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%      { opacity: 0.45; transform: scale(0.85); }
    }
    .studio-title {
      font-family: 'Inter', sans-serif;
      font-size: clamp(36px, 5.6vw, 64px);
      font-weight: 300; line-height: 1.02;
      letter-spacing: -0.05em;
      color: #fff;
      margin: 0 0 16px;
      animation: studio-fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .studio-title strong {
      font-weight: 700;
      background: linear-gradient(135deg, #06bfdd 0%, #a78bfa 50%, #f97316 100%);
      -webkit-background-clip: text;
              background-clip: text;
      color: transparent;
    }
    .studio-sub {
      font-size: 15px;
      color: rgba(255,255,255,0.55);
      margin: 0;
      animation: studio-fade-up 0.7s 0.1s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    @keyframes studio-fade-up {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .studio-grid {
      max-width: 920px;
      margin: 0 auto;
    }

    .section-head { margin-bottom: 16px; }
    .section-label {
      display: inline-block;
      font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.14em;
      color: rgba(255,255,255,0.45);
      padding: 4px 10px;
      border-radius: 999px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
    }

    .tile-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
      justify-content: center;
    }
    @media (max-width: 1024px) {
      .tile-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @media (max-width: 640px) {
      .tile-grid { grid-template-columns: 1fr; }
    }
    .tile-grid :global(.pt-card) {
      animation: studio-fade-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .tile-grid :global(.pt-card:nth-child(1)) { animation-delay: 0.10s; }
    .tile-grid :global(.pt-card:nth-child(2)) { animation-delay: 0.18s; }
    .tile-grid :global(.pt-card:nth-child(3)) { animation-delay: 0.26s; }
    .tile-grid :global(.pt-card:nth-child(4)) { animation-delay: 0.34s; }
    .tile-grid :global(.pt-card:nth-child(5)) { animation-delay: 0.42s; }

  </style>

  <!-- Defensive click handler: ensure tiles navigate even if the anchor's
       default action gets swallowed by something upstream. -->
  <script is:inline>
    document.addEventListener('click', function(e){
      var t = e.target;
      var card = t && t.closest ? t.closest('a.pt-card[data-tile-href]') : null;
      if (!card) return;
      // If browser already handled the navigation, don't fire twice.
      // We only kick in when default got prevented somehow.
      if (e.defaultPrevented) return;
      var href = card.getAttribute('data-tile-href');
      if (!href) return;
      // Let middle-click / cmd+click open in new tab natively.
      if (e.metaKey || e.ctrlKey || e.shiftKey || e.button === 1) return;
      // Small timeout so native nav (if any) takes precedence.
      setTimeout(function(){
        if (window.location.pathname + window.location.search === href) return;
        window.location.href = href;
      }, 50);
    });
  </script>
</Dashboard>
