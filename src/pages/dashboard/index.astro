---
import Dashboard from '../../layouts/Dashboard.astro';
import ProductTile from '../../components/ProductTile.astro';
import { db } from '../../lib/db';
import { createAdminClient } from '../../lib/supabase';

const authUser = Astro.locals.user!;

let dbUser = null;
let projects: import('../../lib/db').Project[] = [];

try {
  dbUser = await db.users.findById(authUser.id);
  if (!dbUser) {
    const client = createAdminClient();
    await client.from('users').upsert({
      id: authUser.id,
      email: authUser.email ?? '',
      name: authUser.user_metadata?.full_name ?? authUser.user_metadata?.name ?? null,
    }, { onConflict: 'id' });
    dbUser = await db.users.findById(authUser.id);
  }
  if (dbUser) {
    projects = await db.projects.findByUser(dbUser.id);
  }
} catch (err) {
  console.error('[dashboard/studio] DB error:', err);
}

const totalSites = projects.length;
const sitesLimit = dbUser?.projects_limit ?? 1;

const reelCredits = dbUser?.reel_credits ?? 0;
const auditCredits = dbUser?.audit_credits ?? 0;

// Press Kit Lab — count drafts + published per user (no credits, per-kit billing)
let kitCount = 0;
let publishedKits = 0;
try {
  const adminClient = createAdminClient();
  const { data: kitRows } = await adminClient
    .from('press_kits')
    .select('id, status')
    .eq('user_id', authUser.id);
  kitCount = kitRows?.length ?? 0;
  publishedKits = kitRows?.filter(k => k.status === 'published').length ?? 0;
} catch (e) {
  console.error('[studio] press_kits count error:', e);
}

// Activity feed: 5 most recent project updates, newest first.
const recent = [...projects]
  .sort((a, b) => new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime())
  .slice(0, 5);

function timeAgo(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const m = Math.floor(diff / 60000);
  const h = Math.floor(diff / 3600000);
  const d = Math.floor(diff / 86400000);
  if (m < 1) return 'just now';
  if (h < 1) return `${m}m ago`;
  if (d < 1) return `${h}h ago`;
  return `${d}d ago`;
}

function statusLabel(status: string): string {
  if (status === 'live') return 'Live';
  if (status === 'generating') return 'Generating';
  if (status === 'deploying') return 'Deploying';
  if (status === 'generated') return 'Ready to publish';
  if (status === 'brief_ready') return 'Brief ready';
  if (status === 'onboarding') return 'Brief in progress';
  if (status === 'failed') return 'Failed';
  return status;
}

const firstName = (authUser.user_metadata?.full_name ?? authUser.user_metadata?.name ?? authUser.email?.split('@')[0] ?? '').split(' ')[0];

const sitesIcon  = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 9h18"/><path d="M8 4v5"/></svg>`;
const reelsIcon  = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>`;
const auditIcon  = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 5-7"/></svg>`;
const kitIcon    = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="3" width="16" height="18" rx="2"/><path d="M8 7h8"/><path d="M8 11h8"/><path d="M8 15h5"/></svg>`;
const soonIcon   = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`;
---

<Dashboard title="Studio">
  <style is:global>
    main { padding-top: 56px !important; padding-bottom: 80px !important; }
    @media (max-width: 768px) {
      main { padding-top: 40px !important; padding-bottom: 60px !important; }
    }
  </style>

  <div class="studio-head">
    <span class="studio-eyebrow">Studio</span>
    <h2 class="studio-title">
      Welcome back{firstName ? ', ' : '.'}{firstName && <strong>{firstName}.</strong>}
    </h2>
    <p class="studio-sub">Your AI creative tools, all in one place.</p>
  </div>

  <div class="studio-grid">
    <section class="studio-tools">
      <div class="section-head">
        <span class="section-label">Your tools</span>
      </div>
      <div class="tile-grid">
        <ProductTile
          name="Sites"
          tagline="AI-generated websites with custom design. From a brief to a live URL in under 90 seconds."
          href="/dashboard/sites"
          icon={sitesIcon}
          meter={`${totalSites} / ${sitesLimit} project${sitesLimit === 1 ? '' : 's'} used`}
          cta="Open Sites"
          accent="#06bfdd"
        />
        <ProductTile
          name="Reels Lab"
          tagline="Upload an Instagram reel, get a frame-by-frame AI breakdown with hook scores, pacing, and retention insights."
          href={reelCredits > 0 ? '/reels' : '/dashboard/reels'}
          icon={reelsIcon}
          meter={`${reelCredits} credit${reelCredits === 1 ? '' : 's'} remaining`}
          cta={reelCredits > 0 ? 'Open Reels' : 'Get credits'}
          accent="#a78bfa"
          isNew={true}
        />
        <ProductTile
          name="Audit Lab"
          tagline="Paste a URL, get a 30-second AI audit. Performance, on-page SEO, technical SEO, and content scored 0-100 with concrete fixes."
          href="/audit"
          icon={auditIcon}
          meter={`${auditCredits} audit${auditCredits === 1 ? '' : 's'} remaining`}
          cta={auditCredits > 0 ? 'Run audit' : 'Get credits'}
          accent="#22d3ee"
          isNew={true}
        />
        <ProductTile
          name="Press Kit Lab"
          tagline="Compose a polished digital press kit. Upload logo, bio, photos, videos. Get a shareable URL and PDF download. €15/kit."
          href="/kits"
          icon={kitIcon}
          meter={kitCount === 0 ? 'No kits yet' : `${kitCount} kit${kitCount === 1 ? '' : 's'}${publishedKits > 0 ? ` · ${publishedKits} live` : ''}`}
          cta={kitCount > 0 ? 'Open kits' : 'New kit'}
          accent="#f97316"
          isNew={true}
        />
        <ProductTile
          name="More tools soon"
          tagline="We're shipping new AI products every month. Lead enrichment, brand kits, copywriting — tell us what you need."
          href="mailto:hello@grappes.dev?subject=Tool%20request"
          icon={soonIcon}
          meter="Roadmap"
          cta=""
          comingSoon={true}
        />
      </div>
    </section>

    <aside class="studio-aside">
      <div class="section-head">
        <span class="section-label">Recent activity</span>
      </div>
      {recent.length === 0 ? (
        <div class="empty-feed">
          <p>No activity yet.</p>
          <p class="empty-feed-sub">Spin up your first site or upload a reel to see things appear here.</p>
        </div>
      ) : (
        <ul class="activity-list">
          {recent.map(p => (
            <li class="activity-item">
              <a href={`/dashboard/${p.id}`} class="activity-link">
                <div class="activity-main">
                  <span class="activity-name">{p.name}</span>
                  <span class={`activity-status activity-status--${p.status}`}>{statusLabel(p.status)}</span>
                </div>
                <div class="activity-time">{timeAgo(p.updated_at)}</div>
              </a>
            </li>
          ))}
        </ul>
      )}
      <a href="/dashboard/sites" class="aside-cta">View all sites →</a>
    </aside>
  </div>

  <style>
    .studio-head { text-align: center; margin-bottom: 48px; position: relative; }
    .studio-eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 12.5px; font-weight: 700;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: #06bfdd; margin-bottom: 14px;
      padding: 6px 14px; border-radius: 999px;
      background: rgba(6,191,221,0.08);
      border: 1px solid rgba(6,191,221,0.22);
    }
    .studio-eyebrow::before {
      content: ''; width: 6px; height: 6px; border-radius: 50%;
      background: #06bfdd;
      animation: studio-pulse 1.8s ease-in-out infinite;
    }
    @keyframes studio-pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%      { opacity: 0.45; transform: scale(0.85); }
    }
    .studio-title {
      font-family: 'Inter', sans-serif;
      font-size: clamp(36px, 5.6vw, 64px);
      font-weight: 300; line-height: 1.02;
      letter-spacing: -0.05em;
      color: #fff;
      margin: 0 0 16px;
      animation: studio-fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .studio-title strong {
      font-weight: 700;
      background: linear-gradient(135deg, #06bfdd 0%, #a78bfa 50%, #f97316 100%);
      -webkit-background-clip: text;
              background-clip: text;
      color: transparent;
    }
    .studio-sub {
      font-size: 15px;
      color: rgba(255,255,255,0.55);
      margin: 0;
      animation: studio-fade-up 0.7s 0.1s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    @keyframes studio-fade-up {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .studio-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.65fr) minmax(0, 1fr);
      gap: 26px;
      align-items: start;
    }
    @media (max-width: 960px) {
      .studio-grid { grid-template-columns: 1fr; gap: 32px; }
    }

    .section-head { margin-bottom: 16px; }
    .section-label {
      display: inline-block;
      font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.14em;
      color: rgba(255,255,255,0.45);
      padding: 4px 10px;
      border-radius: 999px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
    }

    .tile-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 16px;
    }
    .tile-grid :global(.pt-card) {
      animation: studio-fade-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .tile-grid :global(.pt-card:nth-child(1)) { animation-delay: 0.10s; }
    .tile-grid :global(.pt-card:nth-child(2)) { animation-delay: 0.18s; }
    .tile-grid :global(.pt-card:nth-child(3)) { animation-delay: 0.26s; }
    .tile-grid :global(.pt-card:nth-child(4)) { animation-delay: 0.34s; }
    .tile-grid :global(.pt-card:nth-child(5)) { animation-delay: 0.42s; }

    .studio-aside {
      background: rgba(255,255,255,0.025);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 20px;
      padding: 22px 20px 18px;
      animation: studio-fade-up 0.7s 0.25s cubic-bezier(0.16, 1, 0.3, 1) both;
      position: relative;
      overflow: hidden;
    }
    .studio-aside::before {
      content: '';
      position: absolute; inset: 0; z-index: 0; pointer-events: none;
      background: radial-gradient(circle at 0% 0%, rgba(6,191,221,0.06) 0%, transparent 60%);
    }
    .studio-aside > * { position: relative; z-index: 1; }

    .empty-feed {
      padding: 14px 4px 18px;
      color: rgba(255,255,255,0.45);
      font-size: 13px;
    }
    .empty-feed p { margin: 0 0 4px; }
    .empty-feed-sub { font-size: 12px; color: rgba(255,255,255,0.35); }

    .activity-list { list-style: none; margin: 0 0 12px; padding: 0; display: flex; flex-direction: column; gap: 2px; }
    .activity-item { margin: 0; }
    .activity-link {
      display: flex; align-items: center; justify-content: space-between; gap: 12px;
      padding: 10px 10px;
      border-radius: 10px;
      text-decoration: none;
      transition: background 0.18s ease;
    }
    .activity-link:hover { background: rgba(255,255,255,0.05); }
    .activity-main {
      display: flex; flex-direction: column; gap: 3px; min-width: 0; flex: 1;
    }
    .activity-name {
      font-size: 13.5px; font-weight: 600; color: #fff;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .activity-status {
      font-size: 10.5px; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.05em;
      color: rgba(255,255,255,0.45);
    }
    .activity-status--live      { color: #6ee7a3; }
    .activity-status--generating, .activity-status--deploying { color: #f6c547; }
    .activity-status--failed    { color: #ff8a8a; }
    .activity-time {
      font-size: 11.5px; color: rgba(255,255,255,0.4);
      flex-shrink: 0;
    }
    .aside-cta {
      display: block; text-align: center; padding: 8px 12px;
      font-size: 12.5px; font-weight: 600;
      color: rgba(255,255,255,0.6); text-decoration: none;
      border-top: 1px solid rgba(255,255,255,0.06);
      margin-top: 6px; padding-top: 14px;
      transition: color 0.18s ease;
    }
    .aside-cta:hover { color: #06bfdd; }
  </style>
</Dashboard>
