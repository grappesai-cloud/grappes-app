---
// Owner-only live preview (used in the editor iframe). No <Dashboard> chrome.
// Branches on kit.mode → BrandBookTemplate vs PressKitTemplate.

import PressKitTemplate from '../../../components/PressKitTemplate.astro';
import BrandBookTemplate from '../../../components/BrandBookTemplate.astro';
import { createAdminClient } from '../../../lib/supabase';
import type { PressKit } from '../../../lib/press-kit';

const { id } = Astro.params;
const authUser = Astro.locals.user!;
const client = createAdminClient();
const { data } = await client
  .from('press_kits')
  .select('*')
  .eq('id', id!)
  .eq('user_id', authUser.id)
  .maybeSingle();
if (!data) return Astro.redirect('/kits');

const kit = data as unknown as PressKit;
const isBrandBook = (kit as any).mode === 'brand_book';
---
{isBrandBook
  ? <BrandBookTemplate kit={kit} />
  : <PressKitTemplate kit={kit} />}
