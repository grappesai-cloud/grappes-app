---
// Public press kit / brand book page — anyone with the slug, no auth required.
// `?print=1` triggers print on load. Renders BrandBookTemplate when mode==='brand_book',
// PressKitTemplate otherwise.

import PressKitTemplate from '../../components/PressKitTemplate.astro';
import BrandBookTemplate from '../../components/BrandBookTemplate.astro';
import { createAdminClient } from '../../lib/supabase';
import type { PressKit } from '../../lib/press-kit';

const { slug } = Astro.params;
const printMode = Astro.url.searchParams.get('print') === '1';

const client = createAdminClient();
const { data } = await client
  .from('press_kits')
  .select('*')
  .eq('slug', slug!)
  .eq('status', 'published')
  .maybeSingle();

if (!data) {
  return new Response('Not found', { status: 404 });
}

const kit = data as unknown as PressKit;
const isBrandBook = (kit as any).mode === 'brand_book';
---
{isBrandBook
  ? <BrandBookTemplate kit={kit} printMode={printMode} />
  : <PressKitTemplate kit={kit} printMode={printMode} />}
