---
---

<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Resetare parolă — Grappes</title>
    <link rel="icon" type="image/png" href="/assets/grappes/logo.png" />
    
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- Header -->
    <header class="auth-header">
      <div class="auth-container">
        <a href="/" class="auth-logo">
          <img src="/assets/grappes/logo.png" alt="Grappes" />
        </a>
      </div>
    </header>

    <!-- Main content -->
    <main class="auth-main">
      <div class="auth-container" style="display:flex;justify-content:center;">
        <div class="auth-form-wrap">
          <div class="auth-form-card">
            <h2 class="auth-form-title">Set new password</h2>
            <p class="auth-form-sub">Enter and confirm your new password</p>

            <div id="rp-error" class="auth-error" style="display:none;"></div>
            <div id="rp-success" class="auth-success" style="display:none;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <p>Password updated! Redirecting to dashboard…</p>
            </div>

            <form id="rp-form">
              <div class="auth-field">
                <div class="auth-input-wrap">
                  <svg class="auth-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                  <input id="rp-password" name="password" type="password" required minlength="8" autocomplete="new-password"  placeholder="New password (8+ characters)" />
                </div>
              </div>

              <div class="auth-field">
                <div class="auth-input-wrap">
                  <svg class="auth-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                  <input id="rp-confirm" name="confirm" type="password" required minlength="8" autocomplete="new-password"  placeholder="Confirm password" />
                </div>
              </div>

              <button type="submit" class="auth-submit-btn" id="rp-btn">
                <span>Update password</span>
                <svg width="20" height="20" viewBox="0 0 28 28" fill="none"><rect x="5.066" y="19.978" width="20.571" height="2.612" transform="rotate(-40.28 5.066 19.978)" fill="currentColor"/><rect x="7.971" y="7.245" width="2.612" height="2.612" transform="rotate(-40.28 7.971 7.245)" fill="currentColor"/><rect x="11.652" y="7.548" width="2.612" height="2.612" transform="rotate(-40.28 11.652 7.548)" fill="currentColor"/><rect x="15.334" y="7.852" width="2.612" height="2.612" transform="rotate(-40.28 15.334 7.852)" fill="currentColor"/><rect x="18.712" y="11.837" width="2.612" height="2.612" transform="rotate(-40.28 18.712 11.837)" fill="currentColor"/><rect x="18.408" y="15.52" width="2.612" height="2.612" transform="rotate(-40.28 18.408 15.52)" fill="currentColor"/><rect x="18.104" y="19.201" width="2.612" height="2.612" transform="rotate(-40.28 18.104 19.201)" fill="currentColor"/></svg>
              </button>
            </form>

            <p class="auth-footer-link">
              <a href="/sign-in">Back to sign in</a>
            </p>
          </div>
        </div>
      </div>
    </main>

    <link rel="stylesheet" href="/assets/grappes/auth.css" />

    <script>
      import { createClient } from '@supabase/supabase-js';
      const supabase = createClient(
        import.meta.env.PUBLIC_SUPABASE_URL,
        import.meta.env.PUBLIC_SUPABASE_ANON_KEY
      );

      const _lang = (localStorage.getItem('i18nextLng') || 'ro').split('-')[0];
      const isEn = _lang === 'en';

      // Parse hash to get tokens (Supabase sends access_token in the hash)
      const hash = window.location.hash.substring(1);
      const params = new URLSearchParams(hash);
      const accessToken = params.get('access_token');
      const refreshToken = params.get('refresh_token');

      async function init() {
        if (accessToken && refreshToken) {
          // Set the session from the hash tokens
          const { error } = await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
          if (error) {
            showError(isEn ? 'Invalid or expired reset link. Please request a new one.' : 'Link invalid sau expirat. Solicită unul nou.');
            document.getElementById('rp-form')?.remove();
          }
        } else {
          // Check if we already have a session (e.g. PKCE flow)
          const { data: { session } } = await supabase.auth.getSession();
          if (!session) {
            showError(isEn ? 'Invalid or expired reset link. Please request a new one.' : 'Link invalid sau expirat. Solicită unul nou.');
            document.getElementById('rp-form')?.remove();
          }
        }
      }

      function showError(msg: string) {
        const el = document.getElementById('rp-error') as HTMLElement;
        if (el) { el.textContent = msg; el.style.display = 'block'; }
      }

      document.getElementById('rp-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const password = (document.getElementById('rp-password') as HTMLInputElement)?.value;
        const confirm = (document.getElementById('rp-confirm') as HTMLInputElement)?.value;
        const btn = document.getElementById('rp-btn') as HTMLButtonElement;
        const errEl = document.getElementById('rp-error') as HTMLElement;

        errEl.style.display = 'none';

        if (password !== confirm) {
          errEl.textContent = isEn ? 'Passwords do not match.' : 'Parolele nu coincid.';
          errEl.style.display = 'block';
          return;
        }

        btn.disabled = true;
        const span = btn.querySelector('span');
        if (span) span.textContent = isEn ? 'Updating…' : 'Se actualizează…';

        const { error } = await supabase.auth.updateUser({ password });

        if (error) {
          errEl.textContent = error.message;
          errEl.style.display = 'block';
          btn.disabled = false;
          if (span) span.setAttribute('data-en', 'Update password');
          if (span) span.textContent = isEn ? 'Update password' : 'Actualizează parola';
        } else {
          document.getElementById('rp-form')!.style.display = 'none';
          const successEl = document.getElementById('rp-success') as HTMLElement;
          successEl.style.display = 'flex';
          setTimeout(() => { window.location.href = '/dashboard'; }, 2000);
        }
      });

      init();
    </script>
  </body>
</html>
