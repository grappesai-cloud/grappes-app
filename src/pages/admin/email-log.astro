---
import { createAdminClient } from '../../lib/supabase';
import { timingSafeEqual, createHmac } from 'node:crypto';

const ADMIN_SECRET = import.meta.env.ADMIN_SECRET ?? '';
const COOKIE_NAME = 'admin_session';
const RESEND_API_KEY = import.meta.env.RESEND_API_KEY ?? '';

function verifySessionToken(token: string): boolean {
  if (!ADMIN_SECRET || !token) return false;
  const dotIdx = token.indexOf('.');
  if (dotIdx === -1) return false;
  const nonce = token.slice(0, dotIdx);
  const sig = token.slice(dotIdx + 1);
  if (!nonce || !sig) return false;
  const expected = createHmac('sha256', ADMIN_SECRET).update(nonce).digest('hex');
  if (sig.length !== expected.length) return false;
  return timingSafeEqual(Buffer.from(sig), Buffer.from(expected));
}

// ── Auth gate ─────────────────────────────────────────────────────────────
const isAuthed = verifySessionToken(Astro.cookies.get(COOKIE_NAME)?.value ?? '');

if (!isAuthed) {
  return new Response('Unauthorized', { status: 403 });
}

// ── Fetch contact submissions from DB ──────────────────────────────────────
let contactSubmissions: any[] = [];
let dbError = '';

try {
  const db = createAdminClient();
  const { data, error } = await db
    .from('contact_submissions')
    .select('project_id, type, email, forwarded, created_at')
    .order('created_at', { ascending: false })
    .limit(100);

  if (error) {
    dbError = error.message;
  } else {
    contactSubmissions = data ?? [];
  }
} catch (e: any) {
  dbError = e.message;
}

// ── Fetch recent emails from Resend API ────────────────────────────────────
let resendEmails: any[] = [];
let resendError = '';
let bounceRate = 0;

try {
  if (RESEND_API_KEY) {
    const resp = await fetch('https://api.resend.com/emails', {
      headers: { Authorization: `Bearer ${RESEND_API_KEY}` },
    });
    if (!resp.ok) {
      resendError = `HTTP ${resp.status}`;
    } else {
      const json = await resp.json();
      resendEmails = json.data?.slice(0, 50) ?? [];

      // Calculate bounce rate
      if (resendEmails.length > 0) {
        const bounced = resendEmails.filter(
          (e: any) => e.last_event === 'bounced' || e.last_event === 'complained'
        ).length;
        bounceRate = Math.round((bounced / resendEmails.length) * 100);
      }
    }
  } else {
    resendError = 'RESEND_API_KEY not set';
  }
} catch (e: any) {
  resendError = e.message;
}

// Format date for display
function formatDate(dateStr: string): string {
  try {
    const d = new Date(dateStr);
    return d.toLocaleString('en-US', {
      month: 'short',
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    });
  } catch {
    return dateStr;
  }
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Email Log — Admin</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'DM Sans', -apple-system, 'Segoe UI', sans-serif;
      background: #0a0a0a; color: #fff;
      padding: 32px 24px 60px; min-height: 100vh;
    }
    .container { max-width: 1280px; margin: 0 auto; }
    h1 { font-size: 36px; font-weight: 300; letter-spacing: -0.02em; margin-bottom: 6px; }
    .header { margin-bottom: 24px; }
    .breadcrumb { font-size: 13px; color: rgba(255,255,255,0.5); margin-bottom: 12px; }
    .breadcrumb a { color: rgba(255,255,255,0.5); text-decoration: none; }
    .breadcrumb a:hover { color: #fff; }

    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 14px; margin-bottom: 32px; }
    .stat-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 14px;
      padding: 18px 20px;
    }
    .stat-label { font-size: 11px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 6px; }
    .stat-value { font-family: 'DM Sans', sans-serif; font-size: 32px; font-weight: 300; letter-spacing: -0.02em; color: #06bfdd; line-height: 1.1; }

    .filters { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
    .filter-pill {
      background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.7);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 999px; padding: 6px 14px;
      font-family: inherit; font-size: 12px; font-weight: 500;
      cursor: pointer; transition: all 0.15s;
    }
    .filter-pill:hover { background: rgba(255,255,255,0.08); color: #fff; }
    .filter-pill.active { background: #06bfdd; color: #0a0a0a; border-color: #06bfdd; }

    .section {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 14px;
      margin-bottom: 30px; overflow: hidden;
    }
    .section-header { padding: 18px 22px; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .section-title { font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.4); letter-spacing: 0.12em; text-transform: uppercase; }
    .error-msg { color: #ff7b7b; font-size: 13px; margin-top: 8px; }

    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th {
      text-align: left; padding: 12px 22px;
      background: rgba(255,255,255,0.02);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      font-weight: 600; color: rgba(255,255,255,0.4);
      font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
    }
    td { padding: 12px 22px; border-bottom: 1px solid rgba(255,255,255,0.04); color: rgba(255,255,255,0.85); }
    tr:last-child td { border-bottom: none; }
    tr:hover { background: rgba(255,255,255,0.03); }

    .badge {
      display: inline-block; padding: 2px 10px;
      border-radius: 999px; font-size: 11px; font-weight: 500;
      text-transform: uppercase; letter-spacing: 0.04em;
      border: 1px solid;
    }
    .badge-sent      { background: rgba(6,191,221,0.12); color: #06bfdd; border-color: rgba(6,191,221,0.3); }
    .badge-clicked   { background: rgba(108,107,243,0.12); color: #a5a6f9; border-color: rgba(108,107,243,0.3); }
    .badge-bounced   { background: rgba(255,51,52,0.12); color: #ff7b7b; border-color: rgba(255,51,52,0.35); }
    .badge-complained{ background: rgba(251,146,60,0.12); color: #fb923c; border-color: rgba(251,146,60,0.35); }
    .badge-delivered { background: rgba(110,231,163,0.1); color: #6ee7a3; border-color: rgba(110,231,163,0.25); }
    .badge-true      { background: rgba(110,231,163,0.1); color: #6ee7a3; border-color: rgba(110,231,163,0.25); }
    .badge-false     { background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.5); border-color: rgba(255,255,255,0.1); }
    .empty-msg { padding: 40px 22px; text-align: center; color: rgba(255,255,255,0.35); font-size: 13px; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="breadcrumb">
        <a href="/admin">← Admin Dashboard</a>
      </div>
      <h1>Email Activity Log</h1>
    </div>

    <div class="stats">
      <div class="stat-card">
        <div class="stat-label">Contact Submissions</div>
        <div class="stat-value">{contactSubmissions.length}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Recent Resend Emails</div>
        <div class="stat-value">{resendEmails.length}</div>
      </div>
      {resendEmails.length > 0 && (
        <div class="stat-card">
          <div class="stat-label">Bounce Rate</div>
          <div class="stat-value">{bounceRate}%</div>
        </div>
      )}
    </div>

    <!-- Contact Submissions Section -->
    <div class="section">
      <div class="section-header">
        <div class="section-title">Contact Submissions ({contactSubmissions.length})</div>
        {dbError && <div class="error-msg">{dbError}</div>}
      </div>
      {contactSubmissions.length > 0 ? (
        <table>
          <thead>
            <tr>
              <th style="width: 25%;">Project</th>
              <th style="width: 15%;">Type</th>
              <th style="width: 30%;">Email</th>
              <th style="width: 12%;">Forwarded</th>
              <th style="width: 18%;">Created</th>
            </tr>
          </thead>
          <tbody>
            {contactSubmissions.map((sub: any) => (
              <tr>
                <td style="font-family: monospace; font-size: 12px;">{sub.project_id}</td>
                <td>{sub.type}</td>
                <td>{sub.email}</td>
                <td>
                  <span
                    class={`badge ${sub.forwarded ? 'badge-true' : 'badge-false'}`}
                  >
                    {sub.forwarded ? 'Yes' : 'No'}
                  </span>
                </td>
                <td>{formatDate(sub.created_at)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <div class="empty-msg">No contact submissions found.</div>
      )}
    </div>

    <!-- Resend Emails Section -->
    <div class="section">
      <div class="section-header">
        <div class="section-title">Recent Resend Sends (Last 50)</div>
        {resendError && <div class="error-msg">{resendError}</div>}
        <div class="filters" style="margin-top:12px;" id="resend-filters">
          <button class="filter-pill active" data-filter="all">All</button>
          <button class="filter-pill" data-filter="sent">Sent</button>
          <button class="filter-pill" data-filter="delivered">Delivered</button>
          <button class="filter-pill" data-filter="bounced">Bounced</button>
          <button class="filter-pill" data-filter="complained">Complained</button>
          <button class="filter-pill" data-filter="clicked">Clicked</button>
        </div>
      </div>
      {resendEmails.length > 0 ? (
        <table>
          <thead>
            <tr>
              <th style="width: 20%;">To</th>
              <th style="width: 20%;">Subject</th>
              <th style="width: 15%;">Status</th>
              <th style="width: 18%;">Created</th>
              <th style="width: 27%;">Last Event</th>
            </tr>
          </thead>
          <tbody id="resend-rows">
            {resendEmails.map((email: any) => (
              <tr data-status={(email.last_event || email.status || 'unknown').toLowerCase()}>
                <td style="font-size: 12px;">{email.to}</td>
                <td style="font-size: 12px; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                  {email.subject || '(no subject)'}
                </td>
                <td>
                  <span class={`badge badge-${email.status?.toLowerCase() ?? 'unknown'}`}>
                    {email.status || 'unknown'}
                  </span>
                </td>
                <td style="font-size: 12px;">{formatDate(email.created_at)}</td>
                <td style="font-size: 12px;">
                  {email.last_event ? (
                    <span class={`badge badge-${email.last_event?.toLowerCase()}`}>
                      {email.last_event}
                    </span>
                  ) : (
                    '—'
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <div class="empty-msg">
          {resendError
            ? 'Could not fetch Resend data.'
            : 'No recent emails found.'}
        </div>
      )}
    </div>
  </div>
  <script is:inline>
    document.querySelectorAll('#resend-filters .filter-pill').forEach(function (pill) {
      pill.addEventListener('click', function () {
        document.querySelectorAll('#resend-filters .filter-pill').forEach(function (p) { p.classList.remove('active'); });
        pill.classList.add('active');
        var f = pill.dataset.filter;
        document.querySelectorAll('#resend-rows tr').forEach(function (row) {
          var s = row.getAttribute('data-status') || '';
          row.style.display = (f === 'all' || s === f) ? '' : 'none';
        });
      });
    });
  </script>
</body>
</html>
