---
import { createAdminClient } from '../../lib/supabase';
import { checkRateLimit } from '../../lib/rate-limit';
import { timingSafeEqual, randomBytes, createHmac } from 'node:crypto';
import { TOOLS } from '../../lib/tools';

const ADMIN_SECRET = import.meta.env.ADMIN_SECRET ?? '';
const COOKIE_NAME  = 'admin_session';

// Signed session token: HMAC(random_nonce, ADMIN_SECRET) — prevents forgery
function createSessionToken(): string {
  const nonce = randomBytes(32).toString('hex');
  const sig = createHmac('sha256', ADMIN_SECRET).update(nonce).digest('hex');
  return `${nonce}.${sig}`;
}

function verifySessionToken(token: string): boolean {
  if (!ADMIN_SECRET || !token) return false;
  const dotIdx = token.indexOf('.');
  if (dotIdx === -1) return false;
  const nonce = token.slice(0, dotIdx);
  const sig = token.slice(dotIdx + 1);
  if (!nonce || !sig) return false;
  const expected = createHmac('sha256', ADMIN_SECRET).update(nonce).digest('hex');
  if (sig.length !== expected.length) return false;
  return timingSafeEqual(Buffer.from(sig), Buffer.from(expected));
}

// ── Handle POST (login) ────────────────────────────────────────────────────
if (Astro.request.method === 'POST') {
  const ip = Astro.clientAddress ?? Astro.request.headers.get('x-forwarded-for') ?? 'unknown';
  if (!checkRateLimit(`admin-login:${ip}`, 5, 60_000)) {
    return new Response('Too many login attempts. Try again in a minute.', { status: 429 });
  }

  const formData = await Astro.request.formData();
  const secret   = (formData.get('secret') as string | null) ?? '';

  const secretOk = ADMIN_SECRET !== '' && secret.length === ADMIN_SECRET.length &&
    timingSafeEqual(Buffer.from(secret), Buffer.from(ADMIN_SECRET));
  if (secretOk) {
    Astro.cookies.set(COOKIE_NAME, createSessionToken(), {
      httpOnly:  true,
      sameSite:  'strict',
      maxAge:    3600,
      path:      '/',
    });
    return Astro.redirect('/admin');
  } else {
    // Fall through to show login with error
  }
}

// ── Auth gate ─────────────────────────────────────────────────────────────
const isAuthed = verifySessionToken(Astro.cookies.get(COOKIE_NAME)?.value ?? '');

// ── Fetch dashboard data (only if authed) ─────────────────────────────────
let stats = { totalUsers: 0, activeSites: 0, freeDeploymentsLive: 0, expiredSites: 0, failedProjects: 0 };
let recentUsers: any[]    = [];
let allProjects: any[]    = [];
let failedProjects: any[] = [];

if (isAuthed) {
  const client = createAdminClient();

  const [
    { count: totalUsers },
    { count: activeSites },
    { count: freeDeploymentsLive },
    { count: expiredSites },
    { count: failedCount },
    { data: usersData },
    { data: projectsData },
    { data: failedData },
  ] = await Promise.all([
    client.from('users').select('*', { count: 'exact', head: true }),
    client.from('projects').select('*', { count: 'exact', head: true }).eq('billing_status', 'active'),
    client.from('projects').select('*', { count: 'exact', head: true }).eq('status', 'live').eq('billing_status', 'free'),
    client.from('projects').select('*', { count: 'exact', head: true }).eq('billing_status', 'expired'),
    client.from('projects').select('*', { count: 'exact', head: true }).eq('status', 'failed'),
    client.from('users')
      .select('id, email, created_at, plan')
      .order('created_at', { ascending: false })
      .limit(30),
    client.from('projects')
      .select('id, name, status, billing_status, billing_type, expires_at, preview_url, created_at')
      .order('created_at', { ascending: false })
      .limit(50),
    client.from('projects')
      .select('id, name, user_id, created_at')
      .eq('status', 'failed')
      .order('created_at', { ascending: false }),
  ]);

  stats = {
    totalUsers:          totalUsers          ?? 0,
    activeSites:         activeSites         ?? 0,
    freeDeploymentsLive: freeDeploymentsLive ?? 0,
    expiredSites:        expiredSites        ?? 0,
    failedProjects:      failedCount         ?? 0,
  };

  recentUsers    = (usersData   ?? []) as any[];
  allProjects    = (projectsData ?? []) as any[];
  failedProjects = (failedData  ?? []) as any[];
}

function billingColor(status: string): string {
  if (status === 'active')  return '#06bfdd';
  if (status === 'free')    return '#60a5fa';
  if (status === 'expired') return '#f87171';
  return '#888';
}

function fmt(dateStr: string | null | undefined): string {
  if (!dateStr) return '—';
  return new Date(dateStr).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Grappes Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/assets/grappes/design-tokens.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #0a0a0a;
      color: #fff;
      font-family: 'DM Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
      min-height: 100vh;
      padding: 40px 20px;
    }

    .container { max-width: 1280px; margin: 0 auto; }

    h1 {
      font-size: 48px;
      font-weight: 700;
      letter-spacing: -0.05em;
      margin-bottom: 8px;
    }
    h1 span { color: #06bfdd; }

    .subtitle {
      color: rgba(255,255,255,0.4);
      font-size: 14px;
      margin-bottom: 48px;
    }

    /* ── Login form ─────────────────────────────────────────────────── */
    .login-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 80vh;
    }
    .login-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
      padding: 48px;
      width: 100%;
      max-width: 400px;
      text-align: center;
    }
    .login-card h2 {
      font-size: 28px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .login-card p { color: rgba(255,255,255,0.45); font-size: 14px; margin-bottom: 32px; }
    .login-card input[type="password"] {
      width: 100%;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 10px;
      padding: 14px 16px;
      color: #fff;
      font-family: 'DM Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
      font-size: 16px;
      margin-bottom: 16px;
      outline: none;
      transition: border-color 0.2s;
    }
    .login-card input[type="password"]:focus { border-color: #06bfdd; }
    .login-card button {
      width: 100%;
      background: #06bfdd;
      color: #0a0a0a;
      border: none;
      border-radius: 10px;
      padding: 14px;
      font-family: 'DM Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      transition: opacity 0.2s;
    }
    .login-card button:hover { opacity: 0.85; }

    /* ── Stats row ──────────────────────────────────────────────────── */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 16px;
      margin-bottom: 48px;
    }
    .stat-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 14px;
      padding: 24px 20px;
    }
    .stat-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      margin-bottom: 10px;
    }
    .stat-value {
      font-size: 40px;
      font-weight: 700;
      letter-spacing: -0.04em;
      line-height: 1;
    }
    .stat-value.green   { color: #06bfdd; }
    .stat-value.blue    { color: #60a5fa; }
    .stat-value.red     { color: #f87171; }
    .stat-value.orange  { color: #fb923c; }
    .stat-value.yellow  { color: #facc15; }
    .stat-value.default { color: #fff; }

    /* ── Section ────────────────────────────────────────────────────── */
    .section { margin-bottom: 48px; }
    .section-title {
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
      margin-bottom: 16px;
      padding-bottom: 10px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    /* ── Table ──────────────────────────────────────────────────────── */
    .table-wrap { overflow-x: auto; }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }
    thead th {
      text-align: left;
      padding: 10px 14px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    tbody tr {
      border-bottom: 1px solid rgba(255,255,255,0.04);
      transition: background 0.15s;
    }
    tbody tr:hover { background: rgba(255,255,255,0.03); }
    tbody td {
      padding: 12px 14px;
      color: rgba(255,255,255,0.8);
      vertical-align: middle;
    }
    .badge {
      display: inline-block;
      padding: 3px 9px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .badge-green   { background: rgba(6,191,221,0.12); color: #06bfdd; border: 1px solid rgba(6,191,221,0.25); }
    .badge-blue    { background: rgba(96,165,250,0.12); color: #60a5fa; border: 1px solid rgba(96,165,250,0.25); }
    .badge-red     { background: rgba(248,113,113,0.12); color: #f87171; border: 1px solid rgba(248,113,113,0.25); }
    .badge-orange  { background: rgba(251,146,60,0.12); color: #fb923c; border: 1px solid rgba(251,146,60,0.25); }
    .badge-gray    { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.5); border: 1px solid rgba(255,255,255,0.1); }

    .needs-attention {
      display: inline-block;
      padding: 3px 9px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      background: rgba(251,146,60,0.12);
      color: #fb923c;
      border: 1px solid rgba(251,146,60,0.3);
    }

    /* ── Mark Paid button ───────────────────────────────────────────── */
    .btn-mark-paid {
      background: rgba(6,191,221,0.1);
      color: #06bfdd;
      border: 1px solid rgba(6,191,221,0.3);
      border-radius: 8px;
      padding: 6px 14px;
      font-family: 'DM Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .btn-mark-paid:hover { background: rgba(6,191,221,0.2); }
    .btn-mark-paid:disabled { opacity: 0.4; cursor: not-allowed; }

    .empty-row td {
      padding: 24px 14px;
      color: rgba(255,255,255,0.3);
      font-style: italic;
    }

    a.preview-link { color: #60a5fa; text-decoration: none; font-size: 12px; }
    a.preview-link:hover { text-decoration: underline; }

    /* Admin nav */
    .admin-nav { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 28px; }
    .admin-nav-link {
      background: rgba(255,255,255,0.04);
      color: rgba(255,255,255,0.7);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 999px; padding: 8px 18px;
      font-size: 13px; font-weight: 500; text-decoration: none;
      transition: all 0.15s;
    }
    .admin-nav-link:hover { background: rgba(6,191,221,0.1); border-color: rgba(6,191,221,0.35); color: #06bfdd; }

    /* User search */
    .usearch-box { position: relative; margin-bottom: 32px; max-width: 560px; }
    #usearch-input {
      width: 100%; background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px;
      color: #fff; font-family: inherit; font-size: 14px;
      padding: 14px 18px; outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    #usearch-input:focus { border-color: #06bfdd; box-shadow: 0 0 0 3px rgba(6,191,221,0.18); }
    #usearch-input::placeholder { color: rgba(255,255,255,0.35); }
    #usearch-results {
      position: absolute; top: calc(100% + 6px); left: 0; right: 0;
      background: #14141a; border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px; max-height: 400px; overflow-y: auto;
      z-index: 10; box-shadow: 0 20px 60px rgba(0,0,0,0.55);
    }
    #usearch-results[hidden] { display: none; }
    .usearch-item {
      display: block; width: 100%; text-align: left;
      background: transparent; border: none; border-bottom: 1px solid rgba(255,255,255,0.05);
      padding: 12px 16px; cursor: pointer; color: #fff;
      font-family: inherit; transition: background 0.1s;
    }
    .usearch-item:hover { background: rgba(6,191,221,0.08); }
    .usearch-item:last-child { border-bottom: none; }
    .usearch-name { font-size: 14px; font-weight: 500; }
    .usearch-sub { font-size: 12px; color: rgba(255,255,255,0.45); margin-top: 2px; }

    /* Create account card */
    .create-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 22px; max-width: 760px; }
    .create-row { display: flex; gap: 10px; margin-bottom: 12px; flex-wrap: wrap; }
    .create-row input { flex: 1; min-width: 200px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 10px; color: #fff; font-family: inherit; font-size: 14px; padding: 12px 14px; outline: none; transition: border-color 0.15s; }
    .create-row input:focus { border-color: #06bfdd; }
    .create-hint { font-size: 12.5px; color: rgba(255,255,255,0.45); margin-bottom: 14px; }
    .tool-grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 8px; margin-bottom: 16px; }
    @media (min-width: 720px) { .tool-grid { grid-template-columns: repeat(4, minmax(0,1fr)); } }
    .tool-cell { display: flex; flex-direction: column; gap: 8px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 12px; }
    .tool-cell-head { display: flex; align-items: center; gap: 8px; }
    .tool-cell-head input[type=checkbox] { width: 15px; height: 15px; accent-color: #06bfdd; cursor: pointer; }
    .tool-dot { width: 8px; height: 8px; border-radius: 50%; flex: none; }
    .tool-name { font-size: 13px; font-weight: 500; color: #fff; }
    .cu-credit { width: 100%; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 8px; color: #fff; font-family: inherit; font-size: 13px; padding: 7px 10px; outline: none; }
    .cu-credit:focus { border-color: #06bfdd; }
    .cu-credit:disabled { opacity: 0.35; }
    .create-foot { display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
    .cu-sendmail { font-size: 13px; color: rgba(255,255,255,0.7); display: flex; align-items: center; gap: 8px; cursor: pointer; }
    .cu-sendmail input { accent-color: #06bfdd; width: 15px; height: 15px; }
    .btn-create { background: #06bfdd; color: #0a0a0a; border: none; border-radius: 999px; padding: 12px 26px; font-family: inherit; font-size: 14px; font-weight: 700; cursor: pointer; transition: opacity 0.15s; }
    .btn-create:hover { opacity: 0.85; }
    .btn-create:disabled { opacity: 0.5; cursor: wait; }
    #cu-result { margin-top: 16px; }
    #cu-result[hidden] { display: none; }
    .cu-ok { background: rgba(110,231,163,0.08); border: 1px solid rgba(110,231,163,0.3); border-radius: 12px; padding: 16px 18px; }
    .cu-ok h4 { font-size: 14px; color: #6ee7a3; margin-bottom: 10px; }
    .cu-cred { display: flex; align-items: center; gap: 10px; background: rgba(0,0,0,0.3); border-radius: 8px; padding: 10px 12px; margin-bottom: 8px; font-size: 13px; }
    .cu-cred .k { color: rgba(255,255,255,0.45); width: 72px; }
    .cu-cred .v { color: #fff; font-family: 'SFMono-Regular', Consolas, monospace; flex: 1; word-break: break-all; }
    .cu-copy { background: rgba(6,191,221,0.12); color: #06bfdd; border: 1px solid rgba(6,191,221,0.3); border-radius: 6px; padding: 5px 12px; font-size: 12px; font-weight: 600; cursor: pointer; font-family: inherit; white-space: nowrap; }
    .cu-err { background: rgba(255,123,123,0.1); border: 1px solid rgba(255,123,123,0.3); color: #ff7b7b; border-radius: 12px; padding: 14px 16px; font-size: 13px; }

    /* Tool access (drawer) */
    .ta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 7px; margin: 6px 0 12px; }
    .ta-cell { display: flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; padding: 9px 11px; font-size: 13px; color: #fff; cursor: pointer; }
    .ta-cell input { accent-color: #06bfdd; width: 14px; height: 14px; }
    .ta-cell.disabled { opacity: 0.45; }
    .ta-full { font-size: 13px; color: rgba(255,255,255,0.8); display: flex; align-items: center; gap: 8px; margin-bottom: 8px; cursor: pointer; }
    .ta-full input { accent-color: #06bfdd; width: 15px; height: 15px; }

    /* Per-tool credits (drawer) */
    .credit-row { display: grid; grid-template-columns: 1fr auto 68px auto; gap: 8px; align-items: center; padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
    .credit-row:last-child { border-bottom: none; }
    .cr-name { font-size: 13px; color: rgba(255,255,255,0.85); }
    .cr-bal { font-size: 13px; color: #06bfdd; font-weight: 700; min-width: 40px; text-align: right; font-variant-numeric: tabular-nums; }
    .cr-amt { width: 68px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 8px; color: #fff; font-family: inherit; font-size: 13px; padding: 6px 8px; outline: none; }
    .cr-amt:focus { border-color: #06bfdd; }
    .cr-add { background: rgba(6,191,221,0.12); color: #06bfdd; border: 1px solid rgba(6,191,221,0.3); border-radius: 999px; padding: 6px 14px; font-family: inherit; font-size: 12px; font-weight: 600; cursor: pointer; }
    .cr-add:hover { background: rgba(6,191,221,0.22); }

    /* User drawer */
    #user-drawer-backdrop {
      position: fixed; inset: 0; background: rgba(0,0,0,0.5);
      z-index: 800; backdrop-filter: blur(4px);
    }
    #user-drawer-backdrop[hidden] { display: none; }
    #user-drawer {
      position: fixed; top: 0; right: 0; bottom: 0;
      width: 460px; max-width: 100vw;
      background: #14141a; border-left: 1px solid rgba(255,255,255,0.08);
      box-shadow: -20px 0 60px rgba(0,0,0,0.5);
      z-index: 810; overflow-y: auto;
      transform: translateX(100%); transition: transform 0.3s cubic-bezier(0.16,1,0.3,1);
      padding: 24px 26px 40px;
    }
    #user-drawer.open { transform: translateX(0); }
    #user-drawer .close { position: absolute; top: 16px; right: 16px; background: none; border: none; color: rgba(255,255,255,0.5); cursor: pointer; font-size: 20px; padding: 4px 10px; border-radius: 6px; }
    #user-drawer .close:hover { color: #fff; background: rgba(255,255,255,0.05); }
    #user-drawer h2 { font-size: 22px; font-weight: 300; letter-spacing: -0.01em; margin: 10px 0 2px; }
    #user-drawer .u-email { font-size: 13px; color: rgba(255,255,255,0.5); margin-bottom: 18px; }
    .drawer-section { padding-top: 16px; margin-top: 16px; border-top: 1px solid rgba(255,255,255,0.06); }
    .drawer-section h3 { font-size: 11px; color: rgba(255,255,255,0.4); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 10px; font-weight: 600; }
    .kv-row { display: flex; justify-content: space-between; font-size: 13px; padding: 5px 0; color: rgba(255,255,255,0.85); }
    .kv-row .k { color: rgba(255,255,255,0.4); }
    .drawer-actions { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
    .drawer-actions button, .drawer-actions a {
      font-family: inherit; font-size: 12px; font-weight: 500;
      background: rgba(6,191,221,0.1); color: #06bfdd;
      border: 1px solid rgba(6,191,221,0.3);
      border-radius: 999px; padding: 7px 16px; cursor: pointer;
      text-decoration: none; transition: all 0.15s;
    }
    .drawer-actions button:hover, .drawer-actions a:hover { background: rgba(6,191,221,0.2); }
    .drawer-actions button:disabled { opacity: 0.5; cursor: wait; }
    .proj-item { padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.04); font-size: 13px; }
    .proj-item:last-child { border-bottom: none; }
    .proj-name { color: #fff; font-weight: 500; }
    .proj-meta { color: rgba(255,255,255,0.4); font-size: 11px; margin-top: 2px; }
    #drawer-msg { font-size: 12px; padding: 8px 12px; border-radius: 8px; margin-top: 10px; }
    #drawer-msg.success { background: rgba(110,231,163,0.1); color: #6ee7a3; border: 1px solid rgba(110,231,163,0.3); }
    #drawer-msg.error   { background: rgba(255,123,123,0.1); color: #ff7b7b; border: 1px solid rgba(255,123,123,0.3); }
    #drawer-msg[hidden] { display: none; }
  </style>
</head>
<body>

{!isAuthed ? (
  <!-- ── LOGIN FORM ──────────────────────────────────────────────────── -->
  <div class="login-wrap">
    <div class="login-card">
      <h2>Admin Access</h2>
      <p>Enter your admin secret to continue.</p>
      <form method="POST">
        <input type="password" name="secret" placeholder="Admin secret" autofocus required />
        <button type="submit">Sign in</button>
      </form>
    </div>
  </div>
) : (
  <!-- ── DASHBOARD ───────────────────────────────────────────────────── -->
  <div class="container">
    <h1>Grappes <span>Admin</span></h1>
    <p class="subtitle">Last loaded: {new Date().toUTCString()}</p>

    <!-- Nav -->
    <div class="admin-nav">
      <a href="/admin/support" class="admin-nav-link">Support inbox</a>
      <a href="/admin/costs" class="admin-nav-link">Costs</a>
      <a href="/admin/email-log" class="admin-nav-link">Email log</a>
    </div>

    <!-- User search -->
    <div class="usearch-box">
      <input id="usearch-input" type="text" placeholder="Search users by email or name…" autocomplete="off" />
      <div id="usearch-results" hidden></div>
    </div>

    <!-- Create account -->
    <div class="section">
      <div class="section-title">Create account</div>
      <div class="create-card">
        <div class="create-row">
          <input id="cu-email" type="email" placeholder="person@email.com" autocomplete="off" />
          <input id="cu-name" type="text" placeholder="Name (optional)" autocomplete="off" />
        </div>
        <p class="create-hint">Pick the tools this person sees in their account, and how many uses (credits) of each. A password is generated automatically.</p>
        <div class="tool-grid">
          {TOOLS.map((t) => (
            <label class="tool-cell">
              <span class="tool-cell-head">
                <input type="checkbox" class="cu-tool" data-key={t.key} checked />
                <span class="tool-dot" style={`background:${t.accent}`}></span>
                <span class="tool-name">{t.label}</span>
              </span>
              <input type="number" class="cu-credit" data-key={t.key} min="0" value="0" placeholder="0" title="Credits / uses" />
            </label>
          ))}
        </div>
        <div class="create-foot">
          <label class="cu-sendmail"><input id="cu-sendemail" type="checkbox" checked /> Email the login details to the user</label>
          <button id="cu-submit" class="btn-create">Create account</button>
        </div>
        <div id="cu-result" hidden></div>
      </div>
    </div>

    <!-- Stats row -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Total Users</div>
        <div class="stat-value default">{stats.totalUsers}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Active Sites</div>
        <div class="stat-value green">{stats.activeSites}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Free Live</div>
        <div class="stat-value blue">{stats.freeDeploymentsLive}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Expired Sites</div>
        <div class="stat-value red">{stats.expiredSites}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Failed Projects</div>
        <div class="stat-value orange">{stats.failedProjects}</div>
      </div>
    </div>

    <!-- Recent Users -->
    <div class="section">
      <div class="section-title">Recent Users (last 30)</div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Email</th>
              <th>Plan</th>
              <th>Joined</th>
            </tr>
          </thead>
          <tbody>
            {recentUsers.length === 0 ? (
              <tr class="empty-row"><td colspan="3">No users found.</td></tr>
            ) : recentUsers.map((u: any) => (
              <tr>
                <td>{u.email}</td>
                <td>
                  <span class={`badge ${u.plan === 'agency' ? 'badge-orange' : u.plan === 'pro' ? 'badge-blue' : u.plan === 'starter' ? 'badge-green' : 'badge-gray'}`}>
                    {u.plan ?? 'free'}
                  </span>
                </td>
                <td>{fmt(u.created_at)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- All Projects -->
    <div class="section">
      <div class="section-title">All Projects (latest 50)</div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Status</th>
              <th>Billing Status</th>
              <th>Billing Type</th>
              <th>Expires At</th>
              <th>Preview</th>
            </tr>
          </thead>
          <tbody>
            {allProjects.length === 0 ? (
              <tr class="empty-row"><td colspan="6">No projects found.</td></tr>
            ) : allProjects.map((p: any) => (
              <tr>
                <td style="font-weight:600;">{p.name ?? '—'}</td>
                <td>
                  <span class={`badge ${p.status === 'live' ? 'badge-green' : p.status === 'failed' ? 'badge-red' : 'badge-gray'}`}>
                    {p.status ?? '—'}
                  </span>
                </td>
                <td>
                  <span class={`badge ${p.billing_status === 'active' ? 'badge-green' : p.billing_status === 'free' ? 'badge-blue' : p.billing_status === 'expired' ? 'badge-red' : 'badge-gray'}`}
                    style={`color:${billingColor(p.billing_status ?? '')};`}>
                    {p.billing_status ?? '—'}
                  </span>
                </td>
                <td>{p.billing_type ?? '—'}</td>
                <td>{fmt(p.expires_at)}</td>
                <td>
                  {p.preview_url ? (
                    <a class="preview-link" href={p.preview_url} target="_blank" rel="noopener noreferrer">↗ View</a>
                  ) : '—'}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Failed Projects -->
    <div class="section">
      <div class="section-title">Failed Projects ({failedProjects.length})</div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>User ID</th>
              <th>Created At</th>
              <th>Status</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            {failedProjects.length === 0 ? (
              <tr class="empty-row"><td colspan="5">No failed projects.</td></tr>
            ) : failedProjects.map((p: any) => (
              <tr>
                <td style="font-weight:600;">{p.name ?? '—'}</td>
                <td style="font-size:11px;color:rgba(255,255,255,0.5);font-family:monospace;">{p.user_id}</td>
                <td>{fmt(p.created_at)}</td>
                <td><span class="needs-attention">Needs Attention</span></td>
                <td>
                  <button class="btn-mark-paid" onclick={`adminRetry('${p.id}', this)`}>Retry generation</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
)}

<!-- User drawer -->
<div id="user-drawer-backdrop" hidden></div>
<aside id="user-drawer" aria-hidden="true">
  <button class="close" onclick="closeDrawer()" aria-label="Close">×</button>
  <div id="drawer-content">Loading…</div>
</aside>

<script is:inline>
  // ── User search ─────────────────────────────────────────────────────────
  (function () {
    var input = document.getElementById('usearch-input');
    var results = document.getElementById('usearch-results');
    if (!input || !results) return;
    var t;
    input.addEventListener('input', function () {
      clearTimeout(t);
      var q = input.value.trim();
      if (q.length < 2) { results.hidden = true; results.innerHTML = ''; return; }
      t = setTimeout(async function () {
        try {
          var res = await fetch('/api/admin/users/search?q=' + encodeURIComponent(q));
          if (!res.ok) return;
          var data = await res.json();
          if (!data.users || data.users.length === 0) {
            results.innerHTML = '<div class="usearch-item" style="color:rgba(255,255,255,0.4);">No results</div>';
            results.hidden = false;
            return;
          }
          results.innerHTML = data.users.map(function (u) {
            return '<button class="usearch-item" onclick="openUser(\\'' + u.id + '\\')">'
              + '<div class="usearch-name">' + (u.name || u.email) + '</div>'
              + '<div class="usearch-sub">' + u.email + ' · ' + (u.plan || 'free') + '</div>'
              + '</button>';
          }).join('');
          results.hidden = false;
        } catch (e) { /* silently */ }
      }, 220);
    });
    document.addEventListener('click', function (e) {
      if (!input.contains(e.target) && !results.contains(e.target)) {
        results.hidden = true;
      }
    });
  })();

  // ── Tool catalog (mirrors src/lib/tools.ts) ─────────────────────────────────
  var TOOLS = [
    { key: 'site', label: 'Sites' }, { key: 'reel', label: 'Reels Lab' },
    { key: 'social', label: 'Social Lab' }, { key: 'audit', label: 'Audit Lab' },
    { key: 'soc2', label: 'SOC 2 Lab' }, { key: 'brandbook', label: 'Brand Book Lab' },
    { key: 'logo', label: 'Logo Lab' }, { key: 'offer', label: 'Offer Lab' },
  ];

  // ── Create account ──────────────────────────────────────────────────────────
  (function () {
    var btn = document.getElementById('cu-submit');
    if (!btn) return;
    btn.addEventListener('click', async function () {
      var email = (document.getElementById('cu-email').value || '').trim();
      var name = (document.getElementById('cu-name').value || '').trim();
      var sendEmail = document.getElementById('cu-sendemail').checked;
      var result = document.getElementById('cu-result');
      if (!email) { showCuErr('Enter an email.'); return; }

      var tools = [];
      document.querySelectorAll('.cu-tool').forEach(function (c) { if (c.checked) tools.push(c.getAttribute('data-key')); });
      var credits = {};
      document.querySelectorAll('.cu-credit').forEach(function (i) {
        var v = parseInt(i.value, 10);
        if (v > 0) credits[i.getAttribute('data-key')] = v;
      });

      btn.disabled = true; btn.textContent = 'Creating…';
      try {
        var res = await fetch('/api/admin/users/create', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, name: name || undefined, tools: tools, credits: credits, sendEmail: sendEmail }),
        });
        var d = await res.json();
        if (!res.ok) { showCuErr(d.error || 'Failed to create account.'); return; }
        result.hidden = false;
        result.innerHTML =
          '<div class="cu-ok">'
          + '<h4>✓ Account created' + (d.emailed ? ' · login details emailed' : '') + '</h4>'
          + '<div class="cu-cred"><span class="k">Email</span><span class="v" id="cu-r-email">' + d.email + '</span>'
            + '<button class="cu-copy" onclick="cuCopy(\\'cu-r-email\\', this)">Copy</button></div>'
          + '<div class="cu-cred"><span class="k">Password</span><span class="v" id="cu-r-pass">' + d.password + '</span>'
            + '<button class="cu-copy" onclick="cuCopy(\\'cu-r-pass\\', this)">Copy</button></div>'
          + '<p style="font-size:12px;color:rgba(255,255,255,0.45);margin-top:6px;">Shown once. Copy the password now if you are not emailing it.</p>'
          + '</div>';
        // Reset the form for the next one.
        document.getElementById('cu-email').value = '';
        document.getElementById('cu-name').value = '';
        document.querySelectorAll('.cu-credit').forEach(function (i) { i.value = '0'; });
      } catch (e) {
        showCuErr('Network error.');
      } finally {
        btn.disabled = false; btn.textContent = 'Create account';
      }
    });
    function showCuErr(msg) {
      var result = document.getElementById('cu-result');
      result.hidden = false;
      result.innerHTML = '<div class="cu-err">✗ ' + msg + '</div>';
    }
  })();

  window.cuCopy = function (id, btn) {
    var el = document.getElementById(id);
    if (!el) return;
    navigator.clipboard.writeText(el.textContent).then(function () {
      var o = btn.textContent; btn.textContent = 'Copied ✓';
      setTimeout(function () { btn.textContent = o; }, 1500);
    });
  };

  // ── User drawer ─────────────────────────────────────────────────────────
  window.closeDrawer = function () {
    var d = document.getElementById('user-drawer');
    var b = document.getElementById('user-drawer-backdrop');
    if (d) d.classList.remove('open');
    if (b) b.hidden = true;
    setTimeout(function () { if (d) d.setAttribute('aria-hidden', 'true'); }, 300);
  };

  window.openUser = async function (userId) {
    var d = document.getElementById('user-drawer');
    var b = document.getElementById('user-drawer-backdrop');
    var content = document.getElementById('drawer-content');
    b.hidden = false;
    setTimeout(function () { d.classList.add('open'); }, 10);
    d.setAttribute('aria-hidden', 'false');
    content.innerHTML = 'Loading…';
    try {
      var res = await fetch('/api/admin/users/' + userId);
      if (!res.ok) { content.innerHTML = '<p style="color:#ff7b7b">Failed to load user.</p>'; return; }
      var data = await res.json();
      var u = data.user;
      var ps = data.projects || [];
      var projectsHtml = ps.length === 0
        ? '<p style="color:rgba(255,255,255,0.4);font-size:12px;">No projects</p>'
        : ps.map(function (p) {
            return '<div class="proj-item">'
              + '<div class="proj-name">' + (p.name || '—') + '</div>'
              + '<div class="proj-meta">' + p.status + ' · ' + (p.billing_status || 'free') + ' · <code>' + p.id.slice(0, 8) + '</code>'
              + (p.status === 'failed' ? ' <button onclick="adminRetry(\\''+p.id+'\\', this)" style="margin-left:6px;background:rgba(246,197,71,0.15);color:#f6c547;border:1px solid rgba(246,197,71,0.3);font-size:10px;padding:2px 8px;border-radius:999px;cursor:pointer;">Retry</button>' : '')
              + '</div>'
              + '</div>';
          }).join('');

      // Tool access: null allowed_tools = full access; array = allowlist.
      var allowed = u.allowed_tools; // null | string[]
      var isFull = allowed == null;
      var taHtml = '<div class="drawer-section"><h3>Tool access</h3>'
        + '<label class="ta-full"><input type="checkbox" id="ta-full" ' + (isFull ? 'checked' : '') + ' onchange="taFullToggle()"> Full access (all tools)</label>'
        + '<div class="ta-grid">'
        + TOOLS.map(function (t) {
            var on = isFull || (allowed && allowed.indexOf(t.key) >= 0);
            return '<label class="ta-cell ' + (isFull ? 'disabled' : '') + '">'
              + '<input type="checkbox" class="ta-tool" data-key="' + t.key + '" ' + (on ? 'checked' : '') + ' ' + (isFull ? 'disabled' : '') + '> ' + t.label + '</label>';
          }).join('')
        + '</div>'
        + '<div class="drawer-actions"><button onclick="saveTools(\\'' + userId + '\\')">Save tool access</button></div>'
        + '</div>';

      // Per-tool credits: current balance + inline add (negative removes).
      var creditsHtml = '<div class="drawer-section"><h3>Credits — uses per tool</h3>'
        + '<p style="font-size:11.5px;color:rgba(255,255,255,0.4);margin-bottom:10px;">Balance shown per tool. Type an amount (negative to remove) and press Add.</p>'
        + TOOLS.map(function (t) {
            var bal = u[t.key + '_credits'] || 0;
            return '<div class="credit-row">'
              + '<span class="cr-name">' + t.label + '</span>'
              + '<span class="cr-bal" id="bal-' + t.key + '">' + bal + '</span>'
              + '<input type="number" class="cr-amt" id="amt-' + t.key + '" value="10">'
              + '<button class="cr-add" onclick="addCredit(\\'' + userId + '\\', \\'' + t.key + '\\')">Add</button>'
              + '</div>';
          }).join('')
        + '</div>';

      content.innerHTML =
        '<h2>' + (u.name || u.email) + '</h2>'
        + '<p class="u-email">' + u.email + '</p>'
        + taHtml
        + '<div class="drawer-section"><h3>Account</h3>'
          + '<div class="kv-row"><span class="k">Plan</span><span>' + (u.plan || 'free') + '</span></div>'
          + '<div class="kv-row"><span class="k">Projects limit</span><span>' + u.projects_limit + '</span></div>'
          + '<div class="kv-row"><span class="k">Edits used</span><span>' + (u.edits_used ?? 0) + '</span></div>'
          + '<div class="kv-row"><span class="k">Extra edits</span><span>' + (u.extra_edits ?? 0) + '</span></div>'
          + '<div class="kv-row"><span class="k">SOC 2 credits</span><span>' + (u.soc2_credits ?? 0) + '</span></div>'
          + '<div class="kv-row"><span class="k">Multipage lifetime</span><span>' + (u.multipage_addon_lifetime ? 'Yes' : 'No') + '</span></div>'
        + '</div>'
        + creditsHtml
        + '<div class="drawer-section"><h3>Quick actions</h3>'
          + '<div class="drawer-actions">'
            + '<button onclick="grantEdits(\\''+userId+'\\', 10)">+10 edits</button>'
            + '<button onclick="grantEdits(\\''+userId+'\\', 50)">+50 edits</button>'
            + '<button onclick="grantSoc2(\\''+userId+'\\', 10)">+10 SOC 2</button>'
            + '<button onclick="grantSoc2(\\''+userId+'\\', 100)">+100 SOC 2</button>'
            + '<button onclick="extendTrial(\\''+userId+'\\', 7)">+7 days trial</button>'
            + '<button onclick="extendTrial(\\''+userId+'\\', 30)">+30 days trial</button>'
            + '<button onclick="impersonate(\\''+userId+'\\')">Send password reset</button>'
            + '<a href="mailto:' + u.email + '">Email user</a>'
            + '<button onclick="deleteUser(\\''+userId+'\\', \\'' + (u.email || '') + '\\')" style="background:rgba(248,113,113,0.12);color:#f87171;border-color:rgba(248,113,113,0.3);">Delete account</button>'
          + '</div>'
          + '<div id="drawer-msg" hidden></div>'
        + '</div>'
        + '<div class="drawer-section"><h3>Projects (' + ps.length + ')</h3>' + projectsHtml + '</div>';
    } catch (e) {
      content.innerHTML = '<p style="color:#ff7b7b">Error: ' + e.message + '</p>';
    }
  };

  document.addEventListener('click', function (e) {
    if (e.target && e.target.id === 'user-drawer-backdrop') window.closeDrawer();
  });

  function drawerMsg(text, kind) {
    var m = document.getElementById('drawer-msg');
    if (!m) return;
    m.hidden = false;
    m.className = kind;
    m.textContent = text;
    setTimeout(function () { m.hidden = true; }, 5000);
  }

  // ── Tool access (drawer) ────────────────────────────────────────────────────
  window.taFullToggle = function () {
    var full = document.getElementById('ta-full');
    var on = full && full.checked;
    document.querySelectorAll('.ta-tool').forEach(function (c) {
      c.disabled = on;
      if (on) c.checked = true;
      c.closest('.ta-cell').classList.toggle('disabled', on);
    });
  };

  window.saveTools = async function (userId) {
    var full = document.getElementById('ta-full');
    var tools;
    if (full && full.checked) {
      tools = null; // full access
    } else {
      tools = [];
      document.querySelectorAll('.ta-tool').forEach(function (c) { if (c.checked) tools.push(c.getAttribute('data-key')); });
    }
    var res = await fetch('/api/admin/users/' + userId + '/tools', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ tools: tools }),
    });
    var d = await res.json();
    if (res.ok) drawerMsg('✓ Tool access saved' + (tools === null ? ' (full access)' : ' (' + tools.length + ' tools)'), 'success');
    else        drawerMsg('✗ ' + (d.error || 'Failed'), 'error');
  };

  window.deleteUser = async function (userId, email) {
    if (!confirm('Delete this account' + (email ? ' (' + email + ')' : '') + '? This cannot be undone.')) return;
    var res = await fetch('/api/admin/users/' + userId, { method: 'DELETE' });
    var d = await res.json();
    if (res.ok) { drawerMsg('✓ Account deleted', 'success'); setTimeout(function () { window.closeDrawer(); }, 800); }
    else        drawerMsg('✗ ' + (d.error || 'Failed'), 'error');
  };

  window.grantEdits = async function (userId, amount) {
    var res = await fetch('/api/admin/users/' + userId + '/grant-edits', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ amount: amount }),
    });
    var d = await res.json();
    if (res.ok) drawerMsg('✓ Edits updated → ' + d.extra_edits + ' extra', 'success');
    else        drawerMsg('✗ ' + (d.error || 'Failed'), 'error');
  };

  window.grantSoc2 = async function (userId, amount) {
    var res = await fetch('/api/admin/users/' + userId + '/grant-soc2-credits', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ amount: amount }),
    });
    var d = await res.json();
    if (res.ok) drawerMsg('✓ SOC 2 credits → ' + d.soc2_credits, 'success');
    else        drawerMsg('✗ ' + (d.error || 'Failed'), 'error');
  };

  // Add (or remove, if negative) credits for one tool; updates the balance inline.
  window.addCredit = async function (userId, kind) {
    var amtEl = document.getElementById('amt-' + kind);
    var amount = amtEl ? parseInt(amtEl.value, 10) : 0;
    if (!amount) { drawerMsg('Enter a non-zero amount', 'error'); return; }
    var res = await fetch('/api/admin/users/' + userId + '/grant-credits', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ kind: kind, amount: amount }),
    });
    var d = await res.json();
    if (res.ok) {
      var bal = document.getElementById('bal-' + kind);
      if (bal) bal.textContent = d.balance;
      drawerMsg('✓ ' + kind + ' credits → ' + d.balance, 'success');
    } else {
      drawerMsg('✗ ' + (d.error || 'Failed'), 'error');
    }
  };

  // Per-service credit grant (universal endpoint: { kind, amount }).
  window.grantCredit = async function (userId) {
    var kindEl = document.getElementById('credit-kind');
    var amtEl  = document.getElementById('credit-amount');
    var kind = kindEl ? kindEl.value : '';
    var amount = amtEl ? parseInt(amtEl.value, 10) : 0;
    if (!kind || !amount) { drawerMsg('Pick a service and a non-zero amount', 'error'); return; }
    var res = await fetch('/api/admin/users/' + userId + '/grant-credits', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ kind: kind, amount: amount }),
    });
    var d = await res.json();
    if (res.ok) { drawerMsg('✓ ' + d.kind + ' credits → ' + d.balance, 'success'); openUser(userId); }
    else        drawerMsg('✗ ' + (d.error || 'Failed'), 'error');
  };

  window.extendTrial = async function (userId, days) {
    var res = await fetch('/api/admin/users/' + userId + '/extend-trial', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ days: days }),
    });
    var d = await res.json();
    if (res.ok) drawerMsg('✓ Extended ' + d.updated + ' project(s) by ' + days + ' days', 'success');
    else        drawerMsg('✗ ' + (d.error || 'Failed'), 'error');
  };

  window.impersonate = async function (userId) {
    if (!confirm('Send a password-reset email to this user?')) return;
    var res = await fetch('/api/admin/users/' + userId + '/impersonate', { method: 'POST' });
    var d = await res.json();
    if (res.ok) drawerMsg('✓ ' + (d.message || 'Reset email sent to ' + d.email), 'success');
    else        drawerMsg('✗ ' + (d.error || 'Failed'), 'error');
  };

  window.adminRetry = async function (projectId, btn) {
    if (!confirm('Retry generation for this project?')) return;
    if (btn) { btn.disabled = true; btn.textContent = '…'; }
    try {
      var res = await fetch('/api/admin/projects/' + projectId + '/retry', { method: 'POST' });
      if (res.ok) {
        if (btn) { btn.textContent = '✓ Queued'; btn.style.background = 'rgba(110,231,163,0.15)'; btn.style.color = '#6ee7a3'; }
      } else {
        var d = await res.json();
        alert('Retry failed: ' + (d.error || 'unknown'));
        if (btn) { btn.disabled = false; btn.textContent = 'Retry generation'; }
      }
    } catch (e) {
      alert('Network error');
      if (btn) { btn.disabled = false; btn.textContent = 'Retry generation'; }
    }
  };
</script>

</body>
</html>
