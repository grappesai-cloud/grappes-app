  var charWrap=sec.querySelector('.boring-char');
  var bL=sec.querySelector('.bracket-left'),bR=sec.querySelector('.bracket-right');
  var click=sec.querySelector('.click-visual');

  // initial states
  gsap.set([l1,l2,l3],{opacity:0,y:30,color:'#5e5e5e'});
  gsap.set(l4,{opacity:0,scale:0.9});
  gsap.set(l5,{opacity:0,scale:0.9});
  gsap.set(charWrap,{opacity:1});
  gsap.set(charWave,{opacity:1,rotate:-6,scale:1});
  gsap.set(charShrug,{opacity:0,rotate:6,scale:0.96});
  gsap.set(bL,{opacity:0,x:-90,rotate:-14});
  gsap.set(bR,{opacity:0,x:90,rotate:14});
  gsap.set(click,{opacity:0,y:40,scale:0.55});
  

  var tl=gsap.timeline({
    scrollTrigger:{
      trigger:sec,
      start:'top top',
      end:'bottom bottom',
      scrub:0.9,
    }
  });

  // Scene 1 (0-1): "Boring is expensive" + waving character
  tl.to(l1,{opacity:1,y:0,duration:1},0);
  tl.to(charWave,{rotate:-10,scale:1.02,duration:1},0);

  // Scene 2 (1-2): + "Pitches don't land"
  tl.to(l2,{opacity:1,y:0,duration:1},1);
  tl.to(charWave,{rotate:-4,scale:1,duration:1},1);

  // Scene 3 (2-3): + "Websites don't convert" (highlight) + swap to SHRUG pose
  tl.to(l3,{opacity:1,y:0,duration:1},2);
  tl.to(l3,{color:'#ffffff',duration:0.5},2.3);
  tl.to([l1,l2],{color:'#3a3a3a',duration:0.5},2.3);
  tl.to(charWave,{opacity:0,rotate:-14,scale:0.94,duration:0.5},2.15);
  tl.to(charShrug,{opacity:1,rotate:0,scale:1.04,duration:0.6},2.25);

  // Scene 4 (3-4): fade character + text stack, big quote with brackets
  tl.to(charWrap,{opacity:0,duration:0.5},3);
  tl.to([l1,l2,l3],{opacity:0,y:-20,duration:0.5},3);
  tl.to(bL,{opacity:1,x:0,rotate:-6,duration:0.8},3.2);
  tl.to(bR,{opacity:1,x:0,rotate:6,duration:0.8},3.2);
  tl.to(l4,{opacity:1,scale:1,duration:0.8},3.3);

  // Scene 5 (4-end): bg flips light, solution text + click visual
  tl.to(bg,{backgroundColor:'#f5f5f5',duration:0.6},4);
  tl.to([bL,bR],{opacity:0,y:-30,duration:0.5},4);
  tl.to(l4,{opacity:0,duration:0.4},4);
  tl.to(l5,{opacity:1,scale:1,duration:0.7},4.15);
  tl.to(click,{opacity:1,y:0,scale:1,duration:0.8,ease:'back.out(1.7)'},4.35);
})();
</script>
