.click-visual{position:absolute;left:50%;bottom:10vh;transform:translate(-50%,40px) scale(0.55);opacity:0;height:clamp(180px,24vw,340px);width:auto;will-change:transform,opacity;pointer-events:none;z-index:4;}
.click-label{position:absolute;left:50%;bottom:calc(10vh + clamp(180px,24vw,340px) - 14px);transform:translateX(-50%) rotate(-4deg);font-family:'Inter',sans-serif;font-weight:700;font-size:clamp(1rem,1.6vw,1.7rem);color:#0a0a0a;opacity:0;will-change:transform,opacity;z-index:5;pointer-events:none;}

@media (max-width:900px){
  .boring-inner{grid-template-columns:1fr;gap:3vh;}
  .boring-text-stack{height:auto;min-height:42vh;}
