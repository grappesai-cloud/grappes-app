<!-- FAQ components script -->

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.11.5/gsap.min.js" is:inline></script>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
    // find top part (question)
    var faqTriggers = document.querySelectorAll('.faq-trigger');

    faqTriggers.forEach(function(faqTrigger) {
        // item`s answer (bottom part)
        var faqAnswer = faqTrigger.querySelector('.faq-trigger_content-wrapper');
        // vertical line which opacity changes
        var iconWrapper = faqTrigger.querySelector('.faq-trigger_line.vertical');
      	// faq trigger spacing
        var faqSpacing = faqTrigger.querySelector('.faq-trigger_spacing');

        // hide the answer
        gsap.set(faqAnswer, { height: 0, overflow: 'hidden' });
      	gsap.set(faqSpacing, { height: 0, overflow: 'hidden' });
      	gsap.set(iconWrapper, { opacity: 1 });
      	

        faqTrigger.addEventListener('click', function() {
            if (faqTrigger.classList.contains('active')) {
                // Closing
                gsap.to(faqAnswer, { height: 0, duration: 0.3, ease: 'power2.inOut' });
              	gsap.to(faqSpacing, { height: 0, duration: 0.3, ease: 'power2.inOut' });
                gsap.to(iconWrapper, { opacity: 1, duration: 0.3, ease: 'power2.inOut' });
                faqTrigger.classList.remove('active');
            } else {
                // Close all 
                faqTriggers.forEach(function(otherFaqTrigger) {
                    var otherFaqAnswer = otherFaqTrigger.querySelector('.faq-trigger_content-wrapper');
                    var otherIconWrapper = otherFaqTrigger.querySelector('.faq-trigger_line.vertical');
                  	var otherFaqSpacing = otherFaqTrigger.querySelector('.faq-trigger_spacing');

                    if (otherFaqTrigger.classList.contains('active')) {
                        gsap.to(otherFaqAnswer, { height: 0, duration: 0.3, ease: 'power2.inOut' });
                        gsap.to(otherIconWrapper, { opacity: 1, duration: 0.3, ease: 'power2.inOut' });
                      	gsap.to(otherFaqSpacing, { height: 0, duration: 0.3, ease: 'power2.inOut' });
                        otherFaqTrigger.classList.remove('active');
                    }
                });

                // Оppening current 
                gsap.set(faqAnswer, { height: 'auto' }); 
                var contentHeight = faqAnswer.offsetHeight; 
                gsap.set(faqAnswer, { height: 0 });
                gsap.to(faqAnswer, { height: contentHeight, duration: 0.3, ease: 'power2.inOut' });
              	gsap.to(faqSpacing, { height: '2.5em', duration: 0.3, ease: 'power2.inOut' }); 
                gsap.to(iconWrapper, { opacity: 0, duration: 0.3, ease: 'power2.inOut' });
                faqTrigger.classList.add('active');
            }
        });
    });
});

</script>

<script is:inline>
// Detecting if it is an iOS device, true/false
  var iOS = !!navigator.platform && /iPad|iPhone|iPod/.test(navigator.platform); 

  $(document).ready(function(){ 
    // Defining that "overlay" is the element that has a changing display value
    var overlay = document.querySelector('.header-dropdown-mobile');

    // Creating our mutation observer, which we attach to overlay later
    var observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(mutationRecord) {

        // Checking if it's the style attribute got changed and if display value now set to 'none'?
        if( mutationRecord.attributeName === 'style' && window.getComputedStyle(overlay).getPropertyValue('display') !== 'none'){

          //Overlay's  display value is no longer 'none', now changing the "body" styles:
          if (iOS) { 
            // for iOS devices:
            var x = $(window).scrollTop().toFixed()
            

            $('body').css({'overflow': 'hidden',
                           'position': 'fixed',
                           'top' : '-' + x + 'px',
                           'width': '100vw'});
          }
          // for all other devices:
          $('body').css('overflow', 'hidden');  
        } 
         //Overlay's  display value back to 'none' , now changing the "body" styles again:
         else {
               if (iOS) {
               //  for iOS devices:
                  var t = $('body').css('top').replace('-','').replace('px','')
                  $('body').css({'overflow': 'auto',
                                 'position': '',
                                 'width': '100vw'});
                  $('body').animate({scrollTop:t}, 0);
               }
              // for all other devices:
              $('body').css('overflow', '');

        }

      });    
    });
    // Attach the mutation observer to overlay, and only when attribute values change
    observer.observe(overlay, { attributes : true, attributeFilter : ['style']});

  });

