<!-- Services dropdown open/close code -->
<script is:inline>
document.addEventListener('DOMContentLoaded', function () {
    // define elements
    var serviceBtn = document.querySelector('#service-trigger');
  	if (!serviceBtn) return; // Grappes: service-trigger removed, skip dropdown wiring
  	//var heroSection = document.querySelector('.hero-section')
  	var serviceBtnText = serviceBtn.querySelector('.heading-sm');
    var navigationWrapper = $('.site-navigation_wrapper');
    var servicesGrid = $('.site-navigation_services-grid');
    var advertismentLink = $('#advertisment-link');
    var marketingLink = $('#marketing-link');
    var websitesLink = $('#websites-link');
    var creationLink = $('#creation-link');
    var plusVertical = $('#service-trigger_vertical-line')

    const openServiceMenu = () => {
        // open services dropdown menu
        gsap.to(serviceBtn, { background: 'white', duration: 0 });
      	gsap.to(serviceBtnText, { color: 'black', duration: 0 });
        gsap.to(navigationWrapper, { height: '16em', width: '66.25em', borderRadius: '0.5em', duration: 0.5, ease: 'power2.inOut' });
        gsap.to(servicesGrid, { display: 'grid' });
        gsap.to(plusVertical, { opacity: 0,  duration: 0.1, ease: 'power2.inOut'})
        gsap.to(advertismentLink, { opacity: 1, delay: 0.5, duration: 0.3, ease: 'power2.inOut' });
        gsap.to(marketingLink, { opacity: 1, delay: 0.6, duration: 0.3, ease: 'power2.inOut' });
        gsap.to(websitesLink, { opacity: 1, delay: 0.7, duration: 0.3, ease: 'power2.inOut' });
        gsap.to(creationLink, { opacity: 1, delay: 0.8, duration: 0.3, ease: 'power2.inOut' });
        serviceBtn.classList.add('active');
    }

    const closeServiceMenu = () => {
        // close services dropdown menu
        gsap.to(serviceBtn, { background: '#1c1c1c', duration: 0.2, delay: 0.6 });
        gsap.to(serviceBtnText, { color: 'white', duration: 0.2, delay: 0.6 });
        gsap.to(advertismentLink, { opacity: 0, duration: 0.3, ease: 'power2.inOut' });
        gsap.to(marketingLink, { opacity: 0, delay: 0.1, duration: 0.3, ease: 'power2.inOut' });
        gsap.to(websitesLink, { opacity: 0, delay: 0.2, duration: 0.3, ease: 'power2.inOut' });
        gsap.to(creationLink, { opacity: 0, delay: 0.3, duration: 0.3, ease: 'power2.inOut' });
        gsap.to(servicesGrid, { display: 'none', delay: 0.6 });
        gsap.to(plusVertical, { opacity: 1, delay: 0.6,  duration: 0.1, ease: 'power2.inOut'})
        gsap.to(navigationWrapper, { height: '3.375em', width: '48em', borderRadius: '6em', delay: 0.6, duration: 0.5, ease: 'power2.inOut' });
        serviceBtn.classList.remove('active');
    }

    // define initial state for the animation (services dropdown hidden)
    gsap.set(navigationWrapper, { height: '3.375em', width: '48em', borderRadius: '6em' });
    gsap.set(servicesGrid, { display: 'none' });
    gsap.set(advertismentLink, { opacity: 0 });
    gsap.set(marketingLink, { opacity: 0 });
    gsap.set(websitesLink, { opacity: 0 });
    gsap.set(creationLink, { opacity: 0 });
    gsap.set(plusVertical, { opacity: 1 })

    // when clicking on services button
    serviceBtn.addEventListener('click', function () {
        if (serviceBtn.classList.contains('active')) {
            closeServiceMenu()
        } else {
            openServiceMenu()
        }
    })
  	// when clicking outside the opened menu
    /*document.addEventListener('DOMContentLoaded', function () {
      const sections = document.querySelectorAll('section');

      sections.forEach(section => {
        section.addEventListener('click', () => {
          if (serviceBtn.classList.contains('active')) {
              closeServiceMenu()
          }
        });
      });
  	});*/
  	$(document).on('click', function(e) {
      if (!$(e.target).closest(serviceBtn).length) {
        if (serviceBtn.classList.contains('active')) {
          closeServiceMenu();
        }
      }
    });
});
</script>

