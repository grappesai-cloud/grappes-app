.boring-bg{position:absolute;inset:0;background:#0a0a0a;z-index:0;}
.boring-inner{position:relative;z-index:2;width:min(1400px,92vw);display:grid;grid-template-columns:1.4fr 1fr;gap:4vw;align-items:center;}

.boring-text-stack{position:relative;height:58vh;}
.boring-line{position:absolute;left:0;right:0;font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;font-weight:800;letter-spacing:-0.035em;line-height:1;opacity:0;color:#5e5e5e;will-change:transform,opacity;margin:0;}
.boring-line.stack{font-size:clamp(2rem,5.2vw,5rem);}
.line-1{top:4vh;}
.line-2{top:calc(4vh + 6.5vw + 1rem);}
.line-3{top:calc(4vh + 13vw + 2rem);}

.boring-char{position:relative;height:68vh;display:flex;align-items:center;justify-content:center;}
.char-img{position:absolute;height:clamp(260px,34vw,540px);width:auto;filter:drop-shadow(0 30px 70px rgba(139,92,246,0.28));transform-origin:center center;will-change:transform,opacity;}

/* overlay scenes */
.boring-centered{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;z-index:3;pointer-events:none;}
.boring-centered .big-line{font-family:'Inter',sans-serif;font-weight:800;letter-spacing:-0.035em;line-height:0.95;font-size:clamp(2.4rem,6.4vw,6rem);text-align:center;margin:0;opacity:0;will-change:transform,opacity;max-width:64vw;}
.scene-4 .big-line{color:#ffffff;}
.scene-5 .big-line{color:#0a0a0a;}

.bracket{position:absolute;top:50%;transform:translateY(-50%);height:clamp(180px,28vw,420px);width:auto;opacity:0;will-change:transform,opacity;pointer-events:none;}
