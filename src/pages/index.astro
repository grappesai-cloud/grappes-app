r"><a data-wf--let-s-talk-button--variant="dark" data-w-id="cef20cc0-067f-8aa6-856b-0aac9e515314" href="mailto:hello@grappes.ai?subject=Creative%20Direction%20inquiry" target="_blank" class="cta-btn w-variant-f71e3ad8-9e3d-e478-b020-c4c2415a31f5 w-inline-block"><div class="cta-btn-bg hover-in w-variant-f71e3ad8-9e3d-e478-b020-c4c2415a31f5"></div><div class="cta-btn-bg hover-out w-variant-f71e3ad8-9e3d-e478-b020-c4c2415a31f5"></div><div class="text-regular cta-btn-text">Work with our directors</div><div class="svg size-24 cta-btn-svg"><svg xmlns="http://www.w3.org/2000/svg" width="100%" viewBox="0 0 24 24" fill="none"><path d="M18.4795 17.6425V6L6.33081 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"></path><path d="M17.5093 6.97021L6 17.9999" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"></path></svg></div></a></div></div></div></div></div></div></section><section class="boring-section">
<style is:global>
.boring-section{position:relative;height:450vh;background:#0a0a0a;}
