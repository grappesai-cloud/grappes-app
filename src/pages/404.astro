---
// 404 — Page not found
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 — Page not found · Grappes</title>
    <link rel="icon" type="image/png" href="/assets/grappes/logo.png" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="wrapper">
      <div class="code">404</div>
      <h1>Page not found</h1>
      <p>The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="btn">← Back to home</a>
    </div>

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; }
      body {
        background: #0a0a0a; color: #fff;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        display: flex; align-items: center; justify-content: center;
        min-height: 100vh;
      }
      .wrapper { text-align: center; padding: 40px 24px; }
      .code {
        font-family: 'Inter', sans-serif;
        font-size: clamp(96px, 14vw, 160px);
        font-weight: 800; line-height: 1;
        letter-spacing: -0.06em;
        background: linear-gradient(135deg, #9BD4D7, #7ABEC1);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        margin-bottom: 24px;
      }
      h1 {
        font-family: 'Inter', sans-serif;
        font-size: clamp(22px, 3.4vw, 34px);
        font-weight: 800; letter-spacing: -0.03em;
        color: #fff; margin-bottom: 14px;
      }
      p {
        font-size: 16px; color: rgba(255,255,255,0.55); line-height: 1.6;
        max-width: 440px; margin: 0 auto 36px;
      }
      .btn {
        display: inline-flex; align-items: center; gap: 10px;
        padding: 14px 28px; background: #fff; color: #0a0a0a;
        font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 700;
        letter-spacing: -0.01em;
        text-decoration: none; border-radius: 999px;
        transition: transform 0.2s, background 0.2s, box-shadow 0.2s;
      }
      .btn:hover {
        background: #9BD4D7;
        transform: translateY(-1px);
        box-shadow: 0 8px 24px rgba(155,212,215,0.22);
      }
    </style>
  </body>
</html>
