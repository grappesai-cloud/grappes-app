---
import Dashboard from '../../layouts/Dashboard.astro';
import { createAdminClient } from '../../lib/supabase';

const authUser = Astro.locals.user;
if (!authUser) return Astro.redirect('/sign-in');

const { id } = Astro.params;
const client = createAdminClient();
const { data: logo } = await client
  .from('user_logos')
  .select('id, name, png_url, svg_url, primary_color, mood, logo_type, description, created_at')
  .eq('id', id!)
  .eq('user_id', authUser.id)
  .maybeSingle();

if (!logo) return Astro.redirect('/logo');

const l = logo as {
  id: string; name: string; png_url: string; svg_url: string | null;
  primary_color: string | null; mood: string | null; logo_type: string | null;
  description: string | null; created_at: string;
};
---
<Dashboard title={`Logo — ${l.name}`}>
  <style is:global>
    main { padding-top: 40px !important; padding-bottom: 80px !important; max-width: 1080px !important; }
  </style>

  <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:24px;flex-wrap:wrap;">
    <a href="/logo" style="display:inline-flex;align-items:center;gap:6px;font-size:11.5px;font-weight:500;color:rgba(255,255,255,0.5);text-decoration:none;letter-spacing:0.06em;text-transform:uppercase;">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      <span>Logo Lab</span>
    </a>
    <button type="button" id="ll-delete" style="display:inline-flex;align-items:center;gap:6px;background:transparent;color:rgba(255,255,255,0.55);border:1px solid rgba(255,255,255,0.12);border-radius:999px;padding:7px 16px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;letter-spacing:0.04em;">
      Delete
    </button>
  </div>

  <div style="display:grid;grid-template-columns:minmax(0,1fr) 320px;gap:24px;align-items:start;">
    <section style="background:linear-gradient(180deg,rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%),rgba(18,18,22,0.92);backdrop-filter:blur(24px) saturate(1.3);border:1px solid rgba(255,255,255,0.09);border-radius:20px;padding:18px;">
      <div style="background:#fafafa;border-radius:14px;aspect-ratio:1;display:flex;align-items:center;justify-content:center;padding:60px;">
        <img src={l.png_url} alt={l.name} style="max-width:100%;max-height:100%;object-fit:contain;" />
      </div>
    </section>

    <aside style="display:flex;flex-direction:column;gap:14px;">
      <div style="background:linear-gradient(180deg,rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%),rgba(18,18,22,0.92);backdrop-filter:blur(24px) saturate(1.3);border:1px solid rgba(255,255,255,0.09);border-radius:20px;padding:22px;">
        <span style="display:inline-block;font-size:10.5px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#a78bfa;margin-bottom:10px;">Logo</span>
        <h1 style="font-family:'Inter',sans-serif;font-size:26px;font-weight:400;letter-spacing:-0.025em;line-height:1.15;color:#fff;margin:0 0 4px;word-break:break-word;">{l.name}</h1>
        {l.logo_type && (
          <p style="font-size:12px;color:rgba(255,255,255,0.45);margin:0 0 18px;letter-spacing:0.04em;text-transform:capitalize;">{l.logo_type}{l.mood ? ` · ${l.mood}` : ''}</p>
        )}

        <div style="display:flex;flex-direction:column;gap:8px;">
          <a href={l.png_url} download={`${l.name}.png`} style="display:flex;align-items:center;justify-content:center;gap:8px;background:#a78bfa;color:#0a0a0a;border:none;border-radius:999px;height:46px;padding:0 22px;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;text-decoration:none;">
            Download PNG
          </a>
          {l.svg_url ? (
            <a href={l.svg_url} download={`${l.name}.svg`} style="display:flex;align-items:center;justify-content:center;gap:8px;background:rgba(167,139,250,0.14);color:#c4b5fd;border:1px solid rgba(167,139,250,0.4);border-radius:999px;height:46px;padding:0 22px;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;text-decoration:none;">
              Download SVG
            </a>
          ) : (
            <span style="display:flex;align-items:center;justify-content:center;height:42px;font-size:11.5px;color:rgba(255,255,255,0.4);">SVG unavailable</span>
          )}
        </div>
      </div>

      <a href="/logo/new" style="display:flex;align-items:center;justify-content:center;gap:6px;height:46px;background:rgba(255,255,255,0.04);color:rgba(255,255,255,0.85);border:1px solid rgba(255,255,255,0.12);border-radius:999px;text-decoration:none;font-size:12.5px;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;">
        Generate another →
      </a>
    </aside>
  </div>

  <style>
    @media (max-width: 760px) {
      div[style*="grid-template-columns:minmax(0,1fr) 320px"] { grid-template-columns: 1fr !important; }
    }
    #ll-delete:hover { background: rgba(239,68,68,0.12); border-color: rgba(239,68,68,0.4); color: #ff8a8a; }
  </style>

  <script is:inline define:vars={{ logoId: l.id }}>
    document.getElementById('ll-delete').addEventListener('click', async () => {
      if (!confirm('Delete this logo? This cannot be undone.')) return;
      const btn = document.getElementById('ll-delete');
      btn.disabled = true;
      btn.textContent = 'Deleting…';
      try {
        const r = await fetch(`/api/logo/${logoId}`, { method: 'DELETE' });
        if (!r.ok) {
          alert('Could not delete.');
          btn.disabled = false;
          btn.textContent = 'Delete';
          return;
        }
        window.location.href = '/logo';
      } catch {
        alert('Network error.');
        btn.disabled = false;
        btn.textContent = 'Delete';
      }
    });
  </script>
</Dashboard>
