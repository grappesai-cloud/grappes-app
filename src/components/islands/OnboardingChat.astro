---
interface Props {
  projectId: string;
  initialMessages?: { role: 'user' | 'assistant'; content: string; timestamp: string }[];
  initialCompleteness?: number;
  initialPhase?: string;
  briefLocale?: string | null;
  siteLocale?: string | null;
}

const {
  projectId,
  initialMessages = [],
  initialCompleteness = 0,
  initialPhase = 'discovery',
  briefLocale = null,
  siteLocale = null,
} = Astro.props;

const PHASES = ['discovery', 'content', 'branding', 'media', 'preferences', 'review'];
const PHASE_LABELS: Record<string, string> = {
  discovery: 'Discovery',
  content: 'Content',
  branding: 'Branding',
  media: 'Media',
  preferences: 'Preferences',
  review: 'Review',
};
const currentPhaseIdx = Math.max(0, PHASES.indexOf(initialPhase));
---

<div class="chat-wrapper">
<div class="chat-container" id="onboarding-chat">
  <!-- Progress -->
  <div class="progress-section">
    <div class="progress-header">
      <label class="progress-label" for="progress-fill">Brief <span id="completeness-value">{Math.round(initialCompleteness * 100)}%</span> complete</label>
    </div>
    <div class="progress-bar" role="progressbar" aria-label="Brief progress" aria-valuemin="0" aria-valuemax="100" aria-valuenow={Math.round(initialCompleteness * 100)}>
      <div class="progress-fill" id="progress-fill" style={`width: ${initialCompleteness * 100}%`}></div>
    </div>
    <div class="phases" role="list" aria-label="Brief phases">
      {PHASES.map((p, i) => {
        const isActive = i === currentPhaseIdx;
        const isDone = i < currentPhaseIdx;
        return (
          <span
            class={`phase-chip ${isActive ? 'active' : ''} ${isDone ? 'done' : ''}`}
            data-phase={p}
            role="listitem"
            aria-current={isActive ? 'step' : undefined}
          >
            {isDone && <span class="phase-tick" aria-hidden="true">✓</span>}
            {PHASE_LABELS[p]}
          </span>
        );
      })}
    </div>
  </div>

  <!-- Messages -->
  <div class="messages" id="messages">
    {initialMessages.length === 0 && (
      <div class="empty-state" id="empty-state">
        <div class="spinner"></div>
        <p>Starting your onboarding session…</p>
      </div>
    )}
    {initialMessages.map((msg) => (
      <div class={`message ${msg.role === 'user' ? 'user-msg' : 'assistant-msg'}`}>
        {msg.role === 'assistant' && <div class="msg-avatar" aria-hidden="true">AI</div>}
        <div class="bubble" data-raw={msg.role === 'assistant' ? msg.content : undefined}>{msg.content}</div>
      </div>
    ))}
    <!-- Typing indicator (shown via JS while assistant is responding) -->
    <div class="message assistant-msg typing-indicator" id="typing-indicator" hidden aria-live="polite">
      <div class="bubble typing-bubble"><span></span><span></span><span></span></div>
    </div>
  </div>

  <!-- Input -->
  <div class="input-area">
    <!-- Staged image previews (ChatGPT-style) -->
    <div class="staged-strip" id="staged-strip" hidden></div>

    <form class="input-form" id="chat-form">
      <!-- Hidden file input — multiple, up to 5 -->
      <input type="file" id="quick-file-input" accept=".svg,.png,.webp,.jpg,.jpeg,.gif,.heic" multiple hidden />

      <div class="input-row">
        <button type="button" id="attach-btn" class="attach-btn" title="Attach image / logo" aria-label="Attach image or logo">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
          </svg>
        </button>
        <label class="visually-hidden" for="chat-input">Your message</label>
        <textarea id="chat-input" class="chat-input" autocomplete="off" rows="1" placeholder="Type your answer…"></textarea>
      </div>
      <button type="submit" id="send-btn" class="send-btn" aria-label="Send">
        <span class="send-btn-label">Send</span>
        <svg class="send-btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="22" y1="2" x2="11" y2="13"/>
          <polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </form>
  </div>
</div><!-- end chat-container -->
</div><!-- end chat-wrapper -->

<!-- Language picker modal — shown on first session -->
<div class="lang-modal" id="lang-modal" role="dialog" aria-modal="true" aria-labelledby="lang-modal-title" hidden>
  <div class="lang-modal-backdrop"></div>
  <div class="lang-modal-card">
    <h2 id="lang-modal-title" class="lang-modal-title">Choose project languages</h2>
    <p class="lang-modal-sub">You can talk to us in one language and generate the site in another. You can change these anytime.</p>
    <form id="lang-form" class="lang-form">
      <label class="lang-field">
        <span class="lang-field-label">Brief language (chat)</span>
        <span class="lang-field-hint">What language do you want to speak with the AI consultant</span>
        <select id="lang-brief" required>
          <option value="en">English</option>
          <option value="ro">Română</option>
          <option value="fr">Français</option>
          <option value="de">Deutsch</option>
          <option value="es">Español</option>
          <option value="it">Italiano</option>
          <option value="pt">Português</option>
          <option value="nl">Nederlands</option>
          <option value="pl">Polski</option>
          <option value="hu">Magyar</option>
        </select>
      </label>
      <label class="lang-field">
        <span class="lang-field-label">Website language</span>
        <span class="lang-field-hint">What language do you want the site copy in</span>
        <select id="lang-site" required>
          <option value="en">English</option>
          <option value="ro">Română</option>
          <option value="fr">Français</option>
          <option value="de">Deutsch</option>
          <option value="es">Español</option>
          <option value="it">Italiano</option>
          <option value="pt">Português</option>
          <option value="nl">Nederlands</option>
          <option value="pl">Polski</option>
          <option value="hu">Magyar</option>
        </select>
      </label>
      <button type="submit" class="lang-submit">Continue</button>
      <p class="lang-error" id="lang-error" hidden></p>
    </form>
  </div>
</div>

<script define:vars={{ projectId, initialCompleteness, initialPhase, PHASES, hasMessages: initialMessages.length > 0, briefLocale, siteLocale }}>
  const form = document.getElementById('chat-form');
  const input = document.getElementById('chat-input');
  const sendBtn = document.getElementById('send-btn');
  const messagesEl = document.getElementById('messages');
  const progressFill = document.getElementById('progress-fill');
  const completenessValue = document.getElementById('completeness-value');
  // Declared here so setInputEnabled can reference them before the attach section runs
  const attachBtn = document.getElementById('attach-btn');
  const quickFileInput = document.getElementById('quick-file-input');

  let completeness = initialCompleteness;
  let phase = initialPhase;
  let loading = false;

  // ── Auto-resize textarea ────────────────────────────────────────────────
  function autoResize() {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 96) + 'px';
  }
  input.addEventListener('input', autoResize);

  // Enter = submit, Shift+Enter = new line
  input.addEventListener('keydown', function(ev) {
    if (ev.key === 'Enter' && !ev.shiftKey) {
      ev.preventDefault();
      form.dispatchEvent(new Event('submit', { cancelable: true }));
    }
  });

  // ── Utilities ─────────────────────────────────────────────────────────────

  function escapeHtml(str) {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  function scrollToBottom() {
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function renderAssistantBubble(bubble, content) {
    var text = String(content || '');
    var lines = text.split('\n');

    // Extract Note / warning lines (anywhere in text)
    var noteLines = [];
    var rest = [];
    for (var i = 0; i < lines.length; i++) {
      var ln = lines[i];
      if (/^\s*(note\s*:|⚠️)/i.test(ln)) noteLines.push(ln.replace(/^\s*note\s*:\s*/i, '').replace(/^⚠️\s*/, '').trim());
      else rest.push(ln);
    }

    // Find the FIRST contiguous bullet block (lines starting with "- ", allowing blank lines between)
    var bulletStart = -1, bulletEnd = -1;
    for (var j = 0; j < rest.length; j++) {
      var isBullet = /^\s*-\s+/.test(rest[j]);
      var isBlank  = /^\s*$/.test(rest[j]);
      if (isBullet) {
        if (bulletStart === -1) bulletStart = j;
        bulletEnd = j;
      } else if (bulletStart !== -1 && !isBlank) {
        break; // end of bullet block
      }
    }

    var chips = [];
    if (bulletStart !== -1 && bulletEnd > bulletStart) {
      for (var k = bulletStart; k <= bulletEnd; k++) {
        if (/^\s*-\s+/.test(rest[k])) chips.push(rest[k].replace(/^\s*-\s+/, '').trim());
      }
    }
    // Only render as chips if it's a CHOICE list (short labels, no "?").
    // Question lists and open-ended prompts stay as plain bullets.
    var looksLikeQuestions = chips.some(function(c){ return /\?\s*$/.test(c); });
    var tooLong = chips.some(function(c){ return c.length > 60; });
    var useChips = chips.length >= 2 && chips.length <= 6 && !looksLikeQuestions && !tooLong;

    var preText  = '';
    var postText = '';
    if (useChips) {
      preText  = rest.slice(0, bulletStart).join('\n').replace(/\s+$/, '');
      postText = rest.slice(bulletEnd + 1).join('\n').replace(/^\s+|\s+$/g, '');
    } else {
      preText = rest.join('\n').replace(/\s+$/, '');
    }

    // Render pre-text
    if (preText) {
      var pre = document.createElement('div');
      pre.className = 'bubble-text';
      pre.textContent = preText;
      bubble.appendChild(pre);
    }

    // Render chips
    if (useChips) {
      var chipsEl = document.createElement('div');
      chipsEl.className = 'quick-replies';
      chips.forEach(function(label) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'quick-reply';
        var short = label.split(/—|\(|:|,/)[0].trim();
        var displayLabel = (short.length && short.length < 40) ? short : label;
        btn.textContent = displayLabel;
        btn.addEventListener('click', function() {
          input.value = short || displayLabel;
          input.focus();
          form.dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }));
        });
        chipsEl.appendChild(btn);
      });
      bubble.appendChild(chipsEl);
    }

    // Render post-text (e.g. "Which direction feels right?")
    if (postText) {
      var post = document.createElement('div');
      post.className = 'bubble-text bubble-text-post';
      post.textContent = postText;
      bubble.appendChild(post);
    }

    // Note callout (always at bottom, visually distinct)
    if (noteLines.length) {
      var note = document.createElement('div');
      note.className = 'bubble-note';
      note.innerHTML = '<span class="bubble-note-icon">⚠️</span><span>' + noteLines.map(escapeHtml).join('<br>') + '</span>';
      bubble.appendChild(note);
    }
  }

  function appendMessage(role, content) {
    const wrapper = document.createElement('div');
    wrapper.className = `message ${role === 'user' ? 'user-msg' : 'assistant-msg'}`;

    if (role === 'assistant') {
      var avatar = document.createElement('div');
      avatar.className = 'msg-avatar';
      avatar.setAttribute('aria-hidden', 'true');
      avatar.textContent = 'AI';
      wrapper.appendChild(avatar);
    }

    const bubble = document.createElement('div');
    bubble.className = 'bubble';
    if (role === 'assistant') {
      renderAssistantBubble(bubble, content);
    } else {
      bubble.textContent = content;
    }
    wrapper.appendChild(bubble);
    // Insert before the typing indicator so it stays at the bottom
    var typing = document.getElementById('typing-indicator');
    if (typing && typing.parentElement === messagesEl) {
      messagesEl.insertBefore(wrapper, typing);
    } else {
      messagesEl.appendChild(wrapper);
    }
    scrollToBottom();
    return wrapper;
  }
  function showTyping() {
    var t = document.getElementById('typing-indicator');
    if (t) { t.hidden = false; scrollToBottom(); }
  }
  function hideTyping() {
    var t = document.getElementById('typing-indicator');
    if (t) t.hidden = true;
  }

  function updateProgress(newCompleteness, newPhase) {
    completeness = newCompleteness;
    phase = newPhase;
    progressFill.style.width = `${completeness * 100}%`;
    completenessValue.textContent = `${Math.round(completeness * 100)}%`;
    document.querySelectorAll('.phase-chip').forEach((chip, i) => {
      chip.className = 'phase-chip';
      if (chip.dataset.phase === phase) chip.classList.add('active');
      else if (i < PHASES.indexOf(phase)) chip.classList.add('done');
    });
  }

  // Use user's selected language from localStorage, fallback to browser language
  const browserLang = (localStorage.getItem('i18nextLng') || navigator.language || 'en').split('-')[0];

  async function callAPI(body, timeoutMs = 180000) {
    const ctrl = new AbortController();
    const timer = setTimeout(() => ctrl.abort(), timeoutMs);
    try {
      const res = await fetch(`/api/onboarding/${projectId}/message`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ...body, browserLang }),
        signal: ctrl.signal,
      });
      clearTimeout(timer);
      // Session expired → reload to login
      if (res.status === 401) { window.location.href = '/'; throw new Error('Unauthorized'); }
      let data;
      try { data = await res.json(); } catch { data = { error: 'Invalid server response' }; }
      return { res, data };
    } catch (err) {
      clearTimeout(timer);
      if (err.name === 'AbortError') throw new Error('Request timed out. Please try again.');
      throw err;
    }
  }

  function setInputEnabled(enabled) {
    loading = !enabled;
    sendBtn.disabled = !enabled;
    input.disabled = !enabled;
    if (attachBtn) attachBtn.disabled = !enabled;
  }

  function showThinking() {
    showTyping();
    // Return a shim with .remove() so existing callers using `thinking.remove()` still work.
    return { remove: hideTyping };
  }

  function showReviewCTA() {
    const existing = document.querySelector('.review-cta');
    if (existing) return;
    const cta = document.createElement('div');
    cta.className = 'review-cta';
    cta.innerHTML = `<span>Your brief looks great!</span><a href="/dashboard/${projectId}" class="review-btn">Review brief →</a>`;
    messagesEl.appendChild(cta);
    cta.scrollIntoView({ behavior: 'smooth', block: 'end' });
  }

  function showLaunchCTA() {
    const existing = document.querySelector('.launch-cta');
    if (existing) return;
    const cta = document.createElement('div');
    cta.className = 'launch-cta';
    cta.innerHTML = `
      <span>Your brief is complete!</span>
      <div class="launch-cta-btns">
        <a href="/dashboard/${projectId}" class="btn-outline-sm">Review brief</a>
        <button class="btn-launch-sm" id="chat-launch-btn">Launch website →</button>
      </div>`;
    messagesEl.appendChild(cta);
    cta.scrollIntoView({ behavior: 'smooth', block: 'end' });
    document.getElementById('chat-launch-btn')?.addEventListener('click', () => {
      window.location.href = `/dashboard/${projectId}?launch=1`;
    });
  }

  // ── Handle Haiku response ─────────────────────────────────────────────────

  function handleApiResponse(data, thinkingEl) {
    if (thinkingEl) thinkingEl.remove();

    if (data.reply) {
      const msgEl = appendMessage('assistant', data.reply);
      updateProgress(data.completeness ?? completeness, data.phase ?? phase);

      // Render upload widget if present
      if (data.uiAction) {
        const widget = buildWidget(data.uiAction);
        if (widget) {
          msgEl.appendChild(widget);
          msgEl.scrollIntoView({ behavior: 'smooth', block: 'end' });
        }
      }

      if (data.isComplete) {
        // Brief confirmed by AI — confirm THEN redirect to dashboard
        (async () => {
          try {
            await fetch(`/api/onboarding/${projectId}/confirm`, { method: 'POST' });
          } catch (e) {
            console.warn('Brief confirmation failed:', e);
          }
          window.location.href = `/dashboard/${projectId}`;
        })();
      } else if (data.isReviewReady && completeness >= 0.85) {
        showLaunchCTA();
      } else if (data.isReviewReady) {
        showReviewCTA();
      }
    }

    setInputEnabled(true);
    input.focus();
  }

  // ── Media widget builder ───────────────────────────────────────────────────

  const WIDGET_LABELS = {
    logo:    { title: 'Logo',              hint: 'SVG, PNG, WEBP — max 2 MB',  accept: '.svg,.png,.webp,.jpg,.jpeg' },
    hero:    { title: 'Hero Image',        hint: 'JPG, PNG, WEBP — max 10 MB', accept: '.jpg,.jpeg,.png,.webp' },
    section: { title: 'Section Image',     hint: 'JPG, PNG, WEBP — max 5 MB',  accept: '.jpg,.jpeg,.png,.webp' },
    menu:    { title: 'Menu Photo',        hint: 'JPG, PNG — photo of the menu — max 10 MB', accept: '.jpg,.jpeg,.png,.webp' },
    og:      { title: 'OG / Social Image', hint: 'JPG, PNG — 1200×630 — max 2 MB', accept: '.jpg,.jpeg,.png,.webp' },
    favicon: { title: 'Favicon',           hint: 'SVG or PNG — max 512 KB',    accept: '.svg,.png,.ico' },
  };

  function buildWidget(uiAction) {
    const container = document.createElement('div');
    container.className = 'media-widget';

    if (uiAction.type === 'upload') {
      const variant = uiAction.variant || 'section';
      const info = WIDGET_LABELS[variant] || WIDGET_LABELS.section;
      const label = uiAction.sectionTitle ? uiAction.sectionTitle : info.title;

      container.dataset.variant = variant;
      container.dataset.sectionId = uiAction.sectionId || '';
      container.dataset.sectionTitle = uiAction.sectionTitle || '';

      container.innerHTML = `
        <div class="dz-zone" tabindex="0" role="button" aria-label="Upload ${label}">
          <input type="file" class="dz-input" accept="${info.accept}" hidden />
          <div class="dz-body">
            <div class="dz-icon">↑</div>
            <div class="dz-label">${label}</div>
            <div class="dz-hint">${info.hint}</div>
          </div>
          <div class="dz-success" hidden>
            <span class="dz-ok">✓</span>
            <span class="dz-ok-label">Uploaded!</span>
          </div>
        </div>
        <div class="dz-footer">
          <button class="dz-skip-btn" type="button">Skip →</button>
        </div>`;

      wireUploadZone(container, uiAction);

    } else if (uiAction.type === 'choice') {
      container.innerHTML = `
        <div class="dz-choices">
          ${(uiAction.options || []).map(opt =>
            `<button class="dz-choice-btn" type="button">${opt}</button>`
          ).join('')}
        </div>`;

      container.querySelectorAll('.dz-choice-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          container.querySelectorAll('.dz-choice-btn').forEach(b => b.disabled = true);
          btn.classList.add('selected');
          setInputEnabled(false);
          const thinking = showThinking();
          try {
            const { res, data } = await callAPI({
              action: 'media_choice',
              type: uiAction.variant || 'hero',
              choice: btn.textContent,
            });
            handleApiResponse(res.ok ? data : { reply: data.error || 'Something went wrong.' }, thinking);
          } catch (err) {
            thinking.remove();
            appendMessage('assistant', err.message?.includes('timed out') ? 'Request timed out — please try again.' : 'Connection error. Please try again.');
            container.querySelectorAll('.dz-choice-btn').forEach(b => b.disabled = false);
            btn.classList.remove('selected');
            setInputEnabled(true);
          }
        });
      });
    }

    return container;
  }

  function wireUploadZone(container, uiAction) {
    const zone = container.querySelector('.dz-zone');
    const fileInput = container.querySelector('.dz-input');
    const skipBtn = container.querySelector('.dz-skip-btn');
    const dzBody = container.querySelector('.dz-body');
    const dzSuccess = container.querySelector('.dz-success');

    zone.addEventListener('click', () => { if (!zone.dataset.uploaded) fileInput.click(); });
    zone.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') fileInput.click(); });
    zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
    zone.addEventListener('drop', e => {
      e.preventDefault();
      zone.classList.remove('drag-over');
      const file = e.dataTransfer?.files[0];
      if (file) doUpload(file, container, uiAction, dzBody, dzSuccess);
    });
    fileInput.addEventListener('change', e => {
      const file = e.target.files[0];
      if (file) doUpload(file, container, uiAction, dzBody, dzSuccess);
    });
    skipBtn.addEventListener('click', async () => {
      skipBtn.disabled = true;
      skipBtn.textContent = 'Skipping…';
      setInputEnabled(false);
      const thinking = showThinking();
      try {
        const { res, data } = await callAPI({
          action: 'media_skipped',
          type: uiAction.variant || 'section',
          sectionId: uiAction.sectionId,
          sectionTitle: uiAction.sectionTitle,
        });
        handleApiResponse(res.ok ? data : { reply: data.error || 'Something went wrong.' }, thinking);
      } catch (err) {
        thinking.remove();
        appendMessage('assistant', err.message?.includes('timed out') ? 'Request timed out — please try again.' : 'Connection error. Please try again.');
        setInputEnabled(true);
        skipBtn.disabled = false;
        skipBtn.textContent = 'Skip →';
      }
    });
  }

  async function doUpload(file, container, uiAction, dzBody, dzSuccess) {
    const zone = container.querySelector('.dz-zone');
    if (zone.dataset.uploaded) return;
    if (file.size > 10 * 1024 * 1024) {
      dzBody.innerHTML = '<div class="dz-icon">✗</div><div class="dz-label">File too large</div><div class="dz-hint">Maximum 10 MB</div>';
      return;
    }
    zone.dataset.uploaded = '1';

    // Show progress
    dzBody.querySelector('.dz-icon').textContent = '⏳';
    dzBody.querySelector('.dz-label').textContent = 'Uploading…';
    dzBody.querySelector('.dz-hint').textContent = file.name;
    container.querySelector('.dz-skip-btn').disabled = true;

    const fd = new FormData();
    fd.append('file', file);
    fd.append('type', uiAction.variant || 'section');
    if (uiAction.sectionId) fd.append('sectionId', uiAction.sectionId);
    if (uiAction.sectionTitle) fd.append('sectionTitle', uiAction.sectionTitle);

    try {
      const uploadRes = await fetch(`/api/assets/${projectId}/upload`, { method: 'POST', body: fd });
      const uploadData = await uploadRes.json();

      if (!uploadRes.ok) {
        dzBody.querySelector('.dz-icon').textContent = '✕';
        dzBody.querySelector('.dz-label').textContent = uploadData.error || 'Upload failed';
        dzBody.querySelector('.dz-hint').textContent = 'Click to retry';
        delete zone.dataset.uploaded;
        container.querySelector('.dz-skip-btn').disabled = false;
        return;
      }

      // Show success
      dzBody.hidden = true;
      dzSuccess.hidden = false;
      zone.classList.add('uploaded');

      // Show thumbnail if image
      if (uploadData.asset?.public_url) {
        const img = document.createElement('img');
        img.src = uploadData.asset.public_url;
        img.style.cssText = 'max-width:120px;max-height:80px;object-fit:cover;border-radius:4px;border:1px solid rgba(56,161,105,0.2);';
        img.alt = 'Uploaded';
        dzSuccess.appendChild(img);
      }

      setInputEnabled(false);
      const thinking = showThinking();
      const isMenu = uiAction.variant === 'menu';
      const { res, data } = await callAPI({
        action: isMenu ? 'menu_uploaded' : 'media_uploaded',
        type: uiAction.variant || 'section',
        assetId: uploadData.asset?.id,
        assetUrl: isMenu ? uploadData.asset?.public_url : undefined,
        sectionId: uiAction.sectionId,
        sectionTitle: uiAction.sectionTitle,
      });
      handleApiResponse(res.ok ? data : { reply: data.error || 'Something went wrong.' }, thinking);

    } catch {
      dzBody.querySelector('.dz-icon').textContent = '✕';
      dzBody.querySelector('.dz-label').textContent = 'Network error';
      dzBody.querySelector('.dz-hint').textContent = 'Click to retry';
      delete zone.dataset.uploaded;
      container.querySelector('.dz-skip-btn').disabled = false;
    }
  }

  // ── Auto-init ──────────────────────────────────────────────────────────────

  // Scroll to bottom on load when there are existing messages
  if (hasMessages) {
    scrollToBottom();
  } else {
    setInputEnabled(false);
    // If no brief language was chosen yet, show the picker first.
    // Otherwise go straight to AI init.
    if (!briefLocale) {
      showLanguageModal();
    } else {
      setTimeout(() => initSession(0), 200);
    }
  }

  // Re-render any server-rendered assistant bubbles so they get note/chip/avatar treatment
  document.querySelectorAll('.assistant-msg .bubble[data-raw]').forEach(function(b) {
    var raw = b.getAttribute('data-raw') || '';
    b.innerHTML = '';
    renderAssistantBubble(b, raw);
  });

  function showLanguageModal() {
    var modal = document.getElementById('lang-modal');
    if (!modal) { setTimeout(() => initSession(0), 200); return; }
    // Default both to English; user can change before submitting.
    var briefSel = document.getElementById('lang-brief');
    var siteSel = document.getElementById('lang-site');
    if (briefSel) briefSel.value = 'en';
    if (siteSel)  siteSel.value  = 'en';
    modal.hidden = false;
    document.body.style.overflow = 'hidden';

    var form = document.getElementById('lang-form');
    var errEl = document.getElementById('lang-error');
    form?.addEventListener('submit', async function(e) {
      e.preventDefault();
      var btn = form.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.textContent = 'Saving…';
      errEl.hidden = true;
      try {
        var res = await fetch('/api/projects/' + projectId + '/language', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            briefLocale: briefSel.value,
            siteLocale: siteSel.value,
          }),
        });
        if (!res.ok) throw new Error('Save failed');
        modal.hidden = true;
        document.body.style.overflow = '';
        setTimeout(() => initSession(0), 100);
      } catch (err) {
        errEl.textContent = 'Failed to save languages. Try again.';
        errEl.hidden = false;
        btn.disabled = false;
        btn.textContent = 'Continue';
      }
    }, { once: false });
  }

  async function initSession(attempt) {
    try {
      const { res, data } = await callAPI({ init: true });
      document.getElementById('empty-state')?.remove();
      if (res.ok) {
        handleApiResponse(data, null);
      } else if (res.status === 503 && attempt < 1) {
        // AI overloaded — retry once after 3s
        const emptyState = document.getElementById('empty-state');
        if (emptyState) emptyState.querySelector('p').textContent = 'AI is busy, retrying…';
        setTimeout(() => initSession(1), 3000);
      } else {
        document.getElementById('empty-state')?.remove();
        appendMessage('assistant', data.reply || 'Could not start session. Please refresh the page.');
        setInputEnabled(true);
      }
    } catch (err) {
      document.getElementById('empty-state')?.remove();
      const msg = err.message?.includes('timed out')
        ? 'The request timed out. Please refresh the page.'
        : 'Connection error. Please refresh the page.';
      appendMessage('assistant', msg);
      setInputEnabled(true);
    }
  }

  // ── Quick attach (paperclip button) ───────────────────────────────────────
  // Click attach → open file picker directly. User describes in the
  // accompanying message what each file represents (logo / hero / etc.).
  attachBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    quickFileInput.click();
  });

  // ── Staged files (ChatGPT-style) ──────────────────────────────────────────
  const MAX_STAGED = 5;
  let stagedFiles = []; // [{file, type, previewUrl}]
  const stagedStrip = document.getElementById('staged-strip');

  function renderStagedStrip() {
    stagedStrip.hidden = stagedFiles.length === 0;
    stagedStrip.innerHTML = '';
    stagedFiles.forEach((item, idx) => {
      const card = document.createElement('div');
      card.className = 'staged-card';
      card.style.cssText = 'position:relative;width:72px;height:72px;border-radius:8px;overflow:hidden;border:1px solid rgba(0,0,0,0.1);flex-shrink:0;';
      card.innerHTML = `
        <img src="${item.previewUrl}" alt="${item.file.name}" class="staged-thumb" style="width:100%;height:100%;object-fit:cover;display:block;" />
        <span class="staged-type">${item.type}</span>
        <button type="button" class="staged-remove" data-idx="${idx}" aria-label="Remove">×</button>`;
      stagedStrip.appendChild(card);
    });
    stagedStrip.querySelectorAll('.staged-remove').forEach(btn => {
      btn.addEventListener('click', () => {
        const i = parseInt(btn.dataset.idx);
        URL.revokeObjectURL(stagedFiles[i].previewUrl);
        stagedFiles.splice(i, 1);
        renderStagedStrip();
      });
    });
  }

  // Pick a compatible asset type from the file. Server validates MIME per type,
  // so we must match: SVG → logo, video → video, font → font, image → section.
  function inferAssetType(file) {
    var t = (file.type || '').toLowerCase();
    if (t === 'image/svg+xml') return 'logo';
    if (t.startsWith('video/')) return 'video';
    if (t.startsWith('font/') || /\.(woff2?|ttf|otf)$/i.test(file.name)) return 'font';
    return 'section';
  }

  // File selected → stage (don't upload yet). User describes intent in message.
  quickFileInput.addEventListener('change', (e) => {
    const files = Array.from(e.target.files || []);
    quickFileInput.value = '';
    if (!files.length) return;

    const remaining = MAX_STAGED - stagedFiles.length;
    files.slice(0, remaining).forEach(file => {
      stagedFiles.push({ file, type: inferAssetType(file), previewUrl: URL.createObjectURL(file) });
    });
    renderStagedStrip();
    input.focus();
    if (!input.value.trim()) {
      input.placeholder = 'Describe what these are (e.g. "this is my logo")…';
    }
  });

  // ── Form submit ────────────────────────────────────────────────────────────

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const text = input.value.trim();
    const hasFiles = stagedFiles.length > 0;
    if (!text && !hasFiles) return;
    if (loading) return;

    input.value = '';
    input.style.height = 'auto';
    setInputEnabled(false);

    // ── Case 1: staged images to upload ──────────────────────────────────────
    if (hasFiles) {
      const filesToUpload = [...stagedFiles];
      stagedFiles = [];
      renderStagedStrip();

      // Show user bubble with thumbnails + message
      const wrapper = document.createElement('div');
      wrapper.className = 'message user-msg';
      const bubble = document.createElement('div');
      bubble.className = 'bubble upload-bubble';

      const thumbsHtml = filesToUpload.map(f =>
        `<img src="${f.previewUrl}" class="ub-thumb" style="width:72px;height:56px;object-fit:cover;border-radius:4px;border:1px solid rgba(0,0,0,0.06);" alt="${escapeHtml(f.file.name)}" />`
      ).join('');
      bubble.innerHTML = `
        <div class="ub-thumbs-row">${thumbsHtml}</div>
        ${text ? `<div class="ub-text">${escapeHtml(text)}</div>` : ''}
        <div class="ub-status">Uploading...</div>`;
      wrapper.appendChild(bubble);
      messagesEl.appendChild(wrapper);
      wrapper.scrollIntoView({ behavior: 'smooth', block: 'end' });

      // Upload all in parallel
      const results = await Promise.all(filesToUpload.map(async ({ file, type }) => {
        const fd = new FormData();
        fd.append('file', file);
        fd.append('type', type);
        try {
          const res = await fetch(`/api/assets/${projectId}/upload`, { method: 'POST', body: fd });
          const d = await res.json();
          return res.ok ? { ok: true, asset: d.asset, type } : { ok: false, error: d.error };
        } catch {
          return { ok: false, error: 'Network error' };
        }
      }));

      // Clean up object URLs
      filesToUpload.forEach(f => URL.revokeObjectURL(f.previewUrl));

      const succeeded = results.filter(r => r.ok);
      const failed = results.filter(r => !r.ok);

      if (succeeded.length === 0) {
        bubble.querySelector('.ub-status').textContent = `Upload failed: ${failed[0]?.error || 'error'}`;
        setInputEnabled(true);
        return;
      }

      bubble.querySelector('.ub-status').textContent =
        failed.length > 0
          ? `${succeeded.length} uploaded, ${failed.length} failed`
          : `${succeeded.length} ${succeeded.length === 1 ? 'image uploaded' : 'images uploaded'}`;

      // Notify Haiku with all uploaded assets + user's context
      const thinking = showThinking();
      const { res, data } = await callAPI({
        action: 'media_uploaded',
        uploads: succeeded.map(r => ({ type: r.type, assetId: r.asset?.id })),
        // keep single-upload fields for backwards compat with backend
        type: succeeded[succeeded.length - 1].type,
        assetId: succeeded[succeeded.length - 1].asset?.id,
        userContext: text || undefined,
      });
      handleApiResponse(res.ok ? data : { reply: data.error || 'Something went wrong.' }, thinking);
      return;
    }

    // ── Case 2: text only ─────────────────────────────────────────────────────
    appendMessage('user', text);
    const thinking = showThinking();

    try {
      const { res, data } = await callAPI({ message: text });
      if (res.ok) {
        handleApiResponse(data, thinking);
      } else if (res.status === 503) {
        thinking.remove();
        appendMessage('assistant', 'AI is momentarily busy — please resend your message in a few seconds.');
        setInputEnabled(true);
        input.value = text;
      } else {
        thinking.remove();
        appendMessage('assistant', data.reply || data.error || 'Something went wrong. Please try again.');
        setInputEnabled(true);
      }
    } catch (err) {
      thinking.remove();
      const msg = err.message?.includes('timed out')
        ? 'The request timed out — please try again.'
        : 'Connection error. Please try again.';
      appendMessage('assistant', msg);
      setInputEnabled(true);
      if (!err.message?.includes('timed out')) input.value = text;
    }
  });

  // ── Auto-launch trigger (from review CTA redirect) ─────────────────────────
  if (new URLSearchParams(window.location.search).get('launch') === '1') {
    window.history.replaceState({}, '', window.location.pathname);
    (async () => {
      try {
        // Confirm brief first (transitions status onboarding → brief_ready)
        await fetch(`/api/onboarding/${projectId}/confirm`, { method: 'POST' });
        // Fire generation — don't await pipeline (takes 60-800s)
        fetch(`/api/projects/${projectId}/launch`, { method: 'POST' }).catch(() => {});
        // Give server time to set status='generating', then redirect to dashboard
        await new Promise(r => setTimeout(r, 1500));
        window.location.href = `/dashboard/${projectId}`;
      } catch (e) {
        appendMessage('assistant', 'Network error during launch. Please try again.');
      }
    })();
  }

  // ── Chat eyes mouse tracking ────────────────────────────────────────────────
  (function() {
    var _idleTimer;
    document.addEventListener('mousemove', function(e) {
      clearTimeout(_idleTimer);
      document.querySelectorAll('.chat-iris').forEach(function(iris) {
        var eye = iris.closest('.chat-eye');
        if (!eye) return;
        var r = eye.getBoundingClientRect();
        var cx = r.left + r.width / 2;
        var cy = r.top + r.height / 2;
        var dx = e.clientX - cx;
        var dy = e.clientY - cy;
        var ang = Math.atan2(dy, dx);
        var ratio = Math.min(Math.hypot(dx, dy) / 260, 1);
        var ix = (Math.cos(ang) * 7 * ratio).toFixed(2);
        var iy = (Math.sin(ang) * 7 * ratio).toFixed(2);
        iris.style.animationName = 'none';
        iris.style.transform = 'translate(calc(-50% + ' + ix + 'px), calc(-30% + ' + iy + 'px))';
      });
      _idleTimer = setTimeout(function() {
        document.querySelectorAll('.chat-iris').forEach(function(iris) {
          iris.style.animationName = '';
          iris.style.transform = '';
        });
      }, 2500);
    });
  })();
</script>

