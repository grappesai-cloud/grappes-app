---
interface Step {
  selector: string;
  title?: string;
  body: string;
  placement?: 'top' | 'bottom' | 'left' | 'right' | 'auto';
}
interface Props {
  tourId: string;
  steps: Step[];
  autoStart?: boolean;
  helpButton?: boolean;
  helpButtonLabel?: string;
}
const { tourId, steps, autoStart = true, helpButton = true, helpButtonLabel = 'Tour' } = Astro.props;
const stepsJson = JSON.stringify(steps);
---

<div class="otour-root" data-tour-id={tourId} data-tour-steps={stepsJson} data-tour-autostart={autoStart ? '1' : '0'}>
  <div class="otour-backdrop" hidden></div>
  <div class="otour-spotlight" hidden></div>
  <div class="otour-card" hidden role="dialog" aria-modal="true" aria-labelledby={`otour-title-${tourId}`}>
    <div class="otour-counter"></div>
    <h3 class="otour-title" id={`otour-title-${tourId}`}></h3>
    <p class="otour-body"></p>
    <div class="otour-actions">
      <button type="button" class="otour-skip">Skip</button>
      <div class="otour-nav">
        <button type="button" class="otour-back" hidden>← Back</button>
        <button type="button" class="otour-next">Next →</button>
      </div>
    </div>
  </div>
  {helpButton && (
    <button type="button" class="otour-help-btn" aria-label="Replay tour" title="Replay tour">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/>
        <path d="M9.5 9a2.5 2.5 0 1 1 3.5 2.3c-.7.3-1 .8-1 1.7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        <circle cx="12" cy="17" r="1" fill="currentColor"/>
      </svg>
      <span class="otour-help-label">{helpButtonLabel}</span>
    </button>
  )}
</div>

<style>
  .otour-backdrop {
    position: fixed; inset: 0; z-index: 9000;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px);
    transition: opacity 0.2s ease;
  }
  .otour-backdrop[hidden] { display: none; }

  .otour-spotlight {
    position: fixed; z-index: 9001; pointer-events: none;
    border-radius: 12px;
    box-shadow: 0 0 0 9999px rgba(0,0,0,0.55), 0 0 0 3px #06bfdd, 0 0 32px rgba(6,191,221,0.5);
    transition: top 0.25s cubic-bezier(0.16,1,0.3,1), left 0.25s cubic-bezier(0.16,1,0.3,1),
                width 0.25s cubic-bezier(0.16,1,0.3,1), height 0.25s cubic-bezier(0.16,1,0.3,1);
  }
  .otour-spotlight[hidden] { display: none; }

  .otour-card {
    position: fixed; z-index: 9002;
    width: 320px; max-width: calc(100vw - 32px);
    background: rgba(20, 20, 26, 0.96);
    backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.65);
    padding: 18px 18px 16px;
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    transition: top 0.25s cubic-bezier(0.16,1,0.3,1), left 0.25s cubic-bezier(0.16,1,0.3,1);
  }
  .otour-card[hidden] { display: none; }

  .otour-counter { font-size: 11px; font-weight: 700; color: #06bfdd; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px; }
  .otour-title { font-size: 15px; font-weight: 700; color: #fff; margin: 0 0 6px; letter-spacing: -0.01em; }
  .otour-title:empty { display: none; }
  .otour-body { font-size: 13px; line-height: 1.55; color: rgba(255,255,255,0.78); margin: 0 0 14px; }

  .otour-actions { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .otour-nav { display: flex; gap: 6px; }
  .otour-card button {
    background: none; border: 1px solid rgba(255,255,255,0.14);
    color: rgba(255,255,255,0.7); font-family: inherit;
    font-size: 12px; font-weight: 600; letter-spacing: 0.01em;
    padding: 7px 12px; border-radius: 8px; cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .otour-card button:hover { background: rgba(255,255,255,0.06); color: #fff; }
  .otour-card .otour-next {
    background: #06bfdd; color: #0a0a0a; border-color: #06bfdd; font-weight: 700;
  }
  .otour-card .otour-next:hover { background: #37cce2; border-color: #37cce2; color: #0a0a0a; }

  .otour-help-btn {
    position: fixed; bottom: 88px; right: 22px; z-index: 940;
    display: inline-flex; align-items: center; gap: 6px;
    height: 36px; padding: 0 12px;
    background: rgba(20,20,26,0.85);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.14); border-radius: 999px;
    color: rgba(255,255,255,0.75);
    font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 600;
    cursor: pointer; transition: background 0.15s, color 0.15s, transform 0.15s;
  }
  .otour-help-btn:hover { background: rgba(6,191,221,0.18); color: #fff; transform: translateY(-1px); }
  .otour-help-btn svg { color: #06bfdd; }
  @media (max-width: 480px) {
    .otour-help-btn { bottom: 78px; right: 16px; }
    .otour-help-label { display: none; }
    .otour-help-btn { padding: 0; width: 36px; justify-content: center; }
  }
</style>

<script define:vars={{ tourId, stepsJson, autoStart }}>
  (function () {
    var root = document.querySelector('.otour-root[data-tour-id="' + tourId + '"]');
    if (!root) return;
    if (root.dataset.otourBound === '1') return;
    root.dataset.otourBound = '1';

    var STORAGE_KEY = 'grappes_tour_' + tourId + '_done';
    var steps = [];
    try { steps = JSON.parse(stepsJson); } catch (e) { return; }
    if (!steps.length) return;

    var backdrop = root.querySelector('.otour-backdrop');
    var spotlight = root.querySelector('.otour-spotlight');
    var card = root.querySelector('.otour-card');
    var counterEl = root.querySelector('.otour-counter');
    var titleEl = root.querySelector('.otour-title');
    var bodyEl = root.querySelector('.otour-body');
    var skipBtn = root.querySelector('.otour-skip');
    var backBtn = root.querySelector('.otour-back');
    var nextBtn = root.querySelector('.otour-next');
    var helpBtn = root.querySelector('.otour-help-btn');

    var idx = -1;
    var active = false;
    var resizeRaf = 0;

    function placeSpotlightAndCard(anchor, placement) {
      var rect = anchor.getBoundingClientRect();
      var pad = 6;
      var top = Math.max(8, rect.top - pad);
      var left = Math.max(8, rect.left - pad);
      var width = Math.min(window.innerWidth - 16, rect.width + pad * 2);
      var height = Math.min(window.innerHeight - 16, rect.height + pad * 2);
      spotlight.style.top = top + 'px';
      spotlight.style.left = left + 'px';
      spotlight.style.width = width + 'px';
      spotlight.style.height = height + 'px';
      spotlight.hidden = false;

      var cardW = card.offsetWidth || 320;
      var cardH = card.offsetHeight || 160;
      var gap = 14;
      var cTop, cLeft;
      var place = placement || 'auto';
      if (place === 'auto') {
        if (rect.bottom + gap + cardH < window.innerHeight - 8) place = 'bottom';
        else if (rect.top - gap - cardH > 8) place = 'top';
        else if (rect.right + gap + cardW < window.innerWidth - 8) place = 'right';
        else place = 'left';
      }
      if (place === 'bottom') { cTop = rect.bottom + gap; cLeft = rect.left; }
      else if (place === 'top') { cTop = rect.top - gap - cardH; cLeft = rect.left; }
      else if (place === 'right') { cTop = rect.top; cLeft = rect.right + gap; }
      else { cTop = rect.top; cLeft = rect.left - gap - cardW; }

      if (cLeft + cardW > window.innerWidth - 8) cLeft = window.innerWidth - cardW - 8;
      if (cLeft < 8) cLeft = 8;
      if (cTop + cardH > window.innerHeight - 8) cTop = window.innerHeight - cardH - 8;
      if (cTop < 8) cTop = 8;

      card.style.top = cTop + 'px';
      card.style.left = cLeft + 'px';
    }

    function tryFindAnchor(selector, attempts, cb) {
      var el = document.querySelector(selector);
      if (el && el.offsetParent !== null) { cb(el); return; }
      if (attempts <= 0) { cb(null); return; }
      setTimeout(function () { tryFindAnchor(selector, attempts - 1, cb); }, 200);
    }

    function show(i) {
      if (i < 0 || i >= steps.length) { end(); return; }
      idx = i;
      var step = steps[i];
      tryFindAnchor(step.selector, 5, function (anchor) {
        if (!anchor) {
          // Skip missing step
          if (i + 1 < steps.length) show(i + 1);
          else end();
          return;
        }
        active = true;
        backdrop.hidden = false;
        card.hidden = false;
        try { anchor.scrollIntoView({ block: 'center', inline: 'center', behavior: 'smooth' }); } catch (e) {}
        counterEl.textContent = (i + 1) + ' / ' + steps.length;
        titleEl.textContent = step.title || '';
        bodyEl.textContent = step.body;
        backBtn.hidden = i === 0;
        nextBtn.textContent = i === steps.length - 1 ? 'Done' : 'Next →';
        // Wait a tick so card has correct size after content swap
        requestAnimationFrame(function () { placeSpotlightAndCard(anchor, step.placement); });
      });
    }

    function end() {
      active = false;
      backdrop.hidden = true;
      spotlight.hidden = true;
      card.hidden = true;
      try { localStorage.setItem(STORAGE_KEY, '1'); } catch (e) {}
    }

    function start() {
      try { localStorage.removeItem(STORAGE_KEY); } catch (e) {}
      show(0);
    }

    nextBtn.addEventListener('click', function () { show(idx + 1); });
    backBtn.addEventListener('click', function () { show(Math.max(0, idx - 1)); });
    skipBtn.addEventListener('click', end);
    if (helpBtn) helpBtn.addEventListener('click', start);

    document.addEventListener('keydown', function (e) {
      if (!active) return;
      if (e.key === 'Escape') { e.preventDefault(); end(); }
      else if (e.key === 'ArrowRight' || e.key === 'Enter') { e.preventDefault(); show(idx + 1); }
      else if (e.key === 'ArrowLeft') { e.preventDefault(); show(Math.max(0, idx - 1)); }
    });

    function reposition() {
      if (!active || idx < 0) return;
      cancelAnimationFrame(resizeRaf);
      resizeRaf = requestAnimationFrame(function () {
        var anchor = document.querySelector(steps[idx].selector);
        if (anchor) placeSpotlightAndCard(anchor, steps[idx].placement);
      });
    }
    window.addEventListener('resize', reposition);
    window.addEventListener('scroll', reposition, true);

    // Public API for replay from elsewhere
    window.startTour = window.startTour || function (id) {
      if (id === tourId) start();
    };

    if (autoStart) {
      var done = false;
      try { done = localStorage.getItem(STORAGE_KEY) === '1'; } catch (e) {}
      if (!done) setTimeout(function () { show(0); }, 1200);
    }
  })();
</script>
