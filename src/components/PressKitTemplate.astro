---
import type { PressKit, KitType } from '../lib/press-kit';
import { googleFontsUrl, readableForeground } from '../lib/press-kit';

interface Props {
  kit: PressKit;
  printMode?: boolean;
}

const { kit: k, printMode = false } = Astro.props;
const fontsCss = googleFontsUrl(k.fonts);

const KIT_LABEL: Record<KitType, string> = {
  musician: 'Musician',
  agency: 'Agency',
  photographer: 'Photographer',
  founder: 'Founder',
  model: 'Talent',
  other: 'Press kit',
};

const platformLabel: Record<string, string> = {
  spotify: 'Spotify',
  soundcloud: 'SoundCloud',
  youtube: 'YouTube',
  apple_music: 'Apple Music',
  bandcamp: 'Bandcamp',
  instagram: 'Instagram',
  tiktok: 'TikTok',
  website: 'Website',
  booking: 'Booking',
  other: 'Link',
};

// Palette + foregrounds
const text = k.palette.text ?? '#0a0a0a';
const bg = k.palette.bg ?? '#fafafa';
const primary = k.palette.primary ?? '#0a0a0a';
const accent = k.palette.accent ?? '#22d3ee';
const secondary = k.palette.secondary ?? '#262626';
const onPrimary = readableForeground(primary);

// Bio splits
const bioParas = (k.bio_long ?? '').split(/\n+/).map(s => s.trim()).filter(Boolean);

// Stats: cap to 3 in the hero row, rest go to the long page
const heroStats = (k.stats ?? []).slice(0, 3);

// Quick facts sidebar values
const quickFacts: { label: string; value: string }[] = [
  { label: 'Type', value: KIT_LABEL[k.kit_type] ?? 'Press kit' },
];
if (k.contact_email) quickFacts.push({ label: 'Booking', value: k.contact_email });
if (k.contact_phone) quickFacts.push({ label: 'Phone', value: k.contact_phone });

const portrait = k.assets?.portrait;
const photos = k.assets?.photos ?? [];
const videos = k.assets?.videos ?? [];
const logo = k.assets?.logo;
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{k.name} — press kit</title>
{k.tagline && <meta name="description" content={k.tagline} />}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href={fontsCss} />
<style is:inline define:vars={{
  primary,
  secondary,
  accent,
  text,
  bg,
  onPrimary,
  headingFont: `"${k.fonts.heading}", Georgia, serif`,
  bodyFont: `"${k.fonts.body}", -apple-system, system-ui, sans-serif`,
}}>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--bodyFont);
    -webkit-font-smoothing: antialiased;
    line-height: 1.55;
    font-feature-settings: "ss01", "cv01";
  }
  body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  h1, h2, h3, h4 { font-family: var(--headingFont); letter-spacing: -0.025em; line-height: 1; font-weight: 400; }
  img { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }

  /* ── Page (A4 spreads) ───────────────────────────────────────────── */
  .pk {
    --pad-x: 22mm;
    --pad-y: 20mm;
    width: 210mm;
    margin: 0 auto;
    background: var(--bg);
  }
  .pk-spread {
    width: 210mm;
    min-height: 297mm;
    padding: var(--pad-y) var(--pad-x);
    position: relative;
    background: var(--bg);
    page-break-after: always;
    break-after: page;
    display: flex;
    flex-direction: column;
  }
  .pk-spread:last-child { page-break-after: auto; break-after: auto; }

  /* Page header (folio + dot) appears on every spread */
  .pk-folio {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--text) 45%, transparent);
    padding-bottom: 14mm;
  }
  .pk-folio-name { font-weight: 600; }
  .pk-folio-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--accent); }

  /* ── Cover spread ─────────────────────────────────────────────────── */
  .pk-cover { justify-content: space-between; }
  .pk-cover-eyebrow {
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--text) 55%, transparent);
    margin-bottom: 22mm;
  }
  .pk-cover-mark {
    display: flex;
    align-items: flex-end;
    gap: 12mm;
    margin-bottom: 14mm;
  }
  .pk-cover-logo {
    width: 28mm;
    height: 28mm;
    object-fit: contain;
    flex-shrink: 0;
  }
  .pk-cover-title {
    font-size: clamp(48px, 11vw, 96px);
    font-weight: 400;
    color: var(--text);
    line-height: 0.92;
    letter-spacing: -0.045em;
    flex: 1;
  }
  .pk-cover-rule {
    display: flex;
    align-items: center;
    gap: 10mm;
    border-top: 1px solid color-mix(in srgb, var(--text) 18%, transparent);
    padding-top: 6mm;
    margin-bottom: 8mm;
  }
  .pk-cover-tagline {
    font-family: var(--headingFont);
    font-style: italic;
    font-size: clamp(18px, 3vw, 26px);
    line-height: 1.2;
    color: color-mix(in srgb, var(--text) 78%, transparent);
    max-width: 130mm;
    letter-spacing: -0.01em;
  }
  .pk-cover-palette {
    display: flex;
    gap: 0;
    margin-left: auto;
  }
  .pk-cover-swatch {
    width: 10mm;
    height: 10mm;
    border: 1px solid color-mix(in srgb, var(--text) 8%, transparent);
  }
  .pk-cover-portrait-wrap {
    margin-top: auto;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 14mm;
  }
  .pk-cover-portrait {
    width: 90mm;
    height: 110mm;
    object-fit: cover;
    object-position: center;
    filter: contrast(1.02) saturate(0.95);
  }
  .pk-cover-meta {
    text-align: right;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--text) 55%, transparent);
    line-height: 1.8;
  }
  .pk-cover-meta strong {
    display: block;
    font-weight: 600;
    color: var(--text);
    font-size: 11px;
    letter-spacing: 0.16em;
  }

  /* ── Identity spread ──────────────────────────────────────────────── */
  .pk-section-eyebrow {
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 6mm;
  }
  .pk-section-h {
    font-size: clamp(36px, 6vw, 56px);
    line-height: 0.95;
    color: var(--text);
    margin-bottom: 12mm;
    letter-spacing: -0.035em;
  }
  .pk-identity-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
    gap: 16mm;
    align-items: start;
  }
  .pk-bio-pull {
    font-family: var(--headingFont);
    font-size: clamp(24px, 3.6vw, 34px);
    line-height: 1.15;
    color: var(--text);
    letter-spacing: -0.02em;
    margin-bottom: 10mm;
    font-style: italic;
  }
  .pk-bio-pull::first-letter {
    font-size: 1.6em;
    line-height: 0.9;
    float: left;
    margin-right: 0.06em;
    color: var(--primary);
    font-weight: 400;
  }
  .pk-bio-cols {
    column-count: 2;
    column-gap: 8mm;
    font-size: 11px;
    line-height: 1.65;
    color: color-mix(in srgb, var(--text) 90%, transparent);
    text-align: justify;
    hyphens: auto;
  }
  .pk-bio-cols p { break-inside: avoid; }
  .pk-bio-cols p + p { margin-top: 1em; }
  .pk-facts {
    border-top: 1px solid color-mix(in srgb, var(--text) 20%, transparent);
    padding-top: 6mm;
  }
  .pk-fact {
    display: grid;
    grid-template-columns: 22mm 1fr;
    gap: 4mm;
    padding: 4mm 0;
    border-bottom: 1px solid color-mix(in srgb, var(--text) 8%, transparent);
    font-size: 11px;
  }
  .pk-fact-label {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: color-mix(in srgb, var(--text) 55%, transparent);
    padding-top: 2px;
  }
  .pk-fact-value { color: var(--text); word-break: break-word; }

  /* ── Stats ────────────────────────────────────────────────────────── */
  .pk-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid color-mix(in srgb, var(--text) 20%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--text) 20%, transparent);
    margin-top: 12mm;
  }
  .pk-stats--two { grid-template-columns: repeat(2, 1fr); }
  .pk-stats--one { grid-template-columns: 1fr; }
  .pk-stat {
    padding: 10mm 6mm;
    border-right: 1px solid color-mix(in srgb, var(--text) 14%, transparent);
  }
  .pk-stat:last-child { border-right: 0; }
  .pk-stat-v {
    font-family: var(--headingFont);
    font-size: clamp(40px, 6.5vw, 72px);
    font-weight: 400;
    color: var(--primary);
    line-height: 0.9;
    letter-spacing: -0.045em;
    font-feature-settings: "tnum", "lnum";
  }
  .pk-stat-l {
    font-size: 9.5px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: color-mix(in srgb, var(--text) 55%, transparent);
    margin-top: 6mm;
  }

  /* ── Press list ───────────────────────────────────────────────────── */
  .pk-press-list { border-top: 1px solid color-mix(in srgb, var(--text) 18%, transparent); }
  .pk-press-row {
    display: grid;
    grid-template-columns: 50mm 14mm 1fr;
    gap: 8mm;
    padding: 6mm 0;
    border-bottom: 1px solid color-mix(in srgb, var(--text) 10%, transparent);
    align-items: baseline;
  }
  .pk-press-name {
    font-family: var(--headingFont);
    font-size: 18px;
    color: var(--text);
    letter-spacing: -0.015em;
  }
  .pk-press-year {
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--text) 55%, transparent);
  }
  .pk-press-quote {
    font-style: italic;
    font-size: 11.5px;
    line-height: 1.5;
    color: color-mix(in srgb, var(--text) 80%, transparent);
  }

  /* ── Awards (same skeleton as press) ──────────────────────────────── */
  .pk-awards { border-top: 1px solid color-mix(in srgb, var(--text) 18%, transparent); }
  .pk-award-row {
    display: grid;
    grid-template-columns: 1fr 14mm 50mm;
    gap: 8mm;
    padding: 6mm 0;
    border-bottom: 1px solid color-mix(in srgb, var(--text) 10%, transparent);
    align-items: baseline;
  }
  .pk-award-name { font-family: var(--headingFont); font-size: 16px; color: var(--text); letter-spacing: -0.015em; }
  .pk-award-issuer { font-size: 11px; color: color-mix(in srgb, var(--text) 70%, transparent); text-align: right; }
  .pk-award-year { font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: color-mix(in srgb, var(--text) 55%, transparent); }

  /* ── Photo grid ───────────────────────────────────────────────────── */
  .pk-photo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6mm;
    margin-top: 6mm;
  }
  .pk-photo {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    background: color-mix(in srgb, var(--text) 6%, transparent);
  }
  .pk-photo:nth-child(5n+1) {
    grid-column: span 2;
    aspect-ratio: 16/9;
  }

  /* ── Contact spread ───────────────────────────────────────────────── */
  .pk-contact-spread {
    background: var(--primary);
    color: var(--onPrimary);
  }
  .pk-contact-spread .pk-folio { color: color-mix(in srgb, var(--onPrimary) 55%, transparent); }
  .pk-contact-spread .pk-folio-dot { background: var(--accent); }
  .pk-contact-h {
    font-size: clamp(48px, 9vw, 96px);
    line-height: 0.92;
    letter-spacing: -0.045em;
    margin-bottom: 14mm;
    color: var(--onPrimary);
  }
  .pk-contact-rows {
    border-top: 1px solid color-mix(in srgb, var(--onPrimary) 22%, transparent);
  }
  .pk-contact-row {
    display: grid;
    grid-template-columns: 32mm 1fr;
    gap: 8mm;
    padding: 6mm 0;
    border-bottom: 1px solid color-mix(in srgb, var(--onPrimary) 10%, transparent);
    align-items: baseline;
  }
  .pk-contact-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: color-mix(in srgb, var(--onPrimary) 60%, transparent);
  }
  .pk-contact-val {
    font-family: var(--headingFont);
    font-size: clamp(20px, 2.6vw, 26px);
    color: var(--onPrimary);
    letter-spacing: -0.015em;
    word-break: break-word;
  }
  .pk-contact-val a { border-bottom: 1px solid color-mix(in srgb, var(--onPrimary) 32%, transparent); padding-bottom: 2px; }

  .pk-footer {
    margin-top: auto;
    padding-top: 10mm;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--onPrimary) 55%, transparent);
  }
  .pk-footer a {
    color: color-mix(in srgb, var(--onPrimary) 75%, transparent);
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
  }

  /* ── Light-background spread footer ───────────────────────────────── */
  .pk-spread:not(.pk-contact-spread) .pk-footer {
    color: color-mix(in srgb, var(--text) 45%, transparent);
  }
  .pk-spread:not(.pk-contact-spread) .pk-footer a {
    color: color-mix(in srgb, var(--text) 65%, transparent);
  }

  /* ── Responsive (preview iframe shrinks the A4 page) ──────────────── */
  @media (max-width: 820px) {
    .pk { width: 100%; }
    .pk-spread { width: 100%; min-height: auto; padding: 8vw 6vw; }
    .pk-identity-grid { grid-template-columns: 1fr; }
    .pk-bio-cols { column-count: 1; }
    .pk-stats { grid-template-columns: repeat(2, 1fr); }
    .pk-press-row { grid-template-columns: 1fr; gap: 2mm; padding: 4mm 0; }
    .pk-award-row { grid-template-columns: 1fr; gap: 2mm; padding: 4mm 0; }
    .pk-photo-grid { grid-template-columns: 1fr; }
    .pk-cover-mark { flex-direction: column; align-items: flex-start; gap: 6mm; }
    .pk-cover-portrait-wrap { grid-template-columns: 1fr; }
    .pk-cover-portrait { width: 100%; height: auto; aspect-ratio: 4/5; }
  }

  /* ── Print ────────────────────────────────────────────────────────── */
  @page { size: A4; margin: 0; }
  @media print {
    html, body { background: var(--bg); }
    .pk-spread { page-break-after: always; break-after: page; padding: var(--pad-y) var(--pad-x); }
    .pk-spread:last-child { page-break-after: auto; }
    .pk-section, .pk-press-row, .pk-award-row, .pk-photo, .pk-fact, .pk-stat { break-inside: avoid; }
    a { color: inherit; }
  }
</style>
</head>
<body>
  <div class="pk">

    {/* ────────────── COVER SPREAD ────────────── */}
    <section class="pk-spread pk-cover">
      <header class="pk-folio">
        <span class="pk-folio-name">{KIT_LABEL[k.kit_type] ?? 'Press'} — {k.name}</span>
        <span class="pk-folio-dot"></span>
        <span>Press kit · 01</span>
      </header>

      <div class="pk-cover-eyebrow">{KIT_LABEL[k.kit_type] ?? 'Press kit'} · Press kit</div>

      <div class="pk-cover-mark">
        {logo && <img src={logo} alt={`${k.name} logo`} class="pk-cover-logo" />}
        <h1 class="pk-cover-title">{k.name}</h1>
      </div>

      <div class="pk-cover-rule">
        {k.tagline && <p class="pk-cover-tagline">{k.tagline}</p>}
        <div class="pk-cover-palette" aria-hidden="true">
          <span class="pk-cover-swatch" style={`background:${primary};`}></span>
          <span class="pk-cover-swatch" style={`background:${accent};`}></span>
          <span class="pk-cover-swatch" style={`background:${secondary};`}></span>
        </div>
      </div>

      <div class="pk-cover-portrait-wrap">
        {portrait ? (
          <img src={portrait} alt={k.name} class="pk-cover-portrait" />
        ) : (
          <div></div>
        )}
        <div class="pk-cover-meta">
          <strong>{new Date(k.created_at).getFullYear()}</strong>
          <span>Edition 01</span><br />
          <span>{KIT_LABEL[k.kit_type] ?? 'Press kit'}</span>
        </div>
      </div>

      <div class="pk-footer">
        <span>{k.name}</span>
        <span>01 / Press kit</span>
      </div>
    </section>

    {/* ────────────── IDENTITY SPREAD ────────────── */}
    {(k.bio_short || k.bio_long || heroStats.length > 0) && (
      <section class="pk-spread">
        <header class="pk-folio">
          <span class="pk-folio-name">{k.name}</span>
          <span class="pk-folio-dot"></span>
          <span>Identity · 02</span>
        </header>

        <div class="pk-section-eyebrow">About</div>
        <h2 class="pk-section-h">The story.</h2>

        <div class="pk-identity-grid">
          <div>
            {k.bio_short && <p class="pk-bio-pull">{k.bio_short}</p>}
            {bioParas.length > 0 && (
              <div class="pk-bio-cols">
                {bioParas.map(p => <p>{p}</p>)}
              </div>
            )}
          </div>
          {quickFacts.length > 0 && (
            <aside class="pk-facts">
              {quickFacts.map(f => (
                <div class="pk-fact">
                  <span class="pk-fact-label">{f.label}</span>
                  <span class="pk-fact-value">{f.value}</span>
                </div>
              ))}
            </aside>
          )}
        </div>

        {heroStats.length > 0 && (
          <div class={`pk-stats ${heroStats.length === 1 ? 'pk-stats--one' : heroStats.length === 2 ? 'pk-stats--two' : ''}`}>
            {heroStats.map(s => (
              <div class="pk-stat">
                <div class="pk-stat-v">{s.value}</div>
                <div class="pk-stat-l">{s.label}</div>
              </div>
            ))}
          </div>
        )}

        <div class="pk-footer">
          <span>The story</span>
          <span>02</span>
        </div>
      </section>
    )}

    {/* ────────────── PRESS / AWARDS SPREAD ────────────── */}
    {((k.press && k.press.length > 0) || (k.awards && k.awards.length > 0)) && (
      <section class="pk-spread">
        <header class="pk-folio">
          <span class="pk-folio-name">{k.name}</span>
          <span class="pk-folio-dot"></span>
          <span>Press & Recognition · 03</span>
        </header>

        {k.press && k.press.length > 0 && (
          <>
            <div class="pk-section-eyebrow">Featured in</div>
            <h2 class="pk-section-h">Press.</h2>
            <div class="pk-press-list">
              {k.press.map(p => (
                <div class="pk-press-row">
                  <div class="pk-press-name">{p.name}</div>
                  <div class="pk-press-year">{p.year ?? ''}</div>
                  <div class="pk-press-quote">
                    {p.quote && <span>“{p.quote}”</span>}
                    {p.url && (
                      <>
                        {p.quote && <br />}
                        <a href={p.url} target="_blank" rel="noopener" style="text-decoration:underline;text-underline-offset:3px;font-style:normal;">Read article ↗</a>
                      </>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </>
        )}

        {k.awards && k.awards.length > 0 && (
          <div style="margin-top:18mm;">
            <div class="pk-section-eyebrow">Recognition</div>
            <h2 class="pk-section-h">Awards.</h2>
            <div class="pk-awards">
              {k.awards.map(a => (
                <div class="pk-award-row">
                  <div class="pk-award-name">{a.name}</div>
                  <div class="pk-award-year">{a.year ?? ''}</div>
                  <div class="pk-award-issuer">{a.issuer ?? ''}</div>
                </div>
              ))}
            </div>
          </div>
        )}

        <div class="pk-footer">
          <span>Press & recognition</span>
          <span>03</span>
        </div>
      </section>
    )}

    {/* ────────────── GALLERY SPREAD ────────────── */}
    {photos.length > 0 && (
      <section class="pk-spread">
        <header class="pk-folio">
          <span class="pk-folio-name">{k.name}</span>
          <span class="pk-folio-dot"></span>
          <span>Gallery · 04</span>
        </header>

        <div class="pk-section-eyebrow">Visuals</div>
        <h2 class="pk-section-h">Gallery.</h2>

        <div class="pk-photo-grid">
          {photos.slice(0, 9).map(url => <img src={url} alt="" class="pk-photo" />)}
        </div>

        <div class="pk-footer">
          <span>Gallery</span>
          <span>04</span>
        </div>
      </section>
    )}

    {/* ────────────── CONTACT SPREAD ────────────── */}
    <section class="pk-spread pk-contact-spread">
      <header class="pk-folio">
        <span class="pk-folio-name">{k.name}</span>
        <span class="pk-folio-dot"></span>
        <span>Contact · 05</span>
      </header>

      <div class="pk-section-eyebrow" style={`color:${accent};`}>Get in touch</div>
      <h2 class="pk-contact-h">Let's talk.</h2>

      <div class="pk-contact-rows">
        {k.contact_email && (
          <div class="pk-contact-row">
            <span class="pk-contact-label">Email</span>
            <span class="pk-contact-val"><a href={`mailto:${k.contact_email}`}>{k.contact_email}</a></span>
          </div>
        )}
        {k.contact_phone && (
          <div class="pk-contact-row">
            <span class="pk-contact-label">Phone</span>
            <span class="pk-contact-val"><a href={`tel:${k.contact_phone}`}>{k.contact_phone}</a></span>
          </div>
        )}
        {k.contact_other && (
          <div class="pk-contact-row">
            <span class="pk-contact-label">Other</span>
            <span class="pk-contact-val">{k.contact_other}</span>
          </div>
        )}
        {(k.links ?? []).map(l => (
          <div class="pk-contact-row">
            <span class="pk-contact-label">{platformLabel[l.platform] ?? l.platform}</span>
            <span class="pk-contact-val"><a href={l.url} target="_blank" rel="noopener">{l.url.replace(/^https?:\/\//, '').replace(/\/$/, '')}</a></span>
          </div>
        ))}
      </div>

      <div class="pk-footer">
        <span>Press kit by {k.name}</span>
        <a href="https://grappes.dev" target="_blank" rel="noopener">prepared with Grappes</a>
      </div>
    </section>

  </div>

  {printMode && (
    <script is:inline>window.addEventListener('load', () => setTimeout(() => window.print(), 800));</script>
  )}
</body>
</html>
