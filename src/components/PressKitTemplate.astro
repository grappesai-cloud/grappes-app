---
// ── DENY-2026-style Press Kit template ─────────────────────────────────────
// 7-page landscape (A4) PDF / live preview. Modeled on "DENY — PRESSKIT
// 2026": dark cover with a huge distressed wordmark + portrait, then five
// content spreads (Overview, Biography, Career Highlights, Discography /
// Portfolio, Statistics) with a full-bleed portrait on the left and a black
// content panel on the right, and a final "Contact & Booking" variation
// with the wordmark watermarked behind the portrait.
//
// All text is editorial / awwwards-grade typography (Anton + Manrope + Lora
// + Caveat) and section titles get a hand-drawn SVG scribble overlay in the
// kit's auto-derived ACCENT color (see accentForKit()).

import type { PressKit, KitRole } from '../lib/press-kit';
import { accentForKit } from '../lib/press-kit';

interface Props {
  kit: PressKit;
  printMode?: boolean;
}

const { kit: k, printMode = false } = Astro.props;
const accent = accentForKit(k);
const YEAR = new Date(k.created_at ?? Date.now()).getFullYear() || new Date().getFullYear();

// ── Role-driven copy switches ───────────────────────────────────────────────
const role: KitRole | string = (k.role || k.kit_type || 'other') as any;
const isMusician = ['dj','producer','musician'].includes(String(role).toLowerCase()) || k.kit_type === 'musician';
const PORTFOLIO_TITLE  = isMusician ? 'DISCOGRAPHY'     : 'PORTFOLIO';
const FESTIVALS_TITLE  = isMusician ? 'Festival Appearances' : 'Notable Projects';
const INTL_TITLE       = isMusician ? 'International Expansion' : 'International Reach';
const CHARTS_TITLE     = isMusician ? 'Chart & Radio Success' : 'Recognition';

// ── Asset selection (with safe cycling) ─────────────────────────────────────
const coverPortrait = k.assets?.cover_portrait
  || k.assets?.portrait
  || k.assets?.spread_portraits?.[0]
  || k.assets?.photos?.[0]
  || null;

const spreadPool = (k.assets?.spread_portraits && k.assets.spread_portraits.length > 0)
  ? k.assets.spread_portraits
  : (k.assets?.photos && k.assets.photos.length > 0)
    ? k.assets.photos
    : coverPortrait ? [coverPortrait] : [];
const portraitFor = (i: number): string | null =>
  spreadPool.length > 0 ? spreadPool[i % spreadPool.length] : null;

// ── Content blocks ─────────────────────────────────────────────────────────
const overviewIntro = (k.overview_intro ?? '').trim();
const overviewStats = (k.stats ?? []).filter(s => s.value || s.label);
const highlights    = (k.key_highlights ?? []).filter(Boolean);
const bigStats      = (k.big_stats ?? []).filter(s => s.value || s.label);
const bioParas      = (k.bio_long ?? '').split(/\n+/).map(s => s.trim()).filter(Boolean);
const sharedStage   = (k.shared_stage ?? '').split(',').map(s => s.trim()).filter(Boolean);
const festivals     = (k.career?.festivals ?? []).filter(Boolean);
const intlExp       = (k.career?.international ?? []).filter(Boolean);
const charts        = (k.career?.charts ?? []).filter(Boolean);

// Portfolio / discography entries — pulled from `press` jsonb (repurposed)
// row shape used by the wizard: { year, title, role|name }
type PressRow = { year?: string; name?: string; title?: string; role?: string; quote?: string; url?: string };
const portfolioRows: PressRow[] = (k.press ?? []) as any;
const portfolioByYear: Record<string, PressRow[]> = {};
for (const row of portfolioRows) {
  const y = (row.year || '—').toString();
  (portfolioByYear[y] ||= []).push(row);
}
const portfolioYears = Object.keys(portfolioByYear).sort((a, b) => (b > a ? 1 : b < a ? -1 : 0));

// Booking agents
const agents = (k.booking?.agents ?? []).filter(a => a && (a.name || a.email));
const igHandle    = k.booking?.instagram ?? (k.links ?? []).find(l => l.platform === 'instagram')?.url ?? '';
const pressLink   = k.booking?.press_link ?? '';
const monogram    = (k.name || 'PK').replace(/[^A-Za-z]/g, '').slice(0, 2).toUpperCase() || 'PK';

// Pages we actually render based on available content
const showBiography = !!k.bio_long || sharedStage.length > 0;
const showCareer    = festivals.length + intlExp.length + charts.length > 0;
const showPortfolio = portfolioRows.length > 0;
const showStats     = bigStats.length > 0;

// Build section list (used for the footer page numbers)
const pages: { key: string; title: string; show: boolean }[] = [
  { key: 'cover',      title: 'COVER',                 show: true },
  { key: 'overview',   title: 'OVERVIEW',              show: true },
  { key: 'biography',  title: 'BIOGRAPHY',             show: showBiography },
  { key: 'career',     title: 'CAREER HIGHLIGHTS',     show: showCareer },
  { key: 'portfolio',  title: PORTFOLIO_TITLE,         show: showPortfolio },
  { key: 'statistics', title: 'STATISTICS',            show: showStats },
  { key: 'contact',    title: 'CONTACT & BOOKING',     show: true },
].filter(p => p.show);
const pageNumberOf = (key: string) => String(pages.findIndex(p => p.key === key) + 1).padStart(2, '0');
const totalPages = pages.length;

// Google Fonts — Anton (display), Manrope (block sans), Lora (serif body),
// Caveat (script signature/labels), Oswald (alt block).
const fontsCss = `https://fonts.googleapis.com/css2?family=Anton&family=Oswald:wght@500;700&family=Manrope:wght@400;600;700;800&family=Lora:wght@400;500;600&family=Caveat:wght@400;600;700&display=swap`;
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{k.name} — press kit</title>
{k.tagline && <meta name="description" content={k.tagline} />}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href={fontsCss} />
<style is:inline define:vars={{
  accent,
  ink: '#0A0A0A',
  paper: '#FFFFFF',
  dim: 'rgba(255,255,255,0.55)',
  hair: 'rgba(255,255,255,0.14)',
}}>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: #1a1a1d;
    color: var(--paper);
    font-family: 'Manrope', -apple-system, system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    line-height: 1.5;
  }
  body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  img { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }

  /* ── Landscape A4 page (297 × 210mm) ───────────────────────────── */
  .pk {
    width: 297mm;
    margin: 0 auto;
    background: var(--ink);
  }
  .page {
    width: 297mm;
    height: 210mm;
    position: relative;
    overflow: hidden;
    background: var(--ink);
    color: var(--paper);
    page-break-after: always;
    break-after: page;
  }
  .page:last-child { page-break-after: auto; break-after: auto; }

  /* ── Split content layout (used on pages 2-6) ─────────────────── */
  .split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
    height: 100%;
  }
  .split .portrait {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    background: #2a2a2e;
  }
  .split .panel {
    background: var(--ink);
    padding: 22mm 22mm 18mm 22mm;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  /* ── Footer (centered on content pages) ──────────────────────── */
  .pk-footer {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 8mm;
    display: flex;
    justify-content: center;
    gap: 14px;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    font-feature-settings: "tnum", "lnum";
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
  }
  .pk-footer .num { color: var(--paper); }
  .pk-footer .sec { color: var(--accent); font-weight: 800; }
  .pk-footer .pk { color: var(--paper); }

  /* ── Section title with scribble accent ─────────────────────── */
  .sec-title {
    position: relative;
    display: inline-block;
    font-family: 'Anton', 'Oswald', Impact, sans-serif;
    font-size: clamp(56px, 6.4vw, 86px);
    line-height: 0.95;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--paper);
    margin-bottom: 12mm;
    padding: 0 2mm;
    white-space: nowrap;
  }
  .sec-title .scribble {
    position: absolute;
    left: -6mm;
    right: -6mm;
    top: 50%;
    transform: translateY(-50%);
    width: calc(100% + 12mm);
    height: 110%;
    z-index: 0;
    pointer-events: none;
    opacity: 0.92;
  }
  .sec-title .label { position: relative; z-index: 2; }

  .sec-title.sm  { font-size: clamp(28px, 3.2vw, 42px); margin-bottom: 6mm; }

  .panel h3.sub {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 6mm 0 3mm;
  }

  .panel p.body {
    font-family: 'Lora', Georgia, serif;
    font-size: 12.5px;
    line-height: 1.55;
    color: rgba(255,255,255,0.88);
  }
  .panel p.body + p.body { margin-top: 1em; }

  /* ── Inline stats (Overview) ─────────────────────────────────── */
  .istats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3mm 8mm;
    margin-top: 6mm;
    border-top: 1px solid rgba(255,255,255,0.14);
    padding-top: 5mm;
  }
  .istat {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 6px;
    font-family: 'Manrope', sans-serif;
    font-size: 11px;
    padding: 2px 0;
  }
  .istat .lab {
    color: rgba(255,255,255,0.62);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
  }
  .istat .val {
    font-family: 'Lora', serif;
    font-style: italic;
    color: var(--paper);
    font-size: 13px;
  }

  /* ── Highlights bullet list ─────────────────────────────────── */
  .hi {
    list-style: none;
    margin-top: 4mm;
  }
  .hi li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 8px;
    padding: 3.5mm 0;
    border-bottom: 1px dotted rgba(255,255,255,0.12);
    font-size: 12.5px;
    color: rgba(255,255,255,0.88);
    font-family: 'Lora', serif;
    line-height: 1.45;
  }
  .hi li .lead {
    color: var(--accent);
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 10.5px;
    white-space: nowrap;
    padding-top: 2px;
  }

  /* ── Career sub-sections ────────────────────────────────────── */
  .career-block + .career-block { margin-top: 5mm; }
  .career-list {
    list-style: none;
  }
  .career-list li {
    padding: 2mm 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    font-family: 'Lora', serif;
    font-size: 12px;
    color: rgba(255,255,255,0.88);
    line-height: 1.4;
  }

  /* ── Portfolio rows ─────────────────────────────────────────── */
  .yr-block + .yr-block { margin-top: 5mm; }
  .yr-block .yr {
    font-family: 'Anton', sans-serif;
    font-size: 22px;
    color: var(--accent);
    letter-spacing: 0.02em;
    padding-bottom: 1mm;
    border-bottom: 1px solid rgba(255,255,255,0.12);
    margin-bottom: 2mm;
  }
  .yr-block .entry {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    padding: 2mm 0;
    font-family: 'Lora', serif;
    font-size: 12px;
    border-bottom: 1px dotted rgba(255,255,255,0.08);
  }
  .yr-block .entry .ti { color: var(--paper); font-weight: 600; font-family: 'Manrope', sans-serif; font-size: 12.5px; }
  .yr-block .entry .ro { color: rgba(255,255,255,0.65); font-style: italic; }

  /* ── Big statistics rows ────────────────────────────────────── */
  .bigstats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5mm 14mm;
    margin-top: 4mm;
  }
  .bigrow {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 1px solid rgba(255,255,255,0.14);
    padding: 4mm 0;
  }
  .bigrow .lab {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    max-width: 60%;
  }
  .bigrow .val {
    font-family: 'Lora', serif;
    font-style: italic;
    font-size: 22px;
    color: var(--paper);
  }

  /* ── COVER ──────────────────────────────────────────────────── */
  .cover { position: relative; }
  .cover .portrait-r {
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 50%;
    object-fit: cover;
    object-position: center;
    z-index: 1;
  }
  .cover .gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--ink) 0%, var(--ink) 36%, rgba(10,10,10,0.85) 48%, rgba(10,10,10,0) 60%);
    z-index: 2;
  }
  .cover .content {
    position: relative;
    z-index: 3;
    padding: 18mm 22mm;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .cover .topline {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    font-family: 'Manrope', sans-serif;
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    font-weight: 700;
  }
  .cover .wordmark {
    font-family: 'Anton', 'Oswald', Impact, sans-serif;
    font-size: clamp(96px, 14vw, 220px);
    line-height: 0.86;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--paper);
    position: relative;
    max-width: 58%;
    word-break: break-word;
  }
  .cover .wordmark::after {
    /* subtle distressed effect via overlapping gradient noise */
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(8deg, transparent 0 2px, rgba(10,10,10,0.06) 2px 3px),
      repeating-linear-gradient(-12deg, transparent 0 3px, rgba(10,10,10,0.05) 3px 4px);
    mix-blend-mode: multiply;
    pointer-events: none;
  }
  .cover .kit-label {
    font-family: 'Caveat', cursive;
    font-size: 28px;
    color: var(--accent);
    margin-top: 4mm;
    letter-spacing: 0.02em;
  }
  .cover .baseline {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 14mm;
  }
  .cover .monogram {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
  }
  .cover .monogram .ring {
    width: 32px; height: 32px;
    border-radius: 50%;
    border: 1.5px solid var(--accent);
    display: inline-flex; align-items: center; justify-content: center;
    font-family: 'Anton', sans-serif;
    color: var(--paper);
    font-size: 14px;
    letter-spacing: 0;
  }
  .cover .signature {
    text-align: right;
    color: var(--paper);
  }
  .cover .signature .name {
    font-family: 'Caveat', cursive;
    font-size: 30px;
    color: var(--paper);
    line-height: 1;
  }
  .cover .signature .made {
    font-family: 'Manrope', sans-serif;
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-top: 4px;
    font-weight: 600;
  }
  .corner-scribble {
    position: absolute;
    top: 12mm; left: 12mm;
    width: 70mm; height: 36mm;
    z-index: 4;
    pointer-events: none;
    opacity: 0.65;
  }

  /* ── CONTACT ────────────────────────────────────────────────── */
  .contact { position: relative; }
  .contact .portrait-r {
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 60%;
    object-fit: cover;
    object-position: right center;
    z-index: 1;
  }
  .contact .gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--ink) 0%, var(--ink) 38%, rgba(10,10,10,0.78) 56%, rgba(10,10,10,0) 78%);
    z-index: 2;
  }
  .contact .watermark {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 0 12mm 0 0;
    font-family: 'Anton', sans-serif;
    font-size: clamp(180px, 22vw, 320px);
    line-height: 0.86;
    color: rgba(255,255,255,0.06);
    transform: scaleX(-1);
    text-transform: uppercase;
    pointer-events: none;
    white-space: nowrap;
    overflow: hidden;
  }
  .contact .content {
    position: relative;
    z-index: 3;
    padding: 22mm 22mm 18mm;
    height: 100%;
    width: 56%;
    display: flex;
    flex-direction: column;
  }
  .contact h2.title {
    font-family: 'Anton', sans-serif;
    font-size: clamp(56px, 6.4vw, 86px);
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--paper);
    margin-bottom: 8mm;
    position: relative;
    display: inline-block;
  }
  .contact h2.title .scribble {
    position: absolute;
    left: -4mm; right: -4mm;
    bottom: 2mm;
    height: 70%;
    z-index: 0;
    opacity: 0.9;
  }
  .contact h2.title .label { position: relative; z-index: 2; }

  .agents {
    list-style: none;
    margin: 4mm 0 8mm;
  }
  .agents li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 10px;
    padding: 3mm 0;
    border-bottom: 1px solid rgba(255,255,255,0.14);
    font-family: 'Manrope', sans-serif;
    font-size: 12px;
    color: rgba(255,255,255,0.88);
    align-items: baseline;
  }
  .agents li .nm { font-weight: 700; color: var(--paper); }
  .agents li .em { font-family: 'Lora', serif; font-style: italic; }
  .agents li .ph { color: rgba(255,255,255,0.65); margin-left: 4px; }
  .agents li .ro { color: var(--accent); font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; font-size: 10px; }

  .contact .row { margin-bottom: 4mm; font-family: 'Manrope', sans-serif; font-size: 12px; }
  .contact .row .k { color: var(--accent); font-weight: 800; text-transform: uppercase; letter-spacing: 0.18em; font-size: 10px; margin-bottom: 1mm; }
  .contact .row .v { color: var(--paper); font-family: 'Lora', serif; font-style: italic; font-size: 13px; line-height: 1.4; }

  .contact .baseline {
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-top: 4mm;
  }
  .contact .baseline .credit {
    font-family: 'Manrope', sans-serif;
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    font-weight: 600;
  }
  .contact .baseline .signature {
    font-family: 'Caveat', cursive;
    font-size: 28px;
    color: var(--paper);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .contact .baseline .signature .ring {
    width: 30px; height: 30px;
    border-radius: 50%;
    border: 1.5px solid var(--accent);
    display: inline-flex; align-items: center; justify-content: center;
    font-family: 'Anton', sans-serif;
    color: var(--paper);
    font-size: 13px;
  }
  .corner-scribble.tr {
    top: 12mm; right: 12mm;
    left: auto;
    width: 70mm; height: 36mm;
    transform: scaleX(-1);
  }

  /* ── Responsive (preview iframe shrinks the page) ──────────── */
  @media (max-width: 1180px) {
    .pk, .page { width: 100%; }
    .page { height: auto; min-height: 0; aspect-ratio: 297/210; }
  }
  @media (max-width: 820px) {
    .page { aspect-ratio: auto; height: auto; }
    .split { grid-template-columns: 1fr; }
    .split .portrait { aspect-ratio: 4/5; height: auto; }
    .split .panel { padding: 10vw 7vw; }
    .cover .content { padding: 10vw 7vw; }
    .cover .wordmark { max-width: 100%; font-size: clamp(64px, 16vw, 120px); }
    .cover .portrait-r, .contact .portrait-r { position: relative; width: 100%; aspect-ratio: 4/5; }
    .cover .gradient, .contact .gradient, .contact .watermark { display: none; }
    .contact .content { width: 100%; padding: 10vw 7vw; }
    .bigstats { grid-template-columns: 1fr; }
    .istats { grid-template-columns: 1fr; }
  }

  /* ── Print ─────────────────────────────────────────────────── */
  @page { size: A4 landscape; margin: 0; }
  @media print {
    html, body { background: var(--ink); }
    .page { page-break-after: always; break-after: page; height: 210mm; width: 297mm; }
    .page:last-child { page-break-after: auto; }
    a { color: inherit; }
  }
</style>

{/* ── Hidden SVG defs: scribble filter + reusable squiggle ─────── */}
<svg width="0" height="0" style="position:absolute;" aria-hidden="true">
  <defs>
    <filter id="rough" x="-10%" y="-10%" width="120%" height="120%">
      <feTurbulence type="fractalNoise" baseFrequency="0.025" numOctaves="2" seed="7" result="t" />
      <feDisplacementMap in="SourceGraphic" in2="t" scale="5" />
    </filter>
  </defs>
</svg>

</head>
<body>
  <div class="pk">

    {/* ════════════════ PAGE 1 — COVER ════════════════ */}
    <section class="page cover">
      {coverPortrait && <img src={coverPortrait} alt={k.name} class="portrait-r" />}
      <div class="gradient"></div>

      <svg class="corner-scribble" viewBox="0 0 200 100" fill="none" stroke="var(--paper)" stroke-width="1.4" stroke-linecap="round" aria-hidden="true">
        <path d="M5,55 C30,10 60,90 95,40 S150,80 185,30" />
        <path d="M10,70 C40,40 80,80 120,55 S170,70 195,50" opacity="0.7" />
        <path d="M20,20 C40,35 25,55 50,60" opacity="0.6" />
      </svg>

      <div class="content">
        <div class="topline">
          <span>PRESS · MEDIA · BOOKING</span>
          <span>{YEAR}</span>
        </div>

        <div>
          <h1 class="wordmark">{k.name}</h1>
          <div class="kit-label">PRESSKIT {YEAR}</div>
          {k.tagline && (
            <p style="font-family:'Lora',serif;font-style:italic;font-size:14px;color:rgba(255,255,255,0.78);margin-top:6mm;max-width:64%;line-height:1.4;">{k.tagline}</p>
          )}
        </div>

        <div class="baseline">
          <div class="monogram">
            <span class="ring">{monogram}</span>
            <span>Made with Grappes</span>
          </div>
          <div class="signature">
            {k.assets?.signature ? (
              <img src={k.assets.signature} alt="signature" style="max-height:48px;max-width:200px;object-fit:contain;filter:invert(1);margin-left:auto;" />
            ) : (
              <div class="name">{k.name}</div>
            )}
            <div class="made">© {YEAR} — Press Kit</div>
          </div>
        </div>
      </div>
    </section>

    {/* ════════════════ PAGE 2 — OVERVIEW ════════════════ */}
    <section class="page">
      <div class="split">
        {portraitFor(0) ? <img src={portraitFor(0)!} alt="" class="portrait" /> : <div class="portrait"></div>}
        <div class="panel">
          <h2 class="sec-title">
            <svg class="scribble" viewBox="0 0 400 60" preserveAspectRatio="none" fill="none">
              <g filter="url(#rough)">
                <path d="M5,30 Q60,8 130,32 T260,28 T395,30" stroke={accent} stroke-width="8" stroke-linecap="round" />
                <path d="M10,42 Q80,52 160,38 T300,44 T390,40" stroke={accent} stroke-width="5" stroke-linecap="round" opacity="0.85" />
              </g>
            </svg>
            <span class="label">OVERVIEW</span>
          </h2>

          {overviewIntro && <p class="body">{overviewIntro}</p>}

          {overviewStats.length > 0 && (
            <div class="istats">
              {overviewStats.slice(0, 10).map(s => (
                <div class="istat">
                  <span class="lab">{s.label}</span>
                  <span class="val">— {s.value}</span>
                </div>
              ))}
            </div>
          )}

          {highlights.length > 0 && (
            <>
              <h3 class="sub">Key Highlights</h3>
              <ul class="hi">
                {highlights.slice(0, 8).map(h => {
                  const parts = String(h).split(/\s+[—–-]\s+/);
                  const lead = parts.length > 1 ? parts[0] : '';
                  const rest = parts.length > 1 ? parts.slice(1).join(' — ') : h;
                  return (
                    <li>
                      <span class="lead">{lead || '•'}</span>
                      <span>{rest}</span>
                    </li>
                  );
                })}
              </ul>
            </>
          )}
        </div>
      </div>
      <div class="pk-footer">
        <span class="num">{pageNumberOf('overview')}</span>
        <span>/</span>
        <span class="sec">OVERVIEW</span>
        <span>/</span>
        <span class="pk">PK {YEAR}</span>
      </div>
    </section>

    {/* ════════════════ PAGE 3 — BIOGRAPHY ════════════════ */}
    {showBiography && (
      <section class="page">
        <div class="split">
          {portraitFor(1) ? <img src={portraitFor(1)!} alt="" class="portrait" /> : <div class="portrait"></div>}
          <div class="panel">
            <h2 class="sec-title">
              <svg class="scribble" viewBox="0 0 400 60" preserveAspectRatio="none" fill="none">
                <g filter="url(#rough)">
                  <path d="M5,28 Q70,8 150,30 T280,26 T395,30" stroke={accent} stroke-width="8" stroke-linecap="round" />
                  <path d="M10,44 Q90,50 180,40 T320,46 T390,40" stroke={accent} stroke-width="5" stroke-linecap="round" opacity="0.85" />
                </g>
              </svg>
              <span class="label">BIOGRAPHY</span>
            </h2>

            {bioParas.length > 0
              ? bioParas.map(p => <p class="body">{p}</p>)
              : (k.bio_short && <p class="body">{k.bio_short}</p>)
            }

            {sharedStage.length > 0 && (
              <>
                <h3 class="sub">Shared the Stage With</h3>
                <p class="body" style="font-style:italic;">{sharedStage.join(' · ')}</p>
              </>
            )}
          </div>
        </div>
        <div class="pk-footer">
          <span class="num">{pageNumberOf('biography')}</span>
          <span>/</span>
          <span class="sec">BIOGRAPHY</span>
          <span>/</span>
          <span class="pk">PK {YEAR}</span>
        </div>
      </section>
    )}

    {/* ════════════════ PAGE 4 — CAREER HIGHLIGHTS ════════════════ */}
    {showCareer && (
      <section class="page">
        <div class="split">
          {portraitFor(2) ? <img src={portraitFor(2)!} alt="" class="portrait" /> : <div class="portrait"></div>}
          <div class="panel">
            <h2 class="sec-title" style="font-size:clamp(40px,5vw,68px);">
              <svg class="scribble" viewBox="0 0 400 60" preserveAspectRatio="none" fill="none">
                <g filter="url(#rough)">
                  <path d="M5,30 Q60,10 130,32 T260,28 T395,32" stroke={accent} stroke-width="7" stroke-linecap="round" />
                  <path d="M10,42 Q90,52 170,40 T310,44 T390,40" stroke={accent} stroke-width="5" stroke-linecap="round" opacity="0.82" />
                </g>
              </svg>
              <span class="label">CAREER HIGHLIGHTS</span>
            </h2>

            {festivals.length > 0 && (
              <div class="career-block">
                <h3 class="sub">{FESTIVALS_TITLE}</h3>
                <ul class="career-list">{festivals.map(f => <li>{f}</li>)}</ul>
              </div>
            )}
            {intlExp.length > 0 && (
              <div class="career-block">
                <h3 class="sub">{INTL_TITLE}</h3>
                <ul class="career-list">{intlExp.map(f => <li>{f}</li>)}</ul>
              </div>
            )}
            {charts.length > 0 && (
              <div class="career-block">
                <h3 class="sub">{CHARTS_TITLE}</h3>
                <ul class="career-list">{charts.map(f => <li>{f}</li>)}</ul>
              </div>
            )}
          </div>
        </div>
        <div class="pk-footer">
          <span class="num">{pageNumberOf('career')}</span>
          <span>/</span>
          <span class="sec">CAREER</span>
          <span>/</span>
          <span class="pk">PK {YEAR}</span>
        </div>
      </section>
    )}

    {/* ════════════════ PAGE 5 — DISCOGRAPHY / PORTFOLIO ════════════════ */}
    {showPortfolio && (
      <section class="page">
        <div class="split">
          {portraitFor(3) ? <img src={portraitFor(3)!} alt="" class="portrait" /> : <div class="portrait"></div>}
          <div class="panel">
            <h2 class="sec-title">
              <svg class="scribble" viewBox="0 0 400 60" preserveAspectRatio="none" fill="none">
                <g filter="url(#rough)">
                  <path d="M5,30 Q70,8 150,32 T280,28 T395,32" stroke={accent} stroke-width="8" stroke-linecap="round" />
                  <path d="M10,44 Q90,50 180,40 T320,46 T390,40" stroke={accent} stroke-width="5" stroke-linecap="round" opacity="0.85" />
                </g>
              </svg>
              <span class="label">{PORTFOLIO_TITLE}</span>
            </h2>

            <div style="overflow:hidden;">
              {portfolioYears.map(y => (
                <div class="yr-block">
                  <div class="yr">{y}</div>
                  {portfolioByYear[y].map(row => (
                    <div class="entry">
                      <span class="ti">{row.title || row.name || '—'}</span>
                      <span class="ro">{row.role || row.quote || ''}</span>
                    </div>
                  ))}
                </div>
              ))}
            </div>
          </div>
        </div>
        <div class="pk-footer">
          <span class="num">{pageNumberOf('portfolio')}</span>
          <span>/</span>
          <span class="sec">{PORTFOLIO_TITLE}</span>
          <span>/</span>
          <span class="pk">PK {YEAR}</span>
        </div>
      </section>
    )}

    {/* ════════════════ PAGE 6 — STATISTICS ════════════════ */}
    {showStats && (
      <section class="page">
        <div class="split">
          {portraitFor(4) ? <img src={portraitFor(4)!} alt="" class="portrait" /> : <div class="portrait"></div>}
          <div class="panel">
            <h2 class="sec-title">
              <svg class="scribble" viewBox="0 0 400 60" preserveAspectRatio="none" fill="none">
                <g filter="url(#rough)">
                  <path d="M5,30 Q70,8 150,32 T280,28 T395,32" stroke={accent} stroke-width="8" stroke-linecap="round" />
                  <path d="M10,44 Q90,50 180,40 T320,46 T390,40" stroke={accent} stroke-width="5" stroke-linecap="round" opacity="0.85" />
                </g>
              </svg>
              <span class="label">STATISTICS</span>
            </h2>

            <div class="bigstats">
              {bigStats.map(s => (
                <div class="bigrow">
                  <span class="lab">{s.label}</span>
                  <span class="val">— {s.value}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
        <div class="pk-footer">
          <span class="num">{pageNumberOf('statistics')}</span>
          <span>/</span>
          <span class="sec">STATISTICS</span>
          <span>/</span>
          <span class="pk">PK {YEAR}</span>
        </div>
      </section>
    )}

    {/* ════════════════ PAGE 7 — CONTACT & BOOKING ════════════════ */}
    <section class="page contact">
      <div class="watermark">{k.name}</div>
      {coverPortrait && <img src={coverPortrait} alt="" class="portrait-r" />}
      <div class="gradient"></div>

      <svg class="corner-scribble tr" viewBox="0 0 200 100" fill="none" stroke="var(--paper)" stroke-width="1.4" stroke-linecap="round" aria-hidden="true">
        <path d="M5,55 C30,10 60,90 95,40 S150,80 185,30" />
        <path d="M10,70 C40,40 80,80 120,55 S170,70 195,50" opacity="0.7" />
      </svg>

      <div class="content">
        <h2 class="title">
          <svg class="scribble" viewBox="0 0 400 60" preserveAspectRatio="none" fill="none">
            <g filter="url(#rough)">
              <path d="M5,30 Q60,10 130,32 T260,28 T395,32" stroke={accent} stroke-width="7" stroke-linecap="round" />
              <path d="M10,42 Q90,50 170,40 T310,44 T390,40" stroke={accent} stroke-width="5" stroke-linecap="round" opacity="0.82" />
            </g>
          </svg>
          <span class="label">CONTACT &amp; BOOKING</span>
        </h2>

        {agents.length > 0 && (
          <>
            <h3 class="sub">Booking Agents &amp; Management</h3>
            <ul class="agents">
              {agents.map(a => (
                <li>
                  <span class="nm">{a.name}</span>
                  <span>
                    {a.email && <span class="em">— {a.email}</span>}
                    {a.phone && <span class="ph">{a.phone}</span>}
                    {a.role && <span class="ro" style="display:block;margin-top:1mm;">{a.role}</span>}
                  </span>
                </li>
              ))}
            </ul>
          </>
        )}

        {!agents.length && k.contact_email && (
          <div class="row">
            <div class="k">Email</div>
            <div class="v">{k.contact_email}</div>
          </div>
        )}

        {igHandle && (
          <div class="row">
            <div class="k">Instagram</div>
            <div class="v">{igHandle.replace(/^https?:\/\/(www\.)?instagram\.com\//, '@').replace(/\/$/, '')}</div>
          </div>
        )}

        {pressLink && (
          <div class="row">
            <div class="k">Press Materials</div>
            <div class="v">High-resolution press photos, artist logos, and live footage available at: <a href={pressLink} style="border-bottom:1px solid var(--accent);">{pressLink.replace(/^https?:\/\//, '')}</a></div>
          </div>
        )}

        <div class="baseline">
          <div class="credit">© {YEAR} / Artwork &amp; Visual Identity By Grappes</div>
          <div class="signature">
            {k.assets?.signature ? (
              <img src={k.assets.signature} alt="" style="max-height:42px;max-width:160px;object-fit:contain;filter:invert(1);" />
            ) : (
              <span>{k.name}</span>
            )}
            <span class="ring">{monogram}</span>
          </div>
        </div>
      </div>
    </section>

  </div>

  {printMode && (
    <script is:inline>window.addEventListener('load', () => setTimeout(() => window.print(), 800));</script>
  )}
</body>
</html>
