# ===== SUPABASE =====
PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ===== VERCEL =====
VERCEL_TOKEN=<vercel-api-token>
VERCEL_TEAM_ID=<team-id>
VERCEL_WEBHOOK_SECRET=<vercel-webhook-secret-from-dashboard>

# ===== GITHUB =====
GITHUB_TOKEN=<github-personal-access-token>
GITHUB_ORG=<github-username-or-org>

# ===== AI =====
ANTHROPIC_API_KEY=<anthropic-api-key>

# ===== PAYMENTS =====
STRIPE_SECRET_KEY=sk_live_<key>
STRIPE_WEBHOOK_SECRET=whsec_<key>
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_<key>

# Stripe Price IDs — create these in your Stripe dashboard
EXTRA_EDITS_PRICE_ID=price_<extra-edits-pack>
STRIPE_PRICE_STARTER=price_<starter-monthly>
STRIPE_PRICE_PRO=price_<pro-annual>
STRIPE_PRICE_AGENCY=price_<agency-lifetime>
MULTIPAGE_MONTHLY_PRICE_ID=price_<multipage-monthly>
MULTIPAGE_YEARLY_PRICE_ID=price_<multipage-yearly>
MULTIPAGE_LIFETIME_PRICE_ID=price_<multipage-lifetime>

# ===== EMAIL =====
RESEND_API_KEY=re_<key>
ADMIN_EMAIL=admin@yourdomain.com         # Receives referral payout alerts

# ===== DOMAIN PURCHASING =====
DOMAIN_MARKUP_EUR=5                      # Markup added to domain purchase price (default: 5)

# ===== ADMIN =====
ADMIN_SECRET=<long-random-secret>        # Protects /admin and admin API endpoints

# ===== APP =====
PUBLIC_APP_URL=http://localhost:4321     # Full public URL (used in OAuth redirects)
PUBLIC_SITE_URL=https://grappes.ai       # Marketing/product site URL

# ===== PREVIEW SHARING =====
SHARE_TOKEN_SECRET=<long-random-secret>  # HMAC secret for public preview share tokens (optional — falls back to SUPABASE_SERVICE_ROLE_KEY)

# ===== ERROR MONITORING =====
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>  # Leave empty to disable Sentry

# ===== CRON =====
CRON_SECRET=<long-random-secret>         # Vercel Cron auth (set in Vercel dashboard too)
