{
  "crons": [
    {
      "path": "/api/cron/expire-sites",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/trial-reminders",
      "schedule": "0 9 * * *"
    }
  ],
  "rewrites": [
    { "source": "/reels", "destination": "https://grappes-reel-lab.vercel.app/reels" },
    { "source": "/reels/:path*", "destination": "https://grappes-reel-lab.vercel.app/reels/:path*" }
  ]
}
